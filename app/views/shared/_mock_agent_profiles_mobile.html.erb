<%# Locals: agents, header %>
<% return if agents.blank? %>

<div class="font-mono"
     data-controller="mock-agents"
     data-mock-agents-tasks-value='<%= [
       "scanning catalog", "drafting post", "watching checkout",
       "retrying smoke", "parsing JSON-LD", "queueing retry",
       "flushing cache", "running diff", "tracing event", "replaying session",
       "warming edge", "polling feed", "restarting…"
     ].to_json %>'>
  <p class="text-[9px] font-semibold uppercase tracking-wider text-green-400 mb-1"><%= header %></p>
  <div class="space-y-0.5">
    <% agents.each do |agent| %>
      <div class="flex items-center gap-1.5 transition-colors duration-500"
           data-mock-agents-target="line"
           data-status="<%= agent.status %>">
        <span class="inline-block h-1.5 w-1.5 rounded-full shrink-0 bg-green-400 animate-pulse" data-dot></span>
        <span class="text-[10px] text-emerald-300" data-name><%= agent.name %></span>
        <span class="text-[9px] text-green-500" data-role><%= agent.role.match?(/\A[A-Z0-9]+\z/) ? agent.role : agent.role.downcase %></span>
        <span class="text-[9px] text-amber-400 italic truncate" data-task style="display:none"></span>
      </div>
    <% end %>
  </div>
</div>
