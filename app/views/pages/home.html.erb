<% content_for(:title, "Home") %>

<!-- Hero Section -->
<section class="relative bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-800 overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" viewBox="0 0 800 600" fill="none">
      <circle cx="400" cy="300" r="250" stroke="white" stroke-width="0.5" fill="none"/>
      <circle cx="400" cy="300" r="180" stroke="white" stroke-width="0.5" fill="none"/>
      <circle cx="400" cy="300" r="110" stroke="white" stroke-width="0.5" fill="none"/>
    </svg>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight">
        Agent44 &mdash; AI-Augmented<br>Test Automation
      </h1>
      <p class="mt-6 text-lg md:text-xl text-indigo-100 leading-relaxed">
        Expert consulting and SDET placement for teams that need reliable software delivered faster.
        We pair deep QA expertise with AI tooling to accelerate your testing pipeline.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to "Browse Jobs", jobs_path,
              class: "inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-indigo-700 bg-white rounded-lg shadow hover:bg-indigo-50 transition" %>
        <%= link_to "Read the Blog", posts_path,
              class: "inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition" %>
      </div>
    </div>
  </div>
</section>

<!-- Latest Jobs -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold text-gray-900">Latest Jobs</h2>
    <%= link_to "View all jobs &rarr;".html_safe, jobs_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
  </div>

  <% if @recent_jobs.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @recent_jobs.each do |job| %>
        <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-indigo-200 transition group">
          <div class="flex items-start justify-between mb-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">
              <%= job.category&.titleize || "General" %>
            </span>
            <span class="text-xs text-gray-400"><%= days_ago_in_words(job.posted_at) %></span>
          </div>
          <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition">
            <%= link_to job.title, job_path(job) %>
          </h3>
          <p class="text-sm text-gray-500 mt-1"><%= job.company %></p>
          <div class="mt-4 flex items-center gap-3 text-xs text-gray-400">
            <% if job.location.present? %>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <%= job.location %>
              </span>
            <% end %>
            <% if job.salary.present? %>
              <span class="text-green-600 font-medium"><%= job.salary %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 text-center py-12">No jobs posted yet. Check back soon!</p>
  <% end %>
</section>

<!-- Latest Blog Posts -->
<section class="bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Latest from the Blog</h2>
      <%= link_to "All posts &rarr;".html_safe, posts_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
    </div>

    <% if @recent_posts.present? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @recent_posts.each do |post| %>
          <article class="group">
            <div class="bg-gray-50 rounded-xl p-6 hover:bg-indigo-50 transition">
              <time class="text-xs text-gray-400 uppercase tracking-wide">
                <%= post.published_at&.strftime("%B %d, %Y") %>
              </time>
              <h3 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-indigo-600 transition">
                <%= link_to post.title, post_path(post.slug) %>
              </h3>
              <p class="mt-2 text-sm text-gray-500 line-clamp-3">
                <%= truncate(post.body.to_plain_text, length: 160) %>
              </p>
              <%= link_to "Read more &rarr;".html_safe, post_path(post.slug),
                    class: "inline-block mt-3 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-12">No posts yet. Stay tuned!</p>
    <% end %>
  </div>
</section>

<!-- Newsletter CTA -->
<section class="bg-indigo-600">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white">Stay in the Loop</h2>
    <p class="mt-3 text-indigo-100 max-w-xl mx-auto">
      Get new SDET job listings, blog posts, and AI testing insights delivered straight to your inbox. No spam.
    </p>
    <div class="mt-8 max-w-md mx-auto" id="home-newsletter-form">
      <%= render "subscribers/form" %>
    </div>
  </div>
</section>
