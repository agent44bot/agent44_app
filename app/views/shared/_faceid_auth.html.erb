<%# Face ID authentication for Capacitor iOS app.
    Shows "Sign in with Face ID" button when biometrics/passcode available
    and credentials were previously saved from /settings. Sign-in itself does
    NOT save credentials — that's an explicit opt-in via the Settings page,
    otherwise toggling Face ID off from Settings would silently get re-enabled
    on every email sign-in. Works in simulator via passcode fallback. %>
<%= javascript_tag nonce: true do %>
(function() {
  // [FACEID] Diagnostic instrumentation — temporary while debugging the
  // multi-prompt issue Lora reported. Remove once the cause is identified.
  var TAG = "[FACEID " + Math.random().toString(36).slice(2, 7) + "]";
  function log() {
    var args = Array.prototype.slice.call(arguments);
    args.unshift(TAG, new Date().toISOString().slice(11, 23));
    console.log.apply(console, args);
  }

  log("partial executed, path=" + window.location.pathname);

  // Only run inside Capacitor
  if (!window.Capacitor || !window.Capacitor.isNativePlatform()) {
    log("not Capacitor native, bailing");
    return;
  }

  var Bio = window.Capacitor.Plugins.BiometricAuth;
  if (!Bio) {
    log("BiometricAuth plugin missing, bailing");
    return;
  }
  log("Capacitor + Bio ok");

  // Banking-pattern auto-prompt: when the app launches with stored credentials,
  // fire Face ID immediately so the user is signed in before they see the
  // marketing page. Fires once per Capacitor session (not on every Turbo
  // navigation) — the sessionStorage flag is set on the first run regardless
  // of outcome, so post-signout returns to `/` don't ambush the user.
  function autoPrompt() {
    var alreadyChecked = sessionStorage.getItem("_faceid_auto_checked") === "1";
    log("autoPrompt called, alreadyChecked=" + alreadyChecked + ", path=" + window.location.pathname);
    if (alreadyChecked) {
      log("autoPrompt skipped (sessionStorage flag set)");
      return;
    }
    sessionStorage.setItem("_faceid_auto_checked", "1");
    log("autoPrompt sessionStorage flag set");

    // Only on the launch route; deep links go through the menu.
    if (window.location.pathname !== "/") {
      log("autoPrompt skipped (path " + window.location.pathname + " is not /)");
      return;
    }

    var CSRF = document.querySelector('meta[name="csrf-token"]');
    log("autoPrompt calling Bio.isAvailable()");
    Bio.isAvailable().then(function(result) {
      log("isAvailable result: isAvailable=" + result.isAvailable + ", hasCredentials=" + result.hasCredentials + ", hasBiometrics=" + result.hasBiometrics);
      if (!result.isAvailable || !result.hasCredentials) {
        log("autoPrompt bailing — no biometrics or no credentials");
        return;
      }

      log("autoPrompt calling Bio.getCredentials() — this should trigger Face ID #1");
      Bio.getCredentials().then(function(creds) {
        log("getCredentials succeeded — submitting form to /session");
        var form = document.createElement("form");
        form.method = "POST";
        form.action = "<%= session_path %>";
        form.style.display = "none";
        form.setAttribute("autocomplete", "off");

        var fields = {
          "email_address": creds.username,
          "password": creds.password,
          "authenticity_token": CSRF ? CSRF.content : ""
        };

        for (var key in fields) {
          var input = document.createElement("input");
          input.type = "hidden";
          input.name = key;
          input.value = fields[key];
          input.setAttribute("autocomplete", "off");
          form.appendChild(input);
        }

        document.body.appendChild(form);
        log("autoPrompt form.submit() — fly logs should show POST /session next");
        form.submit();
      }).catch(function(e) { log("Face ID cancelled or failed:", e && e.message); });
    }).catch(function(e) { log("BiometricAuth check failed:", e && e.message); });
  }

  // Re-run on every Turbo navigation, not just initial parse — otherwise the
  // post-signout return to `/` swaps the body in but the visibility check
  // never fires, leaving the button at its default display:none and forcing
  // the user to hard-close the app to recover.
  function setup() {
    log("setup called, path=" + window.location.pathname);
    var CSRF = document.querySelector('meta[name="csrf-token"]');
    var btns = document.querySelectorAll('[id="faceid-signin-btn"]');
    log("setup found " + btns.length + " faceid button(s)");
    if (!btns.length) return;

    Bio.isAvailable().then(function(result) {
      if (!result.isAvailable) return;

      if (result.hasCredentials) {
        // Stored credentials — show button, tap triggers Face ID and auto sign-in
        btns.forEach(function(btn) {
          btn.style.display = "flex";
          if (btn.dataset.faceidInit !== "1") {
            btn.dataset.faceidInit = "1";
            btn.addEventListener("click", function() { doFaceIdSignIn(btn, CSRF); });
          }
        });
      } else {
        // No stored credentials yet — show button on home page only (links to sign-in)
        // On the sign-in page itself, hide it (user should sign in with email first)
        var isSignInPage = window.location.pathname.indexOf("session") !== -1;
        if (!isSignInPage) {
          btns.forEach(function(btn) {
            btn.style.display = "flex";
            if (btn.dataset.faceidInit !== "1") {
              btn.dataset.faceidInit = "1";
              btn.addEventListener("click", function() {
                window.location.href = "<%= new_session_path %>";
              });
            }
          });
        }
      }

      // Update button label based on biometry type
      if (!result.hasBiometrics) {
        btns.forEach(function(btn) {
          var label = btn.querySelector(".faceid-label");
          if (label) label.textContent = "Sign in with Passcode";
        });
      }
    }).catch(function(e) { console.log("BiometricAuth check failed:", e); });
  }

  function doFaceIdSignIn(btn, CSRF) {
    btn.disabled = true;
    var origHTML = btn.innerHTML;
    btn.textContent = "Authenticating...";

    Bio.getCredentials().then(function(creds) {
      var form = document.createElement("form");
      form.method = "POST";
      form.action = "<%= session_path %>";
      form.style.display = "none";

      var fields = {
        "email_address": creds.username,
        "password": creds.password,
        "authenticity_token": CSRF ? CSRF.content : ""
      };

      for (var key in fields) {
        var input = document.createElement("input");
        input.type = "hidden";
        input.name = key;
        input.value = fields[key];
        form.appendChild(input);
      }

      document.body.appendChild(form);
      form.submit();
    }).catch(function() {
      btn.disabled = false;
      btn.innerHTML = origHTML;
    });
  }

  // Clean up any stale pending credentials left behind by the previous
  // auto-save behavior so they don't silently repopulate the keychain.
  try {
    sessionStorage.removeItem("_faceid_pending_email");
    sessionStorage.removeItem("_faceid_pending_pw");
  } catch(e) {}

  // Initial load — auto-prompt fires once per Capacitor session before the
  // button-show check, so returning users get signed in immediately.
  autoPrompt();
  setup();
  // Every Turbo navigation (post-signout, back/forward, etc.) re-runs the
  // button-show check but NOT the auto-prompt — that's session-scoped.
  document.addEventListener("turbo:load", setup);
  document.addEventListener("turbo:render", setup);
})();
<% end %>
