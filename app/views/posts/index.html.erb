<% content_for(:title, "Newsletter") %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-12 text-center">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">Newsletter</h1>
    <p class="mt-3 text-lg text-gray-500 max-w-2xl mx-auto">The latest on test automation, AI in QA, and the evolving job market for testers.</p>
  </div>

  <% if @posts.present? %>
    <div class="space-y-8">
      <% @posts.each_with_index do |post, index| %>
        <article class="bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg hover:border-indigo-200 transition group">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 uppercase tracking-wide">
              Newsletter
            </span>
            <time class="text-sm text-gray-400">
              <%= post.published_at&.strftime("%B %d, %Y") %>
            </time>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 group-hover:text-indigo-600 transition leading-snug">
            <%= link_to post.title, post_path(post.slug) %>
          </h2>
          <p class="mt-3 text-gray-500 leading-relaxed line-clamp-3">
            <%= truncate(post.body.to_plain_text, length: 280) %>
          </p>
          <div class="mt-5 flex items-center justify-between">
            <%= link_to "Read more &rarr;".html_safe, post_path(post.slug),
                  class: "inline-flex items-center text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition" %>
            <% if post.user.present? %>
              <span class="text-sm text-gray-400">by <span class="font-medium text-gray-600"><%= post.user.display_identifier %></span></span>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>

    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <div class="mt-12 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-16">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">No posts yet</h3>
      <p class="mt-1 text-sm text-gray-500">Check back soon for new content.</p>
    </div>
  <% end %>
</div>
