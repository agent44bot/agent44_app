<% content_for(:title, "Admin: Videos") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Manage Videos</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @videos.size %> video(s)</p>
    </div>
    <%= link_to "New Video", new_admin_video_path,
          class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition shadow-sm" %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Thumbnail</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Position</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @videos.each do |video| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-6 py-4">
              <img src="<%= video.thumbnail_url %>" alt="<%= video.title %>" class="w-24 h-14 object-cover rounded">
            </td>
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= video.title %></div>
              <div class="text-xs text-gray-400 font-mono"><%= video.youtube_id %></div>
            </td>
            <td class="px-6 py-4">
              <% if video.published? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Published</span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Draft</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= video.position %></td>
            <td class="px-6 py-4 text-right space-x-3">
              <%= link_to "Edit", edit_admin_video_path(video), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
              <%= button_to "Delete", admin_video_path(video), method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete this video?" },
                    class: "text-sm font-medium text-red-600 hover:text-red-800 transition" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @videos.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-500">No videos yet.</p>
        <%= link_to "Add your first video", new_admin_video_path, class: "text-sm text-indigo-600 hover:text-indigo-800" %>
      </div>
    <% end %>
  </div>
</div>
