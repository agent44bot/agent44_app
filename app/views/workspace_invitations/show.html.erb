<% content_for :title, "Accept invitation" %>

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center">
    <h1 class="text-xl font-bold text-white mb-2">You've been invited</h1>
    <p class="text-sm text-gray-300 mb-1">
      <span class="text-gray-400">Workspace:</span> <strong><%= @invitation.workspace.name %></strong>
    </p>
    <p class="text-sm text-gray-300 mb-1">
      <span class="text-gray-400">Role:</span> <%= @invitation.role %>
    </p>
    <p class="text-xs text-gray-500 mt-2">
      Expires <%= @invitation.expires_at.in_time_zone(@invitation.workspace.timezone).strftime("%b %-d") %>
    </p>

    <% if Current.session.user.email_address.present? && Current.session.user.email_address.downcase != @invitation.email.downcase %>
      <p class="text-xs text-yellow-400 mt-3">
        Heads up: this invite was sent to <%= @invitation.email %> but you're signed in as <%= Current.session.user.email_address %>.
      </p>
    <% end %>

    <%= button_to "Accept invitation",
        workspace_invitation_accept_path(token: @invitation.token),
        method: :post,
        class: "mt-6 w-full inline-flex justify-center items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
  </div>
</div>
