<%# Locals: agents (collection of Agent instances), header (string), visible_count (int, default 10) %>
<% return if agents.blank? %>
<% visible_count ||= 10 %>

<div class="font-mono"
     data-controller="mock-agents"
     data-mock-agents-visible-count-value="<%= visible_count %>"
     data-mock-agents-tasks-value='<%= [
       "scanning catalog", "drafting social post", "watching checkout flow",
       "retrying smoke run", "parsing JSON-LD", "queueing retry",
       "flushing cache", "running diff", "tracing event", "replaying session",
       "generating thumbnail", "warming edge", "checking cert", "polling feed",
       "restarting…"
     ].to_json %>'>
  <p class="text-[10px] font-semibold uppercase tracking-wider text-green-400 mb-2"><%= header %></p>
  <div class="space-y-1" data-mock-agents-target="list">
    <% agents.first(visible_count).each do |agent| %>
      <div class="flex items-center gap-2 rounded px-1 -mx-1 overflow-hidden"
           data-mock-agents-target="line"
           data-id="<%= agent.name %>"
           data-status="online"
           style="max-height: 20px;">
        <span class="inline-block h-2 w-2 rounded-full shrink-0 bg-green-400 animate-pulse" data-dot></span>
        <span class="text-[11px] text-green-400" data-name><%= agent.name %></span>
        <span class="text-[8px] text-amber-500 italic" data-task style="display:none"></span>
      </div>
    <% end %>
  </div>
</div>
