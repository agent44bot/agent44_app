<% content_for(:title, "Storage Room · #{@item.name}") %>
<%= render "inventory/header", active: :stock %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24">
  <% low = @item.low_stock?(@on_hand) %>
  <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
    <div class="min-w-0">
      <h2 class="text-2xl font-black text-white">
        <%= @item.name %>
        <% if low %><span class="ml-2 align-middle text-xs font-bold uppercase tracking-wide px-2 py-0.5 rounded bg-amber-900/60 text-amber-300 border border-amber-700/60">Low stock</span><% end %>
      </h2>
      <p class="text-gray-400 text-sm mt-1">
        <%= [ @item.category&.capitalize, @item.size, @item.producer, @item.vintage ].reject(&:blank?).join(" · ").presence || "No details yet" %>
      </p>
    </div>
    <div class="text-right shrink-0">
      <div class="text-4xl font-black tabular-nums <%= low ? "text-amber-400" : "text-white" %>"><%= @on_hand %></div>
      <div class="text-[11px] uppercase tracking-wide text-gray-500">bottles on hand<%= " · par #{@item.par_level}" if @item.par_level.present? %></div>
    </div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6 text-sm">
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-3">
      <div class="text-gray-500 text-xs uppercase tracking-wide">Per case</div>
      <div class="text-white font-semibold mt-0.5"><%= @item.units_per_case %></div>
    </div>
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-3">
      <div class="text-gray-500 text-xs uppercase tracking-wide">Bottle UPC</div>
      <div class="text-white font-semibold mt-0.5 truncate font-mono text-xs"><%= @item.barcode.presence || "—" %></div>
    </div>
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-3">
      <div class="text-gray-500 text-xs uppercase tracking-wide">Case code</div>
      <div class="text-white font-semibold mt-0.5 truncate font-mono text-xs"><%= @item.case_barcode.presence || "—" %></div>
    </div>
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-3">
      <div class="text-gray-500 text-xs uppercase tracking-wide">Vendor</div>
      <div class="text-white font-semibold mt-0.5 truncate"><%= @item.vendor.presence || "—" %></div>
    </div>
  </div>

  <div class="flex items-center gap-3 mb-8">
    <%= link_to "Edit details", edit_nyk_inventory_item_path(@item),
          class: "px-4 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-white text-sm font-semibold" %>
    <%= link_to "Receive →", nyk_inventory_receive_path, class: "text-sm text-orange-400 hover:text-orange-300" %>
    <%= link_to "Remove →", nyk_inventory_remove_path, class: "text-sm text-gray-400 hover:text-white" %>
  </div>

  <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Movement history</h3>
  <% if @movements.empty? %>
    <p class="text-gray-500 text-sm">No movements recorded yet.</p>
  <% else %>
    <div class="overflow-hidden rounded-xl border border-gray-800 divide-y divide-gray-800">
      <% @movements.each do |m| %>
        <div class="flex items-center gap-3 px-4 py-2.5 bg-gray-900 text-sm">
          <span class="<%= m.direction == "in" ? "text-green-400" : "text-red-400" %> font-bold tabular-nums w-12">
            <%= m.direction == "in" ? "+#{m.quantity}" : "-#{m.quantity}" %>
          </span>
          <span class="text-gray-400 flex-1 min-w-0 truncate">
            <%= m.user&.display_identifier || "—" %><%= " · #{m.note}" if m.note.present? %>
          </span>
          <span class="text-gray-500 shrink-0 tabular-nums"><%= m.occurred_at.strftime("%b %-d, %-I:%M %p") %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
