<%# QR Code for agent44labs.ai — generates SVG on server side using rqrcode gem
    Displays on home hero page for easy mobile access. Responsive sizing. %>

<div class="qr-code-container flex flex-col items-center gap-2">
  <%# Generate QR code for agent44labs.ai %>
  <% qr = RQRCode::QRCode.new("https://agent44labs.ai", size: 8, level: :h) %>
  
  <%# SVG QR code — no external network calls, fully self-contained %>
  <div class="qr-code-svg bg-white p-2 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
    <%= qr.as_svg(
      offset: 0,
      color: "000",
      shape_rendering: "crispEdges",
      module_size: 8,
      standalone: false
    ).html_safe %>
  </div>
  
  <p class="text-xs font-semibold text-gray-300 tracking-wide uppercase">Scan to visit</p>
</div>
