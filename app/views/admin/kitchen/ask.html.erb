<% content_for(:title, "NY Kitchen · Super Agent") %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <%= render "admin/kitchen/breadcrumbs" %>

  <div class="mb-6">
    <%= render "admin/kitchen/agent_title", title: "Super Agent", kind: "ask" %>
    <p class="text-gray-400 mt-1">Ask anything about NY Kitchen — classes, sales, sold-outs, agent fleet status, smoke tests, social posts.</p>
  </div>

  <div data-controller="super-chat"
       data-super-chat-endpoint-value="<%= nyk_ask_message_path %>"
       class="rounded-2xl border border-gray-800 bg-gray-950 overflow-hidden flex flex-col relative"
       style="height: calc((100dvh - 280px) * 0.75); min-height: 375px;">

    <button type="button"
            data-super-chat-target="reset"
            data-action="click->super-chat#reset"
            title="Start a new chat"
            hidden
            class="absolute top-3 right-3 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-gray-900/80 border border-gray-800 hover:border-orange-500 text-xs text-gray-400 hover:text-orange-400 cursor-pointer backdrop-blur">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/>
      </svg>
      New chat
    </button>

    <div data-super-chat-target="messages"
         class="flex-1 overflow-y-auto px-4 pt-14 pb-6 space-y-4">
      <div data-super-chat-target="empty" class="text-center text-gray-500 text-sm">
        <p class="mb-3">Ask anything about NY Kitchen — classes, sales, agent status, smoke tests, social posts.</p>
        <div class="flex flex-wrap justify-center gap-2 mt-4">
          <% @chip_prompts.each do |q| %>
            <button type="button" data-action="click->super-chat#useExample"
                    data-example="<%= q %>"
                    class="text-xs px-3 py-1.5 rounded-full bg-gray-900 border border-gray-800 hover:border-orange-500 text-gray-300 cursor-pointer">
              <%= q %>
            </button>
          <% end %>
        </div>

        <% if @can_edit_chips %>
          <details class="mt-8 text-left max-w-2xl mx-auto">
            <summary class="cursor-pointer text-xs text-gray-500 hover:text-orange-400 list-none text-center">
              ✏ Edit examples
            </summary>
            <%= form_with url: nyk_ask_examples_path, method: :post, local: true, class: "mt-3 space-y-3" do %>
              <%= text_area_tag :chip_prompts, @chip_prompts.join("\n"), rows: 6, wrap: "off",
                    class: "block w-full rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none font-normal leading-relaxed whitespace-pre overflow-x-auto",
                    placeholder: "One question per line (up to 4)" %>
              <div class="flex items-center gap-3">
                <%= submit_tag "Save", class: "text-xs px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white font-semibold cursor-pointer border-0" %>
                <span class="text-xs text-gray-600">Blank = restore defaults from snapshot</span>
              </div>
            <% end %>
          </details>
        <% end %>
      </div>
    </div>

    <form data-super-chat-target="form"
          data-action="submit->super-chat#submit"
          class="border-t border-gray-800 bg-gray-900/70 p-3 flex gap-2">
      <input type="text"
             data-super-chat-target="input"
             placeholder="Ask about classes, agents, tests..."
             autocomplete="off"
             <%# text-base (16px) on mobile stops iOS from auto-zooming the page
                 when the input is focused; shrink to text-sm on desktop. %>
             class="flex-1 rounded-md bg-gray-950 border border-gray-800 text-white px-3 py-2 text-base sm:text-sm focus:border-orange-500 focus:outline-none">
      <button type="submit"
              data-super-chat-target="send"
              class="px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-sm font-semibold text-white cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
        Send
      </button>
    </form>
  </div>

  <% if @super_agent_usage %>
    <div class="mt-4 rounded-xl border border-gray-800 bg-gray-900/40 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
          Super Agent usage <span class="normal-case font-normal text-gray-600">· admin only</span>
        </h3>
        <%= link_to "Full cost dashboard →", admin_finance_path, class: "text-xs text-gray-500 hover:text-orange-400" %>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <% [["Today", :today], ["Last 7 days", :week], ["This month", :month], ["All time", :all_time]].each do |label, key| %>
          <% u = @super_agent_usage[key] %>
          <div class="rounded-lg bg-gray-950 border border-gray-800 px-3 py-2">
            <div class="text-[11px] text-gray-500 uppercase tracking-wide"><%= label %></div>
            <div class="mt-1 text-lg font-bold text-white">
              <%= number_to_currency(u[:cost_dollars], precision: u[:cost_dollars] < 1 ? 4 : 2) %>
            </div>
            <div class="text-[11px] text-gray-500">
              <%= number_with_delimiter(u[:total_tokens]) %> tokens · <%= u[:calls] %> <%= "call".pluralize(u[:calls]) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @last_snapshot_taken_on %>
    <p class="text-xs text-gray-600 mt-3">
      Answers are based on calendar data from <%= @last_snapshot_taken_on.strftime("%A, %b %-d") %>.
      Refresh the page after the next Data Agent snapshot to pick up newer data.
    </p>
  <% else %>
    <p class="text-xs text-amber-500 mt-3">
      No calendar snapshot yet — Super Agent has nothing to answer from. Wait for the Data Agent's next run.
    </p>
  <% end %>
</div>
