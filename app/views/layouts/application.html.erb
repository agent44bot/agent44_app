<!DOCTYPE html>
<html lang="en" class="overflow-x-hidden">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <style>html,body{max-width:100vw;overflow-x:hidden}*,*::before,*::after{box-sizing:border-box}</style>
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Agent44 Labs">
  <meta name="mobile-web-app-capable" content="yes">
  <%# Smart App Banner — iOS Safari shows a "Get"/"Open" banner for the app.
      Auto-detects install state and platform; never renders inside the
      Capacitor webview, so it only nudges real mobile-Safari visitors. %>
  <meta name="apple-itunes-app" content="app-id=6762046812">
  <meta name="description" content="Agent44 Labs — agent-driven production smoke tests for small and mid-size teams.">
  <title><%= content_for?(:title) ? "#{yield(:title)} | Agent44 Labs" : "Agent44 Labs" %></title>
  <link rel="icon" href="/agent44_logo.svg?v=2" type="image/svg+xml">
  <link rel="alternate icon" href="/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <meta name="turbo-cache-control" content="auto">

  <%= yield :head %>

  <link rel="icon" href="/agent44_logo.svg?v=2" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= javascript_tag nonce: true do %>
  // Fallback nav toggle — only fires if Stimulus hasn't connected yet.
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-nav-target="menuBtn"]');
    if (!btn) return;
    var navRoot = btn.closest('[data-controller~="nav"]');
    if (!navRoot) return;
    // Skip if Stimulus nav controller is connected (it handles its own click)
    if (window.Stimulus && window.Stimulus.getControllerForElementAndIdentifier &&
        window.Stimulus.getControllerForElementAndIdentifier(navRoot, 'nav')) return;
    // Find the menu target that belongs to this nav (not a nested one)
    var menus = navRoot.querySelectorAll('[data-nav-target="menu"]');
    for (var i = 0; i < menus.length; i++) {
      if (menus[i].closest('[data-controller~="nav"]') === navRoot) {
        menus[i].classList.toggle('hidden');
        break;
      }
    }
  });
  <% end %>
  <%= javascript_tag nonce: true do %>
  // Push notification registration — only runs inside the Capacitor native shell
  (function() {
    if (!window.Capacitor || !window.Capacitor.isNativePlatform()) return;
    var PN = window.Capacitor.Plugins && window.Capacitor.Plugins.PushNotifications;
    if (!PN) return;

    function csrfToken() {
      var el = document.querySelector('meta[name="csrf-token"]');
      return el ? el.getAttribute('content') : '';
    }

    function clearBadge() {
      fetch('/api/v1/badge/clear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken() },
        credentials: 'same-origin'
      }).catch(function() {});
    }

    // Tap-to-route: when the app foregrounds, ask the server what's pending.
    // 1 unread + url → jump straight to it; many unread → /notifications inbox;
    // 0 → stay put. Always clear the badge afterwards.
    function routeFromBadgeAndClear() {
      fetch('/api/v1/badge/peek', {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      }).then(function(r) {
        if (!r.ok) return null;
        return r.json();
      }).then(function(payload) {
        if (payload && payload.count > 0) {
          var dest = (payload.count === 1 && payload.url) ? payload.url : '/notifications';
          if (window.location.pathname + window.location.hash !== dest && window.location.href !== dest) {
            window.location.href = dest;
          }
        }
      }).catch(function() {}).finally(function() { clearBadge(); });
    }

    PN.requestPermissions().then(function(perm) {
      if (perm.receive !== 'granted') return;

      PN.addListener('registration', function(token) {
        fetch('/api/v1/device_tokens', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: token.value, platform: 'ios' })
        });
      });

      // Navigate to the URL when the user taps a notification
      PN.addListener('pushNotificationActionPerformed', function(action) {
        var url = action.notification.data && action.notification.data.url;
        if (url) window.location.href = url;
        clearBadge();
      });

      PN.register();
    });

    // On first load and every foreground, peek at the user's unread state and
    // route to the right place (single → that notification's url, many →
    // inbox), then clear the badge.
    var App = window.Capacitor.Plugins && window.Capacitor.Plugins.App;
    if (App && App.addListener) {
      App.addListener('appStateChange', function(state) {
        if (state.isActive) routeFromBadgeAndClear();
      });
      // Universal Links: a tapped agent44labs.com link (e.g. the passwordless
      // sign-in magic link) opens the app here — route the webview to its path.
      App.addListener('appUrlOpen', function(event) {
        try {
          var u = new URL(event.url);
          if (u.hostname === 'agent44labs.com') {
            window.location.href = u.pathname + u.search + u.hash;
          }
        } catch (e) {}
      });
    }
    routeFromBadgeAndClear();
  })();
  <% end %>
</head>
<body class="bg-gray-950 text-white antialiased overflow-x-hidden">
  <%= render "shared/impersonation_banner" %>

  <!-- Navigation -->
  <nav class="bg-gray-950/80 backdrop-blur-md border-b border-gray-800 sticky top-0 z-50" data-controller="nav">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <!-- Left: Logo -->
        <div class="flex items-center min-w-0 overflow-hidden">
          <%= link_to root_path, class: "flex items-center space-x-2 font-black text-xl tracking-tight min-w-0" do %>
            <img src="/agent44_logo.svg?v=2" alt="Agent44 Labs" width="40" height="40" class="hidden">
            <span class="text-white">Agent44<span class="bg-gradient-to-r from-orange-600 to-amber-600 bg-clip-text text-transparent">Labs</span></span>
          <% end %>
        </div>

        <!-- Right: Auth -->
        <div class="hidden md:flex items-center space-x-4">
          <% if authenticated? %>
            <% if Current.user.admin? %>
              <!-- Admin dropdown -->
              <div class="relative" data-controller="nav">
                <button type="button" data-action="click->nav#toggle" aria-label="Admin menu"
                        class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-orange-400 hover:bg-gray-800 transition">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                  </svg>
                </button>
                <div data-nav-target="menu" class="hidden absolute right-0 mt-2 w-52 rounded-lg bg-gray-900 border border-gray-800 shadow-xl py-1 z-50">
                  <%= link_to "Dashboard", admin_dashboard_path, class: "block px-4 py-2 text-sm font-medium text-orange-500 hover:bg-gray-800" %>
                  <%= link_to "Workspaces", workspaces_path, class: "block px-4 py-2 text-sm font-medium text-orange-500 hover:bg-gray-800" %>
                  <div class="my-1 border-t border-gray-800"></div>
                  <%= link_to "Jobs", jobs_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "NY Kitchen", nykitchen_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "AI News", news_articles_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "Map", globe_jobs_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "Crypto", crypto_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <div class="my-1 border-t border-gray-800"></div>
                  <%= link_to "Saved Jobs", saved_jobs_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                </div>
              </div>
              <%= link_to Current.user.display_identifier, settings_path,
                    class: "text-sm text-gray-400 hover:text-orange-400 transition truncate max-w-[180px]" %>
              <%= button_to "Sign Out", session_path, method: :delete,
                    class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <% else %>
              <!-- User dropdown (non-admin): Workspaces / Settings / Sign Out -->
              <div class="relative" data-controller="nav">
                <button type="button" data-action="click->nav#toggle" aria-label="Menu"
                        class="inline-flex items-center gap-2 p-2 rounded-md text-gray-300 hover:text-orange-400 hover:bg-gray-800 transition">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                  </svg>
                  <span class="text-sm truncate max-w-[140px]"><%= Current.user.display_identifier %></span>
                </button>
                <div data-nav-target="menu" class="hidden absolute right-0 mt-2 w-48 rounded-lg bg-gray-900 border border-gray-800 shadow-xl py-1 z-50">
                  <%= link_to "Workspaces", workspaces_path(force: 1), class: "block px-4 py-2 text-sm font-medium text-orange-500 hover:bg-gray-800" %>
                  <%= link_to "Settings",  settings_path,   class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <div class="my-1 border-t border-gray-800"></div>
                  <%= button_to "Sign Out", session_path, method: :delete,
                        class: "block w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                </div>
              </div>
            <% end %>
          <% else %>
            <%= link_to "Sign In", sign_in_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <%= link_to "Sign Up", sign_in_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-orange-600 rounded-full hover:bg-orange-700 transition" %>
          <% end %>
        </div>

        <!-- Mobile menu button -->
        <div class="flex items-center md:hidden shrink-0">
          <button data-action="click->nav#toggle" data-nav-target="menuBtn" aria-label="Menu"
                  class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-orange-400 hover:bg-gray-800 transition">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="hidden md:hidden" data-nav-target="menu">
      <div class="px-4 pt-2 pb-4 space-y-1 border-t border-gray-800">
        <% if !authenticated? || Current.user.admin? %>
          <%= link_to "Home", root_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% end %>
        <% if authenticated? %>
          <%= link_to "Workspaces", workspaces_path(force: 1), class: "block px-3 py-2 rounded-md text-base font-medium text-orange-500 hover:bg-gray-800" %>
        <% end %>
        <% if authenticated? && Current.user.admin? %>
          <%= link_to "Jobs", jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "Crypto", crypto_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "NY Kitchen", nykitchen_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "AI News", news_articles_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "Map", globe_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% end %>
        <div class="border-t border-gray-800 pt-2">
          <% if authenticated? %>
            <% if Current.user.admin? %>
              <%= link_to "Saved Jobs", saved_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
              <%= link_to "Dashboard", admin_dashboard_path, class: "block px-3 py-2 rounded-md text-base font-medium text-orange-600 hover:bg-gray-800" %>
            <% end %>
            <%= link_to Current.user.display_identifier, settings_path,
                  class: "block px-3 py-2 text-sm text-gray-400 hover:bg-gray-800 rounded-md" %>
            <%= link_to "Settings", settings_path,
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <% else %>
            <%= link_to "Sign In", sign_in_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <%= link_to "Sign Up", sign_in_path, class: "block px-3 py-2 rounded-md text-base font-medium text-orange-600 hover:bg-gray-800" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Email verification banner -->
  <% if !Rails.env.development? && authenticated? && Current.user.email_address.present? && !Current.user.email_verified? %>
    <div class="bg-amber-900/30 border-b border-amber-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex flex-wrap items-center justify-between gap-2">
        <p class="text-sm text-amber-300">Please verify your email. Check your inbox for a verification link.</p>
        <%= button_to "Resend email", resend_email_verification_path, method: :post, class: "text-sm font-medium text-amber-400 hover:text-amber-200 underline whitespace-nowrap" %>
      </div>
    </div>
  <% end %>

  <!-- Flash messages: auto-dismiss after 7s via the flash Stimulus controller -->
  <% if notice.present? %>
    <div data-controller="flash" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-green-900/50 border border-green-700 p-4">
        <p class="text-sm text-green-200"><%= notice %></p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div data-controller="flash" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-red-900/50 border border-red-700 p-4">
        <p class="text-sm text-red-200"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="overflow-x-hidden">
    <%= yield %>
  </main>

  <!-- Footer (copyright only — full footer hidden, see commit 8c65a6f) -->
  <footer class="fixed bottom-0 inset-x-0 z-30 bg-gray-950/90 backdrop-blur text-gray-500 border-t border-gray-800 py-2 text-center text-[11px]">
    &copy; <%= Date.current.year %> Agent44 Labs. All rights reserved.
  </footer>
  <%# Spacer so content can scroll past the fixed footer without being hidden behind it %>
  <div aria-hidden="true" class="h-8"></div>

</body>
</html>
