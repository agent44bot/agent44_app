<%# Shared header + sub-nav for the Cellar (storage-room inventory) section.
    Pass `active:` as one of :stock, :receive, :remove, :import. %>
<% active = local_assigns[:active] %>
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
  <%# Team avatars sit just left of the back button, matching every other NYK
      agent page. The Cellar is NYK-only, so look the workspace up directly. %>
  <div class="flex items-center justify-end gap-3 mb-4">
    <% cellar_members = Workspace.find_by(slug: "nykitchen")&.memberships&.includes(:user)&.map(&:user) %>
    <% if cellar_members&.any? %>
      <%= render "workspaces/member_avatars", members: cellar_members, size: "h-8 w-8" %>
    <% end %>
    <%= link_to nykitchen_path, class: "inline-flex items-center gap-1.5 px-3 h-8 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold transition" do %>
      ← NY Kitchen
    <% end %>
  </div>

  <div class="text-orange-500 text-[11px] font-mono tracking-[0.3em] uppercase mb-1">Agent 44 · Cellar</div>
  <h1 class="text-3xl font-black text-white">Storage Room</h1>
  <p class="text-gray-400 mt-1 text-sm">Wine &amp; spirits inventory. Lora scans cases in, Chris scans bottles out.</p>

  <%
    tab = ->(label, path, key) {
      on = active == key
      cls = "inline-flex items-center gap-1.5 px-3.5 py-2 text-sm font-semibold rounded-t-lg border-b-2 transition " +
            (on ? "border-orange-500 text-white" : "border-transparent text-gray-400 hover:text-white hover:border-gray-600")
      link_to(label, path, class: cls)
    }
  %>
  <nav class="mt-5 flex flex-wrap gap-1 border-b border-gray-800">
    <%= tab.call("📦 Stock",   nyk_inventory_path,         :stock) %>
    <%= tab.call("➕ Receive", nyk_inventory_receive_path, :receive) %>
    <%= tab.call("➖ Remove",  nyk_inventory_remove_path,  :remove) %>
    <%= tab.call("📸 Log",     nyk_inventory_captures_path, :captures) %>
    <%= tab.call("⬆ Import",   nyk_inventory_import_path,  :import) %>
  </nav>
</div>
