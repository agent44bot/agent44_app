<% content_for :title, @user ? "Track · #{@user.email_address}" : (@anonymous ? "Track · anonymous" : "Track users") %>

<% tz = "Eastern Time (US & Canada)" %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-baseline justify-between gap-4 mb-2">
    <h1 class="text-2xl font-bold text-white">
      <% if @user %>
        Track <%= @user.display_identifier %>
      <% elsif @anonymous %>
        Track anonymous visitors
      <% else %>
        Track users
      <% end %>
    </h1>
    <%= link_to "← Users", admin_users_path, class: "text-sm text-gray-500 hover:text-orange-400" %>
  </div>
  <p class="text-sm text-gray-400 mb-6">
    <% if @user %>
      Every page <strong><%= @user.email_address %></strong> hits in the app.
    <% elsif @anonymous %>
      Every page hit by <strong>signed-out</strong> visitors. Use the session column to tell visitors apart.
    <% else %>
      Activity across every signed-in user with tracked page views.
    <% end %>
    <code class="text-orange-300">/api/*</code> and <code class="text-orange-300">/rails/*</code> are excluded — everything else, including <code class="text-orange-300">/admin/*</code>, is tracked.
  </p>

  <%# User picker chips %>
  <% if @filter_users.any? %>
    <div class="flex flex-wrap gap-2 mb-4">
      <%= link_to "All users", admin_track_path(range: @range),
            class: "text-xs px-3 py-1.5 rounded-full border #{@user.nil? ? 'bg-orange-600 border-orange-500 text-white font-semibold' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
      <% @filter_users.each do |u| %>
        <%= link_to u.display_identifier, admin_track_path(user_id: u.id, range: @range),
              class: "text-xs px-3 py-1.5 rounded-full border #{@user&.id == u.id ? 'bg-orange-600 border-orange-500 text-white font-semibold' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
      <% end %>
      <%= link_to "👻 Anonymous", admin_track_path(user_id: "anonymous", range: @range),
            class: "text-xs px-3 py-1.5 rounded-full border #{@anonymous ? 'bg-orange-600 border-orange-500 text-white font-semibold' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
    </div>
  <% end %>

  <%# Time range filter %>
  <div class="flex flex-wrap gap-2 mb-8">
    <% [["today","Today"], ["week","Last 7d"], ["30d","Last 30d"], ["all","All-time"]].each do |val, label| %>
      <%= link_to label, admin_track_path(range: val, user_id: @anonymous ? "anonymous" : @user&.id),
            class: "text-xs px-3 py-1.5 rounded-full border #{@range == val ? 'bg-orange-600 border-orange-500 text-white font-semibold' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
    <% end %>
  </div>

  <% if @user || @anonymous %>
    <%# ========== SINGLE-USER (OR ANONYMOUS) DETAIL ========== %>

    <%# Header summary cards %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
      <div class="rounded-lg bg-gray-900 border border-gray-700 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Today</p>
        <p class="text-2xl font-bold text-white tabular-nums"><%= @counts[:today] %></p>
      </div>
      <div class="rounded-lg bg-gray-900 border border-gray-700 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Last 7 days</p>
        <p class="text-2xl font-bold text-white tabular-nums"><%= @counts[:week] %></p>
      </div>
      <div class="rounded-lg bg-gray-900 border border-gray-700 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Last 30 days</p>
        <p class="text-2xl font-bold text-white tabular-nums"><%= @counts[:d30] %></p>
      </div>
      <div class="rounded-lg bg-gray-900 border border-gray-700 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">All-time</p>
        <p class="text-2xl font-bold text-white tabular-nums"><%= @counts[:all] %></p>
      </div>
    </div>

    <%# Last seen + sessions %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-4 mb-8 text-sm">
      <% if @last_seen %>
        <p class="text-gray-300">
          Last seen
          <span class="text-white font-semibold">
            <%= time_ago_in_words(@last_seen.created_at) %> ago
          </span>
          on <code class="text-orange-300"><%= @last_seen.path %></code>
          <span class="text-gray-500">
            (<%= @last_seen.created_at.in_time_zone(tz).strftime("%a %b %-d, %-l:%M%P %Z") %>
            · <%= @last_seen.browser.presence || "?" %>/<%= @last_seen.os.presence || "?" %>
            · <%= @last_seen.ip_address %>)
          </span>
        </p>
      <% else %>
        <p class="text-gray-500 italic">No tracked activity yet.</p>
      <% end %>
      <p class="text-gray-500 mt-1"><%= pluralize(@session_count, "distinct session") %> in the selected range.</p>
    </div>

    <%# Top paths in window %>
    <% if @top_paths.any? %>
      <h2 class="text-base font-semibold text-white mb-3">Top paths in this window</h2>
      <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden mb-8">
        <table class="w-full text-sm">
          <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2 text-left">Path</th>
              <th class="px-4 py-2 text-right">Hits</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @top_paths.each do |path, n| %>
              <tr>
                <td class="px-4 py-2 font-mono text-orange-300 text-xs"><%= path %></td>
                <td class="px-4 py-2 text-right tabular-nums text-gray-300"><%= n %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# Activity feed %>
    <h2 class="text-base font-semibold text-white mb-3">
      Activity feed
      <% if @range_truncated %>
        <span class="text-xs text-amber-400 font-normal">(showing most recent 500 in window)</span>
      <% end %>
    </h2>

    <% if @page_views.empty? %>
      <p class="text-sm text-gray-500 italic">No page views in this window.</p>
    <% else %>
      <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2 text-left">When (ET)</th>
              <th class="px-4 py-2 text-left">Path</th>
              <% if @anonymous %>
                <th class="px-4 py-2 text-left">Session</th>
              <% end %>
              <th class="px-4 py-2 text-left">Device</th>
              <th class="px-4 py-2 text-left">Location</th>
              <th class="px-4 py-2 text-left">IP</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @page_views.each do |pv| %>
              <tr class="hover:bg-gray-800/40">
                <td class="px-4 py-2 text-gray-300 whitespace-nowrap text-xs tabular-nums">
                  <%= pv.created_at.in_time_zone(tz).strftime("%b %-d %-l:%M:%S%P") %>
                </td>
                <td class="px-4 py-2 text-xs">
                  <% method = pv.method.presence || "GET" %>
                  <% badge_color = method == "GET" ? "bg-gray-800 text-gray-400" : "bg-orange-900/60 text-orange-300" %>
                  <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-mono font-semibold mr-2 <%= badge_color %>"><%= method %></span>
                  <span class="font-mono text-orange-300"><%= pv.path %></span>
                </td>
                <% if @anonymous %>
                  <td class="px-4 py-2 font-mono text-gray-500 text-xs" title="<%= pv.session_id %>">
                    <%= pv.session_id.to_s.first(8).presence || "—" %>
                  </td>
                <% end %>
                <td class="px-4 py-2 text-gray-400 text-xs whitespace-nowrap">
                  <%= pv.browser.presence || "?" %>
                  <span class="text-gray-600">/</span>
                  <%= pv.os.presence || "?" %>
                  <% if pv.device_type.present? %>
                    <span class="text-gray-600">·</span> <%= pv.device_type %>
                  <% end %>
                </td>
                <td class="px-4 py-2 text-gray-400 text-xs whitespace-nowrap">
                  <% loc = [pv.city.presence, pv.country.presence].compact.join(", ") %>
                  <%= loc.presence || "—" %>
                </td>
                <td class="px-4 py-2 font-mono text-gray-500 text-xs"><%= pv.ip_address %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

  <% else %>
    <%# ========== ALL-USERS OVERVIEW ========== %>

    <% if @user_summary.empty? && @anon_summary.nil? %>
      <p class="text-sm text-gray-500 italic">No tracked activity in this window yet.</p>
    <% else %>
      <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2 text-left">User</th>
              <th class="px-4 py-2 text-right">Hits</th>
              <th class="px-4 py-2 text-right">Sessions</th>
              <th class="px-4 py-2 text-left">Last seen</th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @user_summary.each do |row| %>
              <% u = row[:user] %>
              <tr class="hover:bg-gray-800/40">
                <td class="px-4 py-2">
                  <div class="text-white"><%= u.display_identifier %></div>
                  <div class="text-xs text-gray-500"><%= u.email_address %></div>
                </td>
                <td class="px-4 py-2 text-right tabular-nums text-white font-semibold"><%= row[:hits] %></td>
                <td class="px-4 py-2 text-right tabular-nums text-gray-300"><%= row[:sessions] %></td>
                <td class="px-4 py-2 text-gray-400 text-xs whitespace-nowrap">
                  <%= time_ago_in_words(row[:last_seen_at]) %> ago
                  <div class="text-gray-600"><%= row[:last_seen_at].in_time_zone(tz).strftime("%a %b %-d, %-l:%M%P %Z") %></div>
                </td>
                <td class="px-4 py-2 text-right">
                  <%= link_to "Drill in →", admin_track_path(user_id: u.id, range: @range),
                        class: "text-xs text-orange-400 hover:text-orange-300 font-semibold" %>
                </td>
              </tr>
            <% end %>
            <% if @anon_summary %>
              <tr class="hover:bg-gray-800/40 bg-gray-950/40">
                <td class="px-4 py-2">
                  <div class="text-white">👻 Anonymous</div>
                  <div class="text-xs text-gray-500">signed-out visitors</div>
                </td>
                <td class="px-4 py-2 text-right tabular-nums text-white font-semibold"><%= @anon_summary[:hits] %></td>
                <td class="px-4 py-2 text-right tabular-nums text-gray-300"><%= @anon_summary[:sessions] %></td>
                <td class="px-4 py-2 text-gray-400 text-xs whitespace-nowrap">
                  <%= time_ago_in_words(@anon_summary[:last_seen_at]) %> ago
                  <div class="text-gray-600"><%= @anon_summary[:last_seen_at].in_time_zone(tz).strftime("%a %b %-d, %-l:%M%P %Z") %></div>
                </td>
                <td class="px-4 py-2 text-right">
                  <%= link_to "Drill in →", admin_track_path(user_id: "anonymous", range: @range),
                        class: "text-xs text-orange-400 hover:text-orange-300 font-semibold" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% end %>
</div>
