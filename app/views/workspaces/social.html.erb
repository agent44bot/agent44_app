<% content_for :title, "#{@workspace.name} · Social Agent" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="collapsible composer"
     data-collapsible-collapsed-value="true"
     data-collapsible-scroll-on-expand-value="true">
  <div class="flex items-center justify-between gap-3 mb-6 text-sm">
    <% back_btn = "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold transition shrink-0" %>
    <% ws_root = show_workspaces_crumb? ? [["Workspaces", workspaces_path(force: 1)]] : [] %>
    <% if @workspace.slug == "nykitchen" %>
      <%= render "shared/breadcrumbs", crumbs: ws_root + [["NY Kitchen", nykitchen_path], [nyk_agent_callsign("social", @workspace.agent_for("social")), nil]] %>
      <%= link_to "← NY Kitchen", nykitchen_path, class: back_btn %>
    <% else %>
      <%= render "shared/breadcrumbs", crumbs: ws_root + [[@workspace.name, workspace_path(@workspace.slug)], ["Social Agent", nil]] %>
      <%= link_to "← #{@workspace.name}", workspace_path(@workspace.slug), class: back_btn %>
    <% end %>
  </div>

  <div class="flex items-start justify-between gap-2 mb-6 flex-wrap">
    <div>
      <% if @workspace.logo.attached? %>
        <%= image_tag @workspace.logo, alt: "#{@workspace.name} logo",
              class: "h-12 w-auto mb-3 rounded bg-white/5 p-1" %>
      <% end %>
      <%# NY Kitchen uses the "Field Roster" identity (Echo · BROADCAST · #n) to
          match the hub + other agent pages; other workspaces keep the generic
          "Social Agent" heading. %>
      <% if @workspace.slug == "nykitchen" %>
        <% sa = @workspace.agent_for("social") %>
        <% meta = nyk_agent_meta("social") %>
        <div class="flex items-baseline gap-3 flex-wrap">
          <h1 class="text-2xl font-bold text-white"><%= nyk_agent_callsign("social", sa) %></h1>
          <div class="flex items-baseline gap-2 text-sm font-mono uppercase tracking-wider">
            <span class="font-semibold" style="color: <%= meta[:accent] %>"><%= meta[:tag] %></span>
            <% if sa %><span class="text-gray-600">·</span><span class="text-gray-500">#<%= sa.agent_number %></span><% end %>
          </div>
        </div>
      <% else %>
        <h1 class="text-2xl font-bold text-white">Social Agent</h1>
      <% end %>
      <p class="text-xs text-gray-500 font-mono mt-1"><%= @workspace.name %> · /<%= @workspace.slug %> · <%= @workspace.timezone %></p>
    </div>
    <div class="flex items-center gap-2">
      <% if @writer && @connected_platforms.any? %>
        <button type="button"
                data-action="click->composer#toggle"
                class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 hover:border-orange-500 text-sm text-gray-200 transition cursor-pointer">
          <span class="text-orange-400 text-base leading-none">+</span>
          <span>New post</span>
        </button>
      <% end %>
      <% if %w[owner admin].include?(@my_role) %>
        <button type="button"
                data-action="click->collapsible#toggle"
                aria-label="Social Agent settings"
                class="inline-flex items-center gap-1.5 px-3 h-8 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white transition shrink-0 text-sm font-medium">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/>
          </svg>
          Settings
        </button>
      <% end %>
    </div>
  </div>

  <% if %w[owner admin].include?(@my_role) %>
    <div data-collapsible-target="body" class="mb-6 space-y-4">
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-3">Connected accounts</h2>

        <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
          <% @social_accounts.each do |acct| %>
            <div class="flex items-center justify-between px-4 py-3 gap-3">
              <div class="min-w-0">
                <p class="text-sm text-white truncate"><%= acct.label %></p>
                <p class="text-xs text-gray-500"><%= acct.platform %><% if acct.token_expires_at.present? %> · token expires <%= acct.token_expires_at.in_time_zone(@workspace.timezone).strftime("%b %-d, %-l:%M %p") %><% end %></p>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xs uppercase tracking-wide <%= acct.status == 'active' ? 'text-green-400' : 'text-yellow-400' %>"><%= acct.status %></span>
                <%= button_to "Disconnect", workspace_social_account_path(workspace_slug: @workspace.slug, id: acct.id),
                    method: :delete, form: { data: { turbo_confirm: "Disconnect #{acct.label}?" } },
                    class: "text-xs text-red-400 hover:text-red-300 px-3 py-1 border border-red-900 rounded-md cursor-pointer" %>
              </div>
            </div>
          <% end %>

          <%# Unconnected platforms — each gets a row with a Connect CTA.
              Gate on @social_accounts (any status), not @x_account etc.
              (which are .active-only) so a needs_reauth row above doesn't
              also surface here. %>
          <% platforms_with_account = @social_accounts.map(&:platform).to_set %>
          <% [
               ["X",        "x",        workspace_oauth_x_connect_path(workspace_slug: @workspace.slug),       :post],
               ["Bluesky",  "bluesky",  new_workspace_bluesky_account_path(workspace_slug: @workspace.slug),   :get],
               ["Threads",  "threads",  workspace_oauth_threads_connect_path(workspace_slug: @workspace.slug), :post],
               ["Facebook", "facebook", workspace_oauth_facebook_connect_path(workspace_slug: @workspace.slug), :post]
             ].each do |name, platform, path, method| %>
            <% next if platforms_with_account.include?(platform) %>
            <div class="flex items-center justify-between px-4 py-3 gap-3">
              <div class="min-w-0">
                <p class="text-sm text-gray-300"><%= name %></p>
                <p class="text-xs text-gray-600">not connected</p>
              </div>
              <% if method == :get %>
                <%= link_to "Connect", path,
                    class: "text-xs text-orange-400 hover:text-orange-300 px-3 py-1 border border-orange-900 rounded-md inline-block" %>
              <% else %>
                <%= button_to "Connect", path, method: method,
                    class: "text-xs text-orange-400 hover:text-orange-300 px-3 py-1 border border-orange-900 rounded-md cursor-pointer" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @writer %>
    <% if @connected_platforms.any? %>
    <%# Start open when AI just returned a suggested draft, otherwise the
        pre-filled draft is hidden inside the collapsed composer. %>
    <div data-composer-target="body" class="<%= "hidden" unless flash[:draft_text].present? %> mb-10">
      <% draft_text  = flash[:draft_text].to_s %>
      <% draft_topic = flash[:draft_topic].to_s %>
      <% min_len     = @connected_platforms.include?("x") ? 280 : 300 %>
      <div class="rounded-lg border border-gray-800 bg-gray-900 p-4 space-y-3">
          <% if draft_text.present? %>
            <p class="text-xs text-orange-400">✨ AI-suggested draft below — edit, then post.</p>
          <% end %>

          <%= form_with url: workspace_draft_suggest_path(workspace_slug: @workspace.slug), local: true, class: "space-y-2" do %>
            <div class="flex flex-wrap gap-2">
              <%= text_field_tag :topic, draft_topic, placeholder: "What should AI draft about? (optional)",
                  class: "flex-1 min-w-[220px] rounded-md bg-black border border-gray-700 text-white px-3 py-2 text-base focus:border-orange-500 focus:outline-none" %>
              <%= submit_tag "✨ Draft with AI",
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
            </div>
          <% end %>

          <%# Upload a photo → AI captions it on-brand → review on the next
              screen, then post it (with the image) to X. %>
          <%= form_with url: workspace_draft_from_image_path(workspace_slug: @workspace.slug), local: true, multipart: true, class: "space-y-2 pt-1 border-t border-gray-800" do %>
            <p class="text-xs text-gray-500 uppercase tracking-wide pt-2">Or draft from a photo</p>
            <div class="flex flex-wrap items-center gap-2">
              <%= file_field_tag :image, accept: "image/png,image/jpeg,image/gif,image/webp", required: true,
                  class: "flex-1 min-w-[220px] text-sm text-gray-300 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border file:border-gray-700 file:bg-gray-800 file:text-white file:cursor-pointer" %>
              <%= text_field_tag :topic, nil, placeholder: "Occasion/angle (optional)",
                  class: "flex-1 min-w-[180px] rounded-md bg-black border border-gray-700 text-white px-3 py-2 text-base focus:border-orange-500 focus:outline-none" %>
              <%= submit_tag "📸 Draft from image",
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
            </div>
            <p class="text-xs text-gray-500">Posts the photo natively to X. JPEG, PNG, GIF, or WebP, up to 5MB.</p>
          <% end %>

          <%= form_with url: workspace_posts_path(workspace_slug: @workspace.slug), local: true, class: "space-y-3" do |f| %>
            <%= f.text_area :body, rows: 3, maxlength: min_len, required: true,
                value: draft_text.presence,
                placeholder: "Write your post, or use ✨ Draft with AI above",
                class: "w-full rounded-md bg-black border border-gray-700 text-white px-3 py-2 focus:border-orange-500 focus:outline-none font-mono text-sm" %>

            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
              <span class="text-xs text-gray-500 uppercase tracking-wide">Post to:</span>
              <% if @x_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "x", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  X <span class="text-xs text-gray-500"><%= @x_account.handle %></span>
                </label>
              <% end %>
              <% if @bluesky_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "bluesky", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  Bluesky <span class="text-xs text-gray-500"><%= @bluesky_account.handle %></span>
                </label>
              <% end %>
              <% if @threads_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "threads", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  Threads <span class="text-xs text-gray-500"><%= @threads_account.handle %></span>
                </label>
              <% end %>
              <% if @facebook_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "facebook", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  Facebook <span class="text-xs text-gray-500"><%= @facebook_account.handle %></span>
                </label>
              <% end %>
            </div>

            <div class="flex flex-wrap items-center gap-x-3 gap-y-2 pt-1">
              <label class="text-xs text-gray-500 uppercase tracking-wide">Schedule for:</label>
              <%= datetime_field_tag :scheduled_for, nil,
                  class: "rounded-md bg-black border border-gray-700 text-white px-2 py-1 text-xs focus:border-orange-500 focus:outline-none" %>
              <span class="text-xs text-gray-500">(<%= @workspace.timezone %>) — leave blank to post now or save as draft</span>
            </div>

            <div class="flex items-center justify-end gap-2 pt-1">
              <%= submit_tag "Save draft", name: "commit", value: "save",
                  formaction: workspace_drafts_path(workspace_slug: @workspace.slug),
                  formnovalidate: true,
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
              <%= submit_tag "Schedule", name: "commit", value: "schedule",
                  formaction: workspace_drafts_path(workspace_slug: @workspace.slug),
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
              <%= f.submit "Post now",
                  formnovalidate: true,
                  data: { turbo_confirm: "Post to the selected platforms now?" },
                  class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
            </div>
          <% end %>
      </div>
    </div>
    <% else %>
      <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center mb-10">
        <% if %w[owner admin].include?(@my_role) %>
          <p class="text-gray-400 text-sm">No social accounts connected yet. Open the <span aria-hidden="true">⋮</span> menu in the top right to connect X, Bluesky, Threads, or Facebook.</p>
        <% else %>
          <p class="text-gray-400 text-sm">No social accounts connected yet. Ask a workspace admin to connect X, Bluesky, Threads, or Facebook.</p>
        <% end %>
      </div>
    <% end %>

        <% if @scheduled_drafts.any? %>
          <h3 class="text-xs uppercase tracking-wide text-gray-500 mt-6 mb-2">Scheduled</h3>
          <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
            <% @scheduled_drafts.each do |d| %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between mb-1 gap-3">
                  <p class="text-xs text-gray-500 truncate">
                    <%= d.author.display_identifier %> · fires <%= d.scheduled_for.in_time_zone(@workspace.timezone).strftime("%b %-d, %-l:%M %p %Z") %> · <%= Array(d.target_platforms).map(&:titleize).join(", ") %>
                  </p>
                  <div class="flex items-center gap-2 shrink-0">
                    <%= button_to "Post now", publish_workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :post, form: { data: { turbo_confirm: "Publish this draft right now?" } },
                        class: "text-xs text-orange-400 hover:text-orange-300 px-2 py-1 border border-orange-900 rounded-md cursor-pointer" %>
                    <%= button_to workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :delete, form: { data: { turbo_confirm: "Cancel this scheduled post?" } },
                        class: "p-1 text-gray-500 hover:text-red-400 cursor-pointer", title: "Delete" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
                    <% end %>
                  </div>
                </div>
                <p class="text-sm text-white whitespace-pre-wrap break-words"><%= d.body %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @drafts.any? %>
          <div class="mt-8 mb-2 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            <h3 id="drafts" class="text-sm font-semibold uppercase tracking-wide text-orange-300">Drafts</h3>
            <span class="text-xs text-gray-500"><%= @drafts.size %> waiting</span>
          </div>
          <div class="rounded-lg border border-orange-600/40 bg-orange-950/20 divide-y divide-orange-900/40 ring-1 ring-orange-500/10">
            <% @drafts.each do |d| %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between mb-1 gap-3">
                  <p class="text-xs text-gray-400 truncate">
                    <%= d.author.display_identifier %> · saved <%= d.created_at.in_time_zone(@workspace.timezone).strftime("%b %-d, %-l:%M %p") %> · <%= Array(d.target_platforms).map(&:titleize).join(", ") %>
                  </p>
                  <div class="flex items-center gap-2 shrink-0">
                    <%= link_to "Edit", edit_workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        class: "text-xs text-gray-300 hover:text-white px-2 py-1 border border-gray-700 rounded-md hover:border-orange-500" %>
                    <%= button_to "Post now", publish_workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :post, form: { data: { turbo_confirm: "Publish this draft now?" } },
                        class: "text-xs text-orange-400 hover:text-orange-300 px-2 py-1 border border-orange-900 rounded-md cursor-pointer" %>
                    <%= button_to workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :delete, form: { data: { turbo_confirm: "Delete this draft?" } },
                        class: "p-1 text-gray-500 hover:text-red-400 cursor-pointer", title: "Delete" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
                    <% end %>
                  </div>
                </div>
                <p class="text-sm text-white whitespace-pre-wrap break-words"><%= d.body %></p>
              </div>
            <% end %>
          </div>
        <% end %>

      <%# Recent posts, tabbed by platform. Each tab shows a green check when the
          platform is connected, a red dot when it isn't. Unconnected platforms
          (Facebook/Instagram) offer a Connect CTA in place of posts. %>
      <% posts_by_platform = @posts.group_by(&:platform) %>
      <% fb_connect = workspace_oauth_facebook_connect_path(workspace_slug: @workspace.slug) %>
      <% platform_tabs = [
           { key: "x",         label: "X",         account: @x_account },
           { key: "bluesky",   label: "Bluesky",   account: @bluesky_account },
           { key: "facebook",  label: "Facebook",  account: @facebook_account, connect: fb_connect },
           { key: "instagram", label: "Instagram", account: nil,               connect: fb_connect, via_meta: true }
         ] %>
      <% can_connect = %w[owner admin].include?(@my_role) %>

      <div class="mt-6" data-controller="tabs"
           data-tabs-active-classes-value="text-white border-orange-500"
           data-tabs-inactive-classes-value="text-gray-500 border-transparent hover:text-gray-300">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs uppercase tracking-wide text-gray-500">Recent posts</h3>
          <%= button_to refresh_metrics_workspace_path(@workspace.slug),
              method: :post,
              class: "text-xs text-gray-400 hover:text-orange-400 cursor-pointer flex items-center gap-1",
              title: "Pull latest impressions / likes / reposts from X + Bluesky now" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Refresh metrics
          <% end %>
        </div>

        <div class="flex items-center gap-1 border-b border-gray-800 mb-3 overflow-x-auto">
          <% platform_tabs.each_with_index do |t, i| %>
            <button type="button" data-tabs-target="tab" data-action="click->tabs#select"
                    data-tab-index="<%= i %>" data-tab-name="<%= t[:key] %>"
                    class="flex items-center gap-1.5 px-3 py-2 border-b-2 text-sm font-medium whitespace-nowrap cursor-pointer transition">
              <%= t[:label] %>
              <% if t[:account] %>
                <span class="text-green-400 text-xs" title="Connected" aria-label="connected">✓</span>
              <% else %>
                <span class="inline-block w-2 h-2 rounded-full bg-red-500" title="Not connected" aria-label="not connected"></span>
              <% end %>
            </button>
          <% end %>
        </div>

        <% platform_tabs.each_with_index do |t, i| %>
          <% posts = posts_by_platform[t[:key]] || [] %>
          <div data-tabs-target="panel" class="<%= "hidden" unless i.zero? %>">
            <% if posts.any? %>
              <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
                <% posts.each do |p| %>
                  <%= render "workspaces/post_card", p: p, workspace: @workspace, writer: @writer %>
                <% end %>
              </div>
            <% elsif t[:account] %>
              <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center text-sm text-gray-500">
                No <%= t[:label] %> posts yet.
              </div>
            <% else %>
              <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center">
                <p class="text-sm text-gray-400"><%= t[:label] %> isn't connected yet.</p>
                <% if t[:via_meta] %>
                  <p class="text-xs text-gray-600 mt-1">Instagram connects through Meta (the same login as Facebook).</p>
                <% end %>
                <% if can_connect && t[:connect] %>
                  <%= button_to "Connect #{t[:label]}", t[:connect], method: :post,
                      class: "inline-flex items-center mt-3 px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
                <% end %>
                <p class="text-xs text-gray-600 mt-3">No posts yet.</p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
  <% end %>

</div>
