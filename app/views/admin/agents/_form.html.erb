<%= form_with(model: [:admin, agent], class: "space-y-6") do |f| %>
  <% if agent.errors.any? %>
    <div class="rounded-lg bg-red-900/50 border border-red-700 p-4">
      <ul class="text-sm text-red-200 space-y-1">
        <% agent.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Name</label>
      <%= f.text_field :name, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent", placeholder: "Knox" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Role</label>
      <%= f.text_field :role, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent", placeholder: "Security & DevOps" %>
    </div>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-300 mb-1">Description</label>
    <%= f.text_area :description, rows: 2, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent", placeholder: "What does this agent do?" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">LLM Model</label>
      <%= f.text_field :llm_model, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent", placeholder: "ollama/qwen2.5-coder:7b" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Schedule</label>
      <%= f.text_field :schedule, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent", placeholder: "Daily 8 AM EDT" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Status</label>
      <%= f.select :status, Agent::STATUSES.map { |s| [s.capitalize, s] },
            {}, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Color</label>
      <%= f.select :avatar_color, Agent::COLORS.map { |c| [c.capitalize, c] },
            {}, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Position</label>
      <%= f.number_field :position, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit agent.persisted? ? "Update Agent" : "Create Agent",
          class: "inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-orange-600 rounded-lg hover:bg-orange-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_agents_path, class: "text-sm text-gray-400 hover:text-white transition" %>
  </div>
<% end %>
