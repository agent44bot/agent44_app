<h2>You've been invited to <%= @workspace.name %></h2>

<p>
  <strong><%= @inviter.display_identifier %></strong> invited you to join
  <strong><%= @workspace.name %></strong> on Agent44 Labs as a
  <strong><%= @invitation.role %></strong>.
</p>

<p>
  <%= link_to "Accept invitation", @accept_url,
        style: "display:inline-block;padding:10px 18px;background:#ea580c;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;" %>
</p>

<p style="color:#6b7280;font-size:13px;">
  Or copy this link into your browser:<br>
  <%= @accept_url %>
</p>

<p style="color:#6b7280;font-size:13px;">
  This invitation expires <%= @expires_at.strftime("%b %-d, %Y") %>.
  If you didn't expect this, you can ignore this email.
</p>
