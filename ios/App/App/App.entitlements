<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>production</string>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:agent44labs.com</string>
		<string>webcredentials:agent44labs.com</string>
		<!-- agent44labs.ai hosts the QR smart-link (/get). Claim it so an
		     installed app opens directly instead of going to the App Store.
		     The AASA at agent44labs.ai already lists /get for this appID. -->
		<string>applinks:agent44labs.ai</string>
	</array>
</dict>
</plist>
