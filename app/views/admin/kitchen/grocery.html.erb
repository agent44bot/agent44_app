<div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
  <div class="flex items-center justify-between mb-2 no-print">
    <%= link_to "← Back to Sam's list", nyk_list_path, class: "text-sm text-gray-500 hover:text-orange-400" %>
    <div class="flex items-center gap-3 text-sm">
      <% [ [ "This weekend", @default_days ], [ "Next 7 days", 7 ], [ "Next 14 days", 14 ] ].each do |label, d| %>
        <%= link_to label, nyk_grocery_path(days: d),
              class: "px-2.5 py-1 rounded-full border #{@days == d ? 'bg-orange-600 border-orange-500 text-white' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
      <% end %>
    </div>
  </div>

  <h1 class="text-2xl font-bold text-white mt-3 mb-6">Grocery list</h1>

  <%# The list is built by an Opus call, so load it lazily in a frame: this page
      paints instantly and the spinner shows while the list is built (or fetched
      from cache). %>
  <%= turbo_frame_tag "grocery_list", src: nyk_grocery_path(days: @days), loading: "eager" do %>
    <div class="flex flex-col items-center justify-center py-24 text-gray-500">
      <svg class="animate-spin w-8 h-8 text-orange-500 mb-3" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
      </svg>
      <p class="text-sm">Building your grocery list...</p>
    </div>
  <% end %>
</div>

<%= javascript_tag nonce: true do %>
  document.addEventListener("click", function (e) {
    if (e.target.closest("#grocery-print-btn")) window.print();
  });
<% end %>

<style>
  @media print {
    .no-print { display: none !important; }
    .print-sheet { box-shadow: none !important; border: 0 !important; padding: 0 !important; }
    body { background: #fff !important; }
  }
</style>
