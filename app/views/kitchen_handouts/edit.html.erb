<%# Review screen after extraction. Every quantity is editable; the station
    column is an AI proposal and the main thing to double-check. Each recipe
    gets 3 spare blank ingredient rows; blank rows are dropped on save. %>
<div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
  <%= link_to "← Back to Sam's list", nyk_list_path, class: "text-sm text-gray-500 hover:text-orange-400" %>
  <h1 class="text-2xl font-bold text-white mt-3 mb-6">Review the handout</h1>

  <%= form_with url: nyk_handout_path(@handout), method: :patch do |f| %>
    <div class="grid grid-cols-2 gap-4 mb-8">
      <div>
        <label class="block text-sm font-semibold text-gray-300 mb-1">Packet title</label>
        <%= text_field_tag :title, @handout.title, class: "w-full rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2 focus:border-orange-500 focus:outline-none" %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-300 mb-1">Scaled column label</label>
        <%= text_field_tag :station_label, @handout.station_label, class: "w-full rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2 focus:border-orange-500 focus:outline-none" %>
      </div>
    </div>

    <% @handout.recipes.each_with_index do |recipe, ri| %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Recipe <%= ri + 1 %></label>
        <%= text_field_tag "recipes[#{ri}][title]", recipe["title"], class: "w-full rounded-lg bg-gray-950 border border-gray-800 text-white font-semibold text-base px-3 py-2 mb-4 focus:border-orange-500 focus:outline-none" %>

        <div class="grid grid-cols-[1fr_1fr_2fr_1fr] gap-2 text-xs font-semibold text-gray-500 mb-1 px-1">
          <span>Full amount</span><span class="text-amber-400"><%= @handout.station_label %> *</span><span>Ingredient</span><span>Sub-heading</span>
        </div>
        <% rows = Array(recipe["ingredients"]) + Array.new(3) { {} } %>
        <% rows.each_with_index do |ing, ii| %>
          <div class="grid grid-cols-[1fr_1fr_2fr_1fr] gap-2 mb-1.5">
            <%= text_field_tag "recipes[#{ri}][ingredients][#{ii}][qty]", ing["qty"], class: "rounded-lg bg-gray-950 border border-gray-800 text-gray-200 text-base px-2.5 py-1.5 focus:border-orange-500 focus:outline-none" %>
            <%= text_field_tag "recipes[#{ri}][ingredients][#{ii}][station_qty]", ing["station_qty"], class: "rounded-lg bg-gray-950 border border-amber-900/60 text-amber-200 text-base px-2.5 py-1.5 focus:border-amber-500 focus:outline-none" %>
            <%= text_field_tag "recipes[#{ri}][ingredients][#{ii}][item]", ing["item"], class: "rounded-lg bg-gray-950 border border-gray-800 text-gray-200 text-base px-2.5 py-1.5 focus:border-orange-500 focus:outline-none" %>
            <%= text_field_tag "recipes[#{ri}][ingredients][#{ii}][section]", ing["section"], class: "rounded-lg bg-gray-950 border border-gray-800 text-gray-400 text-base px-2.5 py-1.5 focus:border-orange-500 focus:outline-none" %>
          </div>
        <% end %>

        <label class="block text-xs font-semibold text-gray-500 uppercase mt-4 mb-1">Directions (one step per line)</label>
        <% Array(recipe["directions"]).each_with_index do |group, di| %>
          <div class="mb-3">
            <%= text_field_tag "recipes[#{ri}][directions][#{di}][section]", group["section"], placeholder: "Sub-heading (optional)", class: "w-1/2 rounded-lg bg-gray-950 border border-gray-800 text-gray-400 text-base px-2.5 py-1.5 mb-1 focus:border-orange-500 focus:outline-none" %>
            <%= text_area_tag "recipes[#{ri}][directions][#{di}][steps]", Array(group["steps"]).join("\n"), rows: [ Array(group["steps"]).size + 1, 4 ].max, class: "w-full rounded-lg bg-gray-950 border border-gray-800 text-gray-200 text-base px-3 py-2 focus:border-orange-500 focus:outline-none" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <p class="text-xs text-amber-400/80 mb-4">* The <%= @handout.station_label.downcase %> amounts were proposed by the agent. Please double-check them, especially ranges and "to taste" lines.</p>

    <div class="flex items-center gap-3">
      <%= submit_tag "Save and preview print", class: "px-5 py-2.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white font-semibold cursor-pointer" %>
      <% if @handout.persisted? && @handout.recipes.any? %>
        <%= link_to "Print without saving edits", print_nyk_handout_path(@handout), class: "text-sm text-gray-500 hover:text-gray-300" %>
      <% end %>
    </div>
  <% end %>
</div>
