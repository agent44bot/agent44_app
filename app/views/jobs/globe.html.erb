<% content_for(:title, "Job Globe") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Job Globe</h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @globe_data.sum { |d| d[:count] } %> jobs across
        <%= @globe_data.size %> locations worldwide
      </p>
    </div>
    <%= link_to "&larr; Back to Jobs".html_safe, jobs_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
  </div>

  <div id="globe-container" class="rounded-2xl border border-gray-200 overflow-hidden shadow-lg" style="height: 650px; background: #070B1A;"></div>
</div>

<script>
(function() {
  var data = <%= raw @globe_data.to_json %>;

  function initGlobe() {
    var container = document.getElementById("globe-container");
    if (!container) return;

    if (data.length === 0) {
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#9ca3af;font-size:14px;">No geocoded jobs yet.</div>';
      return;
    }

    var maxCount = Math.max.apply(null, data.map(function(d) { return d.count; }));
    var width = container.offsetWidth;
    var height = 650;

    var globe = Globe()
      .globeImageUrl("//unpkg.com/three-globe/example/img/earth-night.jpg")
      .bumpImageUrl("//unpkg.com/three-globe/example/img/earth-topology.png")
      .backgroundImageUrl("//unpkg.com/three-globe/example/img/night-sky.png")
      .pointsData(data)
      .pointLat(function(d) { return d.lat; })
      .pointLng(function(d) { return d.lng; })
      .pointAltitude(function(d) { return (d.count / maxCount) * 0.4 + 0.01; })
      .pointRadius(function(d) { return Math.max(Math.sqrt(d.count) * 0.35, 0.15); })
      .pointColor(function(d) {
        var intensity = d.count / maxCount;
        if (intensity > 0.5) return "rgba(239, 68, 68, 0.95)";
        if (intensity > 0.2) return "rgba(245, 158, 11, 0.9)";
        return "rgba(99, 102, 241, 0.85)";
      })
      .pointLabel(function(d) {
        return '<div style="background:rgba(0,0,0,0.85);color:white;padding:8px 12px;border-radius:8px;font-size:13px;line-height:1.4;border:1px solid rgba(255,255,255,0.1);">' +
          '<div style="font-weight:600;">' + d.location + '</div>' +
          '<div style="color:rgba(255,255,255,0.7);">' + d.count + ' job' + (d.count > 1 ? 's' : '') + '</div>' +
          '</div>';
      })
      .onPointClick(function(d) {
        window.location.href = "/jobs?q=" + encodeURIComponent(d.location);
      })
      .atmosphereColor("#6366f1")
      .atmosphereAltitude(0.25)
      .width(width)
      .height(height)
      (container);

    globe.controls().autoRotate = true;
    globe.controls().autoRotateSpeed = 0.4;
    globe.controls().enableDamping = true;

    globe.pointOfView({ lat: 38, lng: -97, altitude: 2.2 }, 1000);

    window.addEventListener("resize", function() {
      globe.width(container.offsetWidth);
    });
  }

  // Load globe.gl dynamically to avoid Turbo issues
  if (typeof Globe !== "undefined") {
    initGlobe();
  } else {
    var script = document.createElement("script");
    script.src = "https://unpkg.com/globe.gl@2.27.2/dist/globe.gl.min.js";
    script.onload = function() {
      console.log("globe.gl loaded, Globe:", typeof Globe);
      initGlobe();
    };
    script.onerror = function() {
      console.error("Failed to load globe.gl");
    };
    document.head.appendChild(script);
  }
})();
</script>
