<%# Shown while ExtractRecipeJob turns the uploaded source into recipes. The
    packet-build controller polls the status endpoint and reloads the page when
    the job flips it to ready (the editor) or failed (the error state). %>
<div class="mt-6 flex flex-col items-center justify-center text-center py-20 px-6 rounded-xl border border-gray-800 bg-gray-900/40"
     data-controller="packet-build"
     data-packet-build-url-value="<%= status_nyk_packet_path(@packet) %>">
  <svg class="animate-spin w-10 h-10 text-orange-500 mb-4" viewBox="0 0 24 24" fill="none">
    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
  </svg>
  <p class="text-gray-200 text-sm font-medium">Building your recipe with the Opus model...</p>
  <p class="text-gray-500 text-xs mt-1 max-w-sm">Reading the document, splitting out each recipe, and proposing single station amounts. This usually takes under a minute. You can leave this page and come back; it keeps working, and this screen updates itself when it is done.</p>
</div>
