<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Agent 44 Labs">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="description" content="Agent 44 Labs — AI agents, test automation, iOS & web apps">
  <title><%= content_for?(:title) ? "#{yield(:title)} | Agent 44 Labs" : "Agent 44 Labs" %></title>
  <link rel="icon" href="/agent44_logo.svg" type="image/svg+xml">
  <link rel="alternate icon" href="/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <meta name="turbo-cache-control" content="auto">

  <%= yield :head %>

  <link rel="icon" href="/agent44_logo.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= javascript_tag nonce: true do %>
  // Fallback nav toggle — only fires if Stimulus hasn't connected yet.
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-nav-target="menuBtn"]');
    if (!btn) return;
    // Skip if Stimulus nav controller is connected (it handles its own click)
    var navEl = document.querySelector('[data-controller*="nav"]');
    if (navEl && navEl.dataset.controller && window.Stimulus) {
      var app = window.Stimulus;
      if (app.getControllerForElementAndIdentifier && app.getControllerForElementAndIdentifier(navEl, 'nav')) return;
    }
    var menu = document.querySelector('[data-nav-target="menu"]');
    if (menu) menu.classList.toggle('hidden');
  });
  <% end %>
</head>
<body class="h-full flex flex-col bg-gray-950 text-white antialiased">

  <!-- Navigation -->
  <nav class="bg-gray-950/80 backdrop-blur-md border-b border-gray-800 sticky top-0 z-50" data-controller="nav">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <!-- Left: Logo + Links -->
        <div class="flex items-center space-x-8">
          <%= link_to root_path, class: "flex items-center space-x-2 font-black text-xl tracking-tight" do %>
            <img src="/agent44_logo.svg" alt="Agent 44 Labs" width="40" height="40" class="w-10 h-10">
            <span class="text-white">Agent 44 <span class="bg-gradient-to-r from-orange-600 to-amber-600 bg-clip-text text-transparent">Labs</span></span>
          <% end %>

          <div class="hidden md:flex items-center space-x-6">
            <%= link_to "Home", root_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <%= link_to "Jobs", jobs_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <% if authenticated? && Current.session.user.admin? %>
              <%= link_to "Crypto", crypto_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <% end %>
            <%= link_to "AI News", news_articles_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <%= link_to posts_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition flex items-center gap-1" do %>
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>
              Pulse
            <% end %>
            <%= link_to globe_jobs_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition flex items-center gap-1" do %>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/></svg>
              Map
            <% end %>
          </div>
        </div>

        <!-- Right: Auth -->
        <div class="hidden md:flex items-center space-x-4">
          <% if authenticated? %>
            <%= link_to saved_jobs_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition flex items-center gap-1", title: "Saved Jobs" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
              Saved
            <% end %>
            <% if Current.session.user.admin? %>
              <%= link_to "Dashboard", admin_dashboard_path, class: "text-sm font-medium text-orange-600 hover:text-orange-300 transition" %>
            <% end %>
            <span class="text-sm text-gray-400"><%= Current.session.user.display_identifier %></span>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <%= link_to "Sign Up", new_registration_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-orange-600 rounded-full hover:bg-orange-700 transition" %>
          <% end %>
        </div>

        <!-- Mobile menu button -->
        <div class="flex items-center md:hidden">
          <button data-action="click->nav#toggle" data-nav-target="menuBtn"
                  class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-orange-400 hover:bg-gray-800 transition">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="hidden md:hidden" data-nav-target="menu">
      <div class="px-4 pt-2 pb-4 space-y-1 border-t border-gray-800">
        <%= link_to "Home", root_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <%= link_to "Jobs", jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% if authenticated? && Current.session.user.admin? %>
          <%= link_to "Crypto", crypto_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "NY Kitchen", nykitchen_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% end %>
        <%= link_to "AI News", news_articles_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <%= link_to posts_path, class: "flex items-center gap-1 px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800 hover:text-orange-400" do %>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>
          Pulse
        <% end %>
        <%= link_to "Map", globe_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <div class="border-t border-gray-800 pt-2">
          <% if authenticated? %>
            <%= link_to "Saved Jobs", saved_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <% if Current.session.user.admin? %>
              <%= link_to "Dashboard", admin_dashboard_path, class: "block px-3 py-2 rounded-md text-base font-medium text-orange-600 hover:bg-gray-800" %>
            <% end %>
            <span class="block px-3 py-2 text-sm text-gray-400"><%= Current.session.user.display_identifier %></span>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <%= link_to "Sign Up", new_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-orange-600 hover:bg-gray-800" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Email verification banner -->
  <% if authenticated? && Current.session.user.email_address.present? && !Current.session.user.email_verified? %>
    <div class="bg-amber-900/30 border-b border-amber-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
        <p class="text-sm text-amber-300">Please verify your email address. Check your inbox for a verification link.</p>
        <%= button_to "Resend email", resend_email_verification_path, method: :post, class: "text-sm font-medium text-amber-400 hover:text-amber-200 underline" %>
      </div>
    </div>
  <% end %>

  <!-- Flash messages -->
  <% if notice.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-green-900/50 border border-green-700 p-4">
        <p class="text-sm text-green-200"><%= notice %></p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-red-900/50 border border-red-700 p-4">
        <p class="text-sm text-red-200"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="flex-1">
    <%= yield %>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-950 text-gray-400 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- About -->
        <div>
          <h3 class="text-white font-black text-lg mb-3">Agent 44 Labs</h3>
        </div>

        <!-- Links -->
        <div>
          <h3 class="text-white font-semibold text-lg mb-3">Links</h3>
          <ul class="space-y-2 text-sm">
            <li><%= link_to "Jobs", jobs_path, class: "hover:text-orange-400 transition" %></li>
            <li><%= link_to "AI News", news_articles_path, class: "hover:text-orange-400 transition" %></li>
            <li><%= link_to posts_path, class: "hover:text-orange-400 transition inline-flex items-center gap-1" do %><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg> Pulse<% end %></li>
          </ul>
        </div>

        <!-- Newsletter -->
        <div>
          <h3 class="text-white font-semibold text-lg mb-3">Subscribe</h3>
          <p class="text-sm text-gray-500 mb-4">Jobs, articles, and engineering insights.</p>
          <div id="newsletter-form">
            <%= render "subscribers/form" %>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-800 mt-10 pt-6 text-center text-sm text-gray-400">
        &copy; <%= Date.current.year %> Agent 44 Labs. All rights reserved.
      </div>
    </div>
  </footer>

</body>
</html>
