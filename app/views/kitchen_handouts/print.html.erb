<%# Branded print packet: one page per recipe at full quantities, then the
    same recipes again at single-station quantities (tagged top-right), the
    same structure as the kitchen's hand-made Publisher packets. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>NY Kitchen · <%= @handout.title %></title>
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #fff; color: #111;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      line-height: 1.35;
      -webkit-print-color-adjust: exact; print-color-adjust: exact;
    }
    .page { max-width: 7.5in; margin: 0.4in auto; padding: 0 0.25in; position: relative; min-height: 9.4in; display: flex; flex-direction: column; }
    .tag { position: absolute; top: 0; right: 0.25in; font-size: 9pt; color: #444; }
    .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 28px; }
    .brand .mark { width: 40px; height: 40px; border: 2.5px solid #111; border-radius: 50%; display: grid; place-items: center; font-weight: 800; font-size: 15pt; }
    .brand .name { font-size: 12pt; font-weight: 700; letter-spacing: 0.18em; }
    h1 { font-family: Georgia, "Times New Roman", serif; font-weight: 800; font-size: 26pt; text-align: center; margin-bottom: 36px; }
    .cols { display: grid; grid-template-columns: 1fr 1.4fr; gap: 0.4in; }
    h2 { font-size: 12pt; margin-bottom: 6px; }
    h2 span { text-decoration: underline; }
    .ing-section { font-weight: 700; font-size: 10.5pt; margin-top: 6px; }
    table.ing { border-collapse: collapse; }
    table.ing td { font-size: 10.5pt; padding: 1.5px 0; vertical-align: top; }
    table.ing td.qty { white-space: nowrap; padding-right: 10px; font-variant-numeric: diagonal-fractions; }
    .dir-section { font-weight: 700; font-size: 10.5pt; margin: 8px 0 2px; }
    ol.steps { list-style: none; }
    ol.steps li { font-size: 10.5pt; margin-bottom: 5px; padding-left: 0.22in; text-indent: -0.22in; }
    .footer { margin-top: auto; padding-top: 20px; font-size: 8.5pt; color: #555; text-align: center; }
    .actions { max-width: 7.5in; margin: 0.3in auto 0; padding: 0 0.25in; display: flex; gap: 10px; }
    .btn { font-size: 10pt; padding: 6px 14px; border: 1px solid #bbb; border-radius: 6px; text-decoration: none; color: #333; background: #f7f7f7; }
    @media print {
      .actions { display: none; }
      .page { margin: 0 auto; page-break-after: always; min-height: auto; height: 9.6in; }
      @page { margin: 0.4in; }
    }
  </style>
</head>
<body>
  <div class="actions">
    <a class="btn" href="<%= edit_nyk_handout_path(@handout) %>">← Edit</a>
    <a class="btn" href="<%= nyk_list_path %>">Sam's list</a>
    <a class="btn" href="javascript:window.print()">🖨 Print</a>
  </div>

  <% [ nil, @handout.station_label ].each do |scale_tag| %>
    <% @handout.recipes.each do |recipe| %>
      <div class="page">
        <% if scale_tag %><div class="tag"><%= scale_tag %></div><% end %>
        <div class="brand">
          <div class="mark">NK</div>
          <div class="name">NEW YORK KITCHEN</div>
        </div>
        <h1><%= recipe["title"] %></h1>
        <div class="cols">
          <div>
            <h2><span>Ingredients</span>:</h2>
            <table class="ing">
              <% current_section = :none %>
              <% Array(recipe["ingredients"]).each do |ing| %>
                <% if ing["section"] != current_section && ing["section"].present? %>
                  <tr><td colspan="2" class="ing-section"><%= ing["section"] %>:</td></tr>
                <% end %>
                <% current_section = ing["section"] %>
                <tr>
                  <td class="qty"><%= scale_tag ? ing["station_qty"] : ing["qty"] %></td>
                  <td><%= ing["item"] %></td>
                </tr>
              <% end %>
            </table>
          </div>
          <div>
            <h2><span>Directions</span>:</h2>
            <% Array(recipe["directions"]).each do |group| %>
              <% if group["section"].present? %><div class="dir-section"><%= group["section"] %>:</div><% end %>
              <ol class="steps">
                <% Array(group["steps"]).each do |step| %>
                  <li><%= step %></li>
                <% end %>
              </ol>
            <% end %>
          </div>
        </div>
        <div class="footer">800 South Main Street, Canandaigua, NY 14424&nbsp;&nbsp;|&nbsp;&nbsp;www.nykitchen.com&nbsp;&nbsp;|&nbsp;&nbsp;(585) 394-7070</div>
      </div>
    <% end %>
  <% end %>
</body>
</html>
