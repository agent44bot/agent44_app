<%# Workspace-level team management: members list + invite form + danger zone.
    Rendered on the workspace hub (/workspaces/:slug) and the NYK agents hub
    (/nykitchen) so workspace admins can manage their team without going into
    the Social Agent composer.

    Locals:
      workspace        — the Workspace
      memberships      — workspace.memberships.includes(:user).order(:created_at)
      invitations      — workspace.invitations.pending.order(created_at: :desc)
      social_accounts  — workspace.social_accounts.order(:platform, :handle)
      my_role          — workspace.role_for(current_user)
%>
<% admin = %w[owner admin].include?(my_role) %>

<section class="mt-12 mb-10">
  <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Members</h2>
  <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
    <% memberships.each do |m| %>
      <div class="flex items-center justify-between gap-3 px-4 py-3">
        <div class="flex items-center gap-3 min-w-0">
          <%= user_avatar_tag m.user, size: "h-8 w-8", ring: "" %>
          <div class="min-w-0">
            <p class="text-sm text-white truncate"><%= m.user.display_identifier %></p>
            <% if m.user.email_address.present? %>
              <p class="text-xs text-gray-500 truncate"><%= m.user.email_address %></p>
            <% end %>
          </div>
        </div>
        <span class="text-xs uppercase tracking-wide text-gray-400 shrink-0"><%= m.role %></span>
      </div>
    <% end %>
  </div>
</section>

<% if admin %>
  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Brand logo</h2>
    <%= form_with model: workspace, url: workspace_path(workspace.slug), method: :patch, local: true,
                  html: { multipart: true }, class: "flex flex-wrap items-center gap-3" do |f| %>
      <% if workspace.logo.attached? %>
        <%= image_tag workspace.logo, alt: "current logo", class: "h-10 w-auto rounded bg-white/5 p-1" %>
      <% end %>
      <%= f.file_field :logo, accept: "image/png,image/jpeg,image/webp",
            class: "text-sm text-gray-300 file:mr-2 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:bg-gray-700 file:text-white file:cursor-pointer" %>
      <% if workspace.logo.attached? %>
        <label class="text-xs text-gray-400 inline-flex items-center gap-1"><%= check_box_tag "workspace[remove_logo]", "1" %> remove</label>
      <% end %>
      <%= f.submit "Save logo", class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
    <% end %>
    <p class="text-xs text-gray-500 mt-2">PNG, JPEG, or WebP, up to 2 MB. Shown on your workspace pages.</p>
  </section>

  <% if workspace.slug == "nykitchen" %>
    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Agent photos</h2>
      <p class="text-xs text-gray-500 mb-3">Each bot uses a shared stock avatar by default. Give one its own photo here.</p>
      <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
        <% WorkspaceAgent::KINDS.each do |kind| %>
          <% agent = workspace.agent_for(kind) %>
          <div class="flex items-center gap-3 px-4 py-3 flex-wrap">
            <%= workspace_agent_avatar_tag(agent, size: 40, html_class: "h-10 w-10 rounded-lg object-cover bg-gray-800 shrink-0") %>
            <div class="min-w-0 w-28 shrink-0">
              <p class="text-sm text-white truncate"><%= nyk_agent_callsign(kind, agent) %></p>
              <p class="text-xs text-gray-500"><%= nyk_agent_meta(kind)[:tag] %></p>
            </div>
            <%= form_with url: nyk_agent_avatar_path(kind: kind), method: :patch, local: true,
                          html: { multipart: true }, class: "flex flex-wrap items-center gap-2 flex-1 min-w-[200px]" do %>
              <%= file_field_tag :avatar, accept: "image/png,image/jpeg,image/webp",
                    class: "flex-1 min-w-[140px] text-xs text-gray-300 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-gray-700 file:text-white file:cursor-pointer" %>
              <%= submit_tag "Save", class: "text-xs text-gray-300 hover:text-white px-3 py-1.5 border border-gray-700 rounded-md hover:border-orange-500 cursor-pointer" %>
            <% end %>
            <% if agent.avatar.attached? %>
              <%= button_to "Remove", nyk_agent_avatar_path(kind: kind, remove: 1), method: :patch,
                    class: "text-xs text-gray-500 hover:text-red-400 px-2 py-1.5 cursor-pointer shrink-0" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Website URL</h2>
    <%= form_with model: workspace, url: workspace_path(workspace.slug), method: :patch, local: true,
                  class: "flex flex-wrap items-center gap-2" do |f| %>
      <%= f.url_field :source_url, value: workspace.source_url, placeholder: "https://example.com",
            class: "flex-1 min-w-[240px] bg-gray-900 border border-gray-700 rounded-md px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-orange-500" %>
      <%= f.submit "Save URL", class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
    <% end %>
    <p class="text-xs text-gray-500 mt-2">The main site your agents watch and pull from. Include https://.</p>
  </section>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Timezone</h2>
    <%= form_with model: workspace, url: workspace_path(workspace.slug), method: :patch, local: true,
                  class: "flex flex-wrap items-center gap-2" do |f| %>
      <%= f.time_zone_select :timezone,
            ActiveSupport::TimeZone.us_zones,
            { default: workspace.timezone },
            { class: "flex-1 min-w-[240px] rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none" } %>
      <%= f.submit "Save", class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
    <% end %>
    <p class="text-xs text-gray-500 mt-2">Used across the workspace for scheduling and timestamps. Also editable from the Social Agent page.</p>
  </section>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Invite a teammate</h2>
    <%= form_with url: workspace_invitations_path(workspace_slug: workspace.slug), local: true, class: "flex flex-wrap gap-2" do |f| %>
      <%= f.email_field :email, required: true, placeholder: "boss@magenta.com",
          class: "flex-1 min-w-[220px] rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2 focus:border-orange-500 focus:outline-none" %>
      <%= f.select :role, [["editor","editor"],["admin","admin"],["viewer","viewer"]], {},
          class: "rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2" %>
      <%= f.submit "Send invite", class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
    <% end %>

    <dl class="mt-3 text-xs text-gray-500 space-y-1">
      <div class="flex gap-2">
        <dt class="text-gray-400 font-semibold w-14 shrink-0">Admin</dt>
        <dd>Invite teammates, connect social accounts, delete the workspace.</dd>
      </div>
      <div class="flex gap-2">
        <dt class="text-gray-400 font-semibold w-14 shrink-0">Editor</dt>
        <dd>Compose, schedule, and post.</dd>
      </div>
      <div class="flex gap-2">
        <dt class="text-gray-400 font-semibold w-14 shrink-0">Viewer</dt>
        <dd>Read-only access.</dd>
      </div>
    </dl>

    <% if invitations.any? %>
      <div class="mt-4 rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
        <% invitations.each do |inv| %>
          <div class="flex items-center justify-between px-4 py-3 gap-3">
            <div class="min-w-0">
              <p class="text-sm text-white truncate"><%= inv.email %></p>
              <p class="text-xs text-gray-500 truncate">
                <%= inv.role %> · expires <%= inv.expires_at.in_time_zone(workspace.timezone).strftime("%b %-d") %>
              </p>
              <p class="text-[11px] text-gray-600 font-mono break-all mt-1">
                <%= workspace_invitation_view_url(token: inv.token) %>
              </p>
            </div>
            <%= button_to "Revoke", workspace_invitation_path(workspace_slug: workspace.slug, id: inv.id),
                method: :delete, form: { data: { turbo_confirm: "Revoke this invite?" } },
                class: "text-xs text-red-400 hover:text-red-300 px-3 py-1 border border-red-900 rounded-md cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <% if Current.user&.admin? %>
    <% billing_on = workspace.pricing_visible_to_members? %>
    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Site admin</h2>
      <div class="space-y-2">
        <% if workspace.slug == "nykitchen" %>
          <%= link_to nyk_billing_path,
                class: "rounded-lg border border-gray-800 bg-gray-900 px-4 py-3 flex items-center justify-between gap-3 flex-wrap hover:border-gray-700 hover:bg-gray-850 transition" do %>
            <div class="min-w-0">
              <p class="text-sm text-white">View billing</p>
              <p class="text-xs text-gray-500 mt-0.5">Workspace spend, plan, and usage history.</p>
            </div>
            <div class="flex items-center gap-1.5 shrink-0 text-gray-400">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm">→</span>
            </div>
          <% end %>
        <% end %>
        <div class="rounded-lg border border-gray-800 bg-gray-900 px-4 py-3 flex items-center justify-between gap-3 flex-wrap">
          <div class="min-w-0">
            <p class="text-sm text-white">Show billing to members</p>
            <p class="text-xs text-gray-500 mt-0.5">When on, workspace members see $ amounts on agent pages.</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs font-semibold uppercase <%= billing_on ? 'text-gray-500' : 'text-gray-300' %>">Off</span>
            <%= button_to toggle_pricing_workspace_path(workspace.slug),
                  method: :post,
                  form_class: "inline-flex",
                  data: { test: "billing-toggle" },
                  aria: { label: "Show billing to members", checked: billing_on.to_s },
                  class: "relative inline-flex h-6 w-11 items-center rounded-full transition cursor-pointer #{billing_on ? 'bg-green-600 hover:bg-green-500' : 'bg-gray-700 hover:bg-gray-600'}" do %>
              <span class="absolute inline-block h-5 w-5 rounded-full bg-white shadow transition transform <%= billing_on ? 'translate-x-5' : 'translate-x-0.5' %>"></span>
            <% end %>
            <span class="text-xs font-semibold uppercase <%= billing_on ? 'text-green-400' : 'text-gray-500' %>">On</span>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  <% if my_role == "owner" %>
  <section class="mt-12 pt-6 border-t border-red-950">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-red-500 mb-3">Danger zone</h2>
    <div class="rounded-lg border border-red-900 bg-red-950/20 p-4 flex flex-wrap items-center justify-between gap-3">
      <div class="min-w-0">
        <p class="text-sm text-white">Delete this workspace</p>
        <p class="text-xs text-gray-400 mt-1">
          Removes <%= workspace.name %> and all <%= pluralize(memberships.size, "member") %>,
          <%= pluralize(invitations.size, "pending invite") %>,
          <%= pluralize(social_accounts.size, "connected account") %>, and
          <%= pluralize(workspace.workspace_posts.count, "post") %>. Cannot be undone.
        </p>
      </div>
      <%= button_to "Delete workspace",
          workspace_path(workspace.slug),
          method: :delete,
          form: { data: { turbo_confirm: "Permanently delete '#{workspace.name}' and everything in it? This cannot be undone." } },
          class: "inline-flex items-center px-4 py-2 rounded-md bg-red-900 hover:bg-red-800 text-white text-sm font-semibold cursor-pointer" %>
    </div>
  </section>
  <% end %>
<% end %>
