<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Agent44">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="description" content="Agent44 — AI-Augmented Test Automation consulting and SDET placement">
  <title><%= content_for?(:title) ? "#{yield(:title)} | Agent44" : "Agent44 — AI-Augmented Test Automation" %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full flex flex-col bg-gray-50 text-gray-900 antialiased">

  <!-- Navigation -->
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-50" data-controller="nav">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <!-- Left: Logo + Links -->
        <div class="flex items-center space-x-8">
          <%= link_to root_path, class: "flex items-center space-x-2 text-indigo-600 font-bold text-xl tracking-tight" do %>
            <span>Agent44</span>
          <% end %>

          <div class="hidden md:flex items-center space-x-6">
            <%= link_to "Home", root_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition" %>
            <%= link_to "Jobs", jobs_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition" %>
            <%= link_to "Newsletter", posts_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition" %>
            <%= link_to "Videos", videos_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition" %>
          </div>
        </div>

        <!-- Right: Auth -->
        <div class="hidden md:flex items-center space-x-4">
          <% if authenticated? %>
            <%= link_to saved_jobs_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition flex items-center gap-1", title: "Saved Jobs" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
              Saved
            <% end %>
            <% if Current.session.user.admin? %>
              <%= link_to "Dashboard", admin_dashboard_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
            <% end %>
            <span class="text-sm text-gray-500"><%= Current.session.user.display_identifier %></span>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition" %>
            <%= link_to "Sign Up", new_registration_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition" %>
          <% end %>
        </div>

        <!-- Mobile menu button -->
        <div class="flex items-center md:hidden">
          <button data-action="click->nav#toggle" data-nav-target="menuBtn"
                  class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-indigo-600 hover:bg-gray-100 transition">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="hidden md:hidden" data-nav-target="menu">
      <div class="px-4 pt-2 pb-4 space-y-1 border-t border-gray-200">
        <%= link_to "Home", root_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
        <%= link_to "Jobs", jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
        <%= link_to "Newsletter", posts_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
        <%= link_to "Videos", videos_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
        <div class="border-t border-gray-200 pt-2">
          <% if authenticated? %>
            <%= link_to "Saved Jobs", saved_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
            <% if Current.session.user.admin? %>
              <%= link_to "Dashboard", admin_dashboard_path, class: "block px-3 py-2 rounded-md text-base font-medium text-indigo-600 hover:bg-gray-100" %>
            <% end %>
            <span class="block px-3 py-2 text-sm text-gray-500"><%= Current.session.user.display_identifier %></span>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-100" %>
            <%= link_to "Sign Up", new_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-indigo-600 hover:bg-gray-100" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Email verification banner -->
  <% if authenticated? && Current.session.user.email_address.present? && !Current.session.user.email_verified? %>
    <div class="bg-amber-50 border-b border-amber-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
        <p class="text-sm text-amber-800">Please verify your email address. Check your inbox for a verification link.</p>
        <%= button_to "Resend email", resend_email_verification_path, method: :post, class: "text-sm font-medium text-amber-700 hover:text-amber-900 underline" %>
      </div>
    </div>
  <% end %>

  <!-- Flash messages -->
  <% if notice.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-green-50 border border-green-200 p-4">
        <p class="text-sm text-green-800"><%= notice %></p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-red-50 border border-red-200 p-4">
        <p class="text-sm text-red-800"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="flex-1">
    <%= yield %>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-300 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- About -->
        <div>
          <h3 class="text-white font-semibold text-lg mb-3">Agent44</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            AI-augmented test automation consulting and SDET placement. Helping teams ship reliable software faster.
          </p>
        </div>

        <!-- Links -->
        <div>
          <h3 class="text-white font-semibold text-lg mb-3">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><%= link_to "Jobs", jobs_path, class: "hover:text-white transition" %></li>
            <li><%= link_to "Newsletter", posts_path, class: "hover:text-white transition" %></li>
            <li><%= link_to "Videos", videos_path, class: "hover:text-white transition" %></li>
          </ul>
        </div>

        <!-- Newsletter -->
        <div>
          <h3 class="text-white font-semibold text-lg mb-3">Stay Updated</h3>
          <p class="text-sm text-gray-400 mb-4">Get the latest jobs and articles delivered to your inbox.</p>
          <div id="newsletter-form">
            <%= render "subscribers/form" %>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-800 mt-10 pt-6 text-center text-sm text-gray-500">
        &copy; <%= Date.current.year %> Agent44. All rights reserved.
      </div>
    </div>
  </footer>

</body>
</html>
