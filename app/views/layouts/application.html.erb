<!DOCTYPE html>
<html lang="en" class="overflow-x-hidden">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <style>html,body{max-width:100vw;overflow-x:hidden}*,*::before,*::after{box-sizing:border-box}</style>
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Agent 44 Labs">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="description" content="Agent 44 Labs — agent-driven production smoke tests for small and mid-size teams.">
  <title><%= content_for?(:title) ? "#{yield(:title)} | Agent 44 Labs" : "Agent 44 Labs" %></title>
  <link rel="icon" href="/agent44_logo.svg?v=2" type="image/svg+xml">
  <link rel="alternate icon" href="/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <meta name="turbo-cache-control" content="auto">

  <%= yield :head %>

  <link rel="icon" href="/agent44_logo.svg?v=2" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= javascript_tag nonce: true do %>
  // Fallback nav toggle — only fires if Stimulus hasn't connected yet.
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-nav-target="menuBtn"]');
    if (!btn) return;
    var navRoot = btn.closest('[data-controller~="nav"]');
    if (!navRoot) return;
    // Skip if Stimulus nav controller is connected (it handles its own click)
    if (window.Stimulus && window.Stimulus.getControllerForElementAndIdentifier &&
        window.Stimulus.getControllerForElementAndIdentifier(navRoot, 'nav')) return;
    // Find the menu target that belongs to this nav (not a nested one)
    var menus = navRoot.querySelectorAll('[data-nav-target="menu"]');
    for (var i = 0; i < menus.length; i++) {
      if (menus[i].closest('[data-controller~="nav"]') === navRoot) {
        menus[i].classList.toggle('hidden');
        break;
      }
    }
  });
  <% end %>
  <%= javascript_tag nonce: true do %>
  // Push notification registration — only runs inside the Capacitor native shell
  (function() {
    if (!window.Capacitor || !window.Capacitor.isNativePlatform()) return;
    var PN = window.Capacitor.Plugins && window.Capacitor.Plugins.PushNotifications;
    if (!PN) return;

    PN.requestPermissions().then(function(perm) {
      if (perm.receive !== 'granted') return;

      PN.addListener('registration', function(token) {
        fetch('/api/v1/device_tokens', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: token.value, platform: 'ios' })
        });
      });

      // Navigate to the URL when the user taps a notification
      PN.addListener('pushNotificationActionPerformed', function(action) {
        var url = action.notification.data && action.notification.data.url;
        if (url) window.location.href = url;
      });

      PN.register();
    });
  })();
  <% end %>
</head>
<body class="bg-gray-950 text-white antialiased overflow-x-hidden">

  <!-- Navigation -->
  <nav class="bg-gray-950/80 backdrop-blur-md border-b border-gray-800 sticky top-0 z-50" data-controller="nav">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <!-- Left: Logo -->
        <div class="flex items-center min-w-0 overflow-hidden">
          <%= link_to root_path, class: "flex items-center space-x-2 font-black text-xl tracking-tight min-w-0" do %>
            <img src="/agent44_logo.svg?v=2" alt="Agent 44 Labs" width="40" height="40" class="w-10 h-10">
            <span class="text-white">Agent 44 <span class="bg-gradient-to-r from-orange-600 to-amber-600 bg-clip-text text-transparent">Labs</span></span>
          <% end %>
        </div>

        <!-- Right: Auth -->
        <div class="hidden md:flex items-center space-x-4">
          <% if authenticated? %>
            <% if Current.session.user.reviewer? %>
              <%= link_to "NY Kitchen", nykitchen_path, class: "text-sm text-gray-300 hover:text-orange-400 transition" %>
            <% end %>
            <% if Current.session.user.admin? %>
              <!-- Admin dropdown -->
              <div class="relative" data-controller="nav">
                <button type="button" data-action="click->nav#toggle" aria-label="Admin menu"
                        class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-orange-400 hover:bg-gray-800 transition">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                  </svg>
                </button>
                <div data-nav-target="menu" class="hidden absolute right-0 mt-2 w-52 rounded-lg bg-gray-900 border border-gray-800 shadow-xl py-1 z-50">
                  <%= link_to "Dashboard", admin_dashboard_path, class: "block px-4 py-2 text-sm font-medium text-orange-500 hover:bg-gray-800" %>
                  <div class="my-1 border-t border-gray-800"></div>
                  <%= link_to "Jobs", jobs_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "NY Kitchen", nykitchen_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "AI News", news_articles_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "Pulse", posts_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "Map", globe_jobs_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <%= link_to "Crypto", crypto_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                  <div class="my-1 border-t border-gray-800"></div>
                  <%= link_to "Saved Jobs", saved_jobs_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white" %>
                </div>
              </div>
            <% end %>
            <%= link_to Current.session.user.display_identifier, settings_path,
                  class: "text-sm text-gray-400 hover:text-orange-400 transition truncate max-w-[180px]" %>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "text-sm font-medium text-gray-500 hover:text-orange-400 transition" %>
            <%= link_to "Sign Up", new_registration_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-orange-600 rounded-full hover:bg-orange-700 transition" %>
          <% end %>
        </div>

        <!-- Mobile menu button -->
        <div class="flex items-center md:hidden shrink-0">
          <button data-action="click->nav#toggle" data-nav-target="menuBtn" aria-label="Menu"
                  class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-orange-400 hover:bg-gray-800 transition">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="hidden md:hidden" data-nav-target="menu">
      <div class="px-4 pt-2 pb-4 space-y-1 border-t border-gray-800">
        <%= link_to "Home", root_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% if authenticated? && Current.session.user.reviewer? %>
          <%= link_to "NY Kitchen", nykitchen_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% end %>
        <% if authenticated? && Current.session.user.admin? %>
          <%= link_to "Jobs", jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "Crypto", crypto_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "NY Kitchen", nykitchen_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "AI News", news_articles_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to posts_path, class: "flex items-center gap-1 px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800 hover:text-orange-400" do %>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>
            Pulse
          <% end %>
          <%= link_to "Map", globe_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
        <% end %>
        <div class="border-t border-gray-800 pt-2">
          <% if authenticated? %>
            <%= link_to "Saved Jobs", saved_jobs_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <% if Current.session.user.admin? %>
              <%= link_to "Dashboard", admin_dashboard_path, class: "block px-3 py-2 rounded-md text-base font-medium text-orange-600 hover:bg-gray-800" %>
            <% end %>
            <%= link_to Current.session.user.display_identifier, settings_path,
                  class: "block px-3 py-2 text-sm text-gray-400 hover:bg-gray-800 rounded-md" %>
            <%= link_to "Settings", settings_path,
                  class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <%= button_to "Sign Out", session_path, method: :delete,
                  class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:bg-gray-800" %>
            <%= link_to "Sign Up", new_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-orange-600 hover:bg-gray-800" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Email verification banner -->
  <% if !Rails.env.development? && authenticated? && Current.session.user.email_address.present? && !Current.session.user.email_verified? %>
    <div class="bg-amber-900/30 border-b border-amber-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex flex-wrap items-center justify-between gap-2">
        <p class="text-sm text-amber-300">Please verify your email. Check your inbox for a verification link.</p>
        <%= button_to "Resend email", resend_email_verification_path, method: :post, class: "text-sm font-medium text-amber-400 hover:text-amber-200 underline whitespace-nowrap" %>
      </div>
    </div>
  <% end %>

  <!-- Flash messages -->
  <% if notice.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-green-900/50 border border-green-700 p-4">
        <p class="text-sm text-green-200"><%= notice %></p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-red-900/50 border border-red-700 p-4">
        <p class="text-sm text-red-200"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="overflow-x-hidden">
    <%= yield %>
  </main>

  <!-- Footer (copyright only — full footer hidden, see commit 8c65a6f) -->
  <footer class="bg-gray-950 text-gray-500 border-t border-gray-800 py-4 text-center text-xs">
    &copy; <%= Date.current.year %> Agent 44 Labs. All rights reserved.
  </footer>

</body>
</html>
