<% content_for :title, @workspace.name %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="collapsible"
     data-collapsible-collapsed-value="true"
     data-collapsible-scroll-on-expand-value="true">
  <div class="flex items-center gap-3 mb-4 text-sm">
    <%= render "shared/breadcrumbs", crumbs: [["Workspaces", workspaces_path(force: 1)], [@workspace.name, nil]] %>
  </div>

  <%# Compact identity band: logo inline with the title, meta beneath, and the
      team avatars + Settings toggle grouped on the right of the same row. %>
  <div class="mb-6 flex items-center justify-between gap-3 flex-wrap">
    <div class="flex items-center gap-4 min-w-0">
      <% if @workspace.logo.attached? %>
        <%= image_tag @workspace.logo,
              alt: "#{@workspace.name} logo",
              class: "h-14 w-14 rounded-lg object-contain bg-white/5 p-1 shrink-0" %>
      <% end %>
      <div class="min-w-0">
        <h1 class="text-2xl font-black text-white tracking-tight truncate"><%= @workspace.name %></h1>
        <p class="text-gray-400 mt-0.5">
          <span class="text-xs text-gray-500 font-mono">/<%= @workspace.slug %></span>
          &middot; <%= @workspace.timezone %>
        </p>
      </div>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <%= render "member_avatars", members: @memberships.map(&:user), size: "h-8 w-8" %>
      <button type="button"
              data-action="click->collapsible#toggle"
              aria-label="Workspace settings"
              class="inline-flex items-center gap-1.5 px-3 h-8 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white transition shrink-0 text-sm font-medium">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/>
        </svg>
        Settings
      </button>
    </div>
  </div>

  <div data-collapsible-target="body">
    <%= render "team",
          workspace:       @workspace,
          memberships:     @memberships,
          invitations:     @invitations,
          social_accounts: @social_accounts,
          my_role:         @my_role %>
  </div>

  <%# Agent cards: full-width compact rows so a single agent fills the width and
      future agents (analytics, alerts) stack as a tidy list. %>
  <div class="space-y-3">
    <%= link_to social_workspace_path(@workspace.slug),
          class: "flex items-center gap-4 bg-gray-900 hover:bg-gray-850 border border-gray-800 hover:border-orange-500/50 rounded-xl p-4 transition group" do %>
      <%= workspace_agent_avatar_tag(@workspace.agent_for("social"), size: 40,
            html_class: "h-10 w-10 rounded-lg object-cover bg-gray-800 shrink-0") %>
      <div class="flex-1 min-w-0">
        <h2 class="text-base font-bold text-white">Social Agent</h2>
        <p class="text-sm text-gray-400 truncate">
          <%= @platforms_connected.any? ? "#{@platforms_connected.join(' · ')} connected" : "No platforms connected yet" %>
          · <%= pluralize(@posts_total, "post") %><% if @last_post_at %> · last <%= time_ago_in_words(@last_post_at) %> ago<% end %>
        </p>
      </div>
      <span class="text-gray-600 group-hover:text-orange-400 transition shrink-0">→</span>
    <% end %>
  </div>
</div>
