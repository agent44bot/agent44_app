<%# Top-nav bell linking to the user's Notifications page, with an unread badge
    that mirrors the iOS app-icon badge. `unread` is passed in so the count is
    queried once per request in the layout, not per render. %>
<%= link_to notifications_path,
      class: "relative inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-orange-400 hover:bg-gray-800 transition",
      aria: { label: "Notifications" } do %>
  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
  </svg>
  <% if unread.positive? %>
    <span class="notif-badge absolute top-0.5 right-0.5 min-w-[18px] h-[18px] px-1 flex items-center justify-center rounded-full bg-orange-600 text-white text-[11px] font-bold leading-none">
      <%= unread > 99 ? "99+" : unread %>
    </span>
  <% end %>
<% end %>
