<% content_for :title, "June plan" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-baseline justify-between gap-4 mb-2">
    <h1 class="text-2xl font-bold text-white">June 2026 plan</h1>
    <span class="text-sm text-gray-500">Agent44Labs DBA setup</span>
  </div>
  <p class="text-sm text-gray-400 mb-6">
    Step by step to a sole-proprietor DBA with clean, deductible books.
    Check things off as you go; timestamps are saved.
  </p>

  <%# Progress bar %>
  <div class="mb-8">
    <div class="flex justify-between text-xs text-gray-500 mb-1">
      <span><%= @completed %> of <%= @total %> done</span>
      <span><%= @total.positive? ? (100 * @completed / @total) : 0 %>%</span>
    </div>
    <div class="h-2 rounded-full bg-gray-800 overflow-hidden">
      <div class="h-full bg-orange-500 transition-all" style="width: <%= @total.positive? ? (100.0 * @completed / @total).round : 0 %>%"></div>
    </div>
  </div>

  <% @plan.each do |section| %>
    <h2 class="text-base font-semibold text-white mb-3"><%= section[:title] %></h2>
    <div class="rounded-lg bg-gray-900 border border-gray-800 divide-y divide-gray-800 mb-8">
      <% section[:steps].each do |step| %>
        <% done_at = @done[step[:id]] %>
        <div class="flex items-start gap-3 p-4 <%= "opacity-60" if done_at %>">
          <%= button_to admin_plan_toggle_path(step_id: step[:id]), method: :post,
                class: "mt-0.5 shrink-0 w-5 h-5 rounded border flex items-center justify-center text-xs
                        #{done_at ? 'bg-orange-600 border-orange-500 text-white' : 'bg-gray-950 border-gray-700 hover:border-orange-500'}" do %><%= "\u2713" if done_at %><% end %>
          <div>
            <p class="text-sm font-semibold <%= done_at ? "text-gray-400 line-through" : "text-white" %>"><%= step[:title] %></p>
            <p class="text-xs text-gray-500 mt-0.5"><%= step[:detail] %></p>
            <% if step[:links].present? %>
              <div class="flex flex-wrap gap-1.5 mt-1.5">
                <% step[:links].each do |l| %>
                  <%= link_to l[:label], l[:url], target: "_blank", rel: "noopener",
                        class: "text-[11px] px-2 py-0.5 rounded-full border border-gray-700 text-orange-300 hover:border-orange-500 hover:text-orange-200 transition" %>
                <% end %>
              </div>
            <% end %>
            <% if done_at %>
              <p class="text-[11px] text-orange-400/80 mt-1">Done <%= done_at.strftime("%b %-d, %-l:%M%P") %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <p class="text-xs text-gray-600">
    Reference: deduct everything since Jan 2026 on the 2026 Schedule C (TurboTax Premium handles it).
    The DBA does not create deductions; it makes them defensible.
  </p>
</div>
