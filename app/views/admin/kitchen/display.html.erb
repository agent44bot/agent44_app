<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%# Pull fresh data every 10 minutes. The slideshow keeps cycling
      between refreshes from the JS below. %>
  <meta http-equiv="refresh" content="<%= @agent.setting(:refresh_minutes).to_i * 60 %>">
  <title>New York Kitchen · What's Coming Up</title>
  <%# NY Kitchen uses Proxima Nova (Adobe, domain-locked); Montserrat is the
      standard free stand-in and matches the site's clean geometric sans. %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --navy: #1b1e34; --ink: #1b1e34; --muted: #6b7280; --body: #374151; }
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      background: #ffffff;
      color: var(--ink);
      font-family: "Montserrat", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      overflow: hidden;
    }
    .page {
      height: 100vh;
      display: flex;
      flex-direction: column;
      padding: 4vh 6vw;
    }
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 2vh;
      border-bottom: 2px solid var(--navy);
    }
    .brand-row { display: flex; align-items: center; gap: clamp(10px, 1.2vw, 20px); min-width: 0; }
    .brand-logo { height: clamp(32px, 3.6vw, 64px); width: auto; display: block; }
    .brand {
      font-size: clamp(20px, 2.4vw, 36px);
      font-weight: 700;
      letter-spacing: 0.01em;
      color: var(--navy);
      text-transform: uppercase;
    }
    .header .meta {
      font-size: clamp(12px, 1vw, 16px);
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .stage {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .slide {
      display: none;
      width: 100%;
      max-width: 90vw;
      text-align: center;
    }
    .slide.active { display: block; animation: fade 0.6s ease-out; }
    .slide.with-image {
      display: none;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 3vw;
      align-items: start;
      text-align: left;
    }
    .slide.with-image.active { display: grid; animation: fade 0.6s ease-out; }
    .slide.with-image .name {
      text-align: left;
      margin-bottom: 2.5vh;
      font-size: clamp(24px, 3.2vw, 52px);
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 4;
      line-clamp: 4;
      overflow: hidden;
    }
    .slide.with-image .meta-block,
    .slide.with-image .blurb,
    .slide.with-image .qr-block { text-align: left; align-items: flex-start; }
    .hero-image {
      width: 100%;
      max-height: 70vh;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    }
    @keyframes fade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .slide .name {
      font-size: clamp(30px, 4.8vw, 80px);
      font-weight: 600;
      letter-spacing: 0;
      line-height: 1.08;
      text-transform: uppercase;
      color: var(--navy);
      margin-bottom: 3vh;
    }
    /* Date line in the NYK event-page style: navy, uppercase, e.g.
       "SUNDAY, JUNE 14 @ 6:00 PM". */
    .meta-block { display: flex; flex-direction: column; gap: 1vh; align-items: center; }
    .when {
      color: var(--navy);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      font-size: clamp(16px, 2.1vw, 34px);
    }
    .price {
      color: var(--navy);
      font-weight: 700;
      font-size: clamp(18px, 2.4vw, 40px);
    }
    .where {
      color: var(--muted);
      font-weight: 500;
      font-size: clamp(14px, 1.6vw, 26px);
    }
    .blurb {
      margin-top: 2.6vh;
      color: var(--body);
      font-weight: 400;
      font-size: clamp(14px, 1.6vw, 25px);
      line-height: 1.45;
      max-width: 48ch;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      overflow: hidden;
    }
    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 2vh;
      border-top: 1px solid #e5e7eb;
      font-size: clamp(12px, 1.1vw, 18px);
      color: var(--muted);
    }
    .footer strong { color: var(--navy); }
    .pulse {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #22c55e;
      margin-right: 8px;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.35 } }
    .empty {
      text-align: center;
      color: var(--muted);
      font-size: clamp(22px, 2.6vw, 40px);
    }
    .qr-block {
      margin-top: 3.5vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.2vh;
    }
    .qr-code {
      background: #fff;
      padding: 1.2vh;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      line-height: 0;
    }
    .qr-code svg {
      width: clamp(110px, 11vw, 190px);
      height: clamp(110px, 11vw, 190px);
      display: block;
    }
    .qr-cap {
      font-size: clamp(13px, 1.3vw, 22px);
      color: var(--muted);
      letter-spacing: 0.01em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="page">
    <%# Slim header: just the logo and the underline. The "What's Coming Up"
        title and the "Next X of Y available" status are hidden so the screen is
        mostly the cycling classes. %>
    <header class="header">
      <div class="brand-row">
        <% if @display_workspace&.logo&.attached? %>
          <img class="brand-logo" src="<%= url_for(@display_workspace.logo) %>" alt="New York Kitchen">
        <% end %>
      </div>
    </header>

    <main class="stage">
      <% if @events.any? %>
        <% @events.each_with_index do |event, i| %>
          <% start = event.start_at %>
          <% when_str = "#{start.strftime('%A, %B %-d').upcase} @ #{start.strftime('%-l:%M %p')}" %>
          <% when_str += " to #{event.end_at.strftime('%-l:%M %p')}" if @agent.setting(:show_end_time) && event.end_at.present? %>
          <% venue = event.venue.presence || "New York Kitchen, Canandaigua" %>
          <% show_image = @agent.setting(:show_image) && event.image_url.present? %>
          <% blurb = event.description.present? ? truncate(strip_tags(event.description).squish, length: 180, separator: " ") : nil %>
          <article class="slide<%= ' with-image' if show_image %><%= ' active' if i == 0 %>">
            <div>
              <h1 class="name"><%= event.name.presence || "Class at New York Kitchen" %></h1>
              <div class="meta-block">
                <p class="when"><%= when_str %></p>
                <% if @agent.setting(:show_price) && event.price.present? %>
                  <% price = event.price.to_s.strip %>
                  <% price = "$#{price}" unless price.match?(/[$£€]/) %>
                  <p class="price"><%= price %></p>
                <% end %>
                <p class="where">
                  <%= venue %><% if @agent.setting(:show_spots) && event.spots_left.present? && event.spots_left > 0 %> · <%= event.spots_left %> spot<%= "s" unless event.spots_left == 1 %> left<% end %>
                </p>
              </div>
              <% if blurb.present? %>
                <p class="blurb"><%= blurb %></p>
              <% end %>
              <% if @agent.setting(:show_qr) && event.url.present? %>
                <div class="qr-block">
                  <div class="qr-code"><%= nyk_scan_qr(event, workspace: @display_workspace, source: "display") %></div>
                  <div class="qr-cap">Scan to reserve</div>
                </div>
              <% end %>
            </div>
            <% if show_image %>
              <img class="hero-image" src="<%= event.image_url %>" alt="" loading="lazy">
            <% end %>
          </article>
        <% end %>
      <% else %>
        <div class="empty">
          New classes coming soon.<br>
          Check back at nykitchen.com.
        </div>
      <% end %>
    </main>

    <footer class="footer">
      <span>Visit <strong>nykitchen.com/calendar</strong> to reserve</span>
      <span>Auto-refreshes every <%= @agent.setting(:refresh_minutes) %> min</span>
    </footer>
  </div>

  <%= javascript_tag nonce: true do %>
    // Cycle through slides every 10s. Pure CSS class swap — no Stimulus
    // needed since this page runs no app JS stack.
    (function() {
      var slides = document.querySelectorAll('.slide');
      if (slides.length < 2) return;
      var i = 0;
      setInterval(function() {
        slides[i].classList.remove('active');
        i = (i + 1) % slides.length;
        slides[i].classList.add('active');
      }, <%= @agent.setting(:advance_seconds).to_i * 1000 %>);
    })();

    // Liveness heartbeat: let the hub know this screen is on. Only fires when
    // the URL carries a share token (private mode) — the server records
    // last-seen only when it matches, so the Display Agent dot reflects the
    // real kitchen screen, not a public-URL visitor. Beats now + every 60s.
    (function() {
      var token = new URLSearchParams(location.search).get('token');
      if (!token) return;
      function beat() {
        fetch('<%= nyk_display_heartbeat_path %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'token=' + encodeURIComponent(token),
          keepalive: true
        }).catch(function() {});
      }
      beat();
      setInterval(beat, 60000);
    })();
  <% end %>
</body>
</html>
