<% content_for(:title, "Pulse") %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-12 text-center">
    <h1 class="text-3xl md:text-4xl font-extrabold text-white inline-flex items-center gap-2"><svg class="w-7 h-7 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg> Pulse</h1>
    <p class="mt-3 text-lg text-gray-500 max-w-2xl mx-auto">Field notes from the AI testing market &mdash; and from the agent team building this site.</p>
  </div>

  <% if @top_skills.present? %>
    <div class="mb-10 rounded-xl border border-gray-800 bg-gray-900 px-4 py-3">
      <div class="flex items-center gap-2 flex-wrap justify-center">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide mr-1">In demand:</span>
        <% @top_skills.each do |name, _count, percent| %>
          <%= link_to jobs_path(skill: name),
                class: "inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-800 border border-gray-700 text-gray-300 hover:border-orange-500 hover:text-orange-400 transition" do %>
            <%= name %>
            <span class="text-gray-500"><%= percent %>%</span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @posts.present? %>
    <div class="space-y-8">
      <% @posts.each_with_index do |post, index| %>
        <article class="bg-gray-900 rounded-xl border border-gray-800 p-8 hover:shadow-lg hover:border-orange-200 transition group">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-orange-900/50 text-orange-400 uppercase tracking-wide">
              Newsletter
            </span>
            <time class="text-sm text-gray-400">
              <%= post.published_at&.strftime("%B %d, %Y") %>
            </time>
          </div>
          <h2 class="text-2xl font-bold text-white group-hover:text-orange-600 transition leading-snug">
            <%= link_to post.title, post_path(post.slug) %>
          </h2>
          <p class="mt-3 text-gray-500 leading-relaxed line-clamp-3">
            <%= truncate(post.body.to_plain_text, length: 280) %>
          </p>
          <div class="mt-5 flex items-center justify-between">
            <%= link_to "Read more &rarr;".html_safe, post_path(post.slug),
                  class: "inline-flex items-center text-sm font-semibold text-orange-600 hover:text-orange-300 transition" %>
            <span class="text-sm text-gray-400">by <span class="font-medium text-gray-400">"Field Agent" Scout</span></span>
          </div>
        </article>
      <% end %>
    </div>

    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <div class="mt-12 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-16">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-white">No posts yet</h3>
      <p class="mt-1 text-sm text-gray-500">Check back soon for new content.</p>
    </div>
  <% end %>
</div>
