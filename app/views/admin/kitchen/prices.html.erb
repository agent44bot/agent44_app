<% content_for(:title, "NY Kitchen · Pantry prices") %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <%= render "admin/kitchen/breadcrumbs" %>

  <div class="mb-6">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <h1 class="text-2xl font-bold text-white">🥫 Pantry prices</h1>
      <%= link_to "Grocery list", nyk_grocery_path,
            class: "px-3 py-1.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" %>
    </div>
    <p class="text-gray-400 mt-1">
      The latest price we have for each ingredient, learned from your uploaded receipts.
      These feed the weekly grocery estimate. Fix anything that looks off, or remove a line that is not a real ingredient.
    </p>
  </div>

  <% if @prices.empty? %>
    <div class="bg-gray-900 rounded-xl p-8 text-center">
      <p class="text-gray-400">No prices yet. Upload a grocery receipt from a week on Sam's schedule and the items will show up here.</p>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @prices.each do |p| %>
        <div class="bg-gray-900 rounded-lg px-4 py-3 flex flex-col sm:flex-row sm:items-center gap-3">
          <div class="min-w-0 sm:flex-1">
            <div class="text-white font-medium capitalize truncate"><%= p.canonical_name %></div>
            <div class="text-xs text-gray-500">
              Seen <%= p.observed_on&.strftime("%b %-d") %>
              <% if p.grocery_receipt&.store.present? %>&middot; <%= p.grocery_receipt.store %><% end %>
              <% if p.raw_label.present? %>&middot; <span class="text-gray-600"><%= p.raw_label %></span><% end %>
            </div>
          </div>
          <%= form_with url: nyk_price_path(p), method: :patch, class: "flex items-center gap-2 shrink-0" do %>
            <span class="text-gray-500">$</span>
            <%= number_field_tag :unit_price_dollars, sprintf("%.2f", p.unit_price_dollars), step: "0.01", min: "0",
                  class: "w-20 px-2 py-1 rounded bg-gray-800 text-white text-base border border-gray-700 focus:border-orange-500 focus:outline-none" %>
            <span class="text-gray-500 text-sm">per</span>
            <%= text_field_tag :unit, p.unit, placeholder: "unit",
                  class: "w-20 px-2 py-1 rounded bg-gray-800 text-white text-base border border-gray-700 focus:border-orange-500 focus:outline-none" %>
            <%= submit_tag "Save",
                  class: "px-3 py-1 rounded bg-gray-700 text-white text-sm hover:bg-gray-600 transition cursor-pointer" %>
          <% end %>
          <%= button_to "Delete", nyk_price_path(p), method: :delete,
                form: { data: { turbo_confirm: "Remove #{p.canonical_name} from the pantry?" } },
                class: "px-3 py-1 rounded text-red-400 text-sm hover:bg-red-900/30 transition cursor-pointer shrink-0" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
