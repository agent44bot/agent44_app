<%
  s = @s
  money    = ->(n) { number_to_currency(n, precision: 0) }
  left_k   = "~$#{number_with_delimiter((s[:rev_left] / 1000.0).round)}K"
  pct_sold = s[:rev_total].to_f.positive? ? (100.0 * s[:rev_sold] / s[:rev_total]).round : 0
  analyst_url = "https://agent44labs.com/nykitchen/analyst"
%>
<div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;max-width:600px;margin:0 auto;padding:24px;color:#111">

  <div style="border-bottom:2px solid #111;padding-bottom:10px;margin-bottom:18px">
    <div style="font-size:20px;font-weight:800">NY Kitchen <span style="color:#c2410c">· Weekly Sales Recap</span></div>
    <div style="font-size:12px;color:#777;margin-top:3px">
      <%= s[:snapshot_date]&.strftime("Week of %b %-d, %Y") %><% if s[:stale] %> · based on the latest snapshot (<%= s[:snapshot_date]&.strftime("%b %-d") %>)<% end %>
    </div>
  </div>

  <%# Revenue headline — Sold (hard) + Left to sell (estimate, rounded). %>
  <table role="presentation" width="100%" style="margin-bottom:8px"><tr>
    <td style="vertical-align:bottom">
      <span style="font-size:30px;font-weight:800;color:#1b6e3a"><%= money.call(s[:rev_sold]) %></span>
      <span style="font-size:13px;color:#888;text-transform:uppercase;letter-spacing:0.04em">&nbsp;sold</span>
    </td>
    <td style="text-align:right;vertical-align:bottom">
      <span style="font-size:22px;font-weight:700;color:#b35900"><%= left_k %></span>
      <span style="font-size:13px;color:#888;text-transform:uppercase;letter-spacing:0.04em">&nbsp;left to sell</span>
    </td>
  </tr></table>
  <div style="font-size:12px;color:#777;margin-bottom:6px"><%= pct_sold %>% of face value sold across <%= s[:total_upcoming] %> upcoming classes.</div>
  <div style="font-size:11px;color:#999;margin-bottom:20px">
    Face value (list price × seats)<% if s[:rev_proxy_count].to_i.positive? %> · <%= s[:rev_proxy_count] %> of <%= s[:rev_priced_count] %> classes use an observed-capacity estimate, so “left to sell” is approximate (biased low)<% end %>.
  </div>

  <% if s[:weekly_tickets].present? %>
    <h3 style="font-size:15px;color:#111;border-bottom:2px solid #111;padding-bottom:6px;margin:24px 0 8px">📈 Tickets sold by week</h3>
    <table role="presentation" width="100%" style="font-size:13px;color:#333">
      <% s[:weekly_tickets].last(6).each do |w| %>
        <tr>
          <td style="padding:3px 0;color:#666"><%= w[:label] %></td>
          <td style="padding:3px 0;text-align:right;font-weight:600"><%= w[:tickets] %> tickets</td>
        </tr>
      <% end %>
    </table>
  <% end %>

  <% if s[:selling_fastest].present? %>
    <h3 style="font-size:15px;color:#111;border-bottom:2px solid #111;padding-bottom:6px;margin:24px 0 8px">🔥 Selling fastest</h3>
    <% s[:selling_fastest].each_with_index do |row, i| %>
      <% e = row[:event] %>
      <div style="padding:7px 0;border-bottom:1px solid #eee">
        <table role="presentation" width="100%"><tr>
          <td style="font-size:13px">
            <strong style="color:#666"><%= i + 1 %>.</strong>
            <a href="<%= e.url %>" style="color:#0a58ca;text-decoration:none;font-weight:600"><%= e.name %></a>
            <span style="color:#888">· <%= e.start_at&.strftime("%a %-m/%-d") %></span>
          </td>
          <td style="text-align:right;white-space:nowrap;font-size:13px;font-weight:700;color:#111">~<%= row[:pace] %>/day</td>
        </tr></table>
      </div>
    <% end %>
  <% end %>

  <% if s[:needs_a_push].present? %>
    <h3 style="font-size:15px;color:#111;border-bottom:2px solid #111;padding-bottom:6px;margin:24px 0 8px">📣 Needs a push</h3>
    <% s[:needs_a_push].each_with_index do |row, i| %>
      <% e = row[:event] %>
      <div style="padding:7px 0;border-bottom:1px solid #eee">
        <table role="presentation" width="100%"><tr>
          <td style="font-size:13px">
            <strong style="color:#666"><%= i + 1 %>.</strong>
            <a href="<%= e.url %>" style="color:#0a58ca;text-decoration:none;font-weight:600"><%= e.name %></a>
            <span style="color:#888">· <%= e.start_at&.strftime("%a %-m/%-d") %> · in <%= row[:days_until] %> <%= "day".pluralize(row[:days_until]) %></span>
          </td>
          <td style="text-align:right;white-space:nowrap;font-size:13px">
            <strong style="color:#b35900">needs ~<%= row[:needed_pace] %>/day</strong>
            <div style="font-size:11px;color:#888">selling ~<%= row[:observed_pace] %>/day</div>
          </td>
        </tr></table>
      </div>
    <% end %>
  <% end %>

  <div style="margin-top:28px;text-align:center">
    <a href="<%= analyst_url %>" style="display:inline-block;background:#c2410c;color:#fff;text-decoration:none;font-weight:700;font-size:14px;padding:10px 20px;border-radius:8px">View the full dashboard →</a>
  </div>

  <div style="margin-top:24px;padding-top:12px;border-top:1px solid #ddd;font-size:11px;color:#999;text-align:center">
    Sent every Friday by the NY Kitchen Analyst Agent.
    Manage this email from the <a href="<%= analyst_url %>" style="color:#999">Analyst dashboard</a>.
  </div>
</div>
