<% content_for :title, "#{@workspace.name} · Social Agent" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="composer echo-tabs"
     data-echo-tabs-storage-key-value="echo-tab:<%= @workspace.slug %>:<%= Current.user&.id %>">
  <%# Generic workspaces always show the Workspaces root; NY Kitchen keeps the
      adaptive root (its pinned customers see NY Kitchen, not Workspaces). %>
  <% ws_root = (@workspace.slug != "nykitchen" || show_workspaces_crumb?) ? [["Workspaces", workspaces_path(force: 1)]] : [] %>
  <% social_crumbs = capture do %>
    <% if @workspace.slug == "nykitchen" %>
      <%= render "shared/breadcrumbs", crumbs: ws_root + [["NY Kitchen", nykitchen_path], [nyk_agent_callsign("social", @workspace.agent_for("social")), nil]] %>
    <% else %>
      <%= render "shared/breadcrumbs", crumbs: ws_root + [[@workspace.name, workspace_path(@workspace.slug)], ["Social Agent", nil]] %>
    <% end %>
  <% end %>
  <% social_actions = capture do %>
    <% if @writer && @connected_platforms.any? %>
      <button type="button"
              data-action="click->echo-tabs#show" data-show-tab="newpost"
              class="inline-flex items-center gap-1.5 px-3 h-8 rounded-lg bg-gray-800 border border-gray-700 hover:border-orange-500 text-sm text-gray-200 transition cursor-pointer">
        <span class="text-orange-400 text-base leading-none">+</span>
        <span>New post</span>
      </button>
    <% end %>
  <% end %>
  <%= render "shared/ws_header", workspace: @workspace, breadcrumbs: social_crumbs, actions: social_actions %>

  <%# Compact identity band: logo inline with the title (matches the workspace
      hub). NY Kitchen keeps its "Field Roster" callsign identity. %>
  <div class="flex items-center justify-between gap-3 mb-6 flex-wrap">
    <div class="flex items-center gap-4 min-w-0">
      <% if @workspace.logo.attached? %>
        <%= image_tag @workspace.logo, alt: "#{@workspace.name} logo",
              class: "h-14 w-14 rounded-lg object-contain bg-white/5 p-1 shrink-0" %>
      <% end %>
      <div class="min-w-0">
        <% if @workspace.slug == "nykitchen" %>
          <% sa = @workspace.agent_for("social") %>
          <% meta = nyk_agent_meta("social") %>
          <div class="flex items-baseline gap-3 flex-wrap">
            <h1 class="text-2xl font-bold text-white"><%= nyk_agent_callsign("social", sa) %></h1>
            <div class="flex items-baseline gap-2 text-sm font-mono uppercase tracking-wider">
              <span class="font-semibold" style="color: <%= meta[:accent] %>"><%= meta[:tag] %></span>
              <% if sa %><span class="text-gray-600">·</span><span class="text-gray-500">#<%= sa.agent_number %></span><% end %>
            </div>
          </div>
        <% else %>
          <h1 class="text-2xl font-bold text-white">Social Agent</h1>
        <% end %>
        <%# Internal meta (name / slug / timezone): hidden from clients, kept for
            site admins. The name already shows in the breadcrumb. %>
        <% if Current.user&.admin? %>
          <p class="text-xs text-gray-500 font-mono mt-0.5"><%= @workspace.name %> · /<%= @workspace.slug %> · <%= @workspace.timezone %></p>
        <% end %>
      </div>
    </div>
  </div>

  <% if @writer %>
    <%# Echo tabs: Listen / New post / Post history. Client-side show/hide via
        echo_tabs_controller; remembers the last tab per user. %>
    <nav class="flex items-center gap-1 border-b border-gray-800 mb-6 overflow-x-auto" role="tablist">
      <% [ [ "listen", "Listen" ], [ "newpost", "New post" ], [ "history", "Post history" ] ].each do |key, label| %>
        <button type="button" role="tab" data-echo-tabs-target="tab" data-tab="<%= key %>"
                data-action="click->echo-tabs#select"
                class="px-3.5 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-gray-400 hover:text-white transition whitespace-nowrap"><%= label %></button>
      <% end %>
    </nav>

  <%# ===== Listen tab: conversations worth joining + listening topics ===== %>
  <div data-echo-tabs-target="panel" data-tab="listen">
  <% if @social_leads.present? %>
    <%= render "workspaces/social_leads", leads: @social_leads, workspace: @workspace %>
  <% end %>

  <%# Manager-editable listening topics (what Echo searches for). Only shown to
      managers when listening is on for this workspace. %>
  <% if @is_manager && @listening_enabled %>
    <section class="mb-8" data-controller="dialog">
      <div class="flex items-center gap-2 mb-3">
        <span class="ra-eyebrow">Listening topics</span>
        <button type="button" data-action="click->dialog#open" title="How does Echo listening work?"
                aria-label="How Echo listening works" class="text-gray-500 hover:text-orange-400 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </button>
      </div>

      <%# Info dialog: how often Echo runs + which platforms it searches. %>
      <dialog data-dialog-target="modal" data-action="click->dialog#backdropClose"
              class="bg-transparent backdrop:bg-black/80 p-0 w-[92vw] max-w-lg fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
        <div class="bg-gray-900 rounded-xl border border-gray-800 max-h-[85vh] overflow-y-auto">
          <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-gray-800">
            <span class="ra-eyebrow">How Echo listening works</span>
            <button type="button" data-action="click->dialog#close" aria-label="Close" class="text-gray-500 hover:text-white text-2xl leading-none">&times;</button>
          </div>
          <div class="p-5 space-y-4 text-sm text-gray-300">
            <p><span class="text-gray-400 font-semibold">How often:</span> Echo checks every 6 hours (about 4 times a day). Each run searches your topics, scores the fresh hits with AI, keeps the good ones, and pings your phone if it found any.</p>
            <div>
              <p class="text-gray-400 font-semibold mb-2">Where it searches:</p>
              <ul class="space-y-2">
                <li><span class="text-white font-semibold">X</span> <span class="text-green-400 text-xs uppercase tracking-wide">live</span><br>Real search of recent tweets (last 7 days). X has the most local volume, and its search understands OR groups and exact phrases, so a topic like (cooking class OR wine tasting) (Rochester OR Finger Lakes) works.</li>
                <li><span class="text-sky-300 font-semibold">Bluesky</span> <span class="text-green-400 text-xs uppercase tracking-wide">live</span><br>Real search of posts and hashtags. Lower local volume than X, but it adds mentions X can miss.</li>
                <li><span class="text-orange-300 font-semibold">Reddit</span> <span class="text-gray-500 text-xs uppercase tracking-wide">limited</span><br>Wired up (r/Rochester, r/FingerLakes), but Reddit blocks our server, so it returns nothing for now. A Reddit login would unblock it.</li>
                <li><span class="text-white font-semibold">Instagram, Facebook, Threads</span> <span class="text-gray-500 text-xs uppercase tracking-wide">not available</span><br>Their APIs do not allow this kind of keyword search.</li>
              </ul>
            </div>
          </div>
        </div>
      </dialog>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 items-start">
        <%# Left: the editable topic list. %>
        <div class="rounded-lg border border-gray-800 bg-gray-900 p-4">
          <p class="text-xs text-gray-500 mb-2">One topic per line. Echo searches these on X and Bluesky, and the AI keeps only the on-topic, local ones. Short phrases work best (each word must match). On X you can also use OR groups and exact phrases, like (cooking class OR wine tasting) (Rochester OR "Finger Lakes"), and hashtags like #winetasting or #FingerLakes catch tagged posts a plain phrase would miss.</p>
          <%= form_with url: listening_topics_workspace_path(@workspace.slug), method: :patch, class: "space-y-2" do %>
            <textarea name="queries" rows="14"
                      class="w-full rounded-md bg-black border border-gray-700 text-white px-3 py-2 text-base focus:border-orange-500 focus:outline-none font-mono"><%= @listening_topics %></textarea>
            <button type="submit" class="inline-flex items-center px-3 h-8 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold transition">Save topics</button>
          <% end %>
        </div>

        <%# Right: the last few conversations Echo drafted from these topics. %>
        <div class="rounded-lg border border-gray-800 bg-gray-900 p-4">
          <p class="text-xs text-gray-500 mb-3">Recent drafts Echo generated from these topics, newest first.</p>
          <% if @recent_leads.present? %>
            <ul class="space-y-3">
              <% @recent_leads.each do |lead| %>
                <li class="border-b border-gray-800 pb-3 last:border-0 last:pb-0">
                  <div class="flex items-center gap-2 text-xs mb-1 flex-wrap">
                    <span class="px-1.5 py-0.5 rounded <%= lead.platform == "bluesky" ? "bg-sky-900/50 text-sky-300" : "bg-orange-900/50 text-orange-300" %> font-semibold"><%= lead.platform_label %></span>
                    <span class="text-green-400 font-semibold"><%= lead.score %></span>
                    <span class="text-gray-500"><%= time_ago_in_words(lead.created_at) %> ago</span>
                    <% unless lead.status == "new" %><span class="text-gray-600 uppercase text-[10px] tracking-wide"><%= lead.status %></span><% end %>
                    <%= button_to workspace_social_lead_path(workspace_slug: @workspace.slug, id: lead.id),
                          method: :delete,
                          form: { class: "ml-auto", data: { turbo_confirm: "Delete this draft? This cannot be undone." } },
                          class: "text-gray-600 hover:text-red-400 transition", "aria-label": "Delete draft", title: "Delete draft" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    <% end %>
                  </div>
                  <%# The drafted reply Echo wrote (the actual draft), then the post it replies to. %>
                  <% draft = lead.draft_reply.to_s.gsub(/\s+/, " ").strip %>
                  <% if draft.present? %>
                    <p class="text-sm text-gray-200"><%= truncate(draft, length: 140) %></p>
                    <p class="text-[11px] text-gray-600 mt-1">re: <%= truncate(lead.text.to_s.gsub(/\s+/, " ").strip, length: 60) %><% if lead.matched_query.present? %> · via <%= lead.matched_query %><% end %></p>
                  <% else %>
                    <p class="text-sm text-gray-300"><%= truncate(lead.text.to_s.gsub(/\s+/, " ").strip, length: 120) %></p>
                    <% if lead.matched_query.present? %><p class="text-[11px] text-gray-600 mt-0.5">via <%= lead.matched_query %></p><% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-gray-500">No drafts yet. Echo checks every few hours and lists what it finds here, newest first.</p>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <% unless @social_leads.present? || (@is_manager && @listening_enabled) %>
    <p class="text-sm text-gray-500">Nothing here yet. When Echo finds a conversation worth joining, it shows up here.</p>
  <% end %>
  </div><%# /listen panel %>

  <%# ===== New post tab: composer + scheduled + drafts ===== %>
  <div data-echo-tabs-target="panel" data-tab="newpost" class="hidden">
    <% if @connected_platforms.any? %>
    <%# The composer is always visible inside the New post tab. %>
    <div data-composer-target="body" class="mb-6">
      <% draft_text  = flash[:draft_text].to_s %>
      <% draft_topic = flash[:draft_topic].to_s %>
      <% min_len     = @connected_platforms.include?("x") ? 280 : 300 %>
      <div class="rounded-lg border-2 border-green-500 bg-gray-900 p-4 space-y-3 shadow-lg shadow-green-500/20">
          <% if draft_text.present? %>
            <p class="text-xs text-orange-400">✨ AI-suggested draft below — edit, then post.</p>
          <% end %>

          <%= form_with url: workspace_draft_suggest_path(workspace_slug: @workspace.slug), local: true, class: "space-y-2" do %>
            <div class="flex flex-wrap gap-2">
              <%= text_field_tag :topic, draft_topic, placeholder: "What should AI draft about? (optional)",
                  class: "flex-1 min-w-[220px] rounded-md bg-white border border-gray-300 text-black placeholder-gray-500 px-3 py-2 text-base focus:border-orange-500 focus:outline-none" %>
              <%= submit_tag "✨ Draft with AI",
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
            </div>
          <% end %>

          <%# Upload a photo → AI captions it on-brand → review on the next
              screen, then post it (with the image) to X. %>
          <%= form_with url: workspace_draft_from_image_path(workspace_slug: @workspace.slug), local: true, multipart: true, class: "space-y-2 pt-3 border-t border-gray-800" do %>
            <p class="text-xs text-gray-500 uppercase tracking-wide">Or draft from a photo</p>
            <div class="flex flex-wrap items-center gap-2">
              <%= file_field_tag :image, accept: "image/png,image/jpeg,image/gif,image/webp", required: true,
                  class: "flex-1 min-w-[220px] text-sm text-gray-300 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border file:border-gray-700 file:bg-gray-800 file:text-white file:cursor-pointer" %>
              <%= text_field_tag :topic, nil, placeholder: "Occasion/angle (optional)",
                  class: "flex-1 min-w-[180px] rounded-md bg-white border border-gray-300 text-black placeholder-gray-500 px-3 py-2 text-base focus:border-orange-500 focus:outline-none" %>
              <%= submit_tag "📸 Draft from image",
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
            </div>
            <p class="text-xs text-gray-500">Posts the photo natively to X. JPEG, PNG, GIF, or WebP, up to 5MB.</p>
          <% end %>

          <%= form_with url: workspace_posts_path(workspace_slug: @workspace.slug), local: true, class: "space-y-3" do |f| %>
            <%= f.text_area :body, rows: 3, maxlength: min_len, required: true,
                value: draft_text.presence,
                placeholder: "Write your post, or use ✨ Draft with AI above",
                class: "w-full rounded-md bg-white border border-gray-300 text-black placeholder-gray-500 px-3 py-2 focus:border-orange-500 focus:outline-none font-mono text-sm" %>

            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
              <span class="text-xs text-gray-500 uppercase tracking-wide">Post to:</span>
              <% if @x_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "x", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  X <span class="text-xs text-gray-500"><%= @x_account.handle %></span>
                </label>
              <% end %>
              <% if @bluesky_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "bluesky", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  Bluesky <span class="text-xs text-gray-500"><%= @bluesky_account.handle %></span>
                </label>
              <% end %>
              <% if @threads_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "threads", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  Threads <span class="text-xs text-gray-500"><%= @threads_account.handle %></span>
                </label>
              <% end %>
              <% if @facebook_account %>
                <label class="flex items-center gap-2 text-gray-300">
                  <%= check_box_tag "target_platforms[]", "facebook", true, class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                  Facebook <span class="text-xs text-gray-500"><%= @facebook_account.handle %></span>
                </label>
              <% end %>
            </div>

            <div class="flex flex-wrap items-center gap-x-3 gap-y-2 pt-1">
              <label class="text-xs text-gray-500 uppercase tracking-wide">Schedule for:</label>
              <%= datetime_field_tag :scheduled_for, nil,
                  class: "rounded-md bg-white border border-gray-300 text-black placeholder-gray-500 px-2 py-1 text-xs focus:border-orange-500 focus:outline-none" %>
              <span class="text-xs text-gray-500">(<%= @workspace.timezone %>) — leave blank to post now or save as draft</span>
            </div>

            <div class="flex items-center justify-end gap-2 pt-1">
              <%= submit_tag "Save draft", name: "commit", value: "save",
                  formaction: workspace_drafts_path(workspace_slug: @workspace.slug),
                  formnovalidate: true,
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
              <%= submit_tag "Schedule", name: "commit", value: "schedule",
                  formaction: workspace_drafts_path(workspace_slug: @workspace.slug),
                  class: "inline-flex items-center px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-orange-500 text-white text-sm cursor-pointer" %>
              <%= f.submit "Post now",
                  formnovalidate: true,
                  data: { turbo_confirm: "Post to the selected platforms now?" },
                  class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
            </div>
          <% end %>
      </div>
    </div>
    <% else %>
      <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center mb-10">
        <% if %w[owner admin].include?(@my_role) %>
          <p class="text-gray-400 text-sm">No social accounts connected yet. Open the <span aria-hidden="true">⋮</span> menu in the top right to connect X, Bluesky, Threads, or Facebook.</p>
        <% else %>
          <p class="text-gray-400 text-sm">No social accounts connected yet. Ask a workspace admin to connect X, Bluesky, Threads, or Facebook.</p>
        <% end %>
      </div>
    <% end %>

        <% if @scheduled_drafts.any? %>
          <h3 class="text-xs uppercase tracking-wide text-gray-500 mt-6 mb-2">Scheduled</h3>
          <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
            <% @scheduled_drafts.each do |d| %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between mb-1 gap-3">
                  <p class="text-xs text-gray-500 truncate">
                    <%= d.author.display_identifier %> · fires <%= d.scheduled_for.in_time_zone(@workspace.timezone).strftime("%b %-d, %-l:%M %p %Z") %> · <%= Array(d.target_platforms).map(&:titleize).join(", ") %>
                  </p>
                  <div class="flex items-center gap-2 shrink-0">
                    <%= button_to "Post now", publish_workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :post, form: { data: { turbo_confirm: "Publish this draft right now?" } },
                        class: "text-xs text-orange-400 hover:text-orange-300 px-2 py-1 border border-orange-900 rounded-md cursor-pointer" %>
                    <%= button_to workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :delete, form: { data: { turbo_confirm: "Cancel this scheduled post?" } },
                        class: "p-1 text-gray-500 hover:text-red-400 cursor-pointer", title: "Delete" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
                    <% end %>
                  </div>
                </div>
                <p class="text-sm text-white whitespace-pre-wrap break-words"><%= d.body %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @drafts.any? %>
          <div class="mt-8 mb-2 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            <h3 id="drafts" class="text-sm font-semibold uppercase tracking-wide text-orange-300">Drafts</h3>
            <span class="text-xs text-gray-500"><%= @drafts.size %> waiting</span>
          </div>
          <div class="rounded-lg border border-orange-600/40 bg-orange-950/20 divide-y divide-orange-900/40 ring-1 ring-orange-500/10">
            <% @drafts.each do |d| %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between mb-1 gap-3">
                  <p class="text-xs text-gray-400 truncate">
                    <%= d.author.display_identifier %> · saved <%= d.created_at.in_time_zone(@workspace.timezone).strftime("%b %-d, %-l:%M %p") %> · <%= Array(d.target_platforms).map(&:titleize).join(", ") %>
                  </p>
                  <div class="flex items-center gap-2 shrink-0">
                    <%= link_to "Edit", edit_workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        class: "text-xs text-gray-300 hover:text-white px-2 py-1 border border-gray-700 rounded-md hover:border-orange-500" %>
                    <%= button_to "Post now", publish_workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :post, form: { data: { turbo_confirm: "Publish this draft now?" } },
                        class: "text-xs text-orange-400 hover:text-orange-300 px-2 py-1 border border-orange-900 rounded-md cursor-pointer" %>
                    <%= button_to workspace_draft_path(workspace_slug: @workspace.slug, id: d.id),
                        method: :delete, form: { data: { turbo_confirm: "Delete this draft?" } },
                        class: "p-1 text-gray-500 hover:text-red-400 cursor-pointer", title: "Delete" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
                    <% end %>
                  </div>
                </div>
                <p class="text-sm text-white whitespace-pre-wrap break-words"><%= d.body %></p>
              </div>
            <% end %>
          </div>
        <% end %>
    </div><%# /newpost panel %>

    <%# ===== Post history tab: recent posts ===== %>
    <div data-echo-tabs-target="panel" data-tab="history" class="hidden">
      <%# Recent posts, tabbed by platform. Each tab shows a green check when the
          platform is connected (active account), a red dot otherwise. Connected
          tabs list their posts + a Disconnect control; unconnected tabs offer a
          Connect CTA. This is now the single place to manage connections (the
          old Settings panel was retired). %>
      <% posts_by_platform   = @posts.group_by(&:platform) %>
      <% accounts_by_platform = @social_accounts.group_by(&:platform) %>
      <% fb_connect = workspace_oauth_facebook_connect_path(workspace_slug: @workspace.slug) %>
      <% platform_tabs = [
           { key: "x",         label: "X",         connect: workspace_oauth_x_connect_path(workspace_slug: @workspace.slug),       method: :post,
             steps: ["Click Connect below.", "Log in to X and authorize Agent44 Labs.", "You'll come right back here with X connected."] },
           { key: "bluesky",   label: "Bluesky",   connect: new_workspace_bluesky_account_path(workspace_slug: @workspace.slug),   method: :get,
             steps: ["In Bluesky, open Settings, then App Passwords, and create one (use that, not your main password).", "Click Connect below.", "Enter your handle and the app password, then save."] },
           { key: "threads",   label: "Threads",   connect: workspace_oauth_threads_connect_path(workspace_slug: @workspace.slug), method: :post,
             steps: ["Click Connect below.", "Log in with your Threads (Instagram) account through Meta and approve access.", "You'll come right back here with Threads connected."] },
           { key: "facebook",  label: "Facebook",  connect: fb_connect, method: :post,
             steps: ["Click Connect below.", "Log in with Facebook and pick the Page you post from.", "Grant access, and you'll come right back here connected."] },
           { key: "instagram", label: "Instagram", connect: fb_connect, method: :post, via_meta: true,
             steps: ["Make sure your Instagram is a Professional account linked to a Facebook Page.", "Click Connect below to log in through Meta.", "Approve access, and you'll come right back here connected."] }
         ] %>
      <% can_connect = %w[owner admin].include?(@my_role) %>
      <%# Owner/admin can hide platform tabs (e.g. Instagram before it's used).
          Hidden tabs drop out for everyone; managers re-show them via "Edit
          tabs". visible_tabs drives both the tab bar and the panels so their
          indices stay in lockstep with the tabs Stimulus controller. %>
      <% hidden_tab_keys = @workspace.hidden_social_tabs %>
      <% visible_tabs    = platform_tabs.reject { |t| hidden_tab_keys.include?(t[:key]) } %>

      <div class="mt-6" data-controller="tabs"
           data-tabs-active-classes-value="text-white border-orange-500"
           data-tabs-inactive-classes-value="text-gray-500 border-transparent hover:text-gray-300">
        <div class="flex items-center justify-between gap-3 mb-2 flex-wrap">
          <h3 class="text-xs uppercase tracking-wide text-gray-500">Recent posts</h3>
          <div class="flex items-center gap-4">
            <%# AI usage counter, tiered by workspace role: owner (and site admins)
                see raw + billed; admins see billed only; everyone else nothing.
                Billed = raw cost x the workspace usage multiplier. %>
            <% ai_role     = @workspace.role_for(Current.user) %>
            <% ai_raw_view = Current.user&.admin? || ai_role == "owner" %>
            <% ai_billed_view = ai_raw_view || ai_role == "admin" %>
            <% if ai_billed_view %>
              <% ai_mult   = @workspace.effective_usage_multiplier %>
              <% ai_raw    = AiCallLog.usage_rollup(AiCallLog.for_workspace(@workspace).this_month)[:cost_dollars] %>
              <% ai_billed = ai_raw * ai_mult %>
              <span class="text-xs text-gray-500 flex items-center gap-1.5"
                    title="This workspace's AI usage this month (updates live as the assistant is used)">
                <span class="text-gray-600">AI this month</span>
                <% if ai_raw_view %>
                  <span id="ws-ai-cost-raw" class="font-mono text-gray-400">$<%= sprintf("%.4f", ai_raw) %></span>
                  <span class="text-gray-600">raw &times;<%= ai_mult.to_f.round(1) %> &rarr;</span>
                <% end %>
                <span id="ws-ai-cost-billed" class="font-mono text-orange-300">$<%= sprintf("%.4f", ai_billed) %></span>
                <% if ai_raw_view %><span class="text-gray-600">billed</span><% end %>
                <span id="ws-ai-cost-delta" class="font-mono text-green-400 opacity-0 transition-opacity duration-500"></span>
              </span>
            <% end %>
            <% if can_connect %>
              <%# Native <details> disclosure: no JS, closes on outside click via
                  the page. Checked = visible; submit hides the unchecked ones. %>
              <details class="relative">
                <summary class="text-xs text-gray-400 hover:text-orange-400 cursor-pointer list-none flex items-center gap-1" title="Show or hide platform tabs">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
                  Edit tabs
                </summary>
                <%= form_with url: social_tabs_workspace_path(@workspace.slug), method: :patch,
                      data: { turbo: false },
                      class: "absolute right-0 z-20 mt-2 w-44 rounded-md border border-gray-800 bg-gray-900 p-3 shadow-lg space-y-2 text-left" do %>
                  <p class="text-xs text-gray-500">Show these tabs:</p>
                  <% platform_tabs.each do |t| %>
                    <label class="flex items-center gap-2 text-xs text-gray-300">
                      <%= check_box_tag "visible_tabs[]", t[:key], !hidden_tab_keys.include?(t[:key]),
                            class: "rounded border-gray-700 bg-gray-800 text-orange-500 focus:ring-orange-500" %>
                      <%= t[:label] %>
                    </label>
                  <% end %>
                  <%= submit_tag "Save", class: "w-full text-xs text-orange-400 hover:text-orange-300 px-3 py-1 border border-orange-900 rounded-md cursor-pointer" %>
                <% end %>
              </details>
            <% end %>
            <%# Agent44 team (site admin) only: review what members asked the
                connect-help assistant. Hidden from workspace owners/admins, and
                from "View as" impersonation (Current.user is the impersonee). %>
            <% if Current.user&.admin? %>
              <%= link_to connect_chats_workspace_path(@workspace.slug),
                    class: "text-xs text-gray-400 hover:text-orange-400 flex items-center gap-1",
                    title: "See what members asked the connect-help assistant" do %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 3v-3z"/></svg>
                Questions
              <% end %>
            <% end %>
            <%= button_to refresh_metrics_workspace_path(@workspace.slug),
                method: :post,
                class: "text-xs text-gray-400 hover:text-orange-400 cursor-pointer flex items-center gap-1",
                title: "Pull latest impressions / likes / reposts from X + Bluesky now" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
              Refresh metrics
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-1 border-b border-gray-800 mb-3 overflow-x-auto">
          <% visible_tabs.each_with_index do |t, i| %>
            <% account = accounts_by_platform[t[:key]]&.first %>
            <button type="button" data-tabs-target="tab" data-action="click->tabs#select"
                    data-tab-index="<%= i %>" data-tab-name="<%= t[:key] %>"
                    class="flex items-center gap-1.5 px-3 py-2 border-b-2 text-sm font-medium whitespace-nowrap cursor-pointer transition">
              <%= t[:label] %>
              <% if account&.status == "active" %>
                <span class="text-green-400 text-xs" title="Connected" aria-label="connected">✓</span>
              <% else %>
                <span class="inline-block w-2 h-2 rounded-full bg-red-500" title="Not connected" aria-label="not connected"></span>
              <% end %>
            </button>
          <% end %>
        </div>

        <% visible_tabs.each_with_index do |t, i| %>
          <% posts   = posts_by_platform[t[:key]] || [] %>
          <% account = accounts_by_platform[t[:key]]&.first %>
          <% connect_control = capture do %>
            <% if t[:method] == :get %>
              <%= link_to "Connect", t[:connect], class: "text-xs text-orange-400 hover:text-orange-300 px-3 py-1 border border-orange-900 rounded-md inline-block" %>
            <% else %>
              <%= button_to "Connect", t[:connect], method: :post, class: "text-xs text-orange-400 hover:text-orange-300 px-3 py-1 border border-orange-900 rounded-md cursor-pointer" %>
            <% end %>
          <% end %>
          <div data-tabs-target="panel" class="<%= "hidden" unless i.zero? %>">
            <% if account %>
              <%# Connected (or needs-reauth) account: management line + posts. %>
              <div class="flex items-center justify-between gap-3 mb-3 px-1 text-xs">
                <span class="text-gray-500 truncate">
                  <%= account.handle %><% if account.token_expires_at.present? %> · token expires <%= account.token_expires_at.in_time_zone(@workspace.timezone).strftime("%b %-d, %-l:%M %p") %><% end %>
                </span>
                <div class="flex items-center gap-3 shrink-0">
                  <% unless account.status == "active" %>
                    <span class="uppercase tracking-wide text-amber-400">needs reconnect</span>
                    <% if can_connect %><%= connect_control %><% end %>
                  <% end %>
                  <% if can_connect %>
                    <%= button_to "Disconnect", workspace_social_account_path(workspace_slug: @workspace.slug, id: account.id),
                        method: :delete, form: { data: { turbo_confirm: "Disconnect #{account.label}?" } },
                        class: "text-red-400 hover:text-red-300 cursor-pointer" %>
                  <% end %>
                </div>
              </div>
              <% if posts.any? %>
                <%# Posts come back newest-first, so grouping by day yields
                    Today, then Yesterday, then older dates in order. %>
                <% posts.group_by { |p| social_post_day_label(p.created_at, @workspace.timezone) }.each do |day_label, day_posts| %>
                  <h4 class="text-xs uppercase tracking-wide text-gray-500 mt-4 mb-2 first:mt-0"><%= day_label %></h4>
                  <div class="rounded-lg border border-gray-800 bg-gray-900 divide-y divide-gray-800">
                    <% day_posts.each do |p| %>
                      <%= render "workspaces/post_card", p: p, workspace: @workspace, writer: @writer %>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center text-sm text-gray-500">No <%= t[:label] %> posts yet.</div>
              <% end %>
            <% else %>
              <%# Not connected: offer to connect, with steps to follow. %>
              <div class="rounded-lg border border-gray-800 bg-gray-900 p-6 text-center">
                <p class="text-sm text-gray-400"><%= t[:label] %> isn't connected yet.</p>
                <% if t[:via_meta] %>
                  <p class="text-xs text-gray-600 mt-1">Instagram connects through Meta (the same login as Facebook).</p>
                <% end %>
                <% if can_connect %>
                  <% if t[:steps].present? %>
                    <ol class="mt-4 mx-auto max-w-sm text-left text-xs text-gray-400 space-y-1.5 list-decimal list-inside marker:text-orange-400">
                      <% t[:steps].each do |step| %>
                        <li><%= step %></li>
                      <% end %>
                    </ol>
                  <% end %>
                  <div class="mt-4 inline-block"><%= connect_control %></div>
                <% else %>
                  <p class="text-xs text-gray-600 mt-2">Ask a workspace admin to connect <%= t[:label] %>.</p>
                <% end %>
                <p class="text-xs text-gray-600 mt-4">No posts yet.</p>
              </div>
            <% end %>
            <%= render "workspaces/connect_chat", workspace: @workspace, platform: t[:key], label: t[:label] %>
          </div>
        <% end %>
      </div>
    </div><%# /history panel %>
  <% end %><%# /@writer %>

</div>
