<%
  ink="#1a1a1a"; mut="#555"; faint="#999"; line="#e7e2d8"; cream="#f7f4ee"; accent="#c2410c"; green="#15803d"; blue="#1d4ed8"
  serif="Georgia, 'Times New Roman', serif"
  sans="-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"
  mono="'JetBrains Mono', 'SF Mono', Consolas, monospace"
  role_meta = {
    "agent_director" => ["AI Agent", blue],
    "ai_augmented"   => ["AI-Augmented QA", green],
    "traditional"    => ["Test Automation", accent]
  }
%>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f0ece3;margin:0;padding:0">
<tr><td align="center" style="padding:24px 12px">
<table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;max-width:600px;background:#ffffff;border:1px solid <%= line %>;border-radius:12px;overflow:hidden">

  <tr><td style="border-top:4px solid <%= accent %>;padding:24px 30px 12px">
    <div style="font-family:<%= serif %>;font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:<%= accent %>;font-weight:bold">Your Job Matches</div>
    <div style="font-family:<%= serif %>;font-size:25px;font-weight:bold;color:<%= ink %>;margin-top:3px"><%= @matches.size %> new <%= "match".pluralize(@matches.size) %> today</div>
    <div style="font-family:<%= sans %>;font-size:12px;color:<%= mut %>;margin-top:6px">Ranked for <%= @profile["name"] %>. AI-augmented QA first, agent roles flagged ★, automation as backstop.</div>
  </td></tr>

  <% @matches.each do |m| %>
    <% job = m.job; label, color = role_meta[job.role_class] || [job.role_class, mut] %>
    <tr><td style="padding:8px 30px">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:<%= cream %>;border:1px solid <%= line %>;border-radius:10px">
        <tr><td style="padding:14px 16px">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
            <td style="vertical-align:top">
              <div style="font-family:<%= serif %>;font-size:16px;font-weight:bold;color:<%= ink %>;line-height:1.3">
                <% if m.is_dream %><span style="color:#b45309">★ </span><% end %><%= job.title %>
              </div>
              <div style="font-family:<%= sans %>;font-size:12px;color:<%= mut %>;margin-top:3px">
                <%= job.company %><% if job.location.present? %> &middot; <%= job.location %><% end %><% if job.salary.present? %> &middot; <span style="color:<%= green %>;font-weight:bold"><%= job.salary %></span><% end %>
              </div>
              <div style="margin-top:6px"><span style="font-family:<%= sans %>;font-size:10px;font-weight:bold;text-transform:uppercase;letter-spacing:.4px;color:<%= color %>;border:1px solid <%= color %>;border-radius:10px;padding:2px 8px"><%= label %></span></div>
            </td>
            <td style="vertical-align:top;text-align:right;width:56px">
              <div style="font-family:<%= mono %>;font-size:24px;font-weight:bold;color:<%= m.score >= 85 ? green : accent %>"><%= m.score %></div>
              <div style="font-family:<%= sans %>;font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:<%= faint %>">match</div>
            </td>
          </tr></table>

          <% if m.why.present? %>
            <div style="font-family:<%= sans %>;font-size:13px;color:#333;line-height:1.5;margin-top:10px"><span style="color:<%= accent %>;font-weight:bold">Why it fits:</span> <%= m.why %></div>
          <% end %>
          <% if m.pitch.present? %>
            <div style="font-family:<%= sans %>;font-size:12px;color:#444;font-style:italic;line-height:1.5;margin-top:8px;padding:8px 10px;background:#fff;border:1px solid <%= line %>;border-radius:6px"><%= m.pitch %></div>
          <% end %>
          <% if m.lead_skills.present? %>
            <div style="font-family:<%= sans %>;font-size:11px;color:<%= mut %>;margin-top:8px"><span style="color:<%= faint %>;text-transform:uppercase;letter-spacing:.4px">Lead with:</span> <%= Array(m.lead_skills).join(" &middot; ").html_safe %></div>
          <% end %>

          <div style="margin-top:12px">
            <a href="<%= job.url %>" style="font-family:<%= sans %>;font-size:13px;font-weight:bold;color:#fff;background:<%= accent %>;text-decoration:none;padding:8px 18px;border-radius:6px;display:inline-block">Apply →</a>
            <a href="<%= jobs_url(host: "agent44labs.com") %>/<%= job.id %>" style="font-family:<%= sans %>;font-size:12px;color:<%= mut %>;text-decoration:none;padding:8px 12px;display:inline-block">Details</a>
          </div>
        </td></tr>
      </table>
    </td></tr>
  <% end %>

  <tr><td style="padding:14px 30px 26px">
    <div style="text-align:center">
      <a href="https://agent44labs.com/jobs/for_me" style="font-family:<%= sans %>;font-size:13px;font-weight:bold;color:<%= accent %>;text-decoration:none">See all your matches →</a>
    </div>
    <div style="font-family:<%= sans %>;font-size:11px;color:<%= faint %>;text-align:center;margin-top:10px;line-height:1.5">Scored daily from fresh listings across 6 job boards. Tune your profile in config/job_match_profile.yml.</div>
  </td></tr>

</table>
</td></tr>
</table>
