<% content_for(:title, "NY Kitchen Classes") %>

<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
     data-controller="tabs kitchen-filter"
     data-tabs-active-classes-value="text-orange-400 border-orange-400"
     data-tabs-inactive-classes-value="text-gray-500 border-transparent">

  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <h1 class="text-3xl font-black text-white tracking-tight">NY Kitchen</h1>
      <div class="flex items-center gap-2">
        <% if authenticated? && (Current.session.user.admin? || Current.session.user.kitchen_only?) %>
          <%= link_to nyk_x_posts_path,
                class: "flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" do %>
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span>X Posts</span>
          <% end %>
        <% end %>
        <% if authenticated? && Current.session.user.admin? %>
          <%= link_to nyk_billing_path,
                class: "flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Billing</span>
          <% end %>
        <% end %>
        <button data-controller="clipboard" data-action="click->clipboard#copy"
                data-clipboard-url-value="<%= nykitchen_url %>"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
          </svg>
          <span data-clipboard-target="label">Share</span>
        </button>
      </div>
    </div>
    <p class="text-gray-400 mt-1">
      Cooking classes at NY Kitchen &middot;
      <%= @total %> upcoming
      <% if @last_updated %>
        &middot; Updated <%= @last_updated.strftime("%b %-d") %>
      <% end %>
    </p>
  </div>

  <!-- Tabs -->
  <div class="flex gap-1 mb-6 border-b border-gray-700">
    <button data-tabs-target="tab" data-tab-index="0" data-tab-name="list" data-action="click->tabs#select"
            class="px-4 py-2 text-sm font-semibold border-b-2 text-orange-400 border-orange-400 transition">
      List
    </button>
    <button data-tabs-target="tab" data-tab-index="1" data-tab-name="smoke" data-action="click->tabs#select"
            class="px-4 py-2 text-sm font-semibold border-b-2 text-gray-500 border-transparent hover:text-gray-300 transition">
      Smoke
    </button>
    <button data-tabs-target="tab" data-tab-index="2" data-tab-name="scrapes" data-action="click->tabs#select"
            class="px-4 py-2 text-sm font-semibold border-b-2 text-gray-500 border-transparent hover:text-gray-300 transition">
      Scrapes
    </button>
  </div>

  <% if @events.empty? %>
    <div class="bg-gray-900 rounded-xl p-8 text-center">
      <p class="text-gray-400">No events scraped yet. The scraper runs every 3 hours.</p>
    </div>
  <% else %>

    <!-- Filter chips (apply to all three views) -->
    <%
      # [status, label, active_classes, inactive_classes]
      chips = [
        ["all",     "All",                 "bg-orange-500 text-white",           "bg-gray-800 text-gray-400 hover:bg-gray-700"],
        ["instock", "Available",           "bg-green-700 text-green-100",        "bg-green-900/40 text-green-400 hover:bg-green-900/60"],
        ["limited", "Limited",             "bg-amber-700 text-amber-100",        "bg-amber-900/40 text-amber-400 hover:bg-amber-900/60"],
        ["soldout", "Sold Out",            "bg-red-800 text-red-100",            "bg-red-900/40 text-red-400 hover:bg-red-900/60"],
        ["closed",  "No Longer Available", "bg-red-900 text-red-100",            "bg-red-900/40 text-red-400 hover:bg-red-900/60"],
        ["other",   "Unknown",             "bg-gray-600 text-gray-100",          "bg-gray-800 text-gray-400 hover:bg-gray-700"]
      ]
    %>
    <div class="flex flex-wrap gap-2 mb-5" data-tabs-chrome-for="0">
      <% chips.each do |status, text, active_cls, inactive_cls| %>
        <% count = @filter_counts[status] %>
        <% next if count == 0 && status != "all" %>
        <% start_cls = status == "all" ? active_cls : inactive_cls %>
        <button data-kitchen-filter-target="chip"
                data-action="click->kitchen-filter#filter"
                data-filter-status="<%= status %>"
                data-active-classes="<%= active_cls %>"
                data-inactive-classes="<%= inactive_cls %>"
                class="px-3 py-1 rounded-full text-xs font-semibold transition <%= start_cls %>">
          <%= text %> (<%= count %>)
        </button>
      <% end %>
    </div>

    <!-- List View -->
    <div data-tabs-target="panel">
      <% @weeks.each_with_index do |week, week_index| %>
        <% next if week[:events].empty? %>
        <section id="week-<%= week_index %>"
                 data-kitchen-filter-target="section"
                 data-controller="collapsible"
                 data-collapsible-collapsed-value="<%= week[:expanded] ? 'false' : 'true' %>"
                 class="mb-8">
          <%
            total = week[:events].size
            statuses = week[:events].map(&:availability_status)
            unavail = statuses.count { |s| s == "soldout" || s == "closed" }
            limited = statuses.count("limited")
            avail = statuses.count("instock")
            other = statuses.count("other")
            pct_unavail = (unavail.to_f / total * 100).round(1)
            pct_limited = (limited.to_f / total * 100).round(1)
            pct_avail   = (avail.to_f / total * 100).round(1)
            pct_other   = (100 - pct_unavail - pct_limited - pct_avail).round(1)
          %>
          <button type="button"
                  data-action="click->collapsible#toggle"
                  class="w-full text-left border-b border-gray-700 pb-2 mb-4 hover:text-orange-400 transition">
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-white">
                <%= week[:label] %>
                <span class="text-gray-500 font-normal">(<%= total %>)</span>
              </span>
              <svg data-collapsible-target="icon"
                   class="w-5 h-5 text-gray-500 transition-transform shrink-0"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <div class="flex w-full h-1.5 rounded-full overflow-hidden mt-2 bg-gray-800">
              <% if unavail > 0 %>
                <div class="bg-red-500 h-full" style="width: <%= pct_unavail %>%" title="<%= unavail %> sold out / closed"></div>
              <% end %>
              <% if limited > 0 %>
                <div class="bg-amber-500 h-full" style="width: <%= pct_limited %>%" title="<%= limited %> limited"></div>
              <% end %>
              <% if other > 0 %>
                <div class="bg-gray-500 h-full" style="width: <%= pct_other %>%" title="<%= other %> unknown"></div>
              <% end %>
              <% if avail > 0 %>
                <div class="bg-green-500 h-full" style="width: <%= pct_avail %>%" title="<%= avail %> available"></div>
              <% end %>
            </div>
          </button>
          <div data-collapsible-target="body" class="space-y-3">
            <% week[:events].each do |e| %>
              <%= render partial: "admin/kitchen/event_card", locals: { event: e, show_date: true } %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>

    <!-- Smoke Tab -->
    <div data-tabs-target="panel" class="hidden">
      <h2 class="text-lg font-bold text-white border-b border-gray-700 pb-2 mb-4">
        Smoke Tests
      </h2>
      <p class="text-gray-400 text-sm mb-4">
        Hourly round-trip through the
        <a href="https://nykitchen.com/calendar/" class="text-orange-400 hover:text-orange-300 underline" target="_blank" rel="noopener">NY Kitchen calendar</a>
        to make sure the same classes still show up when you flip through the months. If something looks off, admins get an email with a video of what happened.
      </p>
      <div data-controller="smoke-trigger"
           data-smoke-trigger-url-value="<%= nyk_trigger_smoke_path %>"
           class="mb-4 flex flex-wrap items-center gap-3">
        <button type="button"
                data-smoke-trigger-target="button"
                data-action="click->smoke-trigger#trigger"
                class="px-4 py-2 rounded-lg bg-orange-500 text-white text-sm font-semibold hover:bg-orange-400 transition">
          Run Smoke Test
        </button>
        <span data-smoke-trigger-target="status" class="text-sm"></span>
      </div>

      <% if @smoke_runs_total_count > 0 %>
        <%
          rate_color = ->(pct) {
            pct >= 20 ? "text-red-400" : pct >= 5 ? "text-amber-400" : "text-green-400"
          }
          current_days   = (@smoke_days || "all").to_s
          current_status = @smoke_status
          window_label   = @smoke_days ? "last #{pluralize(@smoke_days, 'day')}" : "all-time"
        %>

        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider mr-1">Range</span>
          <% [["1","1 day"], ["5","5 days"], ["30","30 days"], ["all","All"]].each do |val, label| %>
            <% active = current_days == val %>
            <%= link_to label,
                  nykitchen_path(days: val, status: current_status, anchor: "smoke"),
                  class: "px-3 py-1 rounded-full text-xs font-semibold transition #{active ? 'bg-orange-500 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}" %>
          <% end %>
        </div>

        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider mr-1">Status</span>
          <% [["all","All"], ["passed","Passed"], ["failed","Failed"]].each do |val, label| %>
            <%
              active = current_status == val
              active_cls = case val
                           when "passed" then "bg-green-700 text-green-100"
                           when "failed" then "bg-red-800 text-red-100"
                           else               "bg-orange-500 text-white"
                           end
            %>
            <%= link_to label,
                  nykitchen_path(days: current_days, status: val, anchor: "smoke"),
                  class: "px-3 py-1 rounded-full text-xs font-semibold transition #{active ? active_cls : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}" %>
          <% end %>
        </div>

        <div class="grid grid-cols-1 <%= 'sm:grid-cols-2' if @smoke_days %> gap-3 mb-6">
          <div class="bg-gray-900 rounded-lg border border-gray-800 px-4 py-3">
            <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Failure rate · all-time</div>
            <div class="mt-1 text-xl font-bold <%= rate_color.call(@smoke_failure_rate) %>"><%= @smoke_failure_rate %>%</div>
            <div class="text-xs text-gray-500"><%= @smoke_failed_count %> failed of <%= @smoke_runs_total_count %> runs</div>
          </div>
          <% if @smoke_days %>
            <div class="bg-gray-900 rounded-lg border border-gray-800 px-4 py-3">
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Failure rate · <%= window_label %></div>
              <div class="mt-1 text-xl font-bold <%= rate_color.call(@smoke_failure_rate_window) %>"><%= @smoke_failure_rate_window %>%</div>
              <div class="text-xs text-gray-500"><%= @smoke_failed_count_window %> failed of <%= @smoke_runs_count_window %> runs</div>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @can_see_pricing %>
        <p class="text-sm text-gray-500 mb-6">
          Total cost: <span class="text-white font-semibold">$<%= "%.2f" % @smoke_runs_total_cost %></span>
          (<%= @smoke_runs_total_count %> runs &middot; <%= @smoke_runs_total_minutes %> min &middot; $0.00044/min)
        </p>
      <% end %>

      <% if @smoke_runs.empty? %>
        <div class="bg-gray-900 rounded-xl p-8 text-center">
          <% if @smoke_runs_total_count.zero? %>
            <p class="text-gray-400">No test runs yet.</p>
            <p class="text-gray-500 text-xs mt-1">First scheduled run is tomorrow at 9 AM EDT.</p>
          <% else %>
            <p class="text-gray-400">No runs match this filter.</p>
            <p class="text-gray-500 text-xs mt-1">Try widening the range or switching status to All.</p>
          <% end %>
        </div>
      <% else %>
        <div class="overflow-x-auto rounded-lg border border-gray-800" data-controller="video-modal console-modal">
          <table class="min-w-full divide-y divide-gray-800">
            <thead class="bg-gray-900">
              <% admin = @admin %>
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">When</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Status</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Duration</th>
                <th class="hidden sm:table-cell px-4 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Notes</th>
                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Video</th>
                <% if @can_see_pricing %>
                  <th class="hidden sm:table-cell px-4 py-2 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Cost</th>
                <% end %>
                <% if admin %>
                  <th class="px-4 py-2 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">&nbsp;</th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-gray-950 divide-y divide-gray-800">
              <% @smoke_runs.each do |run| %>
                <tr id="<%= dom_id(run) %>">
                  <td class="px-3 py-3 text-sm text-gray-300 whitespace-nowrap sm:px-4">
                    <%= run.started_at.strftime("%b %-d") %>
                    <span class="block sm:inline text-gray-500"><%= run.started_at.strftime("%-I:%M %p") %></span>
                  </td>
                  <td class="px-3 py-3 whitespace-nowrap sm:px-4">
                    <% if run.passed? %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-900/50 text-green-400 text-xs font-semibold">
                        ✓ PASSED
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-900/50 text-red-400 text-xs font-semibold">
                        🚨 FAILED
                      </span>
                    <% end %>
                  </td>
                  <td class="px-3 py-3 text-sm text-gray-400 whitespace-nowrap sm:px-4">
                    <%= run.duration_label %>
                  </td>
                  <td class="hidden sm:table-cell px-4 py-3 text-sm text-gray-400">
                    <% if run.passed? %>
                      <%= run.summary.presence || "—" %>
                    <% else %>
                      <span class="text-red-400"><%= run.error_message.to_s.truncate(140) %></span>
                      <% if run.console_errors.present? %>
                        <button data-action="click->console-modal#open"
                                data-console-errors="<%= run.console_errors %>"
                                data-console-label="Console errors · <%= run.started_at.strftime("%b %-d %-I:%M %p") %>"
                                class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded bg-red-950/60 border border-red-800/60 text-red-300 hover:text-red-100 hover:bg-red-900/50 text-[10px] font-semibold uppercase tracking-wider transition">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                          </svg>
                          console
                        </button>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="px-3 py-3 text-center whitespace-nowrap sm:px-4">
                    <% if run.video.attached? && run.thumbnail.attached? %>
                      <img src="<%= url_for(run.thumbnail) %>"
                           class="rounded w-16 h-10 object-cover hover:opacity-80 transition border border-gray-700 cursor-pointer inline-block"
                           data-action="click->video-modal#open"
                           data-video-modal-src-param="<%= url_for(run.video) %>"
                           alt="Test recording">
                    <% elsif run.video.attached? %>
                      <button data-action="click->video-modal#open"
                              data-video-modal-src-param="<%= url_for(run.video) %>"
                              class="text-orange-400 text-xs hover:text-orange-300">▶</button>
                    <% else %>
                      <span class="text-gray-600 text-xs">—</span>
                    <% end %>
                  </td>
                  <% if @can_see_pricing %>
                    <td class="hidden sm:table-cell px-4 py-3 text-sm text-gray-500 text-right whitespace-nowrap">
                      $<%= "%.4f" % run.cost_dollars %>
                    </td>
                  <% end %>
                  <% if admin %>
                    <td class="px-4 py-3 text-right whitespace-nowrap">
                      <%= button_to admin_smoke_run_path(run),
                            method: :delete,
                            form: { class: "inline", data: { turbo_confirm: "Delete this test run?" } },
                            class: "text-gray-500 hover:text-red-400 transition p-1",
                            aria: { label: "Delete run" } do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
          <% if @smoke_runs_truncated %>
            <p class="px-4 py-2 text-[11px] text-gray-500 bg-gray-900 border-t border-gray-800">
              Showing the latest 500 runs. Narrow the range to see different windows.
            </p>
          <% end %>
          <dialog data-video-modal-target="dialog"
                  data-action="click->video-modal#backdropClose"
                  class="bg-transparent backdrop:bg-black/80 p-0 max-w-4xl w-[90vw] fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
            <div class="bg-gray-900 rounded-xl p-4">
              <div class="flex justify-between items-center mb-3">
                <h3 class="text-sm font-semibold text-gray-400">Smoke Test Recording</h3>
                <button data-action="click->video-modal#close"
                        class="text-gray-500 hover:text-white text-lg">&times;</button>
              </div>
              <video data-video-modal-target="video" controls class="rounded-lg w-full" preload="metadata">
              </video>
            </div>
          </dialog>

          <dialog data-console-modal-target="dialog"
                  data-action="click->console-modal#backdropClose"
                  class="bg-transparent backdrop:bg-black/80 p-0 max-w-3xl w-[90vw] fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
            <div class="bg-gray-950 rounded-xl border border-red-900/50 p-4">
              <div class="flex justify-between items-center mb-3">
                <h3 class="text-sm font-semibold text-red-300" data-console-modal-target="title">Browser console</h3>
                <button data-action="click->console-modal#close"
                        class="text-gray-500 hover:text-white text-lg">&times;</button>
              </div>
              <pre data-console-modal-target="body"
                   class="bg-black rounded-lg p-4 text-xs font-mono text-red-200 leading-relaxed overflow-auto max-h-[70vh] whitespace-pre-wrap break-words"></pre>
              <p class="mt-3 text-[10px] text-gray-500">Captured live from <code class="text-gray-400">page.on("console")</code> + <code class="text-gray-400">page.on("pageerror")</code> during this smoke run.</p>
            </div>
          </dialog>
        </div>
      <% end %>
    </div>

    <!-- Scrapes Tab -->
    <div data-tabs-target="panel" class="hidden">
      <h2 class="text-lg font-bold text-white border-b border-gray-700 pb-2 mb-4">
        Scrapes
      </h2>
      <p class="text-gray-400 text-sm mb-4">
        Full re-scrape of the
        <a href="https://nykitchen.com/calendar/" class="text-orange-400 hover:text-orange-300 underline" target="_blank" rel="noopener">NY Kitchen calendar</a>
        every three hours. Each run snapshots the day's events; the latest snapshot of the day powers the List view above.
      </p>

      <% if @can_see_pricing %>
        <p class="text-sm text-gray-500 mb-6">
          Total cost: <span class="text-white font-semibold">$<%= "%.2f" % @scrape_runs_total_cost %></span>
          (<%= @scrape_runs_total_count %> runs &middot; <%= @scrape_runs_total_minutes %> min &middot; $0.00044/min)
        </p>
      <% end %>

      <% if @scrape_runs.empty? %>
        <div class="bg-gray-900 rounded-xl p-8 text-center">
          <p class="text-gray-400">No scrape runs yet.</p>
          <p class="text-gray-500 text-xs mt-1">Scrapes run every 3 hours.</p>
        </div>
      <% else %>
        <div class="overflow-x-auto rounded-lg border border-gray-800">
          <table class="min-w-full divide-y divide-gray-800">
            <thead class="bg-gray-900">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">When</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Status</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Duration</th>
                <th class="px-3 py-2 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Events</th>
                <th class="hidden sm:table-cell px-4 py-2 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Available</th>
                <th class="hidden sm:table-cell px-4 py-2 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Sold out</th>
                <th class="hidden sm:table-cell px-4 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Notes</th>
              </tr>
            </thead>
            <tbody class="bg-gray-950 divide-y divide-gray-800">
              <% @scrape_runs.each do |run| %>
                <% summary = @scrape_day_summary[run.started_at.to_date] %>
                <tr id="<%= dom_id(run) %>">
                  <td class="px-3 py-3 text-sm text-gray-300 whitespace-nowrap sm:px-4">
                    <%= run.started_at.strftime("%b %-d") %>
                    <span class="block sm:inline text-gray-500"><%= run.started_at.strftime("%-I:%M %p") %></span>
                  </td>
                  <td class="px-3 py-3 whitespace-nowrap sm:px-4">
                    <% if run.passed? %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-900/50 text-green-400 text-xs font-semibold">
                        ✓ PASSED
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-900/50 text-red-400 text-xs font-semibold">
                        🚨 FAILED
                      </span>
                    <% end %>
                  </td>
                  <td class="px-3 py-3 text-sm text-gray-400 whitespace-nowrap sm:px-4">
                    <%= run.duration_label %>
                  </td>
                  <td class="px-3 py-3 text-sm text-gray-300 text-right whitespace-nowrap sm:px-4">
                    <%= summary ? summary[:total] : "—" %>
                  </td>
                  <td class="hidden sm:table-cell px-4 py-3 text-sm text-green-400 text-right whitespace-nowrap">
                    <%= summary ? summary[:available] : "—" %>
                  </td>
                  <td class="hidden sm:table-cell px-4 py-3 text-sm text-red-400 text-right whitespace-nowrap">
                    <%= summary ? summary[:soldout] : "—" %>
                  </td>
                  <td class="hidden sm:table-cell px-4 py-3 text-sm text-gray-400">
                    <% if run.passed? %>
                      <%= run.summary.presence || "—" %>
                    <% else %>
                      <span class="text-red-400"><%= run.error_message.to_s.truncate(140) %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>

  <% end %>
</div>

<%= javascript_tag nonce: true do %>
// Inline fallback for tab switching — works before Stimulus/importmap loads.
(function() {
  var root = document.querySelector('[data-controller*="tabs"]');
  if (!root) return;
  var tabs = root.querySelectorAll('[data-tab-index]');
  var panels = root.querySelectorAll('[data-tabs-target="panel"]');
  var chromes = root.querySelectorAll('[data-tabs-chrome-for]');
  var activeClasses = (root.dataset.tabsActiveClassesValue || 'text-orange-400 border-orange-400').split(' ');
  var inactiveClasses = (root.dataset.tabsInactiveClassesValue || 'text-gray-500 border-transparent').split(' ');

  function selectTab(index) {
    tabs.forEach(function(tab, i) {
      if (i === index) {
        activeClasses.forEach(function(c) { tab.classList.add(c); });
        inactiveClasses.forEach(function(c) { tab.classList.remove(c); });
      } else {
        activeClasses.forEach(function(c) { tab.classList.remove(c); });
        inactiveClasses.forEach(function(c) { tab.classList.add(c); });
      }
    });
    panels.forEach(function(panel, i) {
      panel.classList.toggle('hidden', i !== index);
    });
    chromes.forEach(function(el) {
      var indices = el.dataset.tabsChromeFor.split(' ');
      el.classList.toggle('hidden', indices.indexOf(String(index)) === -1);
    });
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      selectTab(parseInt(tab.dataset.tabIndex));
    });
  });

  // Deep-link: #smoke / #scrapes pre-select the matching tab.
  var hash = window.location.hash;
  if (hash === '#smoke') {
    selectTab(1);
  } else if (hash === '#scrapes') {
    selectTab(2);
  }

  // Deep-link: #week-N scrolls to and expands that week section (List tab)
  if (hash && hash.match(/^#week-\d+$/)) {
    // Ensure List tab is active (index 0)
    selectTab(0);
    var section = document.getElementById(hash.slice(1));
    if (section) {
      // Expand if collapsed
      var body = section.querySelector('[data-collapsible-target="body"]');
      var icon = section.querySelector('[data-collapsible-target="icon"]');
      if (body && body.classList.contains('hidden')) {
        body.classList.remove('hidden');
        if (icon) icon.classList.remove('-rotate-90');
      }
      // Scroll into view after a short delay for layout
      setTimeout(function() {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
})();
<% end %>
