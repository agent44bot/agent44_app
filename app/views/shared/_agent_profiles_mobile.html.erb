<%# Locals: agents (collection of Agent records) %>
<% return if agents.blank? %>

<% strip_emoji = ->(s) { s.gsub(/[\u{1F000}-\u{1FAFF}\u{2600}-\u{27BF}\u{FE00}-\u{FE0F}\u{2702}-\u{27B0}\u{200D}\u{20E3}\u{E0020}-\u{E007F}\u2705\u274C\u{1F3FB}-\u{1F3FF}]/u, "").strip } %>

<div class="font-mono" data-controller="agent-status">
  <p class="text-[9px] font-semibold uppercase tracking-wider text-green-400 mb-1">agents</p>
  <div class="space-y-0.5">
    <% agents.each do |agent| %>
      <% clean_name = strip_emoji.(agent.name) %>
      <div class="flex items-center gap-1.5"
           data-agent-status-target="agent"
           data-agent-name="<%= agent.name %>">
        <% if agent.busy? %>
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-amber-400 animate-agent-pulse shrink-0" data-dot></span>
          <span class="text-[10px] text-amber-300" data-name><%= clean_name %></span>
          <span class="text-[9px] text-amber-500" data-role><%= agent.role.downcase %></span>
          <span class="text-[9px] text-amber-400 italic truncate" data-task>(<%= agent.status_label %>)</span>
        <% elsif agent.error? %>
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-red-500 shrink-0" data-dot></span>
          <span class="text-[10px] text-red-300" data-name><%= clean_name %></span>
          <span class="text-[9px] text-red-500" data-role><%= agent.role.downcase %></span>
          <span class="text-[9px] text-red-400 italic truncate" data-task>(<%= agent.status_label %>)</span>
        <% elsif agent.online? %>
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse shrink-0" data-dot></span>
          <span class="text-[10px] text-emerald-300" data-name><%= clean_name %></span>
          <span class="text-[9px] text-green-500" data-role><%= agent.role.downcase %></span>
          <span data-task style="display:none"></span>
        <% else %>
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-gray-600 shrink-0" data-dot></span>
          <span class="text-[10px] text-gray-500" data-name><%= clean_name %></span>
          <span class="text-[9px] text-gray-600" data-role><%= agent.role.downcase %></span>
          <span data-task style="display:none"></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
