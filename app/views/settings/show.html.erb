<% content_for(:title, "Settings") %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <h1 class="text-3xl font-black text-white tracking-tight mb-1">Settings</h1>
  <p class="text-gray-400 mb-8 text-sm break-words">
    Signed in as <span class="text-gray-200"><%= Current.user&.email_address %></span>
  </p>

  <!-- Email address -->
  <div data-controller="email-change"
       data-email-change-url-value="<%= update_email_settings_path %>"
       class="mb-6 bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-800">
      <h2 class="text-white font-semibold text-base">Email address</h2>
      <p class="text-xs text-gray-500 mt-0.5">
        Used to sign in and receive notifications. A verification link is sent to any new address.
      </p>
    </div>

    <!-- View -->
    <div data-email-change-target="view" class="px-5 py-4 flex items-center justify-between gap-3 min-w-0">
      <span class="text-sm text-gray-300 truncate min-w-0" data-email-change-target="currentEmail"><%= Current.user&.email_address %></span>
      <button type="button"
              data-action="click->email-change#open"
              class="px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-200 text-xs font-semibold transition flex-shrink-0">
        Change
      </button>
    </div>

    <!-- Form -->
    <div data-email-change-target="form" class="hidden px-5 py-4 space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1">New email</label>
        <input type="email" autocomplete="email"
               data-email-change-target="newEmail"
               class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1">Current password</label>
        <input type="password" autocomplete="current-password"
               data-email-change-target="password"
               class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition">
      </div>
      <div data-email-change-target="error" class="hidden text-sm text-red-400"></div>
      <div class="flex items-center gap-2">
        <button type="button"
                data-action="click->email-change#submit"
                data-email-change-target="saveBtn"
                class="px-4 py-2 rounded-lg bg-orange-600 text-white text-sm font-semibold hover:bg-orange-500 transition">
          Save changes
        </button>
        <button type="button"
                data-action="click->email-change#cancel"
                class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm transition">
          Cancel
        </button>
      </div>
    </div>
  </div>

  <!-- Face ID / biometrics. The inner panel flips to whichever state
       the device supports — card (Capacitor), web fallback, or unsupported. -->
  <div data-controller="biometric"
       data-biometric-verify-url-value="<%= verify_password_settings_path %>"
       data-biometric-email-value="<%= Current.user&.email_address %>"
       class="mb-6">

    <!-- State: in-app (Capacitor) -->
    <div data-biometric-target="card"
         class="hidden bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-800 flex items-center justify-between gap-3">
        <div>
          <h2 class="text-white font-semibold text-base">Face ID</h2>
          <p class="text-xs text-gray-500 mt-0.5">
            Sign in to this device with Face ID instead of your password.
          </p>
        </div>
        <span data-biometric-target="status"
              class="text-xs font-semibold px-2 py-1 rounded-full bg-gray-800 text-gray-400">
          Checking…
        </span>
      </div>

      <!-- ON -->
      <div data-biometric-target="onState" class="hidden px-5 py-4">
        <p class="text-sm text-gray-300 mb-3 break-words">
          Face ID is enabled for <span class="text-white font-medium"><%= Current.user&.email_address %></span>.
          Tapping sign-in will prompt Face ID automatically.
        </p>
        <button type="button"
                data-action="click->biometric#disable"
                data-biometric-target="disableBtn"
                class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold hover:bg-red-500 transition">
          Turn off Face ID
        </button>
      </div>

      <!-- OFF -->
      <div data-biometric-target="offState" class="hidden px-5 py-4">
        <p class="text-sm text-gray-300 mb-3">
          Face ID is off. Enter your password once to enable it — we'll save it securely to the device keychain.
        </p>
        <div class="space-y-3">
          <input type="password" autocomplete="current-password"
                 data-biometric-target="password"
                 placeholder="Your password"
                 class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition">
          <div data-biometric-target="error" class="hidden text-sm text-red-400"></div>
          <button type="button"
                  data-action="click->biometric#enable"
                  data-biometric-target="enableBtn"
                  class="px-4 py-2 rounded-lg bg-orange-600 text-white text-sm font-semibold hover:bg-orange-500 transition">
            Turn on Face ID
          </button>
        </div>
      </div>

      <!-- Unsupported device -->
      <div data-biometric-target="unsupportedState" class="hidden px-5 py-4">
        <p class="text-sm text-gray-400">
          Biometric authentication isn't available on this device.
        </p>
      </div>
    </div>

    <!-- State: web browser (not Capacitor) -->
    <div data-biometric-target="webState"
         class="hidden bg-gray-900 border border-gray-800 rounded-xl p-5 text-sm text-gray-400">
      Face ID settings are only available inside the Agent 44 Labs iOS app (TestFlight).
    </div>

    <!-- Pre-JS placeholder (controller hides it in connect so only one panel shows) -->
    <noscript>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 text-sm text-gray-400">
        Enable JavaScript to manage device settings.
      </div>
    </noscript>
  </div>

  <!-- Delete account. Permanently destroys the user record and all associated
       data; required for App Store compliance (guideline 5.1.1(v)). -->
  <div data-controller="account-deletion"
       data-account-deletion-has-password-value="<%= Current.user&.password_digest.present? %>"
       class="mb-6 bg-gray-900 border border-red-900/40 rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-800">
      <h2 class="text-white font-semibold text-base">Delete account</h2>
      <p class="text-xs text-gray-500 mt-0.5">
        Permanently delete your account and all data we've stored for you. This can't be undone.
      </p>
    </div>

    <!-- View: just the trigger button -->
    <div data-account-deletion-target="view" class="px-5 py-4">
      <button type="button"
              data-action="click->account-deletion#open"
              class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-red-900/40 text-red-400 text-sm font-semibold transition border border-red-900/40">
        Delete account…
      </button>
    </div>

    <!-- Form: confirmation -->
    <%= form_with url: settings_path, method: :delete,
          data: { account_deletion_target: "form" },
          class: "hidden px-5 py-4 space-y-3" do |f| %>
      <p class="text-sm text-gray-300">
        This will delete your account, sign you out, and remove your saved jobs,
        posts, and other data we've stored for you. <span class="text-red-400 font-semibold">This is permanent.</span>
      </p>

      <% if Current.user&.password_digest.present? %>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">Confirm with your password</label>
          <%= f.password_field :password,
                autocomplete: "current-password",
                class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition" %>
        </div>
      <% else %>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">
            Type <span class="font-mono text-red-400">DELETE</span> to confirm
          </label>
          <%= f.text_field :confirm,
                autocomplete: "off", autocapitalize: "characters", spellcheck: "false",
                data: { account_deletion_target: "confirm", action: "input->account-deletion#checkConfirm" },
                class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition" %>
        </div>
      <% end %>

      <div class="flex items-center gap-2">
        <%= f.submit "Delete my account",
              data: { account_deletion_target: "submitBtn" },
              class: "px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold hover:bg-red-500 transition disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer" %>
        <button type="button"
                data-action="click->account-deletion#cancel"
                class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm transition">
          Cancel
        </button>
      </div>
    <% end %>
  </div>
</div>
