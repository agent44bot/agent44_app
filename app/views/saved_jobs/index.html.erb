<% content_for(:title, "Saved Jobs") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white">Saved Jobs</h1>
    <p class="mt-2 text-gray-500">Jobs you've bookmarked for later.</p>
  </div>

  <% if @saved_jobs.present? %>
    <div class="space-y-4">
      <% @saved_jobs.each do |job| %>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 hover:shadow-md hover:border-orange-500/30 transition group">
          <div class="flex items-start gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-1">
                <h2 class="text-lg font-semibold text-white group-hover:text-orange-600 transition truncate">
                  <%= link_to job.title, job_path(job) %>
                </h2>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-900/50 text-orange-400 whitespace-nowrap">
                  <%= job.category&.titleize || "General" %>
                </span>
              </div>
              <p class="text-sm text-gray-400"><%= job.company %></p>
              <div class="mt-2 flex flex-wrap items-center gap-4 text-xs text-gray-400">
                <% if job.location.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <%= job.location %>
                  </span>
                <% end %>
                <% if job.salary.present? %>
                  <span class="text-green-600 font-medium"><%= job.salary %></span>
                <% end %>
                <% if job.url.present? %>
                  <%= link_to job.url, target: "_blank", rel: "noopener noreferrer", class: "flex items-center gap-1 text-orange-500 hover:text-orange-700 transition" do %>
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    See listing
                  <% end %>
                <% end %>
                <% if job.source.present? %>
                  <span>via <%= job.source %></span>
                <% end %>
                <span><%= time_ago_in_words(job.posted_at) %> ago</span>
              </div>
            </div>
            <%= button_to job_saved_job_path(job), method: :delete, class: "flex-shrink-0 p-2 rounded-lg hover:bg-red-50 transition", title: "Unsave job" do %>
              <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-white">No saved jobs yet</h3>
      <p class="mt-1 text-sm text-gray-500">Click the bookmark icon on any job to save it here.</p>
      <%= link_to "Browse Jobs", jobs_path, class: "mt-4 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-orange-600 rounded-lg hover:bg-orange-700 transition" %>
    </div>
  <% end %>
</div>
