<% content_for :title, "On-demand team report" %>

<div class="max-w-3xl mx-auto px-4 py-6">
  <div class="flex items-center justify-between gap-3 mb-4">
    <div>
      <h1 class="text-lg font-semibold text-gray-100">Team report</h1>
      <p class="text-xs text-gray-500">Fresh copy generated just now<%= @report_snapshot_date ? " (data from #{@report_snapshot_date.strftime('%b %-d, %Y')})" : "" %>.</p>
    </div>
    <%= link_to "Back", nyk_analyst_path, class: "text-sm text-orange-400 hover:text-orange-300" %>
  </div>

  <%# Confirmation: the report was just emailed to the logged-in user (only). %>
  <% if @emailed_to %>
    <div class="bg-green-950/40 border border-green-800/60 rounded-xl p-4 mb-4">
      <p class="text-sm text-green-300">✓ A copy was emailed to you at <span class="font-medium"><%= @emailed_to %></span>.</p>
    </div>
  <% else %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
      <p class="text-sm text-gray-300"><%= link_to "Add an email to your profile", settings_path, class: "text-orange-400 hover:text-orange-300 underline" %> to also get a copy in your inbox.</p>
    </div>
  <% end %>

  <%# How it works: a short walkthrough a manager can read before using it. %>
  <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4" open>
    <summary class="text-sm font-medium text-gray-200 cursor-pointer">How it works (quick demo)</summary>
    <ol class="list-decimal ml-5 mt-3 space-y-1 text-sm text-gray-400">
      <li>Open the Analyst dashboard and tap <span class="text-gray-200 font-medium">Generate report</span> any time you need a fresh copy, like before a board meeting.</li>
      <li>We email the report straight to your own inbox, and show the full copy on this page.</li>
      <li>Tap <span class="text-gray-200 font-medium">Print or save as PDF</span> to take it into a meeting.</li>
    </ol>
    <video controls preload="metadata" playsinline
           class="mt-3 w-full max-w-xl rounded-lg border border-gray-800"
           aria-label="Walkthrough: generating and emailing the report">
      <source src="/demos/generate-report.webm" type="video/webm">
      Your browser can't play this walkthrough video.
    </video>
  </details>

  <%# Toolbar: print. %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
    <button type="button" onclick="window.print()"
            class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-800 text-gray-100 text-sm font-medium hover:bg-gray-700">
      Print or save as PDF
    </button>
  </div>

  <%# The report itself, isolated in an iframe so its email styles don't bleed
      into the app shell (and vice versa). %>
  <div class="bg-white rounded-xl overflow-hidden border border-gray-800">
    <iframe title="Team report preview" style="width:100%;height:1400px;border:0;background:#ffffff" srcdoc="<%= h(@report_html) %>"></iframe>
  </div>
</div>
