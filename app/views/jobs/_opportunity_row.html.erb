<% job = match.job; req = @apply_requests[job.id] %>
<div class="rounded-lg border border-gray-800 bg-gray-900 p-4 flex items-start justify-between gap-4">
  <div class="min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <%= link_to job.title, job_path(job), class: "text-base font-semibold text-white hover:text-orange-400 transition" %>
      <% if job.part_time_ish? %>
        <span class="text-[10px] font-bold uppercase tracking-wide text-green-400 border border-green-700 rounded-full px-2 py-0.5">Part-time / Contract</span>
      <% else %>
        <span class="text-[10px] font-bold uppercase tracking-wide text-gray-500 border border-gray-700 rounded-full px-2 py-0.5">Full-time</span>
      <% end %>
    </div>
    <div class="text-sm text-gray-400 mt-1">
      <%= job.company %><% if job.location.present? %> &middot; <%= job.location %><% end %><% if job.salary.present? %> &middot; <span class="text-green-400"><%= job.salary %></span><% end %>
    </div>
  </div>

  <div class="shrink-0 text-right">
    <% if req %>
      <div class="text-xs font-semibold <%= req.status == "applied" ? "text-green-400" : (req.status == "error" ? "text-red-400" : "text-amber-400") %>"><%= req.status_label %></div>
      <% if req.status.in?(%w[queued error skipped applied]) %>
        <%= button_to "Re-queue", enqueue_apply_job_path(job), method: :post, class: "mt-1 text-[11px] text-gray-500 hover:text-orange-400 transition", form: { class: "inline" } %>
      <% end %>
    <% else %>
      <%= button_to "Apply &rarr;".html_safe, enqueue_apply_job_path(job), method: :post,
            class: "inline-block px-4 py-2 text-sm font-semibold text-white bg-orange-600 rounded-lg hover:bg-orange-700 transition" %>
    <% end %>
    <div class="mt-1.5 flex items-center justify-end gap-3">
      <a href="<%= job.url %>" target="_blank" rel="noopener" class="text-[11px] text-gray-500 hover:text-orange-400 transition">Open posting &#8599;</a>
      <%= button_to "Remove", dismiss_job_path(job), method: :delete,
            class: "text-[11px] text-gray-600 hover:text-red-400 transition",
            form: { class: "inline" },
            data: { turbo_confirm: "Remove this role from Today's Opportunities?" } %>
    </div>
  </div>
</div>
