      <h2 class="text-lg font-bold text-white border-b border-gray-700 pb-2 mb-4">
        Smoke Tests
      </h2>
      <p class="text-gray-400 text-sm mb-4">
        Hourly round-trip through the
        <a href="https://nykitchen.com/calendar/" class="text-orange-400 hover:text-orange-300 underline" target="_blank" rel="noopener">NY Kitchen calendar</a>
        to make sure the same classes still show up when you flip through the months. If something looks off, admins get an email with a video of what happened.
      </p>
      <div data-controller="smoke-trigger"
           data-smoke-trigger-url-value="<%= nyk_trigger_smoke_path %>"
           class="mb-4 flex flex-wrap items-center gap-3">
        <button type="button"
                data-smoke-trigger-target="button"
                data-action="click->smoke-trigger#trigger"
                class="px-4 py-2 rounded-lg bg-orange-500 text-white text-sm font-semibold hover:bg-orange-400 transition">
          Run Smoke Test
        </button>
        <span data-smoke-trigger-target="status" class="text-sm"></span>
      </div>

      <% if @smoke_runs_total_count > 0 %>
        <%
          rate_color = ->(pct) {
            pct >= 20 ? "text-red-400" : pct >= 5 ? "text-amber-400" : "text-green-400"
          }
          current_status = @smoke_status
          window_label   = "last #{pluralize(@smoke_days, 'day')}"
        %>

        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="text-[10px] text-gray-500 font-semibold uppercase tracking-wider mr-1">Status</span>
          <% [["all","All"], ["passed","Passed"], ["failed","Failed"]].each do |val, label| %>
            <%
              active = current_status == val
              active_cls = case val
                           when "passed" then "bg-green-700 text-green-100"
                           when "failed" then "bg-red-800 text-red-100"
                           else               "bg-orange-500 text-white"
                           end
            %>
            <%= link_to label,
                  nyk_test_path(status: val),
                  class: "px-3 py-1 rounded-full text-xs font-semibold transition #{active ? active_cls : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}" %>
          <% end %>
        </div>

        <section class="mb-6"
                 data-controller="collapsible"
                 data-collapsible-mobile-collapsed-value="true">
          <button type="button"
                  data-action="click->collapsible#toggle"
                  class="w-full flex items-center justify-between gap-3 bg-gray-900 rounded-lg border border-gray-800 px-4 py-3 text-left hover:border-gray-700 transition sm:cursor-default">
            <div class="min-w-0">
              <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Failure rate</div>
              <div class="mt-0.5 text-sm">
                <span class="font-bold <%= rate_color.call(@smoke_failure_rate) %>"><%= @smoke_failure_rate %>%</span>
                <span class="text-gray-500">all-time</span>
                <span class="text-gray-700 mx-1">·</span>
                <span class="font-bold <%= rate_color.call(@smoke_failure_rate_window) %>"><%= @smoke_failure_rate_window %>%</span>
                <span class="text-gray-500"><%= window_label %></span>
              </div>
            </div>
            <svg data-collapsible-target="icon"
                 class="w-5 h-5 text-gray-500 transition-transform shrink-0 sm:hidden"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div data-collapsible-target="body" class="mt-3 space-y-3">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div class="bg-gray-900 rounded-lg border border-gray-800 px-4 py-3">
                <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Failure rate · all-time</div>
                <div class="mt-1 text-xl font-bold <%= rate_color.call(@smoke_failure_rate) %>"><%= @smoke_failure_rate %>%</div>
                <div class="text-xs text-gray-500"><%= @smoke_failed_count %> failed of <%= @smoke_runs_total_count %> runs</div>
              </div>
              <div class="bg-gray-900 rounded-lg border border-gray-800 px-4 py-3">
                <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Failure rate · <%= window_label %></div>
                <div class="mt-1 text-xl font-bold <%= rate_color.call(@smoke_failure_rate_window) %>"><%= @smoke_failure_rate_window %>%</div>
                <div class="text-xs text-gray-500"><%= @smoke_failed_count_window %> failed of <%= @smoke_runs_count_window %> runs</div>
              </div>
            </div>

            <%
              chart_h_px       = 80
              chart_padding_b  = 14
              bar_area_h       = chart_h_px - chart_padding_b
              max_failed       = [@smoke_chart.map { |d| d[:failed] }.max || 0, 1].max
              n                = @smoke_chart.size
              bar_total_w      = 100.0 / n
              bar_inner_pad    = 0.25
            %>
            <div class="bg-gray-900 rounded-lg border border-gray-800 px-4 py-3">
              <div class="flex items-baseline justify-between mb-2">
                <div class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Failures by day · <%= window_label %></div>
                <div class="text-[10px] text-gray-600">peak: <%= max_failed %></div>
              </div>
              <svg viewBox="0 0 100 <%= chart_h_px %>" preserveAspectRatio="none"
                   class="w-full h-20" role="img" aria-label="Daily failure counts">
                <% @smoke_chart.each_with_index do |day, i| %>
                  <%
                    bar_h    = day[:failed].zero? ? 0 : (day[:failed].to_f / max_failed * bar_area_h).round(2)
                    tick_h   = day[:total].zero? ? 0 : 1.5
                    x        = (i * bar_total_w).round(3)
                    w        = (bar_total_w - bar_inner_pad).round(3)
                    fill     = day[:failed].zero? ? "#374151" : "#dc2626"
                    tooltip  = if day[:total].zero?
                                 "#{day[:date].strftime('%a %b %-d')}: no runs"
                               else
                                 "#{day[:date].strftime('%a %b %-d')}: #{day[:failed]} failed of #{day[:total]} runs"
                               end
                    bar_y    = bar_area_h - bar_h
                    tick_y   = bar_area_h - tick_h
                  %>
                  <rect x="<%= x %>" y="<%= day[:failed].zero? ? tick_y : bar_y %>"
                        width="<%= w %>"
                        height="<%= day[:failed].zero? ? tick_h : bar_h %>"
                        fill="<%= fill %>">
                    <title><%= tooltip %></title>
                  </rect>
                <% end %>
                <line x1="0" y1="<%= bar_area_h %>" x2="100" y2="<%= bar_area_h %>"
                      stroke="#1f2937" stroke-width="0.3" />
              </svg>
              <div class="flex justify-between text-[10px] text-gray-600 mt-1 font-mono">
                <span><%= @smoke_chart.first[:date].strftime("%b %-d") %></span>
                <span>today</span>
              </div>
            </div>
          </div>
        </section>
      <% end %>

      <% if @can_see_pricing %>
        <p class="text-sm text-gray-500 mb-6">
          Total cost: <span class="text-white font-semibold">$<%= "%.2f" % @smoke_runs_total_cost %></span>
          (<%= @smoke_runs_total_count %> runs &middot; <%= @smoke_runs_total_minutes %> min &middot; $0.00044/min)
        </p>
      <% end %>

      <% if @smoke_runs.empty? %>
        <div class="bg-gray-900 rounded-xl p-8 text-center">
          <% if @smoke_runs_total_count.zero? %>
            <p class="text-gray-400">No test runs yet.</p>
            <p class="text-gray-500 text-xs mt-1">First scheduled run is tomorrow at 9 AM EDT.</p>
          <% else %>
            <p class="text-gray-400">No runs match this filter.</p>
            <p class="text-gray-500 text-xs mt-1">Try widening the range or switching status to All.</p>
          <% end %>
        </div>
      <% else %>
        <div class="overflow-x-auto rounded-lg border border-gray-800" data-controller="video-modal console-modal">
          <table class="min-w-full divide-y divide-gray-800">
            <thead class="bg-gray-900">
              <% admin = @admin %>
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">When</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Status</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Duration</th>
                <th class="hidden sm:table-cell px-4 py-2 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Notes</th>
                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-400 uppercase tracking-wider sm:px-4">Video</th>
                <% if @can_see_pricing %>
                  <th class="hidden sm:table-cell px-4 py-2 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Cost</th>
                <% end %>
                <% if admin %>
                  <th class="px-4 py-2 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">&nbsp;</th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-gray-950 divide-y divide-gray-800">
              <% @smoke_runs.each do |run| %>
                <tr id="<%= dom_id(run) %>">
                  <td class="px-3 py-3 text-sm text-gray-300 whitespace-nowrap sm:px-4">
                    <%= run.started_at.strftime("%b %-d") %>
                    <span class="block sm:inline text-gray-500"><%= run.started_at.strftime("%-I:%M %p") %></span>
                  </td>
                  <td class="px-3 py-3 whitespace-nowrap sm:px-4">
                    <% if run.passed? %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-900/50 text-green-400 text-xs font-semibold">
                        ✓ PASSED
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-900/50 text-red-400 text-xs font-semibold">
                        🚨 FAILED
                      </span>
                    <% end %>
                  </td>
                  <td class="px-3 py-3 text-sm text-gray-400 whitespace-nowrap sm:px-4">
                    <%= run.duration_label %>
                  </td>
                  <td class="hidden sm:table-cell px-4 py-3 text-sm text-gray-400">
                    <% if run.passed? %>
                      <%= run.summary.presence || "—" %>
                    <% else %>
                      <span class="text-red-400"><%= run.error_message.to_s.truncate(140) %></span>
                      <% if run.console_errors.present? %>
                        <button data-action="click->console-modal#open"
                                data-console-errors="<%= run.console_errors %>"
                                data-console-label="Console errors · <%= run.started_at.strftime("%b %-d %-I:%M %p") %>"
                                class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded bg-red-950/60 border border-red-800/60 text-red-300 hover:text-red-100 hover:bg-red-900/50 text-[10px] font-semibold uppercase tracking-wider transition">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                          </svg>
                          console
                        </button>
                      <% end %>
                      <% if @nyk_workspace&.manager?(Current.user) %>
                        <details class="mt-2">
                          <summary class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-orange-950/60 border border-orange-800/60 text-orange-300 hover:text-orange-100 hover:bg-orange-900/50 text-[10px] font-semibold uppercase tracking-wider transition cursor-pointer">
                            Send report
                          </summary>
                          <%= form_with url: nyk_send_smoke_report_path(run), method: :post, class: "mt-2 flex flex-col gap-2 max-w-sm" do %>
                            <%# 16px (text-base) so iOS doesn't zoom on focus. %>
                            <%= email_field_tag :email, nil, required: true, placeholder: "developer@example.com",
                                  class: "text-base px-2 py-1.5 rounded bg-gray-950 border border-gray-700 text-gray-100 placeholder-gray-600" %>
                            <%= text_field_tag :note, nil, placeholder: "Optional note",
                                  class: "text-base px-2 py-1.5 rounded bg-gray-950 border border-gray-700 text-gray-100 placeholder-gray-600" %>
                            <%= submit_tag "Email failure report",
                                  class: "px-3 py-1.5 rounded bg-orange-500 text-white text-xs font-semibold hover:bg-orange-400 cursor-pointer" %>
                          <% end %>
                        </details>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="px-3 py-3 text-center whitespace-nowrap sm:px-4">
                    <% if run.video.attached? && run.thumbnail.attached? %>
                      <img src="<%= url_for(run.thumbnail) %>"
                           class="rounded w-16 h-10 object-cover hover:opacity-80 transition border border-gray-700 cursor-pointer inline-block"
                           data-action="click->video-modal#open"
                           data-video-modal-src-param="<%= url_for(run.video) %>"
                           alt="Test recording">
                    <% elsif run.video.attached? %>
                      <button data-action="click->video-modal#open"
                              data-video-modal-src-param="<%= url_for(run.video) %>"
                              class="text-orange-400 text-xs hover:text-orange-300">▶</button>
                    <% else %>
                      <span class="text-gray-600 text-xs">—</span>
                    <% end %>
                  </td>
                  <% if @can_see_pricing %>
                    <td class="hidden sm:table-cell px-4 py-3 text-sm text-gray-500 text-right whitespace-nowrap">
                      $<%= "%.4f" % run.cost_dollars %>
                    </td>
                  <% end %>
                  <% if admin %>
                    <td class="px-4 py-3 text-right whitespace-nowrap">
                      <%= button_to admin_smoke_run_path(run),
                            method: :delete,
                            form: { class: "inline", data: { turbo_confirm: "Delete this test run?" } },
                            class: "text-gray-500 hover:text-red-400 transition p-1",
                            aria: { label: "Delete run" } do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
          <% if @smoke_runs_truncated %>
            <p class="px-4 py-2 text-[11px] text-gray-500 bg-gray-900 border-t border-gray-800">
              Showing the latest 500 runs. Narrow the range to see different windows.
            </p>
          <% end %>
          <dialog data-video-modal-target="dialog"
                  data-action="click->video-modal#backdropClose"
                  class="bg-transparent backdrop:bg-black/80 p-0 max-w-4xl w-[90vw] fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
            <div class="bg-gray-900 rounded-xl p-4">
              <div class="flex justify-between items-center mb-3">
                <h3 class="text-sm font-semibold text-gray-400">Smoke Test Recording</h3>
                <button data-action="click->video-modal#close"
                        class="text-gray-500 hover:text-white text-lg">&times;</button>
              </div>
              <video data-video-modal-target="video" controls class="rounded-lg w-full" preload="metadata">
              </video>
            </div>
          </dialog>

          <dialog data-console-modal-target="dialog"
                  data-action="click->console-modal#backdropClose"
                  class="bg-transparent backdrop:bg-black/80 p-0 max-w-3xl w-[90vw] fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
            <div class="bg-gray-950 rounded-xl border border-red-900/50 p-4">
              <div class="flex justify-between items-center mb-3">
                <h3 class="text-sm font-semibold text-red-300" data-console-modal-target="title">Browser console</h3>
                <button data-action="click->console-modal#close"
                        class="text-gray-500 hover:text-white text-lg">&times;</button>
              </div>
              <pre data-console-modal-target="body"
                   class="bg-black rounded-lg p-4 text-xs font-mono text-red-200 leading-relaxed overflow-auto max-h-[70vh] whitespace-pre-wrap break-words"></pre>
              <p class="mt-3 text-[10px] text-gray-500">Captured live from <code class="text-gray-400">page.on("console")</code> + <code class="text-gray-400">page.on("pageerror")</code> during this smoke run.</p>
            </div>
          </dialog>
        </div>
      <% end %>
