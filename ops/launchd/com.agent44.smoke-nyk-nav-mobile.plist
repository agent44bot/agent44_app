<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hourly NYK calendar nav regression check in a MOBILE viewport on the Mac
  mini runner. Same round-trip as the desktop nav check, but in a phone-sized
  Chromium context (most of Lora's customers view the calendar on a phone).

  - Fires every hour at :00, then sleeps a uniformly random 0-1799 seconds
    before triggering the workflow, so it spreads across the hour and does not
    collide with the desktop nav run (which has its own independent jitter).
  - Triggers smoke-nyk.yml with test=nav_mobile, which runs
    test/smoke/nyk_calendar_nav_test.rb with MOBILE=true. Results post under
    the name "nyk_calendar_nav_mobile" (still inside the nyk_nav scope, so it
    shows in the Test agent dashboard + freshness checks).
  - Test failures email botwhisperer@hey.com only (NYK_SMOKE_RECIPIENTS).
    Lora is never notified by this test.

  Install:
    cp ops/launchd/com.agent44.smoke-nyk-nav-mobile.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.agent44.smoke-nyk-nav-mobile.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agent44.smoke-nyk-nav-mobile</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>sleep $((RANDOM % 1800)); /opt/homebrew/bin/gh workflow run smoke-nyk.yml --ref main -R agent44bot/agent44_app -f test=nav_mobile</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/agent44</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>

    <!-- Fire every hour at :00. Command-level sleep adds 0-30 min jitter. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Minute</key><integer>0</integer></dict>
    </array>

    <key>StandardOutPath</key>
    <string>/tmp/smoke-nyk-nav-mobile.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/smoke-nyk-nav-mobile.err.log</string>
</dict>
</plist>
