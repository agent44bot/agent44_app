<% content_for :title, "Tweet draft" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-white mb-1">Tweet draft</h1>
  <p class="text-sm text-gray-400 mb-6">
    Review before it posts to <a class="text-orange-400" target="_blank" href="https://x.com/agent44bot">@agent44bot</a>.
  </p>

  <% if @log.x_post_id.present? && @log.x_deleted_at.blank? %>
    <div class="rounded-lg bg-green-950/40 border border-green-700 p-4 mb-6">
      <p class="text-sm text-green-300 mb-3">
        Posted —
        <a class="underline" target="_blank" href="https://x.com/agent44bot/status/<%= @log.x_post_id %>">view tweet</a>
        (<%= time_ago_in_words(@log.x_posted_at) %> ago).
      </p>
      <%= button_to "Delete tweet from X", "/nykitchen/x_drafts/#{@log.x_approval_token}/delete_tweet",
            method: :post,
            data: { turbo_confirm: "Delete this tweet from X? This can't be undone." },
            class: "px-3 py-1.5 rounded-md bg-red-600 hover:bg-red-500 text-white text-xs font-semibold transition cursor-pointer" %>
    </div>
  <% elsif @log.x_post_id.present? && @log.x_deleted_at.present? %>
    <div class="rounded-lg bg-gray-900 border border-gray-700 p-4 mb-6">
      <p class="text-sm text-gray-400">
        Posted, then deleted <%= time_ago_in_words(@log.x_deleted_at) %> ago.
      </p>
    </div>
  <% elsif @log.x_skipped_at.present? %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-4 mb-6">
      <p class="text-sm text-gray-400">Skipped <%= time_ago_in_words(@log.x_skipped_at) %> ago.</p>
    </div>
  <% end %>

  <div class="rounded-lg bg-gray-900 border border-gray-700 p-5 mb-4">
    <p class="text-xs text-gray-500 mb-2 font-mono">
      <%= @log.x_draft_text.to_s.length %> / <%= XClient::MAX_TWEET_LENGTH %> chars
    </p>
    <p class="text-base text-white whitespace-pre-wrap break-words"><%= @log.x_draft_text %></p>
  </div>

  <p class="text-xs text-gray-500 mb-6 break-all">
    Event: <a class="text-orange-400 underline" target="_blank" href="<%= @log.event_url %>"><%= @log.event_url %></a>
  </p>

  <% if @log.x_post_id.blank? && @log.x_skipped_at.blank? %>
    <% # Action row: show Post/Skip only when there's nothing posted yet. %>
    <div class="flex items-center gap-3">
      <%= button_to "Post to X", "/nykitchen/x_drafts/#{@log.x_approval_token}/post",
            method: :post,
            data: { turbo_confirm: "Post this to @agent44bot now?" },
            class: "px-4 py-2 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold transition cursor-pointer" %>
      <%= button_to "Skip", "/nykitchen/x_drafts/#{@log.x_approval_token}/skip",
            method: :post,
            class: "px-4 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm transition cursor-pointer" %>
    </div>
  <% end %>
</div>
