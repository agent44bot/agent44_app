<% content_for :title, "New workspace" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-white mb-1">New workspace</h1>
  <p class="text-sm text-gray-400 mb-6">A workspace owns one brand's social accounts and drafts.</p>

  <%= form_with model: @workspace, local: true, html: { multipart: true }, class: "space-y-4" do |f| %>
    <% if @workspace.errors.any? %>
      <div class="rounded-md border border-red-700 bg-red-950/40 text-red-200 px-4 py-3 text-sm">
        <ul class="list-disc pl-5">
          <% @workspace.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.text_field :name, required: true, autofocus: true, placeholder: "Magenta NYC",
          class: "w-full rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2 focus:border-orange-500 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.text_area :description, rows: 3,
          class: "w-full rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2 focus:border-orange-500 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :timezone, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.time_zone_select :timezone,
          ActiveSupport::TimeZone.us_zones,
          { default: (@workspace.timezone.presence || "Eastern Time (US & Canada)") },
          { class: "w-full rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-2 focus:border-orange-500 focus:outline-none" } %>
    </div>

    <div>
      <%= f.label :logo, "Brand logo", class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.file_field :logo, accept: "image/png,image/jpeg,image/webp",
          class: "text-sm text-gray-300 file:mr-2 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:bg-gray-700 file:text-white file:cursor-pointer" %>
      <p class="text-xs text-gray-500 mt-1">Optional. PNG, JPEG, or WebP, up to 2 MB. Shown on your workspace pages.</p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Create workspace", class: "inline-flex items-center px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
      <%= link_to "Cancel", workspaces_path, class: "text-sm text-gray-400 hover:text-gray-200" %>
    </div>
  <% end %>
</div>
