      <% @weeks.each_with_index do |week, week_index| %>
        <% next if week[:events].empty? %>
        <section id="week-<%= week_index %>"
                 data-kitchen-filter-target="section"
                 data-controller="collapsible"
                 data-collapsible-collapsed-value="true"
                 class="mb-8">
          <%
            total    = week[:events].size
            statuses = week[:events].map(&:availability_status)
            sold     = statuses.count { |s| s == "soldout" || s == "closed" }
            avail    = statuses.count { |s| s == "instock" || s == "limited" }

            # Capacity-weighted %: sum of tickets sold over sum of capacity,
            # across events where capacity is known. KitchenEvent#tickets_total
            # uses a three-tier fallback (live cap → snapshotted cap →
            # observed-high-water proxy). Falls back to the old class-count
            # ratio when no event in the week qualifies (rare).
            priced_events  = week[:events].select(&:capacity_known?)
            proxy_events   = priced_events.select(&:capacity_via_proxy?)
            tickets_total  = priced_events.sum(&:tickets_total)
            tickets_sold   = priced_events.sum(&:tickets_sold)
            denom          = sold + avail

            # Revenue (face value) for this week — same priced_events set.
            week_rev_sold  = priced_events.sum(&:revenue_sold)
            week_rev_total = priced_events.sum(&:revenue_total)
            week_rev_left  = week_rev_total - week_rev_sold

            # Revenue-based % so it reconciles with the dollar line below
            # ($sold ÷ $total). Falls back to seat-based, then class-count,
            # when no priced/capacity data exists for the week.
            sold_pct = if week_rev_total.positive?
              (week_rev_sold.to_f / week_rev_total * 100).round
            elsif tickets_total.positive?
              (tickets_sold.to_f / tickets_total * 100).round
            elsif denom.positive?
              (sold.to_f / denom * 100).round
            else
              0
            end

            pct_sold       = sold_pct
            pct_avail      = 100 - sold_pct
            sold_pct_color = sold_pct >= 60 ? "text-red-400"
                           : sold_pct >= 25 ? "text-amber-400"
                           :                   "text-gray-500"
            proxy_note     = proxy_events.any? ? " (#{proxy_events.size} use observed baseline as capacity proxy — biased low)" : ""
            sold_tooltip   = if week_rev_total.positive?
              "#{number_to_currency(week_rev_sold, precision: 0)} of #{number_to_currency(week_rev_total, precision: 0)} booked (face value) · #{tickets_sold} of #{tickets_total} seats#{proxy_note}"
            elsif priced_events.any?
              "#{tickets_sold} of #{tickets_total} tickets sold across #{priced_events.size} of #{total} classes#{proxy_note}"
            else
              "No capacity data — falling back to class-count ratio (#{sold} of #{denom} classes sold out)"
            end
          %>
          <% week_has_recipe = defined?(@handouts_by_url) && @handouts_by_url &&
                               week[:events].any? { |e| @handouts_by_url[e.url] } %>
          <div class="border-b border-gray-700 pb-2 mb-4">
            <div class="flex items-center justify-between gap-3">
              <button type="button" data-action="click->collapsible#toggle"
                      class="flex items-baseline gap-2 min-w-0 text-left hover:text-orange-400 transition">
                <span class="text-lg font-bold text-white truncate"><%= week[:label] %></span>
                <span class="text-gray-500 font-normal">(<%= total %>)</span>
              </button>
              <div class="flex items-center gap-3 shrink-0">
                <%# Grocery cart for this week, only when a class here has a recipe. %>
                <% if week_has_recipe %>
                  <%= link_to nyk_grocery_path(from: week[:start].iso8601, to: week[:end].iso8601),
                        title: "Grocery list for #{week[:label]}",
                        class: "flex items-center gap-1 text-gray-500 hover:text-orange-400 transition" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    <% if week[:grocery_total] %>
                      <span class="text-xs font-semibold" title="Estimated grocery total for this week">~$<%= number_with_delimiter(week[:grocery_total].round) %></span>
                    <% end %>
                  <% end %>
                <% end %>
                <button type="button" data-action="click->collapsible#toggle"
                        class="flex items-center gap-3 hover:text-orange-400 transition">
                  <span class="text-xs font-semibold <%= sold_pct_color %>" title="<%= sold_tooltip %>"><%= sold_pct %>% sold</span>
                  <svg data-collapsible-target="icon"
                       class="w-5 h-5 text-gray-500 transition-transform"
                       fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
              </div>
            </div>
            <button type="button" data-action="click->collapsible#toggle" class="block w-full text-left cursor-pointer">
              <div class="flex w-full h-1.5 rounded-full overflow-hidden mt-2 bg-gray-800">
                <% if sold > 0 %>
                  <div class="bg-red-500 h-full" style="width: <%= pct_sold %>%" title="<%= sold %> sold out / closed"></div>
                <% end %>
                <% if avail > 0 %>
                  <div class="bg-green-500 h-full" style="width: <%= pct_avail %>%" title="<%= avail %> available"></div>
                <% end %>
              </div>
              <% if @show_revenue && week_rev_total.positive? %>
                <div class="flex items-center gap-2 mt-1.5 text-xs text-gray-500">
                  <span><span class="text-green-400 font-semibold"><%= number_to_currency(week_rev_sold, precision: 0) %></span> sold</span>
                  <span class="text-gray-600">·</span>
                  <span><span class="text-amber-400 font-semibold"><%= number_to_currency(week_rev_left, precision: 0) %></span> left</span>
                  <span class="text-gray-600">·</span>
                  <span><%= number_to_currency(week_rev_total, precision: 0) %> total</span>
                </div>
              <% end %>
            </button>
          </div>
          <div data-collapsible-target="body" class="space-y-3">
            <% week[:events].each do |e| %>
              <%= render partial: "admin/kitchen/event_card", locals: { event: e, show_date: true } %>
            <% end %>
          </div>
        </section>
      <% end %>
