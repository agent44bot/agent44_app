<% mono = "ui-monospace,SFMono-Regular,Menlo,Consolas,monospace" %>
<% sans = "-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif" %>
<div style="font-family:<%= sans %>;max-width:640px;margin:0 auto;color:#1a1a1a">
  <p style="font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:#b91c1c;font-weight:bold;margin:0 0 4px">NY Kitchen test failure</p>
  <h1 style="font-size:20px;margin:0 0 2px;color:#111"><%= @run.name %></h1>
  <p style="font-size:13px;color:#666;margin:0 0 16px"><%= @when_str %> &middot; <%= @run.kind %> check &middot; ran <%= @run.duration_label %></p>

  <% if @from_name %>
    <p style="font-size:14px;color:#333;margin:0 0 12px">Shared by <strong><%= @from_name %></strong> at NY Kitchen.</p>
  <% end %>
  <% if @note %>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f7f7f5;border-left:3px solid #d97706;border-radius:0 6px 6px 0;margin:0 0 16px">
      <tr><td style="padding:12px 14px;font-size:14px;color:#333;line-height:1.5"><%= @note %></td></tr>
    </table>
  <% end %>

  <h2 style="font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:#888;margin:18px 0 6px">What failed</h2>
  <p style="font-size:14px;color:#b91c1c;line-height:1.5;margin:0 0 12px"><%= @run.error_message.presence || "No error message recorded." %></p>

  <% if @run.summary.present? %>
    <h2 style="font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:#888;margin:18px 0 6px">Steps / result</h2>
    <p style="font-size:14px;color:#333;line-height:1.5;margin:0 0 12px"><%= @run.summary %></p>
  <% end %>

  <% if @run.console_errors.present? %>
    <h2 style="font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:#888;margin:18px 0 6px">Console output</h2>
    <pre style="font-family:<%= mono %>;font-size:12px;background:#0f172a;color:#e2e8f0;padding:12px;border-radius:6px;overflow:auto;white-space:pre-wrap;margin:0 0 12px"><%= @run.console_errors %></pre>
  <% end %>

  <h2 style="font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:#888;margin:18px 0 6px">Artifacts</h2>
  <% if @video_url || @trace_url || @page_source_url %>
    <ul style="font-size:14px;color:#333;line-height:1.7;margin:0 0 8px;padding-left:18px">
      <% if @video_url %><li><a href="<%= @video_url %>" style="color:#c2410c">Screen recording of the run</a></li><% end %>
      <% if @trace_url %><li><a href="<%= @trace_url %>" style="color:#c2410c">Playwright trace (open at trace.playwright.dev)</a></li><% end %>
      <% if @page_source_url %><li><a href="<%= @page_source_url %>" style="color:#c2410c">Captured page HTML</a></li><% end %>
    </ul>
    <p style="font-size:11px;color:#999;margin:0 0 16px">Artifact links are signed and need no login. They expire after a while; ask for a fresh report if a link stops working.</p>
  <% else %>
    <p style="font-size:13px;color:#999;margin:0 0 16px">No video or trace was captured for this run.</p>
  <% end %>

  <p style="font-size:11px;color:#aaa;border-top:1px solid #eee;padding-top:12px;margin-top:20px">Sent from the NY Kitchen Test agent (Argus).</p>
</div>
