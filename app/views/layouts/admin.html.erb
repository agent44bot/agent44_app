<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} | Agent44 Admin" : "Agent44 Admin" %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="icon" href="/icon.png" type="image/png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full flex flex-col bg-gray-800 text-white antialiased">
  <%= render "shared/impersonation_banner" %>

  <!-- Admin Navigation: logo + one menu. All admin destinations live in the
       dropdown (zero-JS <details>, works in the iOS webview); the bar keeps
       only the bell, Home, Jobs, and account controls. -->
  <nav class="bg-gray-900 text-white sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-14">
        <div class="flex items-center gap-3">
          <%= link_to admin_dashboard_path, class: "flex items-center space-x-2 font-bold text-lg tracking-tight" do %>
            <span class="text-orange-400">Agent44</span>
          <% end %>

          <details class="relative group">
            <summary class="list-none cursor-pointer select-none flex items-center gap-1.5 text-xs font-medium bg-orange-600 hover:bg-orange-500 px-2.5 py-1 rounded text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              Admin
            </summary>
            <div class="absolute left-0 mt-2 w-64 rounded-xl bg-gray-900 border border-gray-700 shadow-2xl shadow-black/50 p-2 grid grid-cols-2 gap-x-1 text-sm z-50">
              <% nav_item = ->(label, path, match = nil) {
                   active = match ? request.path.start_with?(match) : request.path == path
                   link_to(label, path, class: "block px-3 py-1.5 rounded-md #{active ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition")
                 } %>
              <div>
                <p class="px-3 pt-1 pb-0.5 text-[10px] uppercase tracking-wide text-gray-600">Work</p>
                <%= nav_item.call("Plan", admin_plan_path) %>
                <%= nav_item.call("Dashboard", admin_dashboard_path) %>
                <%= nav_item.call("Track", admin_track_path, "/admin/track") %>
                <%= nav_item.call("Visitor Map", admin_visitors_map_path) %>
                <%= nav_item.call("AI Costs", admin_ai_costs_path) %>
                <%= nav_item.call("Finance", admin_finance_path, "/admin/finance") %>
                <p class="px-3 pt-2 pb-0.5 text-[10px] uppercase tracking-wide text-gray-600">Kitchen</p>
                <%= nav_item.call("Kitchen", nykitchen_path, "/nykitchen") %>
                <%= nav_item.call("Chat", admin_chat_path, "/admin/chat") %>
              </div>
              <div>
                <p class="px-3 pt-1 pb-0.5 text-[10px] uppercase tracking-wide text-gray-600">Content</p>
                <%= nav_item.call("Posts", admin_posts_path, "/admin/posts") %>
                <%= nav_item.call("Videos", admin_videos_path, "/admin/videos") %>
                <%= nav_item.call("Lab", "/lab") %>
                <p class="px-3 pt-2 pb-0.5 text-[10px] uppercase tracking-wide text-gray-600">Manage</p>
                <%= nav_item.call("Scrapers", admin_scrapers_path, "/admin/scrapers") %>
                <%= nav_item.call("Users", admin_users_path, "/admin/users") %>
                <%= nav_item.call("Agents", admin_agents_path, "/admin/agents") %>
                <%= nav_item.call("Notifications", admin_notifications_path, "/admin/notifications") %>
              </div>
            </div>
          </details>
        </div>

        <div class="flex items-center space-x-4">
          <% unread_notifications_count = Notification.unread.count %>
          <%= link_to admin_notifications_path,
                class: "relative text-gray-300 hover:text-orange-400 transition",
                title: "Notifications" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.4-1.4A2 2 0 0118 14.2V11a6 6 0 10-12 0v3.2a2 2 0 01-.6 1.4L4 17h5m6 0a3 3 0 11-6 0" />
            </svg>
            <% if unread_notifications_count > 0 %>
              <span class="absolute -top-1 -right-2 bg-red-600 text-white text-[10px] font-bold rounded-full min-w-[16px] h-4 px-1 flex items-center justify-center">
                <%= unread_notifications_count > 9 ? "9+" : unread_notifications_count %>
              </span>
            <% end %>
          <% end %>
          <%= link_to "Home", root_path, class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
          <%= link_to "Jobs", jobs_path, class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
          <span class="text-gray-400">|</span>
          <span class="text-sm text-gray-500"><%= Current.user.display_identifier %></span>
          <%= button_to "Sign Out", session_path, method: :delete,
                class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Flash messages -->
  <% if notice.present? %>
    <div data-controller="flash" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-green-50 border border-green-200 p-4">
        <p class="text-sm text-green-800"><%= notice %></p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div data-controller="flash" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-red-50 border border-red-200 p-4">
        <p class="text-sm text-red-800"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="flex-1">
    <%= yield %>
  </main>

</body>
</html>
