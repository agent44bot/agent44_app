<%# Print page: the branded recipe packet shown as the actual PDF (rendered by
    KitchenPacketPdf), full-height, with Print / Download / Edit. The PDF is
    the same artifact Lora downloads or prints, so what she sees is what prints. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NY Kitchen · <%= @packet.title %></title>
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: #525659; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; }
    .bar { display: flex; gap: 10px; align-items: center; padding: 10px 14px; background: #1f2937; }
    .bar .title { color: #fff; font-weight: 600; font-size: 14px; margin-right: auto; }
    .btn { font-size: 13px; padding: 7px 14px; border-radius: 6px; text-decoration: none; color: #e5e7eb; background: #374151; border: 0; cursor: pointer; }
    .btn-primary { background: #ea580c; color: #fff; }
    iframe { width: 100%; height: calc(100vh - 52px); border: 0; display: block; }
  </style>
</head>
<body>
  <div class="bar">
    <span class="title"><%= @packet.title %></span>
    <a class="btn" href="<%= edit_nyk_packet_path(@packet) %>">Edit</a>
    <a class="btn" href="<%= nyk_list_path %>">Sam's list</a>
    <a class="btn" href="<%= print_nyk_packet_path(@packet, format: :pdf, download: 1, v: @packet.updated_at.to_i) %>">Download</a>
    <button class="btn btn-primary" id="print-btn" type="button">🖨 Print</button>
  </div>
  <%# v=updated_at busts the browser PDF cache so a fresh save shows fresh pages. %>
  <iframe id="pdf" src="<%= print_nyk_packet_path(@packet, format: :pdf, v: @packet.updated_at.to_i) %>" title="<%= @packet.title %>"></iframe>

  <%= javascript_tag nonce: true do %>
    document.getElementById("print-btn")?.addEventListener("click", function () {
      var f = document.getElementById("pdf");
      try { f.contentWindow.focus(); f.contentWindow.print(); }
      catch (e) { window.open(f.src, "_blank"); }
    });
  <% end %>
</body>
</html>
