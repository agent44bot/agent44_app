<% content_for(:title, "Jobs") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Header -->
  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-white">Test Automation Jobs</h1>
      <p class="mt-2 text-gray-500">Curated positions from across the web, updated daily.</p>
    </div>
    <%= link_to globe_jobs_path, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-400 bg-gray-900 border border-gray-800 rounded-full hover:border-orange-300 hover:text-orange-600 transition shadow-sm" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/></svg>
      Globe
    <% end %>
  </div>

  <!-- Chart Tabs -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <%= link_to jobs_path(tab: "traditional", q: params[:q], sort: params[:sort]), class: "block rounded-xl border p-4 transition #{@tab == 'traditional' ? 'bg-gray-900 border-orange-500 shadow-lg shadow-orange-500/10' : 'bg-gray-900/50 border-gray-800 opacity-60 hover:opacity-80'}" do %>
      <h3 class="text-lg font-semibold text-white mb-1">Traditional</h3>
      <p class="text-sm text-gray-500 mb-4">Standard QA, SDET, and test engineer roles</p>
      <canvas id="autoChart" height="80"></canvas>
    <% end %>
    <%= link_to jobs_path(tab: "ai", q: params[:q], sort: params[:sort]), class: "block rounded-xl border p-4 transition #{@tab == 'ai' ? 'bg-gray-900 border-orange-500 shadow-lg shadow-orange-500/10' : 'bg-gray-900/50 border-gray-800 opacity-60 hover:opacity-80'}" do %>
      <h3 class="text-lg font-semibold text-white mb-1">AI-Augmented</h3>
      <p class="text-sm text-gray-500 mb-4">Roles mentioning AI, ML, or LLM</p>
      <canvas id="aiChart" height="80"></canvas>
    <% end %>
  </div>

  <% content_for(:head) do %>
    <%= javascript_include_tag "chart.umd.min", "data-turbo-track": "reload" %>
  <% end %>

  <script>
    (function() {
      function initCharts() {
        if (typeof Chart === "undefined") return;
        var autoCanvas = document.getElementById("autoChart");
        if (!autoCanvas || autoCanvas.dataset.rendered) return;
        autoCanvas.dataset.rendered = "true";

        const labels = <%= raw @trend_labels.map { |d| d.strftime("%-b %-d") }.to_json %>;

        function trendInfo(data) {
          const total = data.reduce((a, b) => a + b, 0);
          const mid = Math.floor(data.length / 2);
          const firstHalf = data.slice(0, mid).reduce((a, b) => a + b, 0);
          const secondHalf = data.slice(mid).reduce((a, b) => a + b, 0);
          const trending = secondHalf > firstHalf ? "up" : secondHalf < firstHalf ? "down" : "flat";
          const pct = firstHalf > 0 ? Math.round(Math.abs(secondHalf - firstHalf) / firstHalf * 100) : 0;
          return { total, trending, pct };
        }

        function buildChart(canvasId, data, accentColor, yMax) {
          const ctx = document.getElementById(canvasId);
          if (!ctx) return;
          const info = trendInfo(data);
          const color = info.trending === "up" ? "rgb(34,197,94)" : info.trending === "down" ? "rgb(239,68,68)" : accentColor;

          new Chart(ctx, {
            type: "line",
            data: {
              labels: labels,
              datasets: [{
                label: "Jobs posted",
                data: data,
                borderColor: color,
                backgroundColor: color.replace("rgb", "rgba").replace(")", ",0.1)"),
                fill: true, tension: 0.3, pointRadius: 2, pointHoverRadius: 5
              }]
            },
            options: {
              responsive: true,
              plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: function(item) { return item.raw + " jobs posted"; } } }
              },
              scales: {
                y: { beginAtZero: true, max: yMax, ticks: { precision: 0, color: '#9ca3af' }, grid: { color: '#1f2937' } },
                x: { ticks: { maxTicksLimit: 8, color: '#9ca3af' }, grid: { color: '#1f2937' } }
              }
            }
          });

          const arrow = info.trending === "up" ? "&#9650;" : info.trending === "down" ? "&#9660;" : "&#9654;";
          const cls = info.trending === "up" ? "text-green-600" : info.trending === "down" ? "text-red-500" : "text-gray-500";
          const word = info.trending === "up" ? "increase" : info.trending === "down" ? "decrease" : "no change";
          const el = document.createElement("div");
          el.className = "mt-3 flex items-center gap-2 text-sm";
          el.innerHTML = `<span class="font-semibold ${cls}">${arrow} ${info.pct}% ${word}</span><span class="text-gray-400">vs prev 15 days (${info.total} total)</span>`;
          ctx.parentNode.appendChild(el);
        }

        const autoData = <%= raw @trend_data_auto.to_json %>;
        const aiData = <%= raw @trend_data_ai.to_json %>;
        const sharedMax = Math.max(...autoData, ...aiData);

        buildChart("autoChart", autoData, "rgb(249,115,22)", sharedMax);
        buildChart("aiChart", aiData, "rgb(245,158,11)", sharedMax);
      }

      document.addEventListener("turbo:load", initCharts);
      document.addEventListener("DOMContentLoaded", initCharts);
      initCharts();
    })();
  </script>

  <!-- Search -->
  <div class="mb-6">
    <%= form_with url: jobs_path, method: :get, class: "flex gap-3", data: { turbo_frame: "jobs_list" } do |f| %>
      <%= hidden_field_tag :tab, params[:tab] %>
      <div class="flex-1 relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" id="search-input" value="<%= params[:q] %>" placeholder="Search by title, company, or keyword..."
               class="w-full pl-10 pr-10 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
               oninput="document.getElementById('search-clear').style.display = this.value ? 'block' : 'none'">
        <a href="<%= jobs_path(tab: params[:tab], category: params[:category], source: params[:source]) %>"
           id="search-clear"
           class="text-gray-400 hover:text-gray-400 transition"
           style="position:absolute; right:12px; top:50%; transform:translateY(-50%); z-index:10; <%= params[:q].present? ? '' : 'display:none;' %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </a>
      </div>
      <button type="submit" class="px-5 py-2.5 bg-orange-600 text-white text-sm font-medium rounded-lg hover:bg-orange-700 transition">
        Search
      </button>
    <% end %>
  </div>

  <!-- Sort & Saved Filter -->
  <div class="flex items-center gap-4 mb-6">
    <div class="flex items-center gap-2">
      <span class="text-sm text-gray-500">Sort by:</span>
      <% sort_options = [["Newest", nil], ["Salary: High to Low", "salary_desc"], ["Salary: Low to High", "salary_asc"]] %>
      <% sort_options.each do |label, value| %>
        <% active = params[:sort] == value || (value.nil? && params[:sort].blank?) %>
        <%= link_to jobs_path(tab: params[:tab], sort: value, category: params[:category], q: params[:q], source: params[:source], saved: params[:saved], show_hidden: params[:show_hidden]),
              class: "px-3 py-1.5 text-xs font-medium rounded-full transition #{active ? 'bg-orange-600 text-white shadow-sm' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}",
              data: { turbo_frame: "jobs_list" } do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
    <% if authenticated? %>
      <div class="flex items-center gap-2 ml-auto">
        <% saved_active = params[:saved] == "1" %>
        <%= link_to jobs_path(tab: params[:tab], saved: saved_active ? nil : "1", sort: params[:sort], category: params[:category], q: params[:q], source: params[:source], show_hidden: params[:show_hidden]),
              class: "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full transition #{saved_active ? 'bg-red-500 text-white shadow-sm' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}",
              data: { turbo_frame: "jobs_list" } do %>
          <svg class="w-3.5 h-3.5" fill="<%= saved_active ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
          Saved (<%= @saved_job_ids.size %>)
        <% end %>
        <% hidden_active = params[:show_hidden] == "1" %>
        <%= link_to jobs_path(tab: params[:tab], show_hidden: hidden_active ? nil : "1", sort: params[:sort], category: params[:category], q: params[:q], source: params[:source], saved: params[:saved]),
              class: "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full transition #{hidden_active ? 'bg-yellow-500 text-white shadow-sm' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}",
              data: { turbo_frame: "jobs_list" } do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M3 3l18 18"/></svg>
          Hidden (<%= @hidden_job_ids.size %>)
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Category Tabs (Collapsible, open by default) -->
  <details open class="mb-8 bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
    <summary class="flex items-center gap-2 px-4 py-3 cursor-pointer select-none hover:bg-gray-800 transition">
      <svg class="w-4 h-4 text-gray-400 transition-transform details-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Category</span>
      <% if params[:category].present? %>
        <span class="ml-1 px-2 py-0.5 text-xs font-medium rounded-full bg-orange-900/50 text-orange-400"><%= params[:category].titleize %></span>
      <% end %>
    </summary>
    <div class="flex flex-wrap gap-2 px-4 pb-4 pt-2">
      <%
        categories = [
          ["All", nil],
          ["New Today", "new_today"],
          ["Remote", "remote"],
          ["Full-Time", "full_time"],
          ["Part-Time", "part_time"],
          ["Contract", "contract"]
        ]
      %>
      <% categories.each do |label, value| %>
        <% active = params[:category] == value || (value.nil? && params[:category].blank?) %>
        <% count = case value
           when nil then @total_count
           when "new_today" then @new_today_count
           when "remote" then @remote_count
           else @category_counts[value] || 0
           end %>
        <%= link_to jobs_path(tab: params[:tab], category: value, q: params[:q], source: params[:source], sort: params[:sort], saved: params[:saved], show_hidden: params[:show_hidden]),
              class: "px-4 py-2 text-sm font-medium rounded-full transition #{active ? 'bg-orange-600 text-white shadow-sm' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}",
              data: { turbo_frame: "jobs_list" } do %>
          <%= label %> <span class="<%= active ? 'text-orange-200' : 'text-gray-400' %>">(<%= count %>)</span>
        <% end %>
      <% end %>
    </div>
  </details>

  <!-- Source / Job Board Tabs (Collapsible) -->
  <% if @source_counts.any? %>
    <details class="mb-8 bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
      <summary class="flex items-center gap-2 px-4 py-3 cursor-pointer select-none hover:bg-gray-800 transition">
        <svg class="w-4 h-4 text-gray-400 transition-transform details-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Job Board</span>
        <span class="text-xs text-gray-400">(<%= @source_counts.size %> sources)</span>
        <% if params[:source].present? %>
          <span class="ml-1 px-2 py-0.5 text-xs font-medium rounded-full bg-orange-900/50 text-orange-400"><%= params[:source].titleize %></span>
        <% end %>
      </summary>
      <div class="flex flex-wrap gap-2 px-4 pb-4 pt-2">
        <% # Source labels now in ApplicationHelper %>
        <% active_source = params[:source] %>
        <% source_active = active_source.blank? %>
        <%= link_to jobs_path(tab: params[:tab], category: params[:category], q: params[:q], sort: params[:sort], saved: params[:saved], show_hidden: params[:show_hidden]),
              class: "px-3 py-1.5 text-xs font-medium rounded-full transition #{source_active ? 'bg-orange-600 text-white shadow-sm' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}",
              data: { turbo_frame: "jobs_list" } do %>
          All <span class="<%= source_active ? 'text-orange-200' : 'text-gray-400' %>">(<%= @source_counts.values.sum %>)</span>
        <% end %>
        <% @source_counts.sort_by { |_, c| -c }.each do |src, count| %>
          <% next if src.blank? %>
          <% active = active_source == src %>
          <%= link_to jobs_path(tab: params[:tab], category: params[:category], q: params[:q], source: src, sort: params[:sort], saved: params[:saved], show_hidden: params[:show_hidden]),
                class: "px-3 py-1.5 text-xs font-medium rounded-full transition #{active ? 'bg-orange-600 text-white shadow-sm' : 'bg-gray-800 text-gray-400 hover:bg-gray-700'}",
                data: { turbo_frame: "jobs_list" } do %>
            <%= source_label(src) %> <span class="<%= active ? 'text-orange-200' : 'text-gray-400' %>">(<%= count %>)</span>
          <% end %>
        <% end %>
      </div>
    </details>
    <style>
      details[open] .details-chevron { transform: rotate(90deg); }
      details summary::-webkit-details-marker { display: none; }
      details summary { list-style: none; }
    </style>
  <% end %>

  <style>
    .job-tooltip { pointer-events: none; }
  </style>
  <script>
    function showJobTooltip(el) {
      const tooltip = el.querySelector('.job-tooltip');
      if (tooltip) tooltip.classList.remove('hidden');
    }
    function hideJobTooltip(el) {
      const tooltip = el.querySelector('.job-tooltip');
      if (tooltip) tooltip.classList.add('hidden');
    }
  </script>

  <!-- Job List -->
  <%= turbo_frame_tag "jobs_list" do %>
    <% if @jobs.present? %>
      <div class="space-y-4">
        <% @jobs.each do |job| %>
          <% hidden = @hidden_job_ids.include?(job.id) %>
          <div id="<%= dom_id(job) %>" class="<%= hidden ? 'bg-gray-900 rounded-xl border border-gray-700 p-6 opacity-60 transition group' : job.posted_today? ? 'bg-green-950/30 rounded-xl border border-green-800 p-6 hover:shadow-md hover:border-green-600 transition group' : 'bg-gray-900 rounded-xl border border-gray-800 p-6 hover:shadow-md hover:border-orange-500/30 transition group' %>">
            <div class="flex items-start gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-1 relative">
                  <h2 class="text-lg font-semibold text-white group-hover:text-orange-600 transition truncate"
                      onmouseenter="showJobTooltip(this.parentElement)" onmouseleave="hideJobTooltip(this.parentElement)">
                    <% if job.bitcoin_job? %>
                      <svg class="inline-block w-5 h-5 align-middle mr-1 text-orange-500" viewBox="0 0 24 24" fill="currentColor" title="Bitcoin job"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm1.5 14.9V18h-1v-1.1c-1.3-.1-2.5-.6-3.1-1.2l.8-1.4c.6.5 1.5.9 2.3.9.9 0 1.4-.4 1.4-1s-.5-.9-1.7-1.3c-1.6-.5-2.8-1.1-2.8-2.6 0-1.3.9-2.2 2.3-2.5V7h1v1.1c1 .1 1.9.4 2.5.9l-.7 1.4c-.5-.4-1.2-.7-2-.7-.8 0-1.2.4-1.2.9 0 .6.5.8 1.8 1.3 1.7.5 2.7 1.2 2.7 2.6 0 1.3-1 2.3-2.3 2.4z"/></svg>
                    <% end %>
                    <%= link_to job.title, job_path(job), data: { turbo_frame: "_top" } %>
                  </h2>
                  <% if job.description.present? %>
                    <div class="job-tooltip hidden absolute left-0 top-full mt-2 z-50 w-[32rem] max-h-96 overflow-y-auto bg-gray-900 border border-gray-800 rounded-lg shadow-xl p-4 text-sm text-gray-300 font-normal whitespace-normal">
                      <%= simple_format(job.description) %>
                    </div>
                  <% end %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-900/50 text-orange-400 whitespace-nowrap">
                    <%= job.category&.titleize || "General" %>
                  </span>
                  <% if job.posted_today? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-900/50 text-green-400 whitespace-nowrap">
                      New
                    </span>
                  <% end %>
                  <% if @saved_job_ids.include?(job.id) %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-900/50 text-red-400 whitespace-nowrap">
                      Saved
                    </span>
                  <% end %>
                  <% if @applied_jobs[job.id] %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-900/50 text-green-400 whitespace-nowrap">
                      Applied <%= @applied_jobs[job.id].in_time_zone("Eastern Time (US & Canada)").strftime("%-m/%-d") %>
                    </span>
                  <% end %>
                </div>
                <p class="text-sm text-gray-400"><%= job.company %></p>
                <div class="mt-2 flex flex-wrap items-center gap-4 text-xs text-gray-400">
                  <% if job.location.present? %>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      <%= job.location %>
                    </span>
                  <% end %>
                  <% if job.salary.present? %>
                    <span class="text-green-600 font-medium"><%= job.salary %></span>
                  <% end %>
                  <% if job.url.present? %>
                    <%= link_to job.url, target: "_blank", rel: "noopener noreferrer", class: "flex items-center gap-1 text-orange-500 hover:text-orange-700 transition" do %>
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                      See listing
                    <% end %>
                  <% end %>
                  <% if job.job_sources.any? %>
                    <span class="flex items-center gap-1 flex-wrap">
                      <% job.job_sources.each_with_index do |js, i| %>
                        <%= link_to jobs_path(tab: params[:tab], source: js.source),
                              class: "hover:text-orange-600 transition",
                              data: { turbo_frame: "_top" } do %>
                          <%= source_label(js.source) %><% if i < job.job_sources.size - 1 %><span class="text-gray-300">&middot;</span><% end %>
                        <% end %>
                      <% end %>
                    </span>
                  <% elsif job.source.present? %>
                    <%= link_to jobs_path(tab: params[:tab], source: job.source),
                          class: "hover:text-orange-600 transition",
                          data: { turbo_frame: "_top" } do %>
                      via <%= source_label(job.source) %>
                    <% end %>
                  <% end %>
                  <span><%= days_ago_in_words(job.created_at) %></span>
                  <span>Added <%= job.created_at.strftime("%-m/%-d/%Y %-I:%M%P") %></span>
                </div>
              </div>
              <% if authenticated? %>
                <div class="flex flex-col gap-1">
                  <% saved = @saved_job_ids.include?(job.id) %>
                  <% if saved %>
                    <%= button_to job_saved_job_path(job), method: :delete, class: "flex-shrink-0 p-2 rounded-lg hover:bg-red-50 transition", title: "Unsave job", data: { turbo_frame: "_top" } do %>
                      <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
                    <% end %>
                  <% else %>
                    <%= button_to job_saved_job_path(job), method: :post, class: "flex-shrink-0 p-2 rounded-lg hover:bg-orange-900/30 transition", title: "Save job", data: { turbo_frame: "_top" } do %>
                      <svg class="w-5 h-5 text-gray-300 hover:text-orange-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
                    <% end %>
                  <% end %>
                  <% if hidden %>
                    <%= button_to job_hidden_job_path(job), method: :delete, class: "flex-shrink-0 px-3 py-1.5 text-xs font-medium text-yellow-400 bg-yellow-900/50 rounded-lg hover:bg-yellow-900/70 transition", title: "Unhide job", data: { turbo_frame: "_top" } do %>
                      Unhide
                    <% end %>
                  <% else %>
                    <%= button_to job_hidden_job_path(job), method: :post, class: "flex-shrink-0 p-2 rounded-lg hover:bg-gray-800 transition", title: "Hide job", data: { turbo_frame: "_top" } do %>
                      <svg class="w-4 h-4 text-gray-300 hover:text-gray-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @jobs.respond_to?(:total_pages) && @jobs.total_pages > 1 %>
        <div class="mt-8 flex justify-center">
          <%== pagy_nav(@pagy) if defined?(@pagy) %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-16">
        <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-white">No jobs found</h3>
        <p class="mt-1 text-sm text-gray-500">Try adjusting your search or filters.</p>
      </div>
    <% end %>
  <% end %>
</div>
