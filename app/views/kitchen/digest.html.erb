<% content_for(:title, "NY Kitchen — Tickets Sold") %>

<%
  digest = @digest
  weeks = digest.entries_by_week
  fired_at = digest.created_at.in_time_zone("America/New_York")
%>

<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Header -->
  <div class="mb-6">
    <%= link_to nykitchen_path, class: "inline-flex items-center gap-1 text-xs text-gray-500 hover:text-orange-400 transition mb-3" do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <span>NY Kitchen</span>
    <% end %>
    <h1 class="text-3xl font-black text-white tracking-tight">Tickets sold</h1>
    <p class="text-gray-400 mt-1 text-sm">
      <%= fired_at.strftime("%a %b %-d · %-I:%M %p") %> ET
    </p>
  </div>

  <!-- Stat tiles -->
  <div class="grid grid-cols-3 gap-3 mb-8">
    <div class="bg-gray-900 rounded-xl p-4">
      <div class="text-2xl font-black text-orange-400"><%= digest.total_tickets %></div>
      <div class="text-[11px] uppercase tracking-wider text-gray-500 mt-1">tickets bought</div>
    </div>
    <div class="bg-gray-900 rounded-xl p-4">
      <div class="text-2xl font-black text-white"><%= digest.change_count %></div>
      <div class="text-[11px] uppercase tracking-wider text-gray-500 mt-1">classes</div>
    </div>
    <div class="bg-gray-900 rounded-xl p-4">
      <div class="text-2xl font-black <%= digest.sold_out_count > 0 ? 'text-red-400' : 'text-gray-600' %>">
        <%= digest.sold_out_count %>
      </div>
      <div class="text-[11px] uppercase tracking-wider text-gray-500 mt-1">sold out</div>
    </div>
  </div>

  <!-- Per-week change list -->
  <% weeks.each do |(week_index, week_label), entries| %>
    <section class="mb-8">
      <h2 class="text-lg font-bold text-white border-b border-gray-700 pb-2 mb-4">
        <%= week_label.presence || "Week #{week_index}" %>
        <span class="text-gray-500 font-normal text-sm">(<%= entries.size %>)</span>
      </h2>
      <div class="space-y-3">
        <% entries.each do |c| %>
          <%
            old_spots = c["old_spots"].to_i
            new_spots = c["new_spots"].to_i
            tickets   = c["tickets_bought"].to_i
            sold_out  = !!c["sold_out"]
            start_at  = c["start_at"].present? ? Time.parse(c["start_at"]) : nil
          %>
          <a href="<%= c["url"] %>" target="_blank" rel="noopener"
             class="block bg-gray-900 rounded-xl p-4 hover:bg-gray-800 transition">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="text-base font-semibold text-orange-400 leading-tight truncate">
                  <%= c["name"] %>
                </div>
                <div class="text-xs text-gray-400 mt-1">
                  <% if start_at %>
                    <%= start_at.strftime("%a %b %-d · %-I:%M %p") %>
                  <% end %>
                  <% if c["instructor"].present? %>
                    <span class="text-gray-600">·</span> <%= c["instructor"] %>
                  <% end %>
                  <% if @can_see_pricing && c["price"].present? %>
                    <span class="text-gray-600">·</span> $<%= c["price"] %>
                  <% end %>
                </div>
              </div>
              <% if sold_out %>
                <span class="inline-block px-2 py-0.5 rounded-full bg-red-900/50 text-red-400 text-[10px] font-semibold whitespace-nowrap">
                  SOLD OUT
                </span>
              <% end %>
            </div>
            <div class="flex items-center gap-3 mt-3 text-sm">
              <span class="text-gray-300 font-mono">
                <%= old_spots %> <span class="text-gray-600">→</span>
                <span class="<%= sold_out ? 'text-red-400' : 'text-white' %>"><%= new_spots %></span>
              </span>
              <span class="text-gray-500 text-xs">spots</span>
              <span class="ml-auto inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-orange-500/15 text-orange-300 text-xs font-semibold">
                +<%= tickets %> sold
              </span>
            </div>
          </a>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if weeks.empty? %>
    <div class="bg-gray-900 rounded-xl p-8 text-center text-gray-400">
      No changes recorded for this digest.
    </div>
  <% end %>

</div>
