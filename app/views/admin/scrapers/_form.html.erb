<%= form_with model: [:admin, @scraper], class: "space-y-6" do |f| %>
  <% if @scraper.errors.any? %>
    <div class="rounded-lg bg-red-900/30 border border-red-800 p-4">
      <h3 class="text-sm font-medium text-red-400"><%= pluralize(@scraper.errors.count, "error") %> prevented this scraper from being saved:</h3>
      <ul class="mt-2 list-disc list-inside text-sm text-red-300">
        <% @scraper.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="scraper_source_name" class="block text-sm font-medium text-gray-300 mb-1">Name</label>
      <%= f.text_field :name, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition", placeholder: "e.g. RemoteOK" %>
    </div>

    <div>
      <label for="scraper_source_slug" class="block text-sm font-medium text-gray-300 mb-1">Slug</label>
      <%= f.text_field :slug, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono", placeholder: "e.g. remoteok (must match scraper class name)" %>
      <p class="mt-1 text-xs text-gray-600">Lowercase letters, numbers, underscores only. Must match a Scrapers:: class.</p>
    </div>
  </div>

  <div>
    <label for="scraper_source_source_url" class="block text-sm font-medium text-gray-300 mb-1">Source URL</label>
    <%= f.text_field :source_url, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono", placeholder: "https://api.example.com/jobs" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="scraper_source_api_key_name" class="block text-sm font-medium text-gray-300 mb-1">API Key (ENV variable name)</label>
      <%= f.text_field :api_key_name, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono", placeholder: "e.g. RAPIDAPI_KEY" %>
      <p class="mt-1 text-xs text-gray-600">Leave blank if no API key is needed. Only stores the ENV variable name, not the key itself.</p>
    </div>

    <div>
      <label for="scraper_source_schedule" class="block text-sm font-medium text-gray-300 mb-1">Schedule</label>
      <%= f.select :schedule, ScraperSource::SCHEDULES.map { |s| [ScraperSource.new(schedule: s).schedule_label, s] },
            {}, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" %>
    </div>
  </div>

  <div>
    <label for="scraper_source_search_terms_text" class="block text-sm font-medium text-gray-300 mb-1">Search Terms</label>
    <%= f.text_area :search_terms_text,
          value: (@scraper.search_terms || []).join("\n"),
          rows: 5,
          class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono",
          placeholder: "One search term per line\nsdet\ntest automation\nqa engineer" %>
    <p class="mt-1 text-xs text-gray-600">One per line. Leave blank to use defaults.</p>
  </div>

  <div>
    <label for="scraper_source_config_text" class="block text-sm font-medium text-gray-300 mb-1">Extra Config (JSON)</label>
    <%= f.text_area :config_text,
          value: @scraper.config.present? && @scraper.config != {} ? JSON.pretty_generate(@scraper.config) : "",
          rows: 4,
          class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono",
          placeholder: '{"max_pages": 3}' %>
    <p class="mt-1 text-xs text-gray-600">Optional JSON for source-specific settings.</p>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :enabled, class: "h-4 w-4 text-orange-600 border-gray-700 rounded focus:ring-orange-500 bg-gray-800" %>
    <label for="scraper_source_enabled" class="text-sm font-medium text-gray-300">Enabled</label>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-800">
    <%= f.submit class: "px-6 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", admin_scrapers_path, class: "px-4 py-2.5 text-sm font-medium text-gray-300 hover:text-orange-400 transition" %>
  </div>
<% end %>
