<%= form_with model: [:admin, @video], class: "space-y-6" do |f| %>
  <% if @video.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <h3 class="text-sm font-medium text-red-800"><%= pluralize(@video.errors.count, "error") %> prevented this video from being saved:</h3>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% @video.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label for="video_title" class="block text-sm font-medium text-gray-300 mb-1">Title</label>
    <%= f.text_field :title, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition", placeholder: "Video title" %>
  </div>

  <div>
    <label for="video_youtube_id" class="block text-sm font-medium text-gray-300 mb-1">YouTube ID</label>
    <%= f.text_field :youtube_id, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono", placeholder: "e.g. dQw4w9WgXcQ" %>
    <p class="mt-1 text-xs text-gray-400">The ID from the YouTube URL (after v=)</p>
  </div>

  <div>
    <label for="video_description" class="block text-sm font-medium text-gray-300 mb-1">Description</label>
    <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition", placeholder: "Brief description of the video" %>
  </div>

  <div class="flex items-center gap-6">
    <div>
      <label for="video_position" class="block text-sm font-medium text-gray-300 mb-1">Position</label>
      <%= f.number_field :position, class: "w-24 px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition", min: 0 %>
    </div>

    <div class="flex items-center gap-2 pt-6">
      <%= f.check_box :published, class: "h-4 w-4 text-orange-600 border-gray-700 rounded focus:ring-orange-500" %>
      <label for="video_published" class="text-sm font-medium text-gray-300">Published</label>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-800">
    <%= f.submit class: "px-6 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", admin_videos_path, class: "px-4 py-2.5 text-sm font-medium text-gray-300 hover:text-orange-400 transition" %>
  </div>
<% end %>
