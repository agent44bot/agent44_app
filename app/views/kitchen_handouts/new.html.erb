<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">
  <div class="flex justify-end mb-3"><%= back_button "← Back to Sam's list", nyk_list_path %></div>
  <h1 class="text-2xl font-bold text-white mb-1">Add a recipe handout</h1>
  <% if @event_name.present? %>
    <p class="text-sm text-gray-400 mb-6">For <span class="text-orange-400 font-medium"><%= @event_name %></span></p>
  <% end %>


  <% if @event_name.present? %>
    <div class="bg-purple-900/20 border border-purple-800/50 rounded-xl p-4 mb-6">
      <p class="text-sm text-purple-200 mb-3">No recipe to upload yet? Generate a draft from the class description with AI, then review and edit it.</p>
      <%= button_to "✨ Generate recipe with AI", nyk_handouts_path,
            params: { generate: 1, event_url: @event_url, event_name: @event_name },
            form: { data: { controller: "form-spinner", action: "submit->form-spinner#show",
                            "form-spinner-message-value": "Generating your recipe…" } },
            class: "px-4 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-semibold cursor-pointer" %>
      <p class="text-xs text-purple-300/70 mt-2">Uses the Opus model by default (set per feature on the billing page). It's a starting draft, so double-check amounts and steps.</p>
    </div>
    <div class="my-4 text-center text-xs text-gray-600">or upload the real recipe</div>
  <% end %>

  <%= form_with url: nyk_handouts_path, method: :post, multipart: true,
        data: { controller: "form-spinner", action: "submit->form-spinner#show",
                "form-spinner-message-value": "Building your recipe…" } do |f| %>
    <%= hidden_field_tag :event_url, @event_url %>
    <%= hidden_field_tag :event_name, @event_name %>

    <label class="block text-sm font-semibold text-gray-300 mb-2">Upload a recipe PDF</label>
    <div data-controller="dropzone" data-dropzone-accept-value="application/pdf"
         data-action="click->dropzone#browse dragover->dropzone#over dragleave->dropzone#leave drop->dropzone#drop"
         class="dropzone flex flex-col items-center justify-center text-center gap-1 rounded-xl border-2 border-dashed border-gray-700 bg-gray-900/60 px-4 py-8 cursor-pointer hover:border-orange-500 transition">
      <%= file_field_tag :pdf, accept: "application/pdf", class: "hidden",
            data: { dropzone_target: "input", action: "change->dropzone#changed" } %>
      <span class="text-2xl">📄</span>
      <span class="text-sm text-gray-300"><span class="text-orange-400 font-medium">Choose a PDF</span> or drag it here</span>
      <span class="text-xs text-gray-500" data-dropzone-target="name">No file chosen</span>
    </div>
    <p class="text-xs text-gray-600 mt-1">Have a Publisher (.pub) file? Print it to PDF first, then drop that here.</p>

    <div class="my-4 text-center text-xs text-gray-600">or</div>

    <label class="block text-sm font-semibold text-gray-300 mb-2">Paste a recipe link</label>
    <%= url_field_tag :recipe_url, "", placeholder: "https://...",
          class: "w-full rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2.5 focus:border-orange-500 focus:outline-none" %>
    <p class="text-xs text-gray-600 mt-1">A link to a recipe online. We read the page and rebuild it in the NY Kitchen format.</p>

    <div class="my-4 text-center text-xs text-gray-600">or</div>

    <label class="block text-sm font-semibold text-gray-300 mb-2">Paste the recipe text</label>
    <%= text_area_tag :recipe_text, "", rows: 8, placeholder: "Ingredients, amounts, and directions. Multiple recipes are fine (dough, filling, sauce).",
          class: "w-full rounded-xl bg-gray-900 border border-gray-800 text-gray-200 text-base p-4 focus:border-orange-500 focus:outline-none" %>

    <%= submit_tag "Build the recipe", class: "mt-6 px-5 py-2.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white font-semibold cursor-pointer" %>
    <p class="text-xs text-gray-500 mt-2">The agent reads the recipe, splits out each part, and proposes single-station amounts. You review it against a live PDF preview before printing.</p>
  <% end %>

  <div class="mt-10">
    <h2 class="text-sm font-semibold text-gray-400 mb-3">Or copy an existing packet</h2>

    <%= form_with url: new_nyk_handout_path, method: :get, class: "mb-3" do %>
      <%= hidden_field_tag :event_url, @event_url %>
      <%= hidden_field_tag :event_name, @event_name %>
      <div class="flex gap-2">
        <%= search_field_tag :q, @q, placeholder: "Search all recipes (name or ingredient)…",
              autocomplete: "off",
              class: "flex-1 min-w-0 rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2.5 focus:border-orange-500 focus:outline-none" %>
        <%= submit_tag "Search", class: "shrink-0 px-4 py-2.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-semibold cursor-pointer" %>
      </div>
    <% end %>

    <% others = @existing %>
    <% if @q.present? %>
      <p class="text-xs text-gray-500 mb-2">
        <%= pluralize(others.size, "match") %> for "<span class="text-gray-300"><%= @q %></span>"
        &middot; <%= link_to "clear", new_nyk_handout_path(event_url: @event_url, event_name: @event_name), class: "text-orange-400 hover:text-orange-300" %>
      </p>
    <% end %>

    <% if others.any? %>
      <div class="space-y-2">
        <% (@q.present? ? others : others.first(10)).each do |h| %>
          <div class="flex items-center justify-between gap-3 bg-gray-900 border border-gray-800 rounded-lg px-4 py-2.5">
            <span class="text-sm text-gray-300 min-w-0 truncate"><%= h.title %></span>
            <%= button_to "Copy", nyk_handouts_path,
                  params: { existing_id: h.id, event_url: @event_url },
                  class: "shrink-0 text-xs px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% elsif @q.present? %>
      <p class="text-sm text-gray-500">No recipes match that search.</p>
    <% end %>
  </div>
</div>
