<%# No title override — defaults to "Agent 44 Labs" %>

<!-- Hero Section -->
<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950"></div>
  <div class="absolute inset-0 opacity-[0.03]">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dots" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="currentColor"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)" class="text-white"/>
    </svg>
  </div>

  <%# Agent status — mobile: horizontal bar above hero, desktop: pinned top-left %>
  <% if @agents.present? %>
    <%# Mobile: compact horizontal row %>
    <div class="relative z-10 px-4 pt-3 md:hidden overflow-x-hidden">
      <%= render "shared/agent_profiles_mobile", agents: @agents %>
    </div>
    <%# Desktop: absolute positioned top-left %>
    <div class="absolute top-12 left-0 z-10 px-8 sm:px-12 lg:px-24 hidden md:block">
      <%= render "shared/agent_profiles", agents: @agents %>
    </div>
  <% end %>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-36 relative">

    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white tracking-tight leading-[1.05]">
        Agents that <span class="bg-gradient-to-r from-orange-600 to-amber-600 bg-clip-text text-transparent">watch your site</span> so you don't have to.
      </h1>
      <p class="mt-6 text-xl md:text-2xl text-gray-300 leading-snug max-w-2xl mx-auto font-medium">
        Production smoke tests for small and mid-size teams. Run by bots. Billed by the minute.
      </p>
      <p class="mt-6 text-base md:text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
        Replace a $120k QA engineer with agent-driven tests that run day and night, record video on failure, and email you the moment your site breaks.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4">
        <%# Face ID button — shown on mobile native when available %>
        <button type="button" id="faceid-signin-btn" style="display:none"
                class="inline-flex items-center gap-3 px-8 py-4 text-base font-bold text-white bg-gradient-to-r from-orange-600 to-amber-600 rounded-full hover:from-orange-700 hover:to-amber-700 transition shadow-lg shadow-orange-600/30 md:hidden">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M3 17v2a2 2 0 002 2h2M17 21h2a2 2 0 002-2v-2M8 11v1M16 11v1M9 16c.5.5 1.5 1 3 1s2.5-.5 3-1M12 8v5"/>
          </svg>
          <span class="faceid-label">Sign in with Face ID</span>
        </button>
        <%= render "shared/faceid_auth" %>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="#case-studies"
             class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-orange-600 to-amber-600 rounded-full hover:from-orange-700 hover:to-amber-700 transition shadow-lg shadow-orange-600/30">
            See a live test →
          </a>
          <a href="mailto:botwhisperer@hey.com?subject=Agent%2044%20Labs%20%E2%80%94%20QA%20for%20my%20site"
             class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gray-800 rounded-full hover:bg-gray-700 transition border border-gray-700">
            Get a quote
          </a>
        </div>
      </div>
    </div>

    <!-- Live pulse: latest NYK smoke run -->
    <% if @nyk_latest_run.present? %>
      <div class="mt-16 max-w-2xl mx-auto">
        <div class="bg-gray-900/80 rounded-2xl border border-gray-800 p-6 backdrop-blur">
          <div class="flex items-center justify-between gap-3 mb-3">
            <div class="flex items-center gap-3 min-w-0">
              <span class="relative flex h-2.5 w-2.5 flex-shrink-0">
                <% if @nyk_latest_run.passed? %>
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-60"></span>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
                <% else %>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
                <% end %>
              </span>
              <h3 class="text-sm font-semibold text-white truncate">Latest smoke run · NY Kitchen</h3>
            </div>
            <span class="text-xs text-gray-500 flex-shrink-0"><%= time_ago_in_words(@nyk_latest_run.started_at) %> ago</span>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-xs text-gray-500 uppercase tracking-wide">Status</div>
              <div class="mt-1 text-sm font-semibold <%= @nyk_latest_run.passed? ? 'text-green-400' : 'text-red-400' %>">
                <%= @nyk_latest_run.passed? ? "Passed" : "Failed" %>
              </div>
            </div>
            <div>
              <div class="text-xs text-gray-500 uppercase tracking-wide">Duration</div>
              <div class="mt-1 text-sm font-semibold text-white"><%= @nyk_latest_run.duration_label %></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 uppercase tracking-wide">Cost</div>
              <div class="mt-1 text-sm font-semibold text-white">$<%= sprintf("%.4f", @nyk_latest_run.cost_dollars || 0) %></div>
            </div>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</section>

<!-- Services -->
<section id="services" class="border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white">What we do</h2>
      <p class="mt-3 text-gray-500">Production coverage without a QA headcount.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Production Smoke Tests -->
      <div class="text-center group">
        <div class="w-14 h-14 rounded-2xl bg-orange-100 flex items-center justify-center mx-auto mb-5 group-hover:bg-orange-200 transition">
          <svg class="w-7 h-7 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Production Smoke Tests</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Agents run your site's critical flows on a schedule. Video on failure. Email the moment something breaks.
        </p>
      </div>

      <!-- Agent-Driven QA -->
      <div class="text-center group">
        <div class="w-14 h-14 rounded-2xl bg-amber-100 flex items-center justify-center mx-auto mb-5 group-hover:bg-amber-200 transition">
          <svg class="w-7 h-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Agent-Driven QA</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Custom test scenarios for your product. Playwright, Cypress, API checks — authored and maintained by agents, reviewed by humans.
        </p>
      </div>

      <!-- Content & Social Ops -->
      <div class="text-center group">
        <div class="w-14 h-14 rounded-2xl bg-orange-100 flex items-center justify-center mx-auto mb-5 group-hover:bg-orange-200 transition">
          <svg class="w-7 h-7 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Content &amp; Social Ops</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Agent bots that draft, schedule, and polish your social posts and customer content — wired into your business flows, not bolted on.
        </p>
      </div>

      <!-- Custom AI Agents -->
      <div class="text-center group">
        <div class="w-14 h-14 rounded-2xl bg-amber-100 flex items-center justify-center mx-auto mb-5 group-hover:bg-amber-200 transition">
          <svg class="w-7 h-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Custom AI Agents</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Built on Claude and open-source models. Plugged into your stack — web, iOS, Rails, or whatever you ship on.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Case Studies -->
<section id="case-studies" class="bg-gray-900 border-t border-gray-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white">Who we watch</h2>
      <p class="mt-3 text-gray-500">Real sites. Real coverage. Real receipts.</p>
    </div>

    <!-- NY Kitchen -->
    <div class="bg-gray-950 rounded-2xl border border-gray-800 overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <!-- Left: story -->
        <div class="p-8 md:p-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-900/40 border border-green-800/60 text-xs font-semibold text-green-300 mb-4">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-60"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            Actively monitored
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">NY Kitchen</h3>
          <p class="text-sm text-gray-400 leading-relaxed mb-6">
            Cooking-class calendar with 90+ upcoming events across four months. Our agents flip through every month, compare before/after, and flag drift the moment a class disappears.
          </p>

          <!-- Quote slot -->
          <blockquote class="border-l-2 border-orange-600 pl-4 my-6">
            <p class="text-base text-gray-300 italic leading-relaxed">
              <span class="text-gray-600">&ldquo;</span>Placeholder for Lora's quote — e.g. what the smoke tests caught, how often, and what it replaced.<span class="text-gray-600">&rdquo;</span>
            </p>
            <footer class="mt-3 text-xs text-gray-500 not-italic">
              — Lora, NY Kitchen <span class="text-gray-700">(testimonial pending)</span>
            </footer>
          </blockquote>

          <a href="/nykitchen" class="inline-flex items-center text-sm font-semibold text-orange-500 hover:text-orange-300 transition">
            See live test runs
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Right: stats -->
        <div class="bg-gray-900 p-8 md:p-10 border-t md:border-t-0 md:border-l border-gray-800">
          <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-6">Coverage to date</h4>
          <dl class="space-y-5">
            <div class="flex items-baseline justify-between gap-4">
              <dt class="text-sm text-gray-400">Total runs</dt>
              <dd class="text-2xl font-bold text-white"><%= @nyk_total_runs || 0 %></dd>
            </div>
            <% if @nyk_pass_rate %>
              <div class="flex items-baseline justify-between gap-4">
                <dt class="text-sm text-gray-400">Pass rate</dt>
                <dd class="text-2xl font-bold text-green-400"><%= @nyk_pass_rate %>%</dd>
              </div>
            <% end %>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="text-sm text-gray-400">Cost to run</dt>
              <dd class="text-2xl font-bold text-white">$<%= sprintf("%.2f", @nyk_total_cost || 0) %></dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="text-sm text-gray-400">Schedule</dt>
              <dd class="text-sm font-semibold text-white">3× daily</dd>
            </div>
          </dl>
          <div class="mt-6 pt-6 border-t border-gray-800">
            <p class="text-xs text-gray-500 leading-relaxed">
              A human QA engineer at $120k/year runs ~$329/day. Our agents run the same coverage 3× daily for pennies — and never sleep.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact CTA -->
<section class="border-t border-gray-800">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white">Got a production site worth watching?</h2>
    <p class="mt-3 text-gray-500 max-w-md mx-auto">
      Tell us your critical flow. We'll build the smoke test and show you what it catches.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="mailto:botwhisperer@hey.com?subject=Agent%2044%20Labs%20%E2%80%94%20QA%20for%20my%20site"
         class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-orange-600 to-amber-600 rounded-full hover:from-orange-700 hover:to-amber-700 transition shadow-lg shadow-orange-600/30">
        Get a quote
      </a>
      <a href="#case-studies"
         class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gray-800 rounded-full hover:bg-gray-700 transition border border-gray-700">
        See a live test
      </a>
    </div>
    <div class="mt-12 max-w-md mx-auto" id="home-newsletter-form">
      <p class="text-xs text-gray-600 mb-3">Or just watch along — occasional updates on new tests and tooling.</p>
      <%= render "subscribers/form" %>
    </div>
  </div>
</section>
