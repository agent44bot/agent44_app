<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} | Agent44 Admin" : "Agent44 Admin" %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="icon" href="/icon.png" type="image/png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full flex flex-col bg-gray-800 text-white antialiased">

  <!-- Admin Navigation -->
  <nav class="bg-gray-900 text-white sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-14">
        <div class="flex items-center space-x-6">
          <%= link_to admin_dashboard_path, class: "flex items-center space-x-2 font-bold text-lg tracking-tight" do %>
            <span class="text-orange-400">Agent44</span>
            <span class="text-xs font-medium bg-orange-600 px-2 py-0.5 rounded text-white">Admin</span>
          <% end %>

          <div class="hidden md:flex items-center space-x-4">
            <%= link_to "Dashboard", admin_dashboard_path,
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path == admin_dashboard_path ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
            <%= link_to "Posts", admin_posts_path,
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path.start_with?('/admin/posts') ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
            <%= link_to "Videos", admin_videos_path,
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path.start_with?('/admin/videos') ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
            <%= link_to "Scrapers", admin_scrapers_path,
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path.start_with?('/admin/scrapers') ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
            <%= link_to "Users", admin_users_path,
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path.start_with?('/admin/users') ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
            <%= link_to "Visitor Map", admin_visitors_map_path,
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path == '/admin/visitors/map' ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
            <%= link_to "Lab", "/lab",
                  class: "text-sm font-medium px-3 py-1.5 rounded-md #{request.path == '/lab' ? 'bg-gray-700 text-white' : 'text-gray-300 hover:text-orange-400 hover:bg-gray-800'} transition" %>
          </div>
        </div>

        <div class="flex items-center space-x-4">
          <% unread_notifications_count = Notification.unread.count %>
          <%= link_to admin_notifications_path,
                class: "relative text-gray-300 hover:text-orange-400 transition",
                title: "Notifications" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.4-1.4A2 2 0 0118 14.2V11a6 6 0 10-12 0v3.2a2 2 0 01-.6 1.4L4 17h5m6 0a3 3 0 11-6 0" />
            </svg>
            <% if unread_notifications_count > 0 %>
              <span class="absolute -top-1 -right-2 bg-red-600 text-white text-[10px] font-bold rounded-full min-w-[16px] h-4 px-1 flex items-center justify-center">
                <%= unread_notifications_count > 9 ? "9+" : unread_notifications_count %>
              </span>
            <% end %>
          <% end %>
          <%= link_to "Home", root_path, class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
          <%= link_to "Jobs", jobs_path, class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
          <span class="text-gray-400">|</span>
          <span class="text-sm text-gray-500"><%= Current.session.user.display_identifier %></span>
          <%= button_to "Sign Out", session_path, method: :delete,
                class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Flash messages -->
  <% if notice.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-green-50 border border-green-200 p-4">
        <p class="text-sm text-green-800"><%= notice %></p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-lg bg-red-50 border border-red-200 p-4">
        <p class="text-sm text-red-800"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="flex-1">
    <%= yield %>
  </main>

</body>
</html>
