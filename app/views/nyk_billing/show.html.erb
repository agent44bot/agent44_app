<% content_for :title, "NY Kitchen — Billing" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-end mb-6 text-sm">
    <%= link_to "← NY Kitchen", nykitchen_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold transition" %>
  </div>
  <div class="flex items-center justify-between mb-1 gap-3 flex-wrap">
    <h1 class="text-2xl font-bold text-white">Billing</h1>
  </div>
  <p class="text-sm text-gray-400 mb-6">
    What NY Kitchen pays. Includes a $<%= sprintf("%.0f", @base_fee) %>/mo platform fee plus a <%= @raw_multiplier.to_i %>× margin on raw fleet cost (covers developer time, hardware, and reserve capacity).
  </p>

  <div class="rounded-lg bg-gray-900 border border-orange-700/40 p-5 mb-8">
    <p class="text-xs text-orange-400 uppercase tracking-wide mb-1">Total this month</p>
    <p class="text-3xl font-bold text-white">$<%= sprintf("%.2f", @month_total) %></p>
    <div class="text-xs text-gray-400 mt-2 space-y-0.5">
      <div>Platform fee: <%= @base_fee_waived ? %(<span class="line-through text-gray-500">$#{sprintf('%.2f', @base_fee_configured)}</span> <span class="text-green-400 font-semibold">Waived</span>).html_safe : "$#{sprintf('%.2f', @base_fee)}" %></div>
      <div>Usage: $<%= sprintf("%.2f", @raw_total) %> × <%= @raw_multiplier.to_i %> = $<%= sprintf("%.2f", @raw_total * @raw_multiplier) %></div>
      <div>Subtotal: $<%= sprintf("%.2f", @customer_subtotal) %></div>
      <% if @discount_percent.positive? %>
        <div class="text-green-400">Discount (<%= @discount_percent.to_i %>% off): −$<%= sprintf("%.2f", @discount_amount) %></div>
        <div class="text-gray-200">After discount: <span class="font-semibold text-white">$<%= sprintf("%.2f", @customer_total) %></span></div>
      <% end %>
      <% if @flyer_scan_revenue.to_f > 0 %>
        <div>Flyer prints &amp; QR scans: $<%= sprintf("%.2f", @flyer_scan_revenue) %></div>
      <% end %>
      <div class="text-gray-500 pt-0.5">since <%= @month_start.strftime("%b %-d") %></div>
    </div>
  </div>

  <%# Flyer + QR scan revenue: per-print + per-scan rate (Neon). %>
  <h2 id="flyer" style="scroll-margin-top:84px" class="text-base font-semibold text-white mb-3">Flyer prints &amp; QR scans</h2>
  <% if @flyer_print_count.to_i.zero? && @flyer_scan_count.to_i.zero? %>
    <p class="text-sm text-gray-500 italic mb-8">No flyer prints or scans yet this month.</p>
  <% else %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left">Action</th>
            <th class="px-4 py-2 text-right">Count</th>
            <th class="px-4 py-2 text-right">Rate</th>
            <th class="px-4 py-2 text-right">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <tr>
            <td class="px-4 py-2 text-gray-200">🖨 Flyer prints</td>
            <td class="px-4 py-2 text-right tabular-nums text-gray-300"><%= @flyer_print_count %></td>
            <td class="px-4 py-2 text-right tabular-nums text-gray-500">$<%= sprintf("%.2f", @flyer_unit_price) %></td>
            <td class="px-4 py-2 text-right tabular-nums text-white">$<%= sprintf("%.2f", @flyer_print_count * @flyer_unit_price) %></td>
          </tr>
          <tr>
            <td class="px-4 py-2 text-gray-200">📱 QR scans</td>
            <td class="px-4 py-2 text-right tabular-nums text-gray-300"><%= @flyer_scan_count %></td>
            <td class="px-4 py-2 text-right tabular-nums text-gray-500">$<%= sprintf("%.2f", @flyer_unit_price) %></td>
            <td class="px-4 py-2 text-right tabular-nums text-white">$<%= sprintf("%.2f", @flyer_scan_count * @flyer_unit_price) %></td>
          </tr>
        </tbody>
        <tfoot class="bg-gray-800/30 text-sm font-semibold">
          <tr>
            <td class="px-4 py-2 text-gray-300" colspan="3">Total</td>
            <td class="px-4 py-2 text-right tabular-nums text-white">$<%= sprintf("%.2f", @flyer_scan_revenue) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% end %>

  <% auto_recipe_on = Setting.get("nyk:auto_recipe_on_open") != "false" %>
  <div class="mb-8 rounded-lg border border-gray-800 bg-gray-900/40 p-4 flex items-start justify-between gap-4">
    <div>
      <h2 class="text-base font-semibold text-white mb-1">Auto-draft recipes</h2>
      <p class="text-xs text-gray-500 max-w-md">
        When on, opening a class with no recipe drafts one with AI (only for classes within about 6 weeks or already selling). When off, opening a class shows the manual upload/paste form instead. Recurring classes carry forward the last run's recipe either way, at no cost.
      </p>
    </div>
    <%= form_with url: nyk_billing_auto_recipe_path, method: :patch, local: true, class: "shrink-0 flex items-center gap-2" do %>
      <%= hidden_field_tag :auto_recipe_on_open, auto_recipe_on ? "0" : "1" %>
      <span class="text-xs font-semibold uppercase <%= auto_recipe_on ? 'text-gray-500' : 'text-gray-300' %>">Off</span>
      <%= submit_tag(auto_recipe_on ? "Turn off" : "Turn on",
            class: "px-3 py-1.5 rounded-md text-xs font-semibold cursor-pointer #{auto_recipe_on ? 'bg-gray-800 text-gray-200 hover:bg-gray-700' : 'bg-orange-600 text-white hover:bg-orange-500'}") %>
      <span class="text-xs font-semibold uppercase <%= auto_recipe_on ? 'text-green-400' : 'text-gray-500' %>">On</span>
    <% end %>
  </div>

  <h2 id="ai-usage" style="scroll-margin-top:84px" class="text-base font-semibold text-white mb-3">AI usage</h2>
  <% if @highlight_agent %>
    <% hmeta = nyk_agent_meta(@highlight_agent) %>
    <p class="text-sm text-gray-400 mb-3">
      Highlighting <span class="font-semibold" style="color:<%= hmeta[:accent] %>"><%= hmeta[:emoji] %> <%= hmeta[:call] %></span>'s features.
      <%= link_to "Show all", nyk_billing_path(anchor: "ai-usage"), class: "text-orange-400 hover:underline ml-1", data: { turbo: false } %>
    </p>
  <% end %>
  <% if @summary.empty? %>
    <p class="text-sm text-gray-500 italic mb-8">No AI usage yet this month.</p>
  <% else %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden mb-8">
      <table class="w-full text-sm" data-controller="table-sort">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="text">Feature<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="number">Calls<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="number">Cost<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="number">Avg/call<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right">Model</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @summary.sort_by { |_, v| -v[:cost_dollars] }.each do |source, v| %>
            <% avg = v[:calls].to_i.positive? ? v[:cost_dollars] / v[:calls] : 0 %>
            <% hl = @highlight_sources&.include?(source) %>
            <tr class="<%= "opacity-40" if @highlight_sources && !hl %>" style="<%= "background:#{nyk_agent_meta(@highlight_agent)[:accent]}1f" if hl %>">
              <td class="px-4 py-2 <%= hl ? "text-white font-semibold" : "text-gray-200" %>">
                <%= case source
                    when "nyk_enhance"        then "Enhance with AI button"
                    when "nyk_x_autopost"     then "Daily X autopost draft"
                    when "nyk_team_report"    then "Weekly team report"
                    when "nyk_grocery_list"   then "Grocery lists"
                    when "nyk_recipe_extract" then "Recipe import"
                    when "nyk_recipe_generate" then "Recipe generation (AI)"
                    when "nyk_receipt_extract" then "Receipt scanning"
                    when "nyk_ask"            then "Super Agent chat"
                    when "nyk_social_scout"   then "Echo social listening"
                    else                           source
                    end %>
              </td>
              <td class="px-4 py-2 text-right text-gray-300" data-sort-value="<%= v[:calls] %>"><%= v[:calls] %></td>
              <td class="px-4 py-2 text-right text-white" data-sort-value="<%= v[:cost_dollars] %>">$<%= sprintf("%.4f", v[:cost_dollars]) %></td>
              <td class="px-4 py-2 text-right text-gray-300" data-sort-value="<%= avg %>">$<%= sprintf("%.4f", avg) %></td>
              <td class="px-4 py-2">
                <% if AiModelChoice.controllable?(source) %>
                  <div class="flex justify-end gap-1">
                    <% AiModelChoice::OPTIONS.each do |key, opt| %>
                      <% on = @feature_model_keys[source] == key %>
                      <%= button_to opt[:label], nyk_billing_model_path, method: :patch,
                            params: { source: source, model: key },
                            form: { data: { turbo: false } },
                            class: "px-2 py-0.5 rounded border text-xs cursor-pointer #{on ? 'bg-orange-600 border-orange-500 text-white' : 'bg-gray-900 border-gray-700 text-gray-400 hover:border-orange-500'}" %>
                    <% end %>
                  </div>
                <% else %>
                  <p class="text-right text-xs text-gray-500"><%= AiModelChoice::OPTIONS[@feature_model_keys[source]][:label] %> (auto)</p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500 -mt-6 mb-8">
      <span class="font-semibold text-gray-400">Opus</span> highest quality ($5/$25 per M tokens) &middot;
      <span class="font-semibold text-gray-400">Sonnet</span> balanced ($3/$15) &middot;
      <span class="font-semibold text-gray-400">Haiku</span> fastest and cheapest ($1/$5).
      Owners and admins can set the model per feature.
    </p>

    <%# Spend per Anthropic model (Opus vs Haiku) + total. Same this-month NYK
        scope as the per-feature table above, just grouped by model. %>
    <h2 class="text-base font-semibold text-white mb-3">Spend by model</h2>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden mb-8">
      <table class="w-full text-sm" data-controller="table-sort">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="text">Model<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="number">Calls<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="number">Cost<span data-sort-arrow></span></th>
            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-300" data-action="click->table-sort#sort" data-sort-type="number">Avg/call<span data-sort-arrow></span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @model_summary.sort_by { |_, v| -v[:cost_dollars] }.each do |model, v| %>
            <% avg = v[:calls].to_i.positive? ? v[:cost_dollars] / v[:calls] : 0 %>
            <tr>
              <td class="px-4 py-2 text-gray-200"><%= model %></td>
              <td class="px-4 py-2 text-right text-gray-300" data-sort-value="<%= v[:calls] %>"><%= v[:calls] %></td>
              <td class="px-4 py-2 text-right text-white" data-sort-value="<%= v[:cost_dollars] %>">$<%= sprintf("%.4f", v[:cost_dollars]) %></td>
              <td class="px-4 py-2 text-right text-gray-300" data-sort-value="<%= avg %>">$<%= sprintf("%.4f", avg) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="border-t-2 border-gray-700 bg-gray-800/30">
          <tr>
            <td class="px-4 py-2 font-semibold text-gray-200">Total</td>
            <td class="px-4 py-2 text-right font-semibold text-gray-300"><%= @ai_calls %></td>
            <td class="px-4 py-2 text-right font-bold text-white">$<%= sprintf("%.4f", @ai_total) %></td>
            <td class="px-4 py-2 text-right font-semibold text-gray-300">$<%= sprintf("%.4f", @ai_calls.to_i.positive? ? @ai_total / @ai_calls : 0) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% end %>

  <% if @ai_trend.any? { |m| m[:cost_dollars] > 0 } %>
    <h2 class="text-base font-semibold text-white mb-3">AI usage trend</h2>
    <p class="text-xs text-gray-500 mb-3">Monthly AI cost over the last 6 months.</p>
    <div class="rounded-lg bg-gray-900 border border-gray-800 p-5 mb-8">
      <div class="flex items-end gap-2 h-24">
        <% @ai_trend.each do |m| %>
          <% pct = @ai_trend_max > 0 ? [ (m[:cost_dollars] / @ai_trend_max * 100).round, 2 ].max : 0 %>
          <% is_current = (m[:key] == @month_start.strftime("%Y-%m")) %>
          <div class="flex-1 flex flex-col items-center justify-end h-full"
               title="<%= m[:label] %>: $<%= sprintf('%.2f', m[:cost_dollars]) %> raw">
            <span class="text-[10px] text-gray-400 mb-1">$<%= m[:cost_dollars] >= 1 ? m[:cost_dollars].round : sprintf('%.2f', m[:cost_dollars]) %></span>
            <div class="w-full rounded-t <%= is_current ? "bg-orange-500" : "bg-gray-700" %>" style="height: <%= pct %>%"></div>
          </div>
        <% end %>
      </div>
      <div class="flex gap-2 mt-1.5">
        <% @ai_trend.each do |m| %>
          <div class="flex-1 text-center text-[10px] <%= m[:key] == @month_start.strftime("%Y-%m") ? "text-orange-300" : "text-gray-600" %>"><%= m[:label] %></div>
        <% end %>
      </div>
    </div>
  <% end %>

  <h2 class="text-base font-semibold text-white mb-3">Recent calls</h2>
  <% if @recent.empty? %>
    <p class="text-sm text-gray-500 italic">None yet.</p>
  <% else %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left">When</th>
            <th class="px-4 py-2 text-left">Feature</th>
            <th class="px-4 py-2 text-right">Cost</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @recent.each do |log| %>
            <tr>
              <td class="px-4 py-2 text-gray-400 text-xs whitespace-nowrap"><%= log.created_at.in_time_zone.strftime("%b %-d %-l:%M %p") %></td>
              <td class="px-4 py-2 text-gray-300 text-xs">
                <%= case log.source
                    when "nyk_enhance"        then "Enhance with AI"
                    when "nyk_x_autopost"     then "X autopost draft"
                    when "nyk_team_report"    then "Weekly team report"
                    when "nyk_grocery_list"   then "Grocery list"
                    when "nyk_recipe_extract" then "Recipe import"
                    when "nyk_recipe_generate" then "Recipe generation (AI)"
                    when "nyk_receipt_extract" then "Receipt scan"
                    when "nyk_ask"            then "Super Agent chat"
                    when "nyk_social_scout"   then "Echo social listening"
                    else                           log.source
                    end %>
              </td>
              <td class="px-4 py-2 text-right text-white">$<%= sprintf("%.5f", log.cost_dollars) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <h2 id="smoke" style="scroll-margin-top:84px" class="text-base font-semibold text-white mt-8 mb-3">Smoke tests</h2>
  <p class="text-xs text-gray-500 mb-3">
    Browser-driven calendar checks (cron-driven, ~3×/day).
    Billed at $<%= sprintf("%.5f", @test_rate) %>/min of CI runtime.
  </p>
  <div class="rounded-lg bg-gray-900 border border-gray-800 p-5 mb-8">
    <div class="grid grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Runs</p>
        <p class="text-xl font-bold text-white"><%= number_with_delimiter(@smoke_count) %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Minutes</p>
        <p class="text-xl font-bold text-white"><%= number_with_delimiter(@smoke_minutes) %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Cost</p>
        <p class="text-xl font-bold text-white">$<%= sprintf("%.4f", @smoke_cost) %></p>
      </div>
    </div>
  </div>

  <h2 class="text-base font-semibold text-white mb-3">Past invoices</h2>
  <% if @invoices.empty? %>
    <p class="text-sm text-gray-500 italic mb-8">No invoices yet. The first is generated on the 1st of next month.</p>
  <% else %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left">Period</th>
            <th class="px-4 py-2 text-right">Total</th>
            <th class="px-4 py-2 text-center">Status</th>
            <% if Current.user&.admin? %><th class="px-4 py-2 text-right">Action</th><% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @invoices.each do |inv| %>
            <tr>
              <td class="px-4 py-2 text-gray-200"><%= inv.period_label %></td>
              <td class="px-4 py-2 text-right text-white font-medium">$<%= sprintf("%.2f", inv.total_dollars) %></td>
              <td class="px-4 py-2 text-center">
                <% if inv.paid? %>
                  <span class="inline-block text-xs font-semibold text-green-400 border border-green-700/50 rounded-full px-2 py-0.5">Paid</span>
                <% else %>
                  <span class="inline-block text-xs font-semibold text-amber-400 border border-amber-700/50 rounded-full px-2 py-0.5">Unpaid</span>
                <% end %>
              </td>
              <% if Current.user&.admin? %>
                <td class="px-4 py-2 text-right">
                  <% unless inv.paid? %>
                    <%= button_to "Mark paid", nyk_billing_invoice_pay_path(inv),
                          method: :patch,
                          class: "text-xs font-semibold text-orange-400 hover:text-orange-300 cursor-pointer",
                          form_class: "inline" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if Current.user&.admin? %>
    <div class="rounded-lg bg-gray-900 border border-amber-700/40 p-5 mb-8">
      <p class="text-xs text-amber-400 uppercase tracking-wide mb-2">Admin · billing rate</p>
      <%= form_with url: nyk_billing_rate_path, method: :patch, class: "flex flex-wrap items-end gap-3" do %>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Test-run cost per minute ($)</label>
          <input type="number" name="test_cost_per_minute" step="0.00001" min="0" value="<%= @test_rate %>"
                 class="rounded-md bg-gray-950 border border-gray-700 text-white px-3 py-2 w-44 focus:border-orange-500 focus:outline-none">
        </div>
        <%= submit_tag "Save & re-price", class: "px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
      <% end %>
      <p class="text-xs text-gray-500 mt-2">Applies to NY Kitchen's smoke/test runs and re-prices existing runs. Site admin only — Lora can't change this.</p>
    </div>

    <div class="rounded-lg bg-gray-900 border border-amber-700/40 p-5 mb-8">
      <p class="text-xs text-amber-400 uppercase tracking-wide mb-3">Admin · customer pricing</p>
      <%= form_with url: nyk_billing_pricing_path, method: :patch, class: "space-y-3" do %>
        <div class="flex flex-wrap items-end gap-3">
          <div>
            <label class="block text-xs text-gray-400 mb-1">Flat monthly fee ($)</label>
            <input type="number" name="base_fee_dollars" step="0.01" min="0" value="<%= @workspace&.base_fee_dollars %>" placeholder="<%= sprintf('%.2f', @base_fee) %>"
                   class="rounded-md bg-gray-950 border border-gray-700 text-white px-3 py-2 w-36 focus:border-orange-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Discount (% off)</label>
            <input type="number" name="discount_percent" step="1" min="0" max="100" value="<%= @discount_percent.to_i %>"
                   class="rounded-md bg-gray-950 border border-gray-700 text-white px-3 py-2 w-28 focus:border-orange-500 focus:outline-none">
          </div>
          <label class="inline-flex items-center gap-2 text-sm text-gray-300 pb-2">
            <input type="hidden" name="base_fee_waived" value="0">
            <input type="checkbox" name="base_fee_waived" value="1" <%= "checked" if @base_fee_waived %>
                   class="rounded border-gray-600 bg-gray-800 text-orange-500">
            Waive the fee
          </label>
        </div>
        <%= submit_tag "Save pricing", class: "px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
      <% end %>
      <p class="text-xs text-gray-500 mt-2">Lora sees the fee (or "Waived") and the discount before/after on her customer view. Site admin only.</p>
    </div>
  <% end %>
</div>
