<% content_for(:title, "Sign In") %>
<%= render "shared/faceid_auth" %>

<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">Sign In</h1>
      <p class="mt-2 text-sm text-gray-500">Choose your preferred authentication method</p>
    </div>

    <% if Rails.env.development? %>
      <% dev_users = User.where(role: "admin").where.not(email_address: nil).where.not("email_address LIKE ?", "%@example.com").order(:id).to_a %>
      <% dev_users += User.where.not(role: "admin").where.not(email_address: nil).where.not("email_address LIKE ?", "%@example.com").order(:id).limit(1).to_a %>
      <% if dev_users.any? %>
        <div class="mb-6 bg-amber-950/40 border border-amber-800/60 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-amber-600 text-white">Dev only</span>
            <span class="text-xs text-amber-300">Click to sign in without a password (localhost only)</span>
          </div>
          <div class="grid grid-cols-1 gap-2">
            <% dev_users.each do |u| %>
              <%= button_to dev_login_as_path(u.id),
                    method: :post,
                    form_class: "contents",
                    class: "w-full text-left px-3 py-2 bg-gray-900/80 hover:bg-gray-800 border border-gray-800 rounded-lg text-sm text-gray-200 transition flex items-center justify-between gap-3" do %>
                <span class="truncate">
                  <%= u.email_address %>
                </span>
                <span class="flex items-center gap-2 flex-shrink-0">
                  <% if u.admin? %>
                    <span class="text-[10px] font-semibold uppercase text-amber-400">admin</span>
                  <% elsif u.kitchen_only? %>
                    <span class="text-[10px] font-semibold uppercase text-orange-400">kitchen</span>
                  <% else %>
                    <span class="text-[10px] font-semibold uppercase text-gray-500">user</span>
                  <% end %>
                  <span class="text-[10px] text-gray-500">→</span>
                </span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

<div class="bg-gray-900 rounded-xl border border-gray-800 shadow-sm overflow-hidden" data-controller="tabs">
      <!-- Tab Headers -->
      <div class="flex border-b border-gray-800">
        <button data-action="click->tabs#select" data-tabs-target="tab" data-tab-index="0"
                class="flex-1 px-4 py-3 text-sm font-medium text-center text-orange-600 border-b-2 border-orange-600 bg-orange-50/50 transition">
          Email
        </button>
        <button data-action="click->tabs#select" data-tabs-target="tab" data-tab-index="1"
                class="flex-1 px-4 py-3 text-sm font-medium text-center text-gray-500 border-b-2 border-transparent hover:text-gray-300 transition">
          Nostr Key
        </button>
      </div>

      <div class="p-6">
        <!-- Email Tab -->
        <div data-tabs-target="panel" data-tab-index="0">
          <%= form_with url: session_path, class: "space-y-5" do |f| %>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-300 mb-1">Email address</label>
              <input type="email" name="email_address" id="email" required autocomplete="username" autofocus
                     class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
                     placeholder="you@example.com">
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-gray-300 mb-1">Password</label>
              <input type="password" name="password" id="password" required autocomplete="current-password"
                     class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
                     placeholder="Your password">
            </div>
            <button type="submit"
                    class="w-full px-4 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm">
              Sign In
            </button>

            <!-- Face ID button (shown in Capacitor iOS app when biometrics/passcode available) -->
            <button type="button" id="faceid-signin-btn" style="display:none"
                    class="w-full px-4 py-2.5 bg-gray-800 text-white font-semibold rounded-lg hover:bg-gray-700 transition shadow-sm border border-gray-700 flex items-center justify-center gap-2">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M3 17v2a2 2 0 002 2h2M17 21h2a2 2 0 002-2v-2M8 11v1M16 11v1M9 16c.5.5 1.5 1 3 1s2.5-.5 3-1M12 8v5"/>
              </svg>
              <span class="faceid-label">Sign in with Face ID</span>
            </button>

            <div class="text-center space-y-2">
              <%= link_to "Forgot password?", new_password_path, class: "text-sm text-gray-500 hover:text-orange-600 transition" %>
              <p class="text-sm text-gray-500">Don't have an account? <%= link_to "Sign up", new_registration_path, class: "text-orange-600 hover:text-orange-300 font-medium" %></p>
            </div>
          <% end %>
        </div>

        <!-- Nostr Key Tab -->
        <div data-tabs-target="panel" data-tab-index="1" class="hidden">
          <div data-controller="keypair auth nostr">

            <!-- Nostr Extension Button (hidden until detected) -->
            <div class="mb-4">
              <button type="button"
                      style="display:none;"
                      data-nostr-target="extensionBtn"
                      data-action="click->nostr#signInWithExtension"
                      class="w-full px-4 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm text-sm">
                Sign in with Nostr Extension
              </button>
              <p style="display:none;" data-nostr-target="extensionStatus" class="text-xs text-gray-400 text-center mt-2"></p>
            </div>

            <div style="display:none;" data-nostr-target="divider" class="relative mb-4">
              <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-800"></div></div>
              <div class="relative flex justify-center text-xs"><span class="bg-gray-900 px-2 text-gray-400">or enter your key manually</span></div>
            </div>

            <!-- Keypair Tabs -->
            <div class="flex rounded-lg overflow-hidden mb-4">
              <button type="button" data-tab data-action="click->keypair#showGenerate"
                      class="flex-1 px-3 py-2 text-xs font-medium bg-orange-600 text-white transition">
                New Keypair
              </button>
              <button type="button" data-tab data-action="click->keypair#showExisting"
                      class="flex-1 px-3 py-2 text-xs font-medium bg-gray-700 text-gray-300 transition">
                I Have a Key
              </button>
            </div>

            <!-- Generate New Keypair Panel -->
            <div data-keypair-target="generatePanel">
              <p class="text-xs text-gray-500 mb-3">Generate a new keypair to create your account. Save your private key — it's your only way to sign in.</p>

              <button type="button" data-action="click->keypair#generate"
                      class="w-full px-4 py-2.5 bg-gray-800 text-gray-300 font-medium rounded-lg hover:bg-gray-700 transition text-sm">
                Generate Keypair
              </button>

              <div data-keypair-target="keypairDisplay" style="display:none;" class="mt-4 space-y-3">
                <div>
                  <label class="block text-xs font-medium text-gray-500 mb-1">Your Public Key (npub)</label>
                  <input type="text" readonly data-keypair-target="npubField"
                         class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-lg text-xs font-mono">
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-500 mb-1">Your Private Key (nsec)</label>
                  <div class="text-xs text-yellow-400 bg-yellow-50 border border-yellow-200 rounded p-2 mb-1">
                    Save this key now! It cannot be recovered.
                  </div>
                  <input type="text" readonly data-keypair-target="nsecField"
                         class="w-full px-3 py-2 bg-yellow-50 border border-yellow-200 rounded-lg text-xs font-mono">
                </div>
                <button type="button" data-action="click->auth#signIn"
                        class="w-full px-4 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition text-sm">
                  Sign In
                </button>
              </div>
            </div>

            <!-- Use Existing Key Panel -->
            <div data-keypair-target="existingPanel" style="display:none;">
              <p class="text-xs text-gray-500 mb-3">Paste your private key to sign in to your existing account.</p>

              <div class="mb-3">
                <label class="block text-xs font-medium text-gray-500 mb-1">Private Key (nsec or hex)</label>
                <input type="password"
                       data-keypair-target="nsecInput"
                       data-action="input->keypair#deriveFromNsec paste->keypair#deriveFromNsecAfterPaste"
                       class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 font-mono focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
                       placeholder="nsec1... or 64-char hex">
              </div>

              <div data-keypair-target="derivedDisplay" style="display:none;" class="mb-3">
                <label class="block text-xs font-medium text-gray-500 mb-1">Derived Public Key</label>
                <input type="text" readonly data-keypair-target="derivedNpub"
                       class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-lg text-xs font-mono">
              </div>

              <button type="button" data-action="click->keypair#deriveAndSignIn"
                      class="w-full px-4 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition text-sm">
                Sign In
              </button>
            </div>

            <!-- Hidden fields for auth and nostr controllers -->
            <input type="hidden" data-auth-target="pubkeyHex">
            <input type="hidden" data-auth-target="secretKey">
            <input type="hidden" data-auth-target="challengeUrl" value="<%= challenge_session_path %>">
            <input type="hidden" data-auth-target="sessionUrl" value="<%= session_path %>">
            <input type="hidden" data-auth-target="csrfToken" value="<%= form_authenticity_token %>">
            <input type="hidden" data-nostr-target="challengeUrl" value="<%= challenge_session_path %>">
            <input type="hidden" data-nostr-target="sessionUrl" value="<%= session_path %>">
            <input type="hidden" data-nostr-target="csrfToken" value="<%= form_authenticity_token %>">
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
