<% content_for :title, "NY Kitchen — AI Billing" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-white mb-1">AI Billing</h1>
  <p class="text-sm text-gray-400 mb-6">
    Charges for Anthropic Claude calls made on behalf of NY Kitchen this month.
    No markup — these are the raw API costs we're billed by Anthropic.
  </p>

  <div class="rounded-lg bg-gray-900 border border-orange-700/40 p-5 mb-8">
    <p class="text-xs text-orange-400 uppercase tracking-wide mb-1">Total this month</p>
    <p class="text-3xl font-bold text-white">$<%= sprintf("%.2f", @month_total) %></p>
    <p class="text-xs text-gray-500 mt-1"><%= pluralize(@month_calls, "AI call") %> since <%= @month_start.strftime("%b %-d") %></p>
  </div>

  <h2 class="text-base font-semibold text-white mb-3">Breakdown</h2>
  <% if @summary.empty? %>
    <p class="text-sm text-gray-500 italic mb-8">No AI usage yet this month.</p>
  <% else %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left">Feature</th>
            <th class="px-4 py-2 text-right">Calls</th>
            <th class="px-4 py-2 text-right">Cost</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @summary.sort_by { |_, v| -v[:cost_dollars] }.each do |source, v| %>
            <tr>
              <td class="px-4 py-2 text-gray-200">
                <%= case source
                    when "nyk_enhance"     then "Enhance with AI button"
                    when "nyk_x_autopost"  then "Daily X autopost draft"
                    else                        source
                    end %>
              </td>
              <td class="px-4 py-2 text-right text-gray-300"><%= v[:calls] %></td>
              <td class="px-4 py-2 text-right text-white">$<%= sprintf("%.4f", v[:cost_dollars]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <h2 class="text-base font-semibold text-white mb-3">Recent calls</h2>
  <% if @recent.empty? %>
    <p class="text-sm text-gray-500 italic">None yet.</p>
  <% else %>
    <div class="rounded-lg bg-gray-900 border border-gray-800 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2 text-left">When</th>
            <th class="px-4 py-2 text-left">Feature</th>
            <th class="px-4 py-2 text-right">Cost</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @recent.each do |log| %>
            <tr>
              <td class="px-4 py-2 text-gray-400 text-xs whitespace-nowrap"><%= log.created_at.in_time_zone.strftime("%b %-d %-l:%M %p") %></td>
              <td class="px-4 py-2 text-gray-300 text-xs">
                <%= case log.source
                    when "nyk_enhance"     then "Enhance with AI"
                    when "nyk_x_autopost"  then "X autopost draft"
                    else                        log.source
                    end %>
              </td>
              <td class="px-4 py-2 text-right text-white">$<%= sprintf("%.5f", log.cost_dollars) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
