<div class="grocery-shell max-w-3xl mx-auto px-4 sm:px-6 py-10">
  <div class="flex items-center justify-between gap-3 mb-2 no-print">
    <%# A pull sheet is for one specific class, so the day-window pills (which
        re-scope the whole list) don't apply. %>
    <div class="flex items-center gap-3 text-sm">
      <% unless @single_class %>
        <%# Calendar Mon-Sun week windows so they line up with Sam's list and
            Lora's week-based shopping. "Next 2 weeks" = this week + next week. %>
        <% mon = Date.current.beginning_of_week(:monday) %>
        <% sun = Date.current.end_of_week(:monday) %>
        <% pills = [
             { label: "Current week", from: mon,     to: sun },
             { label: "Next week",    from: mon + 7, to: sun + 7 },
             { label: "Next 2 weeks", from: mon,     to: sun + 7 }
           ] %>
        <% pills.each do |p| %>
          <% active = @week_mode && @range && @range.first == p[:from] && @range.last == p[:to] %>
          <%= link_to p[:label], nyk_grocery_path(from: p[:from].iso8601, to: p[:to].iso8601),
                class: "px-2.5 py-1 rounded-full border #{active ? 'bg-orange-600 border-orange-500 text-white' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
        <% end %>
      <% end %>
    </div>
    <%= back_button "← Back to Sam's list", nyk_list_path %>
  </div>

  <%# Screen header only; the printed white sheet carries its own title, so hide
      this on print to avoid a near-empty first page. %>
  <div class="no-print">
    <% if @single_class %>
      <h1 class="text-2xl font-bold text-white mt-3 mb-1">Pull sheet</h1>
      <% if @event_name.present? %><p class="text-sm text-gray-400 mb-6"><%= @event_name %></p><% end %>
    <% else %>
      <h1 class="text-2xl font-bold text-white mt-3 mb-6">Grocery list</h1>
    <% end %>
  </div>

  <%# The list is built by an Opus call, so load it lazily in a frame: this page
      paints instantly and the spinner shows while the list is built (or fetched
      from cache). The frame src carries a single class, a specific week, or a
      day window. %>
  <% frame_params = if @single_class
       { event_url: @event_url, name: @event_name }
     elsif @week_mode
       { from: @range.first.iso8601, to: @range.last.iso8601 }
     else
       { days: @days }
     end %>
  <%= turbo_frame_tag "grocery_list", src: nyk_grocery_path(frame_params), loading: "eager" do %>
    <div class="flex flex-col items-center justify-center py-24 text-gray-500">
      <svg class="animate-spin w-8 h-8 text-orange-500 mb-3" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
      </svg>
      <p class="text-sm">Building your grocery list...</p>
    </div>
  <% end %>
</div>

<%= javascript_tag nonce: true do %>
  document.addEventListener("click", function (e) {
    if (e.target.closest("#grocery-print-btn")) window.print();
  });
  // Opened from the packet Pull sheet "Print" button (?print=1): once the
  // sheet finishes loading in its eager frame, auto-open the print dialog. On
  // the iOS/Android app this page is handed to Safari, where printing works.
  if (new URLSearchParams(location.search).get("print") === "1") {
    document.addEventListener("turbo:frame-load", function (e) {
      if (e.target.id === "grocery_list") setTimeout(function () { window.print(); }, 200);
    }, { once: true });
  }
<% end %>

<style>
  @media print {
    .no-print { display: none !important; }
    /* Hide app chrome so the sheet starts at the top of page 1 (the fixed footer
       and sticky nav otherwise reserve space and push it to a blank page 2). */
    nav, footer { display: none !important; }
    .grocery-shell { padding: 0 !important; max-width: none !important; }
    .print-sheet { box-shadow: none !important; border: 0 !important; padding: 0 !important; }
    body { background: #fff !important; }
  }
</style>
