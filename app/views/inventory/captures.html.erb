<% content_for(:title, "Storage Room · Log") %>
<%= render "inventory/header", active: :captures %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24">
  <h2 class="text-xl font-bold text-white mb-1">Log a product</h2>
  <p class="text-gray-400 text-sm mb-5">Snap a photo, enter the quantity and price, tag the type. Everything you log this month exports to a spreadsheet.</p>

  <%= form_with model: @capture, scope: :capture, url: nyk_inventory_captures_path, method: :post, multipart: true, class: "space-y-4 mb-8", data: { controller: "camera-guard" } do |f| %>
    <% field = "w-full rounded-lg bg-gray-900 border border-gray-700 text-white text-base px-3 py-2.5 focus:border-orange-500 focus:outline-none" %>
    <% label = "block text-xs uppercase tracking-wide text-gray-400 mb-1" %>

    <%# Photo input is hidden until JS confirms the camera is safe to open here
        (mobile Safari/desktop, or an app build with the camera permission). %>
    <div data-camera-guard-target="field" class="hidden">
      <%= f.label :photo, "Photo", class: label %>
      <%= f.file_field :photo, accept: "image/*", capture: "environment",
            class: "block w-full text-sm text-gray-300 file:mr-3 file:px-4 file:py-2.5 file:rounded-lg file:border-0 file:bg-orange-600 file:text-white file:font-semibold hover:file:bg-orange-500 file:cursor-pointer" %>
      <p class="text-xs text-gray-500 mt-1">On a phone this opens the camera. Optional.</p>
    </div>
    <p data-camera-guard-target="note" class="text-xs text-gray-400 rounded-lg bg-gray-900 border border-gray-800 p-3">
      📷 Photo capture comes with the next app update. You can still log quantity &amp; price now, or add photos from your phone's browser.
    </p>

    <div>
      <%= f.label :name, "Product", class: label %>
      <%= f.text_field :name, class: field, placeholder: "e.g. Whispering Angel Rosé" %>
    </div>

    <div class="grid grid-cols-3 gap-3">
      <div>
        <%= f.label :category, "Type", class: label %>
        <%= f.select :category, InventoryCapture::CATEGORIES.map { |c| [ c.capitalize, c ] }, { include_blank: "—" }, class: field %>
      </div>
      <div>
        <%= f.label :quantity, "Qty", class: label %>
        <%= f.number_field :quantity, value: 1, min: 1, inputmode: "numeric", class: field %>
      </div>
      <div>
        <%= f.label :unit_price, "Price (each)", class: label %>
        <%= f.number_field :unit_price, step: "0.01", min: 0, inputmode: "decimal", placeholder: "0.00", class: field %>
      </div>
    </div>

    <div>
      <%= f.label :note, "Note", class: label %>
      <%= f.text_field :note, class: field, placeholder: "optional" %>
    </div>

    <%= f.submit "Log it", class: "w-full px-5 py-3 rounded-xl bg-orange-600 hover:bg-orange-500 text-white font-semibold cursor-pointer" %>
  <% end %>

  <%# Month selector + total + export %>
  <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
    <%= form_with url: nyk_inventory_captures_path, method: :get do %>
      <input type="month" name="month" value="<%= @month_param %>" onchange="this.form.requestSubmit()"
             class="rounded-lg bg-gray-900 border border-gray-700 text-white text-base px-3 py-2 focus:border-orange-500 focus:outline-none">
    <% end %>
    <div class="text-right">
      <div class="text-lg font-black text-white tabular-nums">$<%= "%.2f" % @total %></div>
      <div class="text-[10px] uppercase tracking-wide text-gray-500"><%= @month_label %> total</div>
    </div>
  </div>
  <div class="mb-4">
    <%= link_to "⬇ Export #{@month_label} to spreadsheet (CSV)",
          nyk_inventory_captures_export_path(month: @month_param, format: :csv),
          class: "inline-flex items-center px-3 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-white text-sm font-semibold" %>
  </div>

  <% if @captures.empty? %>
    <p class="text-gray-500 text-sm py-8 text-center rounded-xl border border-dashed border-gray-800">Nothing logged for <%= @month_label %> yet.</p>
  <% else %>
    <div class="overflow-hidden rounded-xl border border-gray-800 divide-y divide-gray-800">
      <% @captures.each do |c| %>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-gray-900">
          <% if c.photo.attached? %>
            <%= image_tag c.photo, class: "w-14 h-14 rounded-lg object-cover shrink-0 bg-gray-800" %>
          <% else %>
            <div class="w-14 h-14 rounded-lg bg-gray-800 grid place-items-center text-gray-600 text-xl shrink-0">📦</div>
          <% end %>
          <div class="min-w-0 flex-1">
            <div class="text-white font-medium truncate"><%= c.name.presence || c.category&.capitalize || "Item" %></div>
            <div class="text-xs text-gray-500 truncate">
              <%= [ c.category&.capitalize, "qty #{c.quantity}", (c.unit_price ? "$#{'%.2f' % c.unit_price} ea" : nil) ].compact.join(" · ") %>
            </div>
            <div class="text-[11px] text-gray-600"><%= c.captured_at.strftime("%b %-d, %-I:%M %p") %><%= " · #{c.user.display_identifier}" if c.user %></div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-white font-semibold tabular-nums">$<%= "%.2f" % c.line_total %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
