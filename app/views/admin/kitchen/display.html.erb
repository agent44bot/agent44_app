<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%# Pull fresh data every 10 minutes. The slideshow keeps cycling
      between refreshes from the JS below. %>
  <meta http-equiv="refresh" content="<%= @agent.setting(:refresh_minutes).to_i * 60 %>">
  <title>NY Kitchen · What's Coming Up</title>
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      background: #ffffff;
      color: #111827;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      overflow: hidden;
    }
    .page {
      height: 100vh;
      display: flex;
      flex-direction: column;
      padding: 4vh 6vw;
    }
    .header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding-bottom: 2vh;
      border-bottom: 2px solid #111827;
    }
    .brand {
      font-size: clamp(20px, 2.4vw, 36px);
      font-weight: 800;
      letter-spacing: 0.01em;
      color: #111827;
    }
    .brand .accent { color: #ea580c; }
    .header .meta {
      font-size: clamp(12px, 1vw, 16px);
      color: #6b7280;
      font-variant-numeric: tabular-nums;
    }
    .stage {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .slide {
      display: none;
      width: 100%;
      max-width: 90vw;
      text-align: center;
    }
    .slide.active { display: block; animation: fade 0.6s ease-out; }
    .slide.with-image {
      display: none;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: 3vw;
      align-items: center;
      text-align: left;
    }
    .slide.with-image.active { display: grid; animation: fade 0.6s ease-out; }
    .slide.with-image .name {
      text-align: left;
      margin-bottom: 2.5vh;
      /* Smaller cap than the no-image variant; long titles otherwise
         dominate the narrow right column. Line-clamp guarantees the
         block height stays sane even for absurdly long class names. */
      font-size: clamp(24px, 3.4vw, 56px);
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 4;
      line-clamp: 4;
      overflow: hidden;
    }
    .slide.with-image .details {
      grid-template-columns: auto 1fr;
      justify-content: start;
      gap: 1.4vh 2vw;
      font-size: clamp(15px, 1.9vw, 30px);
    }
    .slide.with-image .details .icon { text-align: right; }
    .slide.with-image .blurb { text-align: left; }
    .slide.with-image .qr-block { align-items: flex-start; }
    .hero-image {
      width: 100%;
      max-height: 70vh;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    }
    @keyframes fade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .slide .name {
      font-size: clamp(32px, 5.4vw, 92px);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: #111827;
      margin-bottom: 3.5vh;
    }
    .details {
      display: grid;
      grid-template-columns: auto auto;
      gap: 2vh 4vw;
      justify-content: center;
      align-items: center;
      font-size: clamp(18px, 2.6vw, 44px);
      font-weight: 500;
      color: #1f2937;
    }
    .details .icon  { font-size: 1.1em; text-align: right; }
    .details .value { text-align: left; }
    .blurb {
      margin-top: 2.6vh;
      color: #4b5563;
      font-size: clamp(14px, 1.7vw, 26px);
      line-height: 1.4;
      max-width: 46ch;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      line-clamp: 3;
      overflow: hidden;
    }
    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 2vh;
      border-top: 1px solid #e5e7eb;
      font-size: clamp(12px, 1.1vw, 18px);
      color: #6b7280;
    }
    .footer strong { color: #111827; }
    .pulse {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #22c55e;
      margin-right: 8px;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.35 } }
    .empty {
      text-align: center;
      color: #6b7280;
      font-size: clamp(22px, 2.6vw, 40px);
    }
    .qr-block {
      margin-top: 3.5vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.2vh;
    }
    /* QR is black modules on white; on the light page a thin border makes it
       read as a tidy little card. */
    .qr-code {
      background: #fff;
      padding: 1.2vh;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      line-height: 0;
    }
    .qr-code svg {
      width: clamp(110px, 11vw, 190px);
      height: clamp(110px, 11vw, 190px);
      display: block;
    }
    .qr-cap {
      font-size: clamp(13px, 1.3vw, 22px);
      color: #6b7280;
      letter-spacing: 0.01em;
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="header">
      <div class="brand">NY Kitchen <span class="accent">· What's Coming Up</span></div>
      <div class="meta">
        <span class="pulse"></span>
        <span>Next <%= @events.size %> of <%= @available_total %> available<% if @last_updated %> · updated <%= @last_updated.strftime("%b %-d") %><% end %></span>
      </div>
    </header>

    <main class="stage">
      <% if @events.any? %>
        <% @events.each_with_index do |event, i| %>
          <% start = event.start_at %>
          <% date_str = start.strftime("%A, %B %-d") %>
          <% time_str = start.strftime("%-l:%M %p") %>
          <% time_str += " – #{event.end_at.strftime('%-l:%M %p')}" if @agent.setting(:show_end_time) && event.end_at.present? %>
          <% venue = event.venue.presence || "New York Kitchen, Canandaigua" %>
          <% show_image = @agent.setting(:show_image) && event.image_url.present? %>
          <% blurb = event.description.present? ? truncate(strip_tags(event.description).squish, length: 180, separator: " ") : nil %>
          <article class="slide<%= ' with-image' if show_image %><%= ' active' if i == 0 %>">
            <% if show_image %>
              <img class="hero-image" src="<%= event.image_url %>" alt="" loading="lazy">
            <% end %>
            <div>
              <h1 class="name"><%= event.name.presence || "Class at NY Kitchen" %></h1>
              <div class="details">
                <span class="icon">📅</span><span class="value"><%= date_str %></span>
                <span class="icon">⏰</span><span class="value"><%= time_str %></span>
                <% if @agent.setting(:show_price) && event.price.present? %>
                  <% price = event.price.to_s.strip %>
                  <% price = "$#{price}" unless price.match?(/[$£€]/) %>
                  <span class="icon">💵</span><span class="value"><%= price %></span>
                <% end %>
                <span class="icon">📍</span><span class="value"><%= venue %></span>
                <% if @agent.setting(:show_spots) && event.spots_left.present? && event.spots_left > 0 %>
                  <span class="icon">⚡</span><span class="value"><%= event.spots_left %> spot<%= "s" unless event.spots_left == 1 %> left</span>
                <% end %>
              </div>
              <% if blurb.present? %>
                <p class="blurb"><%= blurb %></p>
              <% end %>
              <% if @agent.setting(:show_qr) && event.url.present? %>
                <div class="qr-block">
                  <div class="qr-code"><%= qr_svg(event.url) %></div>
                  <div class="qr-cap">Scan to reserve</div>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      <% else %>
        <div class="empty">
          New classes coming soon.<br>
          Check back at nykitchen.com.
        </div>
      <% end %>
    </main>

    <footer class="footer">
      <span>Visit <strong>nykitchen.com</strong> to reserve</span>
      <span>Auto-refreshes every <%= @agent.setting(:refresh_minutes) %> min</span>
    </footer>
  </div>

  <%= javascript_tag nonce: true do %>
    // Cycle through slides every 10s. Pure CSS class swap — no Stimulus
    // needed since this page runs no app JS stack.
    (function() {
      var slides = document.querySelectorAll('.slide');
      if (slides.length < 2) return;
      var i = 0;
      setInterval(function() {
        slides[i].classList.remove('active');
        i = (i + 1) % slides.length;
        slides[i].classList.add('active');
      }, <%= @agent.setting(:advance_seconds).to_i * 1000 %>);
    })();

    // Liveness heartbeat: let the hub know this screen is on. Only fires when
    // the URL carries a share token (private mode) — the server records
    // last-seen only when it matches, so the Display Agent dot reflects the
    // real kitchen screen, not a public-URL visitor. Beats now + every 60s.
    (function() {
      var token = new URLSearchParams(location.search).get('token');
      if (!token) return;
      function beat() {
        fetch('<%= nyk_display_heartbeat_path %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'token=' + encodeURIComponent(token),
          keepalive: true
        }).catch(function() {});
      }
      beat();
      setInterval(beat, 60000);
    })();
  <% end %>
</body>
</html>
