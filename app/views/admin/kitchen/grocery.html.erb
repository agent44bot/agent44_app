<div class="grocery-shell max-w-3xl mx-auto px-4 sm:px-6 py-10">
  <div class="flex items-center justify-between gap-3 mb-2 no-print">
    <%# A pull sheet is for one specific class, so the day-window pills (which
        re-scope the whole list) don't apply. %>
    <div class="flex items-center gap-3 text-sm">
      <% unless @single_class %>
        <%# Calendar Mon-Sun week windows so they line up with Sam's list and
            Lora's week-based shopping. "Next 2 weeks" = this week + next week. %>
        <% mon = Date.current.beginning_of_week(:monday) %>
        <% sun = Date.current.end_of_week(:monday) %>
        <% pills = [
             { label: "Current week", from: mon,     to: sun },
             { label: "Next week",    from: mon + 7, to: sun + 7 },
             { label: "Next 2 weeks", from: mon,     to: sun + 7 }
           ] %>
        <% pills.each do |p| %>
          <% active = @week_mode && @range && @range.first == p[:from] && @range.last == p[:to] %>
          <%= link_to p[:label], nyk_grocery_path(from: p[:from].iso8601, to: p[:to].iso8601),
                class: "px-2.5 py-1 rounded-full border #{active ? 'bg-orange-600 border-orange-500 text-white' : 'bg-gray-900 border-gray-800 text-gray-300 hover:border-orange-500'}" %>
        <% end %>
      <% end %>
    </div>
    <%= back_button "← Back to Sam's list", nyk_list_path %>
  </div>

  <%# Custom date range: the pills above are quick shortcuts; this lets Lora
      shop any window (e.g. today through two weeks out). The grocery action
      already scopes by from/to, so this just submits those two dates. %>
  <% unless @single_class %>
    <%# Default the fields to at least today: the current-week range starts on
        Monday, but you shop from today forward, so never prefill a past date. %>
    <% picker_from = [ @range.first, Date.current ].max %>
    <% picker_to   = [ @range.last, Date.current ].max %>
    <%= form_with url: nyk_grocery_path, method: :get, class: "flex items-end gap-2 flex-wrap mb-6 no-print" do %>
      <div>
        <label for="groc-from" class="block text-xs text-gray-500 mb-1">From</label>
        <input type="date" id="groc-from" name="from" value="<%= picker_from.iso8601 %>"
               min="<%= Date.current.iso8601 %>"
               class="rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2 focus:border-orange-500 focus:outline-none">
      </div>
      <div>
        <label for="groc-to" class="block text-xs text-gray-500 mb-1">To</label>
        <input type="date" id="groc-to" name="to" value="<%= picker_to.iso8601 %>"
               min="<%= Date.current.iso8601 %>"
               class="rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2 focus:border-orange-500 focus:outline-none">
      </div>
      <button type="submit"
              class="px-4 py-2 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer">Generate</button>
    <% end %>
  <% end %>

  <%# Screen header only; the printed white sheet carries its own title, so hide
      this on print to avoid a near-empty first page. %>
  <div class="no-print">
    <% if @single_class %>
      <h1 class="text-2xl font-bold text-white mt-3 mb-1">Pull sheet</h1>
      <% if @event_name.present? %><p class="text-sm text-gray-400 mb-6"><%= @event_name %></p><% end %>
    <% else %>
      <h1 class="text-2xl font-bold text-white mt-3 mb-6">Grocery list</h1>
    <% end %>
  </div>

  <%# Manager-only (owner/admin) control to show/hide the rough dollar estimates
      on this list. Lives here so Lora flips it right where the prices appear,
      not buried in workspace settings. Hidden on a single-class pull sheet
      (which never shows prices) and for non-managers. %>
  <% if !@single_class && @nyk_workspace && %w[owner admin].include?(@my_workspace_role) %>
    <% grocery_prices_on = @nyk_workspace.show_grocery_prices? %>
    <div class="rounded-lg border border-gray-800 bg-gray-900 px-4 py-3 mb-6 flex items-center justify-between gap-3 flex-wrap no-print">
      <div class="min-w-0">
        <p class="text-sm text-white">Show grocery price estimates</p>
        <p class="text-xs text-gray-500 mt-0.5">When on, the grocery list shows rough dollar estimates. Keep off until real prices are uploaded.</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span class="text-xs font-semibold uppercase <%= grocery_prices_on ? 'text-gray-500' : 'text-gray-300' %>">Off</span>
        <%= button_to toggle_grocery_prices_workspace_path(@nyk_workspace.slug),
              method: :post,
              form_class: "inline-flex",
              data: { test: "grocery-prices-toggle" },
              aria: { label: "Show grocery price estimates", checked: grocery_prices_on.to_s },
              class: "relative inline-flex h-6 w-11 items-center rounded-full transition cursor-pointer #{grocery_prices_on ? 'bg-green-600 hover:bg-green-500' : 'bg-gray-700 hover:bg-gray-600'}" do %>
          <span class="absolute inline-block h-5 w-5 rounded-full bg-white shadow transition transform <%= grocery_prices_on ? 'translate-x-5' : 'translate-x-0.5' %>"></span>
        <% end %>
        <span class="text-xs font-semibold uppercase <%= grocery_prices_on ? 'text-green-400' : 'text-gray-500' %>">On</span>
      </div>
    </div>
  <% end %>

  <%# The list is built by an Opus call, so load it lazily in a frame: this page
      paints instantly and the spinner shows while the list is built (or fetched
      from cache). The frame src carries a single class, a specific week, or a
      day window. %>
  <% frame_params = if @single_class
       { event_url: @event_url, name: @event_name }
     elsif @week_mode
       { from: @range.first.iso8601, to: @range.last.iso8601 }
     else
       { days: @days }
     end %>
  <%= turbo_frame_tag "grocery_list", src: nyk_grocery_path(frame_params), loading: "eager" do %>
    <div class="flex flex-col items-center justify-center py-24 text-gray-500">
      <svg class="animate-spin w-8 h-8 text-orange-500 mb-3" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
      </svg>
      <p class="text-sm">Building your grocery list...</p>
    </div>
  <% end %>
</div>

<%= javascript_tag nonce: true do %>
  document.addEventListener("click", function (e) {
    if (e.target.closest("#grocery-print-btn")) window.print();
  });
  // Opened from the packet Pull sheet Print button: once the sheet finishes
  // loading in its eager frame, auto-open the browser print flow.
  // On the iOS/Android app this page is handed to Safari, where printing works.
  const sheetParams = new URLSearchParams(location.search);
  if (sheetParams.get("print") === "1") {
    document.addEventListener("turbo:frame-load", function (e) {
      if (e.target.id === "grocery_list") setTimeout(function () { window.print(); }, 200);
    }, { once: true });
  }
<% end %>

<style>
  @media print {
    .no-print { display: none !important; }
    /* Hide app chrome so the sheet starts at the top of page 1 (the fixed footer
       and sticky nav otherwise reserve space and push it to a blank page 2). */
    nav, footer { display: none !important; }
    .grocery-shell { padding: 0 !important; max-width: none !important; }
    .print-sheet { box-shadow: none !important; border: 0 !important; padding: 0 !important; }
    body { background: #fff !important; }
  }
</style>
