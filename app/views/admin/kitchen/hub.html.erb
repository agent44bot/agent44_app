<% content_for(:title, "NY Kitchen") %>

<%
  social_href = @nyk_workspace ? nyk_social_path : workspaces_path

  # Agent-presence dot: pulsing green = actively running, solid red =
  # last finished run failed (sustained until next pass), solid green =
  # on-cadence, gray = stale (no recent activity).
  agent_dot = ->(state) {
    case state
    when :running    then %(<span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.7)]" title="Running now"></span>).html_safe
    when :failed     then %(<span class="inline-block w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.7)]" title="Last run failed"></span>).html_safe
    when :on_cadence then %(<span class="inline-block w-2 h-2 rounded-full bg-green-500" title="On cadence"></span>).html_safe
    else                  %(<span class="inline-block w-2 h-2 rounded-full bg-gray-600" title="Idle / stale"></span>).html_safe
    end
  }

  # Renders the small "#207" badge (with optional pet name) next to
  # an agent's title. Returns "" if @workspace_agents doesn't have the
  # kind (anonymous viewer of /nykitchen, no workspace yet).
  agent_badge = ->(kind) {
    a = @workspace_agents[kind.to_s]
    return "".html_safe unless a
    name_part = a.display_name.present? ? %(<span class="text-orange-300/90 font-semibold">#{ERB::Util.h(a.display_name)}</span> · ) : ""
    %(<span class="ml-1 text-xs text-gray-500 font-mono">#{name_part}##{a.agent_number}</span>).html_safe
  }

  # Public profile URL for a connected social account, used by the
  # Social Agent card on the hub. Returns "#" for platforms we can't
  # construct one for so the link still renders harmlessly.
  platform_profile_url = ->(acct) {
    handle = acct.handle.to_s.delete_prefix("@")
    case acct.platform
    when "x"        then "https://x.com/#{handle}"
    when "bluesky"  then "https://bsky.app/profile/#{handle}"
    when "threads"  then "https://www.threads.net/@#{handle}"
    when "facebook" then "https://www.facebook.com/#{handle}"
    else                 "#"
    end
  }

  # Format minutes for the work-time meter. < 60 stays in minutes;
  # otherwise Xh Ym.
  humanize_minutes = ->(min) {
    return "0 min" if min.to_i.zero?
    return "#{min} min" if min < 60
    hours = min / 60
    rem   = min % 60
    rem.positive? ? "#{hours}h #{rem}m" : "#{hours}h"
  }

  # Headline label uses the last *finished* row so an in-flight run
  # doesn't blank out "Passed N ago".
  smoke_status_color = if @hub_smoke_last_finished.nil?            then "text-gray-500"
                      elsif @hub_smoke_last_finished.passed?      then "text-green-400"
                      else                                              "text-red-400"
                      end
  smoke_status_label = if @hub_smoke_last_finished.nil?       then "No runs yet"
                      elsif @hub_smoke_last_finished.passed? then "✓ Passed"
                      else                                        "🚨 Failed"
                      end
  fail_rate_color = @hub_smoke_fail_rate_30d >= 20 ? "text-red-400" :
                    @hub_smoke_fail_rate_30d >= 5  ? "text-amber-400" :
                                                     "text-green-400"
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
     data-controller="collapsible"
     data-collapsible-collapsed-value="true"
     data-collapsible-scroll-on-expand-value="true">
  <div class="flex justify-end mb-6 text-sm">
    <%= link_to workspaces_path(force: 1), class: "text-gray-500 hover:text-gray-300 transition" do %>
      ← All workspaces
    <% end %>
  </div>

  <div class="mb-8">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <h1 class="text-3xl font-black text-white tracking-tight">NY Kitchen</h1>
      <div class="flex items-center gap-2">
        <% if @nyk_workspace %>
          <button type="button"
                  data-action="click->collapsible#toggle"
                  aria-label="Workspace settings"
                  class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/>
            </svg>
          </button>
        <% end %>
      </div>
    </div>
    <p class="text-gray-400 mt-1">NY Kitchen Agent Team — <%= pluralize(WorkspaceAgent::KINDS.size, "helper") %> on the job.</p>
  </div>

  <% if @nyk_workspace %>
    <div data-collapsible-target="body" class="mb-8">
      <%= render "workspaces/team",
            workspace:       @nyk_workspace,
            memberships:     @nyk_memberships,
            invitations:     @nyk_invitations,
            social_accounts: @nyk_social_accounts,
            my_role:         @nyk_my_role %>
    </div>
  <% end %>

  <%# Same card chrome for every agent — equal padding, equal height (via
      auto-rows-fr + h-full), description line under the title. Card body
      uses flex-col so the status stats sit at the bottom regardless of
      varying content length. %>
  <% card_class   = "block h-full flex flex-col bg-gray-900 hover:bg-gray-850 border border-gray-800 hover:border-orange-500/50 rounded-xl p-7 transition group" %>
  <% desc_class   = "text-sm text-gray-400 mb-4" %>
  <% stats_class  = "space-y-1.5 text-sm mt-auto" %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 auto-rows-fr">
    <%= link_to nyk_list_path, class: card_class do %>
      <div class="flex items-start justify-between mb-2">
        <div class="flex items-center gap-2">
          <span class="text-2xl">📋</span>
          <h2 class="text-lg font-bold text-white">List Agent</h2>
          <%= agent_badge.call(:list) %>
          <%= agent_dot.call(@hub_agent_status[:list]) %>
        </div>
        <span class="text-gray-600 group-hover:text-orange-400 transition">→</span>
      </div>
      <p class="<%= desc_class %>">Watches the calendar and surfaces what's coming up — by week, with sold-out percentages.</p>
      <div class="flex-1 flex items-center justify-center py-3">
        <div class="text-center">
          <div class="text-3xl font-black text-white tabular-nums">
            <%= @hub_tickets_sold_today.nil? ? "—" : @hub_tickets_sold_today %>
          </div>
          <div class="text-xs uppercase tracking-wide text-gray-500 mt-1">tickets sold today</div>
          <% if @hub_tickets_pace_pct %>
            <% pace_color, pace_label =
                 if @hub_tickets_pace_pct >= 10
                   ["text-green-400", "#{@hub_tickets_pace_pct}% above daily pace"]
                 elsif @hub_tickets_pace_pct <= -10
                   ["text-red-400",   "#{@hub_tickets_pace_pct.abs}% below daily pace"]
                 else
                   ["text-gray-500",  "on daily pace"]
                 end %>
            <div class="text-xs <%= pace_color %> mt-1 tabular-nums"
                 title="Expected ~<%= @hub_tickets_expected_by_now %> sold by now if today tracked the 14-day daily average (<%= @hub_tickets_sold_avg %>) linearly across an 8am–8pm window.">
              <%= pace_label %>
            </div>
          <% end %>
        </div>
      </div>
      <div class="<%= stats_class %>">
        <div class="text-gray-300"><span class="font-semibold text-white"><%= @hub_events_total %></span> upcoming classes</div>
        <% if @hub_events_updated %>
          <div class="text-gray-500">Updated <%= @hub_events_updated.strftime("%b %-d") %></div>
        <% end %>
      </div>
    <% end %>

    <div class="<%= card_class.sub('block ', '') %>">
      <div class="flex items-start justify-between mb-2">
        <%= link_to social_href, class: "flex items-center gap-2 group/title" do %>
          <span class="text-2xl">📣</span>
          <h2 class="text-lg font-bold text-white group-hover/title:text-orange-400 transition">Social Agent</h2>
          <%= agent_badge.call(:social) %>
          <%= agent_dot.call(@hub_agent_status[:social]) %>
        <% end %>
        <%= link_to social_href, class: "text-gray-600 hover:text-orange-400 transition" do %>→<% end %>
      </div>
      <p class="<%= desc_class %>">Drafts and posts to your connected social accounts. Hand off a class with one click.</p>
      <div class="<%= stats_class %>">
        <% if @nyk_workspace %>
          <% connected   = @nyk_workspace.social_accounts.active.order(:platform).to_a %>
          <% all_present = @nyk_workspace.social_accounts.pluck(:platform).uniq %>
          <% unconfigured = %w[threads facebook] - all_present %>

          <% if connected.any? || unconfigured.any? %>
            <% connected.each do |acct| %>
              <%= link_to platform_profile_url.call(acct), target: "_blank", rel: "noopener",
                    class: "flex items-center justify-between text-gray-200 hover:text-orange-400 transition" do %>
                <span><%= acct.platform.capitalize %></span>
                <span class="inline-block w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
              <% end %>
            <% end %>
            <% unconfigured.each do |platform| %>
              <%= link_to social_href, class: "flex items-center justify-between text-gray-400 hover:text-orange-400 transition" do %>
                <span><%= platform.capitalize %></span>
                <span class="text-xs text-orange-400/80">(setup)</span>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <div class="text-gray-500">No NY Kitchen workspace yet</div>
          <div class="text-gray-500">Click to set one up</div>
        <% end %>
      </div>
    </div>

    <%= link_to nyk_display_settings_path, class: card_class do %>
      <div class="flex items-start justify-between mb-2">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🖥</span>
          <h2 class="text-lg font-bold text-white">Display Agent</h2>
          <%= agent_badge.call(:display) %>
        </div>
        <span class="text-gray-600 group-hover:text-orange-400 transition">→</span>
      </div>
      <p class="<%= desc_class %>">Cycles your live classes on a screen for walk-in customers — sold-out classes drop off automatically. Also prints a paper schedule for the counter.</p>
      <div class="<%= stats_class %>">
        <% display_agent = @workspace_agents["display"] %>
        <div class="text-gray-300"><span class="font-semibold text-white"><%= display_agent&.setting(:slide_count) || 5 %></span> slides · <%= display_agent&.setting(:advance_seconds) || 10 %>s each</div>
        <div class="text-gray-500 truncate font-mono text-xs"><%= nyk_display_path %></div>
        <div class="text-gray-500">🖨 Printable schedule</div>
      </div>
    <% end %>

    <%= link_to nyk_data_path, class: card_class do %>
      <div class="flex items-start justify-between mb-2">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🕷️</span>
          <h2 class="text-lg font-bold text-white">Data Agent</h2>
          <%= agent_badge.call(:data) %>
          <%= agent_dot.call(@hub_agent_status[:data]) %>
        </div>
        <span class="text-gray-600 group-hover:text-orange-400 transition">→</span>
      </div>
      <p class="<%= desc_class %>">Snapshots the calendar every three hours — feeds the List Agent and powers ticket-change alerts.</p>
      <div class="<%= stats_class %>">
        <% if @hub_scrape_last_finished %>
          <div class="text-green-400 font-semibold">✓ Last snapshot <%= time_ago_in_words(@hub_scrape_last_finished.started_at) %> ago</div>
        <% else %>
          <div class="text-gray-500 font-semibold">No snapshots yet</div>
        <% end %>
        <div class="text-gray-500">Worked <%= humanize_minutes.call(@hub_scrape_total_minutes) %> · <%= @hub_scrape_total %> runs<% if @can_see_pricing %> · $<%= "%.2f" % @hub_scrape_cost_total %><% end %></div>
      </div>
    <% end %>

    <%= link_to nyk_test_path, class: card_class do %>
      <div class="flex items-start justify-between mb-2">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🔁</span>
          <h2 class="text-lg font-bold text-white">Test Agent</h2>
          <%= agent_badge.call(:test) %>
          <%= agent_dot.call(@hub_agent_status[:test]) %>
        </div>
        <span class="text-gray-600 group-hover:text-orange-400 transition">→</span>
      </div>
      <p class="<%= desc_class %>">Round-trips the calendar every hour to catch broken pages or missing classes before customers do.</p>
      <div class="<%= stats_class %>">
        <div class="<%= smoke_status_color %> font-semibold"><%= smoke_status_label %><% if @hub_smoke_last_finished %> <%= time_ago_in_words(@hub_smoke_last_finished.started_at) %> ago<% end %></div>
        <div class="text-gray-400"><span class="<%= fail_rate_color %> font-semibold"><%= @hub_smoke_fail_rate_30d %>%</span> fail rate (30d)</div>
        <div class="text-gray-500">Worked <%= humanize_minutes.call(@hub_smoke_total_minutes) %> · <%= @hub_smoke_total %> runs<% if @can_see_pricing %> · $<%= "%.2f" % @hub_smoke_cost_total %><% end %></div>
      </div>
    <% end %>

  </div>

</div>
