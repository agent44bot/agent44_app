<%# Overlapping stack of a workspace's member avatars. Photo if set, else
    initials. Callers pass the members to show; today they exclude the owner
    (the Agent44 Labs side) so the stack shows the customer's team.
    Locals:
      members — array of User
      limit   — max avatars before a "+N" chip (default 4)
      size    — Tailwind h/w pair (default "h-8 w-8")
%>
<% members = Array(members) %>
<% limit ||= 4 %>
<% size  ||= "h-8 w-8" %>
<% return if members.empty? %>
<div class="flex -space-x-2 shrink-0">
  <% members.first(limit).each do |u| %>
    <%= user_avatar_tag u, size: size %>
  <% end %>
  <% if members.size > limit %>
    <%# Hover the +N chip to see who's hidden. %>
    <span title="<%= members[limit..].map(&:display_identifier).join(", ") %>"
          class="<%= size %> rounded-full bg-gray-800 text-gray-300 ring-2 ring-gray-950 inline-flex items-center justify-center text-xs font-semibold shrink-0 cursor-default">+<%= members.size - limit %></span>
  <% end %>
</div>
