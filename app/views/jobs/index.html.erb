<% content_for(:title, "Jobs") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">SDET & Test Automation Jobs</h1>
    <p class="mt-2 text-gray-500">Curated positions from across the web, updated daily.</p>
  </div>

  <!-- Search -->
  <div class="mb-6">
    <%= form_with url: jobs_path, method: :get, class: "flex gap-3", data: { turbo_frame: "jobs_list" } do |f| %>
      <div class="flex-1 relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" id="search-input" value="<%= params[:q] %>" placeholder="Search by title, company, or keyword..."
               class="w-full pl-10 pr-10 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
               oninput="document.getElementById('search-clear').style.display = this.value ? 'block' : 'none'">
        <a href="<%= jobs_path(category: params[:category], source: params[:source]) %>"
           id="search-clear"
           class="text-gray-400 hover:text-gray-600 transition"
           style="position:absolute; right:12px; top:50%; transform:translateY(-50%); z-index:10; <%= params[:q].present? ? '' : 'display:none;' %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </a>
      </div>
      <button type="submit" class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition">
        Search
      </button>
    <% end %>
  </div>

  <!-- Sort & Saved Filter -->
  <div class="flex items-center gap-4 mb-6">
    <div class="flex items-center gap-2">
      <span class="text-sm text-gray-500">Sort by:</span>
      <% sort_options = [["Newest", nil], ["Salary: High to Low", "salary_desc"], ["Salary: Low to High", "salary_asc"]] %>
      <% sort_options.each do |label, value| %>
        <% active = params[:sort] == value || (value.nil? && params[:sort].blank?) %>
        <%= link_to jobs_path(sort: value, category: params[:category], q: params[:q], source: params[:source], saved: params[:saved]),
              class: "px-3 py-1.5 text-xs font-medium rounded-full transition #{active ? 'bg-indigo-600 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}",
              data: { turbo_frame: "jobs_list" } do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
    <% if authenticated? %>
      <div class="flex items-center gap-2 ml-auto">
        <% saved_active = params[:saved] == "1" %>
        <%= link_to jobs_path(saved: saved_active ? nil : "1", sort: params[:sort], category: params[:category], q: params[:q], source: params[:source]),
              class: "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full transition #{saved_active ? 'bg-red-500 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}",
              data: { turbo_frame: "jobs_list" } do %>
          <svg class="w-3.5 h-3.5" fill="<%= saved_active ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
          Saved (<%= @saved_job_ids.size %>)
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Category Tabs -->
  <div class="flex flex-wrap gap-2 mb-8 border-b border-gray-200 pb-4">
    <%
      categories = [
        ["All", nil],
        ["New Today", "new_today"],
        ["Full-Time", "full_time"],
        ["Part-Time", "part_time"],
        ["Contract", "contract"],
        ["AI", "ai"]
      ]
    %>
    <% categories.each do |label, value| %>
      <% active = params[:category] == value || (value.nil? && params[:category].blank?) %>
      <% count = value.nil? ? @total_count : (value == "new_today" ? @new_today_count : (@category_counts[value] || 0)) %>
      <%= link_to jobs_path(category: value, q: params[:q], source: params[:source], sort: params[:sort], saved: params[:saved]),
            class: "px-4 py-2 text-sm font-medium rounded-full transition #{active ? 'bg-indigo-600 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}",
            data: { turbo_frame: "jobs_list" } do %>
        <%= label %> <span class="<%= active ? 'text-indigo-200' : 'text-gray-400' %>">(<%= count %>)</span>
      <% end %>
    <% end %>
  </div>

  <!-- Source / Job Board Tabs -->
  <% if @source_counts.any? %>
    <div class="flex flex-wrap gap-2 mb-8">
      <span class="px-2 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wide">Job Board:</span>
      <%
        source_labels = {
          "remoteok" => "RemoteOK",
          "arbeitnow" => "Arbeitnow",
          "jobicy" => "Jobicy",
          "welcometothejungle" => "WTTJ",
          "linkedin" => "LinkedIn",
          "indeed" => "Indeed",
          "glassdoor" => "Glassdoor",
          "google_jobs" => "Google Jobs",
          "jsearch" => "JSearch",
          "devitjobs" => "DevITjobs"
        }
      %>
      <% active_source = params[:source] %>
      <% source_active = active_source.blank? %>
      <%= link_to jobs_path(category: params[:category], q: params[:q], sort: params[:sort], saved: params[:saved]),
            class: "px-3 py-1.5 text-xs font-medium rounded-full transition #{source_active ? 'bg-indigo-600 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}",
            data: { turbo_frame: "jobs_list" } do %>
        All <span class="<%= source_active ? 'text-indigo-200' : 'text-gray-400' %>">(<%= @source_counts.values.sum %>)</span>
      <% end %>
      <% @source_counts.sort_by { |_, c| -c }.each do |src, count| %>
        <% next if src.blank? %>
        <% active = active_source == src %>
        <%= link_to jobs_path(category: params[:category], q: params[:q], source: src, sort: params[:sort], saved: params[:saved]),
              class: "px-3 py-1.5 text-xs font-medium rounded-full transition #{active ? 'bg-indigo-600 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}",
              data: { turbo_frame: "jobs_list" } do %>
          <%= source_labels[src] || src.titleize %> <span class="<%= active ? 'text-indigo-200' : 'text-gray-400' %>">(<%= count %>)</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Trend Charts -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <h3 class="text-lg font-semibold text-gray-900 mb-1">Traditional SDET & Test Automation</h3>
      <p class="text-sm text-gray-500 mb-4">Standard QA, SDET, and test engineer roles (from Mar 15)</p>
      <canvas id="autoChart" height="80"></canvas>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <h3 class="text-lg font-semibold text-gray-900 mb-1">AI-Enabled SDET & Test Automation</h3>
      <p class="text-sm text-gray-500 mb-4">Roles requiring AI/ML testing skills (from Mar 15)</p>
      <canvas id="aiChart" height="80"></canvas>
    </div>
  </div>

  <% content_for(:head) do %>
    <%= javascript_include_tag "chart.umd.min" %>
  <% end %>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const labels = <%= raw @trend_labels.map { |d| d.strftime("%-b %-d") }.to_json %>;

      function trendInfo(data) {
        const total = data.reduce((a, b) => a + b, 0);
        const mid = Math.floor(data.length / 2);
        const firstHalf = data.slice(0, mid).reduce((a, b) => a + b, 0);
        const secondHalf = data.slice(mid).reduce((a, b) => a + b, 0);
        const trending = secondHalf > firstHalf ? "up" : secondHalf < firstHalf ? "down" : "flat";
        const pct = firstHalf > 0 ? Math.round(Math.abs(secondHalf - firstHalf) / firstHalf * 100) : 0;
        return { total, trending, pct };
      }

      function buildChart(canvasId, data, accentColor, yMax) {
        const ctx = document.getElementById(canvasId);
        if (!ctx) return;
        const info = trendInfo(data);
        const color = info.trending === "up" ? "rgb(34,197,94)" : info.trending === "down" ? "rgb(239,68,68)" : accentColor;

        new Chart(ctx, {
          type: "line",
          data: {
            labels: labels,
            datasets: [{
              label: "Jobs posted",
              data: data,
              borderColor: color,
              backgroundColor: color.replace("rgb", "rgba").replace(")", ",0.1)"),
              fill: true, tension: 0.3, pointRadius: 2, pointHoverRadius: 5
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: { display: false },
              tooltip: { callbacks: { label: function(item) { return item.raw + " jobs posted"; } } }
            },
            scales: {
              y: { beginAtZero: true, max: yMax, ticks: { precision: 0 } },
              x: { ticks: { maxTicksLimit: 8 } }
            }
          }
        });

        const arrow = info.trending === "up" ? "&#9650;" : info.trending === "down" ? "&#9660;" : "&#9654;";
        const cls = info.trending === "up" ? "text-green-600" : info.trending === "down" ? "text-red-500" : "text-gray-500";
        const word = info.trending === "up" ? "increase" : info.trending === "down" ? "decrease" : "no change";
        const el = document.createElement("div");
        el.className = "mt-3 flex items-center gap-2 text-sm";
        el.innerHTML = `<span class="font-semibold ${cls}">${arrow} ${info.pct}% ${word}</span><span class="text-gray-400">vs prev 15 days (${info.total} total)</span>`;
        ctx.parentNode.appendChild(el);
      }

      const autoData = <%= raw @trend_data_auto.to_json %>;
      const aiData = <%= raw @trend_data_ai.to_json %>;
      const sharedMax = Math.max(...autoData, ...aiData);

      buildChart("autoChart", autoData, "rgb(99,102,241)", sharedMax);
      buildChart("aiChart", aiData, "rgb(139,92,246)", sharedMax);
    });
  </script>

  <style>
    .job-tooltip { pointer-events: none; }
  </style>
  <script>
    function showJobTooltip(el) {
      const tooltip = el.querySelector('.job-tooltip');
      if (tooltip) tooltip.classList.remove('hidden');
    }
    function hideJobTooltip(el) {
      const tooltip = el.querySelector('.job-tooltip');
      if (tooltip) tooltip.classList.add('hidden');
    }
  </script>

  <!-- Job List -->
  <%= turbo_frame_tag "jobs_list" do %>
    <% if @jobs.present? %>
      <div class="space-y-4">
        <% @jobs.each do |job| %>
          <div class="<%= job.posted_today? ? 'bg-green-50 rounded-xl border border-green-300 p-6 hover:shadow-md hover:border-green-400 transition group' : 'bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md hover:border-indigo-200 transition group' %>">
            <div class="flex items-start gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-1 relative">
                  <h2 class="text-lg font-semibold text-gray-900 group-hover:text-indigo-600 transition truncate"
                      onmouseenter="showJobTooltip(this.parentElement)" onmouseleave="hideJobTooltip(this.parentElement)">
                    <%= link_to job.title, job_path(job), data: { turbo_frame: "_top" } %>
                  </h2>
                  <% if job.description.present? %>
                    <div class="job-tooltip hidden absolute left-0 top-full mt-2 z-50 w-[32rem] max-h-96 overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-xl p-4 text-sm text-gray-700 font-normal whitespace-normal">
                      <%= simple_format(job.description) %>
                    </div>
                  <% end %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 whitespace-nowrap">
                    <%= job.category&.titleize || "General" %>
                  </span>
                  <% if job.posted_today? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700 whitespace-nowrap">
                      New
                    </span>
                  <% end %>
                </div>
                <p class="text-sm text-gray-600"><%= job.company %></p>
                <div class="mt-2 flex flex-wrap items-center gap-4 text-xs text-gray-400">
                  <% if job.location.present? %>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      <%= job.location %>
                    </span>
                  <% end %>
                  <% if job.salary.present? %>
                    <span class="text-green-600 font-medium"><%= job.salary %></span>
                  <% end %>
                  <% if job.url.present? %>
                    <%= link_to job.url, target: "_blank", rel: "noopener noreferrer", class: "flex items-center gap-1 text-indigo-500 hover:text-indigo-700 transition" do %>
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                      See listing
                    <% end %>
                  <% end %>
                  <% if job.source.present? %>
                    <%= link_to jobs_path(source: job.source),
                          class: "hover:text-indigo-600 transition",
                          data: { turbo_frame: "_top" } do %>
                      via <%= job.source %>
                    <% end %>
                  <% end %>
                  <span><%= days_ago_in_words(job.posted_at) %></span>
                </div>
              </div>
              <% if authenticated? %>
                <% saved = @saved_job_ids.include?(job.id) %>
                <% if saved %>
                  <%= button_to job_saved_job_path(job), method: :delete, class: "flex-shrink-0 p-2 rounded-lg hover:bg-red-50 transition", title: "Unsave job", data: { turbo_frame: "_top" } do %>
                    <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
                  <% end %>
                <% else %>
                  <%= button_to job_saved_job_path(job), method: :post, class: "flex-shrink-0 p-2 rounded-lg hover:bg-indigo-50 transition", title: "Save job", data: { turbo_frame: "_top" } do %>
                    <svg class="w-5 h-5 text-gray-300 hover:text-indigo-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @jobs.respond_to?(:total_pages) && @jobs.total_pages > 1 %>
        <div class="mt-8 flex justify-center">
          <%== pagy_nav(@pagy) if defined?(@pagy) %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-16">
        <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">No jobs found</h3>
        <p class="mt-1 text-sm text-gray-500">Try adjusting your search or filters.</p>
      </div>
    <% end %>
  <% end %>
</div>
