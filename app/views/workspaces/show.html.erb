<% content_for :title, @workspace.name %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
     data-controller="collapsible"
     data-collapsible-collapsed-value="true">
  <div class="flex items-center gap-3 mb-6 text-sm">
    <%= link_to workspaces_path, class: "text-gray-500 hover:text-gray-300 transition" do %>
      ← All workspaces
    <% end %>
  </div>

  <div class="mb-8 flex items-start justify-between gap-2 flex-wrap">
    <div>
      <h1 class="text-3xl font-black text-white tracking-tight"><%= @workspace.name %></h1>
      <p class="text-gray-400 mt-1">
        <span class="text-xs text-gray-500 font-mono">/<%= @workspace.slug %></span>
        &middot; <%= @workspace.timezone %>
      </p>
    </div>
    <button type="button"
            data-action="click->collapsible#toggle"
            aria-label="Workspace settings"
            class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white transition">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/>
      </svg>
    </button>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= link_to social_workspace_path(@workspace.slug),
          class: "block bg-gray-900 hover:bg-gray-850 border border-gray-800 hover:border-orange-500/50 rounded-xl p-5 transition group" do %>
      <div class="flex items-start justify-between mb-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl">📣</span>
          <h2 class="text-lg font-bold text-white">Social Agent</h2>
        </div>
        <span class="text-gray-600 group-hover:text-orange-400 transition">→</span>
      </div>
      <div class="space-y-1 text-sm">
        <% if @platforms_connected.any? %>
          <div class="text-gray-300"><%= @platforms_connected.join(" · ") %> connected</div>
        <% else %>
          <div class="text-gray-500">No platforms connected yet</div>
        <% end %>
        <div class="text-gray-500">
          <%= pluralize(@posts_total, "post") %><% if @last_post_at %> · last <%= time_ago_in_words(@last_post_at) %> ago<% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div data-collapsible-target="body">
    <%= render "team",
          workspace:       @workspace,
          memberships:     @memberships,
          invitations:     @invitations,
          social_accounts: @social_accounts,
          my_role:         @my_role %>
  </div>
</div>
