<% content_for(:title, "Your Fleet") %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-white">
    Hi, <%= Current.session.user.display_name.presence || Current.session.user.email_address.split("@").first %> 👋
  </h1>
  <p class="text-gray-400 mt-1 mb-6 text-sm">
    No agents are working for you yet.
  </p>

  <% if @latest_request && @latest_request.status == "pending" %>
    <div class="rounded-lg bg-green-950/40 border border-green-700 p-4 mb-6">
      <p class="text-sm text-green-300 font-medium mb-1">
        Got it — Rich will reach out within one business day.
      </p>
      <p class="text-xs text-gray-400">
        Requested: <%= @latest_request.services_labels.presence&.join(", ") || "(no services picked yet)" %>
        &middot; <%= time_ago_in_words(@latest_request.created_at) %> ago
      </p>
    </div>
  <% end %>

  <h2 class="text-base font-semibold text-white mb-3">What can a fleet do for you?</h2>
  <p class="text-sm text-gray-400 mb-4">
    Pick what you'd like to delegate to AI agents. We'll scope and set it up.
  </p>

  <%= form_with url: fleet_requests_path, method: :post, local: true,
        data: { controller: "fleet-picker" }, class: "space-y-3 mb-6" do |f| %>
    <% [
         ["smoke",   "🤖", "Smoke testing", "End-to-end checks of your most important user journeys, with diagnostic emails when something breaks."],
         ["monitor", "📅", "Calendar / content monitoring", "Scheduled scrapes of pages that matter — alerts the moment something drops or sells out."],
         ["social",  "✨", "AI-enhanced social posts", "Daily on-brand drafts for your X / IG / FB, approval-first so nothing posts without you."],
         ["custom",  "🛠", "Custom agent", "Tell us what you want monitored or automated — we'll wire it."]
       ].each do |key, icon, title, desc| %>
      <label class="block rounded-lg border border-gray-800 bg-gray-900 hover:border-orange-500 p-4 cursor-pointer transition has-[:checked]:border-orange-500 has-[:checked]:bg-orange-950/20">
        <div class="flex items-start gap-3">
          <input type="checkbox" name="services[]" value="<%= key %>"
                 class="mt-1 h-4 w-4 rounded border-gray-600 bg-gray-800 text-orange-500 focus:ring-orange-500 focus:ring-offset-gray-900 shrink-0">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-base"><%= icon %></span>
              <h3 class="text-sm font-semibold text-white"><%= title %></h3>
            </div>
            <p class="text-xs text-gray-400 break-words"><%= desc %></p>
          </div>
        </div>
      </label>
    <% end %>

    <div class="rounded-lg border border-gray-800 bg-gray-900 p-4">
      <label class="block">
        <span class="text-xs font-medium text-gray-300 mb-2 block">Anything else? (optional)</span>
        <textarea name="note" rows="3" maxlength="500"
                  placeholder="What's the business? What would you most like an agent to handle?"
                  class="w-full bg-gray-800 border border-gray-700 rounded-md px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-orange-500"></textarea>
      </label>
    </div>

    <div class="rounded-lg bg-gradient-to-r from-orange-600 to-amber-600 p-5">
      <h3 class="text-base font-bold text-white mb-1">📬 Request a fleet onboarding call</h3>
      <p class="text-xs text-orange-50 mb-3">
        We'll reach out within one business day to scope your fleet.
      </p>
      <%= f.submit "Request onboarding",
            class: "px-4 py-2 rounded-md bg-white text-orange-600 text-sm font-bold hover:bg-orange-50 transition cursor-pointer" %>
    </div>
  <% end %>
</div>
