<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>New York Kitchen · Upcoming Classes (stall poster)</title>
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #fff;
      color: #111;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      line-height: 1.25;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    /* One side, 6 classes, big type — sized to be read at arm's length when
       posted in a bathroom stall. */
    .page { max-width: 7.5in; margin: 0.4in auto; padding: 0 0.3in; }
    .header {
      text-align: center; padding-bottom: 8px;
      border-bottom: 3px solid #111; margin-bottom: 10px;
    }
    .brand { font-size: 29pt; font-weight: 800; letter-spacing: 0.01em; }
    .brand .accent { color: #c2410c; }
    .brand-logo { height: 110px; width: auto; vertical-align: middle; margin-right: 20px; }
    .subhead { font-size: 12pt; color: #444; margin-top: 3px; font-weight: 600; }

    /* Fixed-height cards so all six land on a single side. */
    .event {
      display: flex; align-items: center; gap: 18px;
      height: 1.40in; border-bottom: 2px solid #e2e2e2;
      page-break-inside: avoid; overflow: hidden;
    }
    .event:last-child { border-bottom: 0; }
    /* 16:9 to match the site's featured photos (768x433) — a square crop
       was cutting the sides off every image. */
    .thumb {
      width: 1.87in; height: 1.05in; flex: 0 0 auto;
      object-fit: cover; border-radius: 8px; background: #f1f1f1;
    }
    .body { flex: 1 1 auto; min-width: 0; }
    .name {
      font-size: 20pt; font-weight: 800; line-height: 1.12; margin-bottom: 6px;
      display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .info { font-size: 14pt; color: #222; font-weight: 600; }
    .info .sep { color: #bbb; padding: 0 4px; }
    .qr { flex: 0 0 auto; text-align: center; width: 1.2in; }
    .qr svg { width: 1.1in; height: 1.1in; display: block; margin: 0 auto; }
    .qr-cap { font-size: 8pt; color: #555; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 3px; font-weight: 700; }

    .footer {
      margin-top: 12px; padding-top: 8px; border-top: 2px solid #ddd;
      font-size: 12pt; color: #555; text-align: center; font-weight: 600;
    }
    .footer-cta { display: inline-flex; align-items: center; gap: 16px; text-align: left; }
    .footer-qr svg { width: 1.1in; height: 1.1in; display: block; }
    .footer-cta .lead { font-size: 15pt; font-weight: 800; color: #333; line-height: 1.3; }
    .footer-cta .url { color: #c2410c; }
    .footer-cta .more { font-size: 11pt; font-weight: 500; color: #777; }
    .empty { text-align: center; padding: 80px 0; color: #777; font-size: 18pt; }
    .actions { max-width: 7.5in; margin: 0.4in auto 0; padding: 0 0.3in; display: flex; gap: 10px; justify-content: flex-end; }
    .btn {
      display: inline-block; padding: 6px 14px; font-size: 10pt;
      border: 1px solid #444; background: #fff; color: #111;
      border-radius: 4px; cursor: pointer; text-decoration: none;
    }
    .btn-primary { background: #111; color: #fff; border-color: #111; }
    @media print {
      .actions { display: none; }
      .page { margin: 0; max-width: none; }
      @page { margin: 0.4in; }
    }
  </style>
</head>
<body>
  <div class="actions">
    <a class="btn" href="<%= nyk_display_settings_path %>">← Back</a>
    <a class="btn" href="<%= nyk_display_print_path %>">Flyer (double-sided)</a>
    <button id="print-btn" type="button" class="btn btn-primary">🖨 Print</button>
  </div>

  <div class="page">
    <div class="header">
      <div class="brand">
        <% if @display_workspace&.logo&.attached? %>
          <img class="brand-logo" src="<%= url_for(@display_workspace.logo) %>" alt="New York Kitchen">
        <% else %>
          New York Kitchen
        <% end %>
      </div>
      <div class="subhead">Scan a code to reserve your spot<% if @last_updated %> · updated <%= @last_updated.strftime("%b %-d") %><% end %></div>
    </div>

    <% if @events.any? %>
      <% @events.each do |event| %>
        <%
          start = event.start_at
          time_str = start.strftime("%-l:%M %p")
          venue = event.venue.presence || "New York Kitchen, Canandaigua"
          parts = [ start.strftime("%A, %b %-d"), time_str ]
          if @agent.setting(:show_price) && event.price.present?
            price = event.price.to_s.strip
            price = "$#{price}" unless price.match?(/[$£€]/)
            parts << price
          end
          if @agent.setting(:show_spots) && event.spots_left.present? && event.spots_left > 0
            parts << "#{event.spots_left} spots left"
          end
        %>
        <div class="event">
          <% if @show_photos && event.image_url.present? %>
            <img class="thumb" src="<%= event.image_url %>" alt="" loading="eager">
          <% end %>
          <div class="body">
            <div class="name"><%= event.name.presence || "Class at New York Kitchen" %></div>
            <div class="info"><%= safe_join(parts, content_tag(:span, "·", class: "sep")) %></div>
          </div>
          <% if event.url.present? %>
            <div class="qr">
              <%= qr_svg(event.url) %>
              <div class="qr-cap">Scan to reserve</div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty">No upcoming classes right now.<br>Check back at nykitchen.com/calendar/.</div>
    <% end %>

    <div class="footer">
      <div class="footer-cta">
        <span class="footer-qr"><%= qr_svg("https://nykitchen.com/calendar/") %></span>
        <span class="lead">
          Check out other New York Kitchen classes<br>
          @ <span class="url">nykitchen.com/calendar/</span>
          <% if @more_count.to_i > 0 %><br><span class="more">+ <%= pluralize(@more_count, "more class") %></span><% end %>
        </span>
      </div>
    </div>
  </div>

  <%# Inline handlers are CSP-blocked; attach via a nonced <script>. %>
  <%= javascript_tag nonce: true do %>
    document.getElementById("print-btn")?.addEventListener("click", function() {
      window.print();
    });
    if (new URLSearchParams(window.location.search).has("autoprint")) {
      window.addEventListener("load", function() {
        setTimeout(function() { window.print(); }, 400);
      });
    }
  <% end %>
</body>
</html>
