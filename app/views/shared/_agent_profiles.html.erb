<%# Locals: agents (collection of Agent records) %>
<% return if agents.blank? %>

<div class="font-mono">
  <p class="text-[10px] font-semibold uppercase tracking-wider text-green-400 mb-2">agents</p>
  <div class="flex flex-wrap justify-start gap-x-8 gap-y-1">
    <% agents.each do |agent| %>
      <div class="flex items-center gap-1.5">
        <span class="inline-block h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-[11px] text-green-400 agent-flicker"><%= agent.name %></span>
        <span class="text-[9px] text-green-600"><%= agent.role %></span>
      </div>
    <% end %>
  </div>
</div>
