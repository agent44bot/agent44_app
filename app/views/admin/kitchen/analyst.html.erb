<% content_for(:title, "NY Kitchen · Analyst Agent") %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <%= render "admin/kitchen/breadcrumbs", kind: "analyst" %>

  <div class="mb-6">
    <%= render "admin/kitchen/agent_title", title: "Analyst Agent", kind: "analyst" %>
    <p class="text-gray-400 mt-1">
      Sales &amp; revenue dashboard for NY Kitchen<% if @last_updated %> &middot; Updated <%= @last_updated.strftime("%b %-d") %><% end %>.
    </p>
  </div>

  <%# The Analyst's proactive output: the weekly recap now goes to everyone on
      the NY Kitchen workspace automatically (no per-person opt-in). Members
      without an email on file are simply skipped at send time. %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-6">
    <div class="text-sm text-gray-300">
      <span class="font-medium">📬 Weekly sales recap</span>: emailed to the NY Kitchen team every Monday and Friday at 10:00 AM ET.
      <% if Current.user&.email_address.blank? %>
        <div class="text-xs text-gray-500 mt-1">
          <%= link_to "Add an email to your profile", settings_path, class: "text-orange-400 hover:text-orange-300 underline" %> to receive it.
        </div>
      <% else %>
        <div class="text-xs text-gray-500 mt-1">Going to <%= Current.user.email_address %>.</div>
      <% end %>
    </div>
  </div>

  <%# Managers (Lora + Rich) can pull a fresh report any time, e.g. before a
      board meeting. It emails a copy to the logged-in user only. The "How it
      works" walkthrough lives on the generated page. %>
  <% if @nyk_workspace&.manager?(Current.user) %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-6">
      <div class="flex items-center justify-between gap-3">
        <div class="text-sm text-gray-300">
          <span class="font-medium">🧾 Need it now?</span> Generate a fresh report on demand. We email a copy straight to your inbox, and you can print it or save it as a PDF.
        </div>
        <%# turbo: false so the POST does a full-page navigation to the report.
            generate_report renders a standalone 200 page (not a redirect), which
            Turbo would otherwise ignore, making the button appear to do nothing. %>
        <%= button_to "Generate report", nyk_generate_report_path, method: :post,
              form: { data: { turbo: false } },
              class: "shrink-0 px-4 py-2 rounded-lg bg-orange-500 text-white text-sm font-medium hover:bg-orange-400 cursor-pointer" %>
      </div>
    </div>
  <% end %>

  <%# Admin-only: who actually opened the dashboard after the last report send.
      Reliable engagement signal: PageView is identified + bot-filtered, and
      Outlook prefetching images/links (which fakes open-pixel hits at delivery)
      never loads the dashboard, so a visit here means a real read. %>
  <% if Current.user&.admin? && @report_engagement %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-6">
      <div class="text-sm text-gray-300 font-medium mb-1">📈 Report engagement</div>
      <% if @report_engagement[:last_sent] %>
        <div class="text-xs text-gray-500 mb-2">
          Dashboard visits since the last report (sent <%= @report_engagement[:last_sent].in_time_zone("Eastern Time (US & Canada)").strftime("%b %-d, %-l:%M %p ET") %>).
          Tracks real visits, not email opens (Outlook prefetching makes open pixels unreliable).
        </div>
        <ul class="text-sm space-y-1">
          <% @report_engagement[:rows].each do |r| %>
            <li>
              <% if r[:viewed_at] %>
                <span class="text-green-400">&#10003;</span>
                <span class="text-gray-300"><%= r[:email] %></span>
                <span class="text-gray-500 text-xs">opened the dashboard <%= time_ago_in_words(r[:viewed_at]) %> ago</span>
              <% else %>
                <span class="text-gray-600">&#9675;</span>
                <span class="text-gray-300"><%= r[:email] %></span>
                <span class="text-gray-500 text-xs">no dashboard visit yet</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="text-xs text-gray-500">No report has been sent yet, so there is nothing to compare visits against.</div>
      <% end %>
    </div>
  <% end %>

  <%# Admin-only: jump to the live weekly team report (same builder as the
      real send). The report_preview action 404s for non-admins, so only
      show the link to site admins to avoid a dead link. %>
  <% if Current.user&.admin? %>
    <div class="mb-6 -mt-3 text-xs">
      <%= link_to nyk_report_preview_path, class: "inline-flex items-center gap-1.5 text-gray-400 hover:text-orange-300" do %>
        <span>👁️ Preview the weekly team report</span>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
      <span class="text-gray-600">· admin only</span>
    </div>
  <% end %>

  <% has_charts = (@dow_avg && @dow_avg.values.sum.positive?) ||
                  (@weekly_sales.present? && @weekly_sales.sum { |w| w[:tickets] }.positive?) ||
                  (@monthly_sales.present? && @monthly_sales.sum { |m| m[:tickets] }.positive?) %>
  <% has_revenue = @show_revenue && @rev_total.to_f.positive? %>
  <% has_leaderboards = @top_sellers.present? || @top_sellers_all.present? || @needs_a_push.present? || @ended_emptiest.present? %>

  <%# Time-range control — scopes the scoreboard + leaderboards. Retrospective
      ranges (Last week/month/…) appear only once they have data; they report
      booked vs missed. Plain links; Turbo re-renders the page with ?range=. %>
  <div class="flex flex-wrap items-center gap-0.5 bg-gray-800 rounded-lg p-0.5 text-xs font-medium mb-5 w-fit">
    <% @range_options.each do |key, label| %>
      <%= link_to label, nyk_analyst_path(range: key),
            class: "px-3 py-1.5 rounded-md transition #{@range == key ? "bg-gray-700 text-white" : "text-gray-400 hover:text-white"}" %>
    <% end %>
  </div>

  <% if @daily_view %>
    <%# Day ranges: tickets actually booked that day (observed sales), not the
        capacity-based revenue rollup. Hero is the ticket count; revenue is
        secondary and shown only to revenue-cleared viewers. %>
    <div class="bg-gray-900 rounded-xl p-6 mb-6">
      <div class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= @range_label %></div>
      <div class="text-5xl sm:text-6xl font-black text-white tabular-nums leading-none">
        <%= number_with_delimiter(@day_booking[:tickets]) %>
      </div>
      <div class="text-xs text-gray-500 uppercase tracking-wide mt-2"><%= "ticket".pluralize(@day_booking[:tickets]) %> sold</div>
      <% if @show_revenue && @day_booking[:revenue].to_f.positive? %>
        <div class="mt-4">
          <div class="text-xl font-bold text-green-400 tabular-nums"><%= number_to_currency(@day_booking[:revenue], precision: 0) %></div>
          <div class="text-xs text-gray-500 uppercase tracking-wide mt-0.5">Revenue</div>
        </div>
      <% end %>
      <p class="text-xs text-gray-600 mt-4">
        Tickets booked on <%= @day_date.strftime("%A, %b %-d") %>, from daily snapshots (observed sales).
      </p>
    </div>
  <% elsif has_revenue %>
    <%# Retrospective windows report booked vs missed; forward windows report
        sold vs still-available. Same layout, range-aware labels. %>
    <% sold_label = @retrospective ? "Booked"  : "Sold" %>
    <% left_label = @retrospective ? "Missed"  : "Left to sell" %>
    <div class="bg-gray-900 rounded-xl p-6 mb-6">
      <div class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= @range_label %></div>
      <%# Hero: the headline figure. tabular-nums keeps digits aligned and stops
          them jittering as the range changes. %>
      <div class="text-5xl sm:text-6xl font-black text-green-400 tabular-nums leading-none">
        <%= number_to_currency(@rev_sold, precision: 0) %>
      </div>
      <div class="text-xs text-gray-500 uppercase tracking-wide mt-2"><%= sold_label %></div>

      <% if @rev_total.to_f.positive? %>
        <% sold_w = [ [ (100.0 * @rev_sold / @rev_total).round, 0 ].max, 100 ].min %>
        <div class="mt-5 h-1.5 w-full rounded-full bg-gray-800 overflow-hidden" title="<%= sold_w %>% of face-value capacity sold">
          <div class="h-full bg-green-500 rounded-full" style="width: <%= sold_w %>%"></div>
        </div>
      <% end %>

      <%# Secondary stats, clearly subordinate to the hero. Each is stacked
          (figure over label) so the two don't run together on one line. %>
      <div class="mt-4 flex flex-wrap items-start gap-x-10 gap-y-3">
        <div>
          <%# Capacity is estimated (biased low) for most classes, so round this
              one and prefix ~ to signal it's an approximation, not an exact figure. %>
          <div class="text-xl font-bold text-amber-400 tabular-nums">~$<%= number_with_delimiter((@rev_left / 1000.0).round) %>K</div>
          <div class="text-xs text-gray-500 uppercase tracking-wide mt-0.5"><%= left_label %></div>
        </div>
        <% if @rev_pct_sold %>
          <div>
            <div class="text-xl font-bold text-gray-300 tabular-nums"><%= @rev_pct_sold %>%</div>
            <div class="text-xs text-gray-500 uppercase tracking-wide mt-0.5">of $ sold</div>
          </div>
        <% end %>
      </div>

      <p class="text-xs text-gray-600 mt-4">
        Face value (list price × seats) across <%= @rev_priced_count %> <%= "class".pluralize(@rev_priced_count) %> with capacity data<%=
          @rev_proxy_count.positive? ? " · #{@rev_proxy_count} use an observed baseline as capacity, so #{left_label.downcase} is approximate (biased low)" : "" %>.
      </p>
    </div>
  <% elsif @show_revenue %>
    <div class="bg-gray-900 rounded-xl p-5 mb-6 text-sm text-gray-500">
      No classes with capacity data for <%= @range_label.downcase %> yet.
    </div>
  <% end %>

  <%# Recent booking momentum — tickets sold yesterday + today, independent of
      the selected range. Hidden on the Yesterday/Today ranges (the hero above
      already shows the selected day). Revenue shown only to cleared viewers. %>
  <% if !@daily_view && @today_bookings && @yesterday_bookings %>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <% [["Yesterday", @yesterday_bookings], ["Today", @today_bookings]].each do |label, b| %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
          <div class="text-xs text-gray-500 uppercase tracking-wide mb-1"><%= label %></div>
          <div class="flex items-baseline gap-2">
            <span class="text-2xl font-bold text-white tabular-nums"><%= b[:tickets] %></span>
            <span class="text-sm text-gray-400"><%= "ticket".pluralize(b[:tickets]) %> sold</span>
          </div>
          <% if @show_revenue && b[:revenue].to_f.positive? %>
            <div class="text-xs text-green-400 mt-1"><%= number_to_currency(b[:revenue], precision: 0) %></div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Per-class performance: what's hot, and what to hand to the Social Agent.
      Forward-looking (pace / at-risk), so hidden on retrospective + day ranges. %>
  <% unless @retrospective || @daily_view %>
    <% if @top_sellers.present? || @top_sellers_all.present? %>
      <%= render "admin/kitchen/top_sellers" %>
    <% end %>
    <% if @needs_a_push.present? || @ended_emptiest.present? %>
      <%= render "admin/kitchen/needs_a_push" %>
    <% end %>
  <% end %>

  <% if @dow_avg && @dow_avg.values.sum.positive? %>
    <% dow_avg_json  = (0..6).map { |w| @dow_avg[w]       || 0 }.to_json %>
    <% dow_week_json = (0..6).map { |w| @dow_this_week[w]            }.to_json %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mt-8"
         data-controller="dow-chart"
         data-dow-chart-avg-value="<%= dow_avg_json %>"
         data-dow-chart-week-value="<%= dow_week_json %>">
      <div class="flex items-baseline justify-between mb-3">
        <h2 class="text-sm font-semibold text-white">Sales by day of week</h2>
        <span class="text-xs text-gray-500">Last 6 weeks</span>
      </div>
      <div class="relative h-48">
        <canvas data-dow-chart-target="canvas"></canvas>
      </div>
    </div>
  <% end %>

  <%# Tickets sold over time — week and month share one card + canvas, toggled
      client-side (sales-bar-chart swaps the dataset, so no hidden-canvas resize
      bug). Only offer the toggle when both series have data. %>
  <% week_has  = @weekly_sales.present?  && @weekly_sales.sum  { |w| w[:tickets] }.positive? %>
  <% month_has = @monthly_sales.present? && @monthly_sales.sum { |m| m[:tickets] }.positive? %>
  <% if week_has || month_has %>
    <% series = [] %>
    <% series << { key: "week",  label: "Week",  tooltipPrefix: "Week of ", caption: "Since tracking began",
                   labels: @weekly_sales.map  { |w| w[:label] }, values: @weekly_sales.map  { |w| w[:tickets] } } if week_has %>
    <% series << { key: "month", label: "Month", tooltipPrefix: "",         caption: "First month partial (tracking began mid-April)",
                   labels: @monthly_sales.map { |m| m[:label] }, values: @monthly_sales.map { |m| m[:tickets] } } if month_has %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mt-8"
         data-controller="sales-bar-chart"
         data-sales-bar-chart-series-value="<%= series.to_json %>">
      <div class="flex items-baseline justify-between gap-2 mb-3">
        <h2 class="text-sm font-semibold text-white">Tickets sold</h2>
        <div class="flex items-center gap-3">
          <% if series.size > 1 %>
            <div class="flex items-center gap-0.5 bg-gray-800 rounded-lg p-0.5 text-xs font-medium">
              <% series.each_with_index do |s, i| %>
                <button type="button" data-sales-bar-chart-target="toggle"
                        data-action="sales-bar-chart#select" data-sales-bar-chart-index-param="<%= i %>"
                        class="px-2.5 py-1 rounded-md transition"><%= s[:label] %></button>
              <% end %>
            </div>
          <% end %>
          <span class="text-xs text-gray-500" data-sales-bar-chart-target="caption"></span>
        </div>
      </div>
      <div class="relative h-48">
        <canvas data-sales-bar-chart-target="canvas"></canvas>
      </div>
    </div>
  <% end %>

  <% unless has_revenue || has_charts || has_leaderboards %>
    <div class="bg-gray-900 rounded-xl p-8 text-center">
      <p class="text-gray-400">No sales data yet. The Data Agent snapshots the calendar every few hours.</p>
    </div>
  <% end %>
</div>
