<%# Shown when ExtractRecipeJob could not build the recipes: the reason plus a
    one, tap retry (back to the upload/paste/link page) and a delete. %>
<% replace_url = @packet.links.first&.event_url %>
<div class="mt-6 rounded-xl border border-red-900/60 bg-red-950/30 p-6">
  <div class="flex items-start gap-3">
    <span class="text-xl leading-none">⚠️</span>
    <div class="min-w-0">
      <p class="text-sm font-semibold text-red-200 mb-1">We could not build this recipe.</p>
      <p class="text-sm text-red-100/80 mb-4"><%= @packet.extract_error.presence || "Something went wrong reading the document. Try again, or paste the recipe as text." %></p>
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to "Try again (upload, paste, or link)",
              new_nyk_packet_path(event_url: replace_url, event_name: (@packet.title == KitchenPacket::BUILDING_TITLE ? nil : @packet.title)),
              class: "inline-flex items-center px-4 h-9 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold" %>
        <%= button_to "Delete this packet", nyk_packet_path(@packet), method: :delete,
              data: { turbo_confirm: "Delete this packet?" },
              class: "inline-flex items-center px-3 h-9 rounded-lg bg-gray-800 border border-gray-700 hover:border-gray-500 text-sm text-gray-300 cursor-pointer" %>
      </div>
    </div>
  </div>
</div>
