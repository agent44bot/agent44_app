<% content_for(:title, "NY Kitchen") %>

<style>
  /* "Field Roster" — Agent 44 dossier cards. Scoped to .ra-* classes used
     only on this hub. Accent colour per card via the inline --accent var.
     JetBrains Mono is self-hosted from /public/fonts (no Google Fonts dep) —
     it's a variable font, so one file covers every weight. The callsign/H1
     display face uses the system stack. */
  @font-face{
    font-family:"JetBrains Mono";
    font-style:normal;
    font-weight:100 800;
    font-display:swap;
    src:url("/fonts/jetbrains-mono.woff2") format("woff2");
  }
  .ra-eyebrow{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
    letter-spacing:.34em;text-transform:uppercase;color:#f97316;font-weight:500}
  .ra-h1{font-family:system-ui,-apple-system,"Segoe UI",sans-serif;font-weight:800;letter-spacing:-.02em}
  .ra-onduty{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:12.5px;color:#8b909b;letter-spacing:.02em}

  .ra-card{--accent:#f97316;position:relative;display:flex;flex-direction:column;height:100%;
    background:#121317;border:1px solid #23262d;border-radius:16px;padding:20px 20px 18px 22px;
    overflow:hidden;text-decoration:none;color:inherit;
    transition:transform .18s ease,border-color .18s ease,background .18s ease;
    opacity:0;transform:translateY(10px);animation:ra-rise .5s cubic-bezier(.2,.7,.3,1) forwards}
  /* Manager view shows a per-agent salary badge bottom-right; reserve a band at
     the bottom so it never overlaps the card's own stats. */
  .pay-on .ra-card{padding-bottom:46px}
  .ra-card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;
    background:var(--accent);opacity:.55;transition:opacity .18s,width .18s}
  .ra-card:hover{transform:translateY(-3px);background:#16181d;
    border-color:color-mix(in srgb,var(--accent) 55%,transparent)}
  .ra-card:hover::before{opacity:1;width:4px}
  @keyframes ra-rise{to{opacity:1;transform:none}}
  @media(prefers-reduced-motion:reduce){.ra-card{animation:none;opacity:1;transform:none}}
  .ra-card:nth-child(1){animation-delay:.04s}.ra-card:nth-child(2){animation-delay:.10s}
  .ra-card:nth-child(3){animation-delay:.16s}.ra-card:nth-child(4){animation-delay:.22s}
  .ra-card:nth-child(5){animation-delay:.28s}.ra-card:nth-child(6){animation-delay:.34s}
  .ra-card:nth-child(7){animation-delay:.40s}

  .ra-head{display:flex;align-items:flex-start;gap:13px}
  .ra-avatar{flex-shrink:0;width:46px;height:46px;border-radius:12px;display:grid;place-items:center;
    font-size:23px;background:color-mix(in srgb,var(--accent) 16%,transparent);
    border:1px solid color-mix(in srgb,var(--accent) 38%,transparent)}
  .ra-id{min-width:0}
  .ra-call{display:block;font-family:system-ui,-apple-system,"Segoe UI",sans-serif;font-weight:800;
    font-size:20px;line-height:1.05;color:#fff}
  .ra-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:5px;
    font-family:"JetBrains Mono",ui-monospace,monospace;font-size:10.5px;letter-spacing:.12em;
    text-transform:uppercase;color:#5b606b}
  .ra-tag{color:var(--accent);font-weight:700}
  .ra-sep{color:#2c2f37}
  .ra-code{color:#8b909b}
  .ra-corner{position:absolute;top:16px;right:16px;display:flex;align-items:center;gap:9px;z-index:1}
  .ra-chev{color:#5b606b;font-family:"JetBrains Mono",ui-monospace,monospace;font-size:13px;
    transition:color .18s,transform .18s}
  .ra-card:hover .ra-chev{color:var(--accent);transform:translateX(2px)}
</style>

<%
  social_href = @nyk_workspace ? nyk_social_path : workspaces_path

  # Agent-presence dot: pulsing green = actively running, solid red =
  # last finished run failed (sustained until next pass), solid green =
  # on-cadence, gray = stale (no recent activity). `title` overrides the
  # hover tooltip (the Display Agent reuses :running/:failed for live/offline).
  agent_dot = ->(state, title = nil) {
    case state
    when :running    then %(<span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.7)]" title="#{title || 'Running now'}"></span>).html_safe
    when :failed     then %(<span class="inline-block w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.7)]" title="#{title || 'Last run failed'}"></span>).html_safe
    when :on_cadence then %(<span class="inline-block w-2 h-2 rounded-full bg-green-500" title="#{title || 'On cadence'}"></span>).html_safe
    else                  %(<span class="inline-block w-2 h-2 rounded-full bg-gray-600" title="#{title || 'Idle / stale'}"></span>).html_safe
    end
  }

  # Per-agent codename callsign, classification tag, and accent colour — shared
  # with the agent detail-page headers via ApplicationHelper::NYK_ROSTER so the
  # naming can't drift. The callsign falls back to a saved display_name (the
  # rename feature still wins). Framing "agents" once in the header lets the
  # cards drop the repeated word "Agent" — each leads with its callsign instead.
  roster = ApplicationHelper::NYK_ROSTER

  accent_style = ->(kind) { "--accent:#{roster[kind.to_s][:accent]}" }

  # Avatar + callsign + classification + codename for a card header. Uses the
  # saved display_name when present; codename is the real agent_number.
  # tokens → compact label: 1234567 → "1.2M", 12345 → "12.3K".
  fmt_tok = ->(n) {
    n = n.to_i
    n >= 1_000_000 ? "#{(n / 1_000_000.0).round(1)}M" : (n >= 1_000 ? "#{(n / 1_000.0).round(1)}K" : n.to_s)
  }

  agent_ident = ->(kind) {
    m = roster[kind.to_s]
    a = @workspace_agents[kind.to_s]
    call = (a&.display_name.presence) || m[:call]
    code = a ? "No.#{a.agent_number}" : nil
    html = +%(<span class="ra-avatar">#{m[:emoji]}</span><span class="ra-id"><span class="ra-call">#{ERB::Util.h(call)}</span><span class="ra-meta"><span class="ra-tag">#{ERB::Util.h(m[:tag])}</span>)
    html << %(<span class="ra-sep">·</span><span class="ra-code">#{ERB::Util.h(code)}</span>) if code
    html << %(</span>) # /ra-meta
    # Per-agent "salary" — this month's tokens + cost. Owner/admin only (Lora).
    if @can_see_pricing && @hub_salary && (s = @hub_salary[kind.to_s])
      toks = s[:tokens].to_i.positive? ? "#{fmt_tok.call(s[:tokens])} tok · " : ""
      html << %(<span style="position:absolute;right:18px;bottom:14px;font-family:'JetBrains Mono',ui-monospace,monospace;font-size:11px;color:#f59e0b;letter-spacing:.04em;z-index:2" title="This month's token usage + cost">💰 #{toks}$#{format('%.2f', s[:cost])}/mo</span>)
    end
    html << %(</span>) # /ra-id
    html.html_safe
  }

  # Public profile URL for a connected social account, used by the
  # Social Agent card on the hub. Returns "#" for platforms we can't
  # construct one for so the link still renders harmlessly.
  platform_profile_url = ->(acct) {
    handle = acct.handle.to_s.delete_prefix("@")
    case acct.platform
    when "x"        then "https://x.com/#{handle}"
    when "bluesky"  then "https://bsky.app/profile/#{handle}"
    when "threads"  then "https://www.threads.net/@#{handle}"
    when "facebook" then "https://www.facebook.com/#{handle}"
    else                 "#"
    end
  }

  # Format minutes for the work-time meter. < 60 stays in minutes;
  # otherwise Xh Ym.
  humanize_minutes = ->(min) {
    return "0 min" if min.to_i.zero?
    return "#{min} min" if min < 60
    hours = min / 60
    rem   = min % 60
    rem.positive? ? "#{hours}h #{rem}m" : "#{hours}h"
  }

  # Headline label uses the last *finished* row so an in-flight run
  # doesn't blank out "Passed N ago".
  smoke_status_color = if @hub_smoke_last_finished.nil?            then "text-gray-500"
                      elsif @hub_smoke_last_finished.passed?      then "text-green-400"
                      else                                              "text-red-400"
                      end
  smoke_status_label = if @hub_smoke_last_finished.nil?       then "No runs yet"
                      elsif @hub_smoke_last_finished.passed? then "✓ Passed"
                      else                                        "🚨 Failed"
                      end
  fail_rate_color = @hub_smoke_fail_rate_30d >= 20 ? "text-red-400" :
                    @hub_smoke_fail_rate_30d >= 5  ? "text-amber-400" :
                                                     "text-green-400"

  # Cards drop the repeated "Agent" word; description/stats styling unchanged.
  desc_class  = "text-sm text-gray-400 mt-3 mb-4"
  stats_class = "space-y-1.5 text-sm mt-auto"

  # How many agents are flagging a problem (red dot) right now.
  attention = (@hub_agent_status || {}).values.count { |s| s == :failed }
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
     data-controller="collapsible"
     data-collapsible-collapsed-value="true"
     data-collapsible-scroll-on-expand-value="true">
  <div class="flex justify-between items-center mb-6 text-sm">
    <div class="flex items-center gap-2">
      <% if Current.user&.email_address == "botwhisperer@hey.com" %>
        <%= link_to admin_track_path(range: "today"),
              class: "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-amber-900/40 border border-amber-800/60 text-amber-300 hover:border-amber-500 text-xs font-semibold" do %>
          👁 Track users
        <% end %>
      <% end %>
      <% if @can_see_pricing %>
        <%= link_to nyk_billing_path,
              class: "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-emerald-900/40 border border-emerald-800/60 text-emerald-300 hover:border-emerald-500 text-xs font-semibold" do %>
          💵 Billing
        <% end %>
      <% end %>
    </div>
    <%= link_to workspaces_path(force: 1), class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold transition" do %>
      ← All workspaces
    <% end %>
  </div>

  <div class="mb-8">
    <div class="ra-eyebrow mb-2">Agent 44 · Field Roster</div>
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <h1 class="ra-h1 text-4xl text-white">NY Kitchen</h1>
      <div class="flex items-center gap-2">
        <% if @nyk_workspace %>
          <button type="button"
                  data-action="click->collapsible#toggle"
                  aria-label="Workspace settings"
                  class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/>
            </svg>
          </button>
        <% end %>
      </div>
    </div>
    <p class="ra-onduty mt-3 flex items-center gap-2">
      <%= agent_dot.call(:running, "Fleet on duty") %>
      <span><%= pluralize(WorkspaceAgent::KINDS.size, "agent") %> on duty<% if attention.positive? %> · <span class="text-red-400"><%= attention %> need<%= "s" if attention == 1 %> attention</span><% end %></span>
    </p>
  </div>

  <% if @nyk_workspace %>
    <div data-collapsible-target="body" class="mb-8">
      <%= render "workspaces/team",
            workspace:       @nyk_workspace,
            memberships:     @nyk_memberships,
            invitations:     @nyk_invitations,
            social_accounts: @nyk_social_accounts,
            my_role:         @nyk_my_role %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 auto-rows-fr <%= "pay-on" if @can_see_pricing %>">
    <%# Analyst / Iris (no liveness dot — it's a dashboard, not a worker) %>
    <%= link_to nyk_analyst_path, class: "ra-card", style: accent_style.call(:analyst) do %>
      <span class="ra-corner"><span class="ra-chev">▶</span></span>
      <div class="ra-head"><%= agent_ident.call(:analyst) %></div>
      <p class="<%= desc_class %>">Sales &amp; revenue trends — what's sold, what's left to sell, and where the money's still on the table.</p>
      <div class="flex-1 flex items-center justify-center py-3">
        <div class="text-center">
          <div class="text-3xl font-black text-white tabular-nums">
            <%= @hub_tickets_sold_today.nil? ? "—" : @hub_tickets_sold_today %>
          </div>
          <div class="text-xs uppercase tracking-wide text-gray-500 mt-1">tickets sold today</div>
          <% if @hub_tickets_pace_pct %>
            <% pace_color, pace_label =
                 if @hub_tickets_pace_pct >= 10
                   ["text-green-400", "#{@hub_tickets_pace_pct}% above daily pace"]
                 elsif @hub_tickets_pace_pct <= -10
                   ["text-red-400",   "#{@hub_tickets_pace_pct.abs}% below daily pace"]
                 else
                   ["text-gray-500",  "on daily pace"]
                 end %>
            <div class="text-xs <%= pace_color %> mt-1 tabular-nums"
                 title="Expected ~<%= @hub_tickets_expected_by_now %> sold by now if today tracked the 14-day daily average (<%= @hub_tickets_sold_avg %>) linearly across an 8am–8pm window.">
              <%= pace_label %>
            </div>
          <% end %>

          <%# Mini "sales by day of week" sparkline (6-week avg, Sun..Sat).
              Pure CSS bars — kept short so it doesn't stretch the grid row.
              Full chart on /analyst. %>
          <% if @hub_dow_avg && @hub_dow_avg.values.compact.sum.to_f.positive? %>
            <% dow_max = @hub_dow_avg.values.compact.max.to_f %>
            <% dow_labels = %w[S M T W T F S] %>
            <div class="mt-4 w-full max-w-[180px] mx-auto" title="Avg tickets sold by weekday (last 6 weeks)">
              <div class="flex items-end justify-between gap-1 h-12">
                <% (0..6).each do |w| %>
                  <% val = @hub_dow_avg[w].to_f %>
                  <% pct = dow_max.positive? ? [(val / dow_max * 100).round, 4].max : 0 %>
                  <div class="flex-1 flex items-end h-full">
                    <div class="w-full rounded-sm bg-gray-600" style="height: <%= pct %>%" title="<%= dow_labels[w] %>: <%= val.round %>"></div>
                  </div>
                <% end %>
              </div>
              <div class="flex justify-between gap-1 mt-1">
                <% dow_labels.each do |d| %>
                  <div class="flex-1 text-center text-[9px] text-gray-600"><%= d %></div>
                <% end %>
              </div>
              <div class="text-[10px] text-gray-600 text-center mt-0.5">avg sales by weekday</div>
            </div>
          <% end %>
        </div>
      </div>
      <div class="<%= stats_class %>">
        <div class="text-gray-300">📬 Weekly recap · <span class="text-gray-400">Mon &amp; Fri 10:00 AM ET</span></div>
      </div>
    <% end %>

    <%# List / Sam %>
    <%= link_to nyk_list_path, class: "ra-card", style: accent_style.call(:list) do %>
      <span class="ra-corner"><%= agent_dot.call(@hub_agent_status[:list]) %><span class="ra-chev">▶</span></span>
      <div class="ra-head"><%= agent_ident.call(:list) %></div>
      <p class="<%= desc_class %>">Watches the calendar and surfaces what's coming up — by week, with sold-out percentages.</p>
      <div class="flex-1 flex items-center justify-center py-3">
        <div class="text-center">
          <div class="text-3xl font-black text-white tabular-nums">
            <%= @hub_events_sold_out_pct.nil? ? "—" : "#{@hub_events_sold_out_pct}%" %>
          </div>
          <div class="text-xs uppercase tracking-wide text-gray-500 mt-1">of upcoming classes sold out</div>
          <% if @hub_events_sold_out_pct %>
            <div class="text-xs text-gray-500 mt-1 tabular-nums"><%= @hub_events_sold_out %> of <%= @hub_events_total %> classes</div>
          <% end %>
        </div>
      </div>
      <div class="<%= stats_class %>">
        <div class="text-gray-300"><span class="font-semibold text-white"><%= @hub_events_total %></span> upcoming classes</div>
        <% if @hub_events_updated %>
          <div class="text-gray-500">Updated <%= @hub_events_updated.strftime("%b %-d") %></div>
        <% end %>
      </div>
    <% end %>

    <%# Social / Echo — title + arrow are links; card itself is not %>
    <div class="ra-card" style="<%= accent_style.call(:social) %>">
      <span class="ra-corner">
        <%= agent_dot.call(@hub_agent_status[:social]) %>
        <%= link_to social_href, class: "ra-chev", aria: { label: "Open Social Agent" } do %>▶<% end %>
      </span>
      <%= link_to social_href, class: "ra-head group/title", style: "text-decoration:none;color:inherit" do %>
        <%= agent_ident.call(:social) %>
      <% end %>
      <p class="<%= desc_class %>">Drafts and posts to your connected social accounts. Hand off a class with one click.</p>

      <%# Last published post (any account) — fills the middle and shows Echo is
          actually broadcasting. Links to the post on its platform. %>
      <% if @hub_last_post %>
        <div class="flex-1 flex items-center py-2">
          <% post_url = @hub_last_post.social_account ? platform_profile_url.call(@hub_last_post.social_account) : social_href %>
          <%= link_to post_url,
                target: (@hub_last_post.social_account ? "_blank" : nil), rel: "noopener",
                class: "block w-full rounded-lg bg-gray-800/40 border border-gray-800 p-3 hover:border-gray-700 transition" do %>
            <div class="flex items-center gap-1.5 text-xs text-gray-500 mb-1.5">
              <span class="uppercase tracking-wide text-purple-300/80 font-semibold"><%= @hub_last_post.platform.capitalize %></span>
              <span>·</span>
              <span>Last post <%= time_ago_in_words(@hub_last_post.posted_at || @hub_last_post.created_at) %> ago</span>
            </div>
            <p class="text-sm text-gray-300 line-clamp-3"><%= @hub_last_post.body %></p>
            <% if (@hub_last_post.likes + @hub_last_post.reposts + @hub_last_post.replies).positive? %>
              <div class="flex items-center gap-3 text-xs text-gray-500 mt-2 tabular-nums">
                <span>♥ <%= @hub_last_post.likes %></span>
                <span>🔁 <%= @hub_last_post.reposts %></span>
                <span>💬 <%= @hub_last_post.replies %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="<%= stats_class %>">
        <% if @nyk_workspace %>
          <% connected   = @nyk_workspace.social_accounts.active.order(:platform).to_a %>
          <% all_present = @nyk_workspace.social_accounts.pluck(:platform).uniq %>
          <% unconfigured = %w[threads facebook] - all_present %>

          <% if connected.any? || unconfigured.any? %>
            <% connected.each do |acct| %>
              <%= link_to platform_profile_url.call(acct), target: "_blank", rel: "noopener",
                    class: "flex items-center justify-between text-gray-200 hover:text-orange-400 transition" do %>
                <span><%= acct.platform.capitalize %></span>
                <span class="inline-block w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
              <% end %>
            <% end %>
            <% unconfigured.each do |platform| %>
              <%= link_to social_href, class: "flex items-center justify-between text-gray-400 hover:text-orange-400 transition" do %>
                <span><%= platform.capitalize %></span>
                <span class="text-xs text-orange-400/80">(setup)</span>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <div class="text-gray-500">No NY Kitchen workspace yet</div>
          <div class="text-gray-500">Click to set one up</div>
        <% end %>
      </div>
    </div>

    <%# Display / Neon %>
    <%= link_to nyk_display_settings_path, class: "ra-card", style: accent_style.call(:display) do %>
      <span class="ra-corner"><% if @hub_agent_status[:display] %><%= agent_dot.call(@hub_agent_status[:display], @hub_agent_status[:display] == :running ? "Carousel live at NY Kitchen" : "Carousel NOT running at NY Kitchen") %><% end %><span class="ra-chev">▶</span></span>
      <div class="ra-head"><%= agent_ident.call(:display) %></div>
      <% display_agent = @workspace_agents["display"] %>
      <p class="<%= desc_class %>">Cycles your live classes on a screen for walk-in customers — sold-out classes drop off automatically. Also prints a paper schedule for the front desk.</p>

      <%# Primary action centered in the card's middle (was pinned to the
          bottom, leaving dead space). Opens the print page (front-desk flyer);
          its toolbar switches to the stall poster. preventDefault in the
          print-schedule controller stops the surrounding card link. %>
      <div class="flex-1 flex flex-col items-center justify-center py-3">
        <span role="button" tabindex="0"
              title="Front-desk flyer and bathroom-stall poster; pick either on the print page"
              data-controller="print-schedule"
              data-print-schedule-url-value="<%= nyk_display_print_path %>"
              data-action="click->print-schedule#open keydown.enter->print-schedule#open"
              class="w-full justify-center inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-green-600 hover:bg-green-500 text-white text-sm font-semibold transition cursor-pointer">
          🖨 Print flyers
        </span>
        <% if Current.user&.admin? %>
          <div class="text-xs text-gray-500 mt-1.5 tabular-nums" title="Total flyer/poster print-page opens (admin only)">
            🖨 <%= @hub_flyer_prints.to_i %> <%= "print".pluralize(@hub_flyer_prints.to_i) %> all-time
          </div>
        <% end %>
      </div>

      <div class="<%= stats_class %>">
        <%# Screen liveness (private mode only — see display_agent_status).
            Red = the carousel isn't playing on the NY Kitchen screen. %>
        <% case @hub_agent_status[:display] %>
        <% when :running %>
          <div class="text-green-400 font-semibold">● Carousel live at NY Kitchen</div>
        <% when :failed %>
          <div class="text-red-400 font-semibold">⚠ Not running at NY Kitchen<%= " · last seen #{time_ago_in_words(@hub_display_last_seen)} ago" if @hub_display_last_seen %></div>
        <% end %>
        <div class="text-gray-300"><span class="font-semibold text-white"><%= display_agent&.setting(:slide_count) || 5 %></span> slides · <%= display_agent&.setting(:advance_seconds) || 10 %>s each</div>
      </div>
    <% end %>

    <%# Data / Scout %>
    <%= link_to nyk_data_path, class: "ra-card", style: accent_style.call(:data) do %>
      <span class="ra-corner"><%= agent_dot.call(@hub_agent_status[:data]) %><span class="ra-chev">▶</span></span>
      <div class="ra-head"><%= agent_ident.call(:data) %></div>
      <p class="<%= desc_class %>">Snapshots the calendar every three hours — feeds Sam and powers ticket-change alerts.</p>
      <div class="flex-1 flex items-center justify-center py-3">
        <div class="text-center">
          <div class="text-3xl font-black text-white tabular-nums"><%= @hub_scrape_changes %></div>
          <div class="text-xs uppercase tracking-wide text-gray-500 mt-1">changes detected this week</div>
          <% if @hub_scrape_changes.to_i.positive? %>
            <div class="text-xs text-gray-500 mt-1 tabular-nums">
              <%= @hub_scrape_churn[:added] %> added · <%= @hub_scrape_churn[:removed] %> removed · <%= @hub_scrape_churn[:price_changes] %> price
            </div>
          <% end %>
        </div>
      </div>
      <div class="<%= stats_class %>">
        <% if @hub_scrape_last_finished %>
          <div class="text-green-400 font-semibold">✓ Last snapshot <%= time_ago_in_words(@hub_scrape_last_finished.started_at) %> ago</div>
        <% else %>
          <div class="text-gray-500 font-semibold">No snapshots yet</div>
        <% end %>
        <div class="text-gray-500">Worked <%= humanize_minutes.call(@hub_scrape_total_minutes) %> · <%= @hub_scrape_total %> runs<% if @can_see_pricing %> · $<%= "%.2f" % @hub_scrape_cost_total %><% end %></div>
      </div>
    <% end %>

    <%# Test / Argus. The card body links to the test page, but the "Watch
        recording" button opens the last run's video inline (video-modal) — so
        it can't be a nested <a>. Wrapper is a div, body is the link (Carson
        pattern). %>
    <div class="ra-card" style="<%= accent_style.call(:test) %>" data-controller="video-modal">
      <span class="ra-corner"><%= agent_dot.call(@hub_agent_status[:test]) %><span class="ra-chev">▶</span></span>
      <%= link_to nyk_test_path, class: "block" do %>
        <div class="ra-head"><%= agent_ident.call(:test) %></div>
        <p class="<%= desc_class %>">Round-trips the calendar every hour to catch broken pages or missing classes before customers do.</p>
      <% end %>

      <%# Clickable recording thumbnail (poster still from the last run) with a
          play overlay — tap to watch the test play inline. Gray placeholder
          when no thumbnail. Sits in the card's middle; opens the video-modal. %>
      <% if @hub_smoke_last_finished&.video&.attached? %>
        <%# Compact recording tile — capped width so it doesn't stretch the
            equal-height grid row (auto-rows-fr). Centered. %>
        <div class="flex items-center py-2">
          <button type="button"
                  data-action="click->video-modal#open"
                  data-video-modal-src-param="<%= url_for(@hub_smoke_last_finished.video) %>"
                  class="group relative block w-full max-w-[200px] rounded-lg overflow-hidden border border-gray-700 bg-gray-950 aspect-video cursor-pointer"
                  aria-label="Watch last smoke recording (<%= @hub_smoke_last_finished.passed? ? "passed" : "failed" %>)">
            <% if @hub_smoke_last_finished.thumbnail.attached? %>
              <img src="<%= url_for(@hub_smoke_last_finished.thumbnail) %>"
                   class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.02] transition"
                   alt="Last smoke recording">
            <% else %>
              <div class="absolute inset-0 flex items-center justify-center text-gray-600 text-3xl">🖥</div>
            <% end %>
            <%# Scrim: darkens the image so the play button + label stay legible
                over any screenshot (bright calendar or dark). %>
            <span class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-black/10"></span>
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="flex items-center justify-center w-9 h-9 rounded-full bg-white/95 shadow-lg group-hover:bg-white group-hover:scale-105 transition">
                <span class="text-gray-900 text-base ml-0.5">▶</span>
              </span>
            </span>
            <span class="absolute bottom-1 left-1.5 text-[10px] font-semibold px-1.5 py-0.5 rounded <%= @hub_smoke_last_finished.passed? ? "text-green-300 bg-green-900/70" : "text-red-300 bg-red-900/70" %>">
              <%= @hub_smoke_last_finished.passed? ? "passed" : "failed" %>
            </span>
          </button>
        </div>
      <% end %>

      <div class="<%= stats_class %>">
        <div class="<%= smoke_status_color %> font-semibold"><%= smoke_status_label %><% if @hub_smoke_last_finished %> <%= time_ago_in_words(@hub_smoke_last_finished.started_at) %> ago<% end %></div>
        <div class="text-gray-400"><span class="<%= fail_rate_color %> font-semibold"><%= @hub_smoke_fail_rate_30d %>%</span> fail rate (30d)</div>
        <div class="text-gray-500">Worked <%= humanize_minutes.call(@hub_smoke_total_minutes) %> · <%= @hub_smoke_total %> runs<% if @can_see_pricing %> · $<%= "%.2f" % @hub_smoke_cost_total %><% end %></div>
      </div>

      <dialog data-video-modal-target="dialog"
              data-action="click->video-modal#backdropClose"
              class="bg-transparent backdrop:bg-black/80 p-0 max-w-4xl w-[90vw] fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
        <div class="bg-gray-900 rounded-xl p-4">
          <div class="flex justify-between items-center mb-3">
            <h3 class="text-sm font-semibold text-gray-400">Argus — last smoke recording</h3>
            <button type="button" data-action="click->video-modal#close"
                    class="text-gray-500 hover:text-white text-lg">&times;</button>
          </div>
          <video data-video-modal-target="video" controls class="rounded-lg w-full" preload="metadata"></video>
        </div>
      </dialog>
    </div>

    <%# Cellar — storage-room wine & spirits inventory. Not a roster worker (no
        codename/liveness dot); links straight to the live stock view. %>
    <%= link_to nyk_inventory_path, class: "ra-card", style: "--accent:#be123c" do %>
      <span class="ra-corner"><span class="ra-chev">▶</span></span>
      <div class="ra-head">
        <span class="ra-avatar">🍷</span>
        <span class="ra-id">
          <span class="ra-call">Cellar</span>
          <span class="ra-meta"><span class="ra-tag">INVENTORY</span></span>
        </span>
      </div>
      <p class="<%= desc_class %>">Tracks the storage room — Lora scans cases in, Chris scans bottles out. Always-live bottle counts with low-stock flags.</p>
      <div class="<%= stats_class %>">
        <div class="text-gray-300"><span class="font-semibold text-white"><%= @hub_inventory_units %></span> bottles on hand</div>
        <% if @hub_inventory_low.to_i.positive? %>
          <div class="text-amber-400 font-semibold">⚠ <%= @hub_inventory_low %> low on stock</div>
        <% end %>
      </div>
    <% end %>

    <%# Super / Carson. Two click targets, not one: the card body opens a FRESH chat
        (no prompt inserted), while the suggestion/alert below is its own chip that
        auto-asks that specific question. Sibling links — never nested. %>
    <div class="ra-card" style="<%= accent_style.call(:ask) %>">
      <span class="ra-corner"><%= agent_dot.call(:running, "Always on — ask anytime") %><span class="ra-chev">▶</span></span>
      <%= link_to nyk_ask_path, class: "block flex-1" do %>
        <div class="ra-head"><%= agent_ident.call(:ask) %></div>
        <p class="<%= desc_class %>">Ask anything about NY Kitchen — classes, sales, sold-outs, agent status, smoke tests, social posts. Reads the whole workspace. <span class="text-gray-500">Tap to start a fresh chat.</span></p>
      <% end %>
      <div class="<%= stats_class %>">
        <% chip_class = "block -mx-2 px-2 py-1 rounded-lg hover:bg-gray-800 transition" %>
        <% if @smoke_alert %>
          <%= link_to nyk_ask_path(q: @smoke_alert[:prompt], go: 1), class: chip_class do %>
            <span class="text-red-400 font-semibold">⚠️ The calendar check has failed <%= @smoke_alert[:count] %> times in a row — want me to draft a note to the developer?</span>
          <% end %>
        <% elsif @daily_prompt %>
          <%= link_to nyk_ask_path(q: @daily_prompt, go: 1), class: chip_class do %>
            <span class="text-orange-300"><%= nyk_time_greeting %></span> <span class="text-gray-300">"<%= @daily_prompt %>"</span>
          <% end %>
        <% else %>
          <div class="text-gray-300">Try: <span class="text-gray-400">"What sold out this week?"</span></div>
        <% end %>
      </div>
    </div>

  </div>

</div>
