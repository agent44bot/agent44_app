<% content_for(:title, "NY Kitchen · List Agent") %>

<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10" data-controller="kitchen-filter">
  <%= render "admin/kitchen/breadcrumbs" %>

  <div class="mb-6">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <%= render "admin/kitchen/agent_title", title: "List Agent", kind: "list" %>
      <div class="flex items-center gap-2">
        <% if authenticated? && Current.user.admin? %>
          <%= link_to nyk_billing_path,
                class: "flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Billing</span>
          <% end %>
        <% end %>
      </div>
    </div>
    <p class="text-gray-400 mt-1">
      Cooking classes at NY Kitchen &middot;
      <%= @total %> upcoming
      <% if @last_updated %>
        &middot; Updated <%= @last_updated.strftime("%b %-d") %>
      <% end %>
    </p>
  </div>

  <% if @events.empty? %>
    <div class="bg-gray-900 rounded-xl p-8 text-center">
      <p class="text-gray-400">No events scraped yet. The scraper runs every 3 hours.</p>
    </div>
  <% else %>
    <% if @top_sellers.present? || @top_sellers_all.present? %>
      <%= render "admin/kitchen/top_sellers" %>
    <% end %>
    <% if @needs_a_push.present? || @ended_emptiest.present? %>
      <%= render "admin/kitchen/needs_a_push" %>
    <% end %>
    <%= render "admin/kitchen/list_panel" %>
    <% if @dow_avg && @dow_avg.values.sum.positive? %>
      <% dow_avg_json  = (0..6).map { |w| @dow_avg[w]       || 0 }.to_json %>
      <% dow_week_json = (0..6).map { |w| @dow_this_week[w]            }.to_json %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mt-8"
           data-controller="dow-chart"
           data-dow-chart-avg-value="<%= dow_avg_json %>"
           data-dow-chart-week-value="<%= dow_week_json %>">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-sm font-semibold text-white">Sales by day of week</h2>
          <span class="text-xs text-gray-500">Last 6 weeks</span>
        </div>
        <div class="relative h-48">
          <canvas data-dow-chart-target="canvas"></canvas>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<%= javascript_tag nonce: true do %>
// Deep-link: #week-N scrolls to and expands that week section.
(function() {
  var hash = window.location.hash;
  if (hash && hash.match(/^#week-\d+$/)) {
    var section = document.getElementById(hash.slice(1));
    if (section) {
      var body = section.querySelector('[data-collapsible-target="body"]');
      var icon = section.querySelector('[data-collapsible-target="icon"]');
      if (body && body.classList.contains('hidden')) {
        body.classList.remove('hidden');
        if (icon) icon.classList.remove('-rotate-90');
      }
      setTimeout(function() {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
})();
<% end %>
