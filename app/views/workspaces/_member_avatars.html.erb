<%# Overlapping stack of a workspace's member avatars. Photo if set, else
    initials. Callers pass the members to show; today they exclude the owner
    (the Agent44 Labs side) so the stack shows the customer's team. Hovering the
    stack opens a flyout listing every shown member with name + email.
    Locals:
      members — array of User
      limit   — max avatars before a "+N" chip (default 4)
      size    — Tailwind h/w pair (default "h-8 w-8")
%>
<% members = Array(members) %>
<% limit ||= 4 %>
<% size  ||= "h-8 w-8" %>
<% return if members.empty? %>
<div class="relative group shrink-0">
  <div class="flex -space-x-2">
    <% members.first(limit).each do |u| %>
      <%= user_avatar_tag u, size: size %>
    <% end %>
    <% if members.size > limit %>
      <span class="<%= size %> rounded-full bg-gray-800 text-gray-300 ring-2 ring-gray-950 inline-flex items-center justify-center text-xs font-semibold shrink-0">+<%= members.size - limit %></span>
    <% end %>
  </div>

  <%# Flyout on hover: the full member list with name + email. %>
  <div class="hidden group-hover:block absolute right-0 top-full mt-2 z-50 w-64 max-h-72 overflow-y-auto rounded-lg bg-gray-900 border border-gray-800 shadow-xl p-1.5">
    <% members.each do |u| %>
      <div class="flex items-center gap-2 px-2 py-1.5">
        <%= user_avatar_tag u, size: "h-7 w-7", ring: "" %>
        <div class="min-w-0">
          <p class="text-sm text-white truncate leading-tight"><%= u.display_identifier %></p>
          <% if u.email_address.present? && u.email_address != u.display_identifier %>
            <p class="text-xs text-gray-500 truncate leading-tight"><%= u.email_address %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
