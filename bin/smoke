#!/usr/bin/env bash
#
# Smoke test runner — fetches API_TOKEN from Fly and runs test/smoke/**.
#
# Usage:
#   bin/smoke                          # run every smoke test against prod
#   bin/smoke ripley_telegram          # run a single file (partial name match)
#   SMOKE_APP=agent44-staging bin/smoke # target a different Fly app
#
# Token lookup order:
#   1. $API_TOKEN if already in env (escape hatch)
#   2. `fly ssh console -C "printenv API_TOKEN" --app $SMOKE_APP`
#
# The token is never written to disk. It lives only in this process's env.

set -euo pipefail

APP="${SMOKE_APP:-agent44-app}"
FILTER="${1:-}"
API_BASE="https://agent44labs.com/api/v1"
VLAD_AGENT="Vlad%20%E2%9C%85"

if [ -z "${API_TOKEN:-}" ]; then
  echo "→ Fetching API_TOKEN from Fly app '$APP'..."
  API_TOKEN="$(fly ssh console -C 'printenv API_TOKEN' --app "$APP" 2>/dev/null | tr -d '\r\n')"
  if [ -z "$API_TOKEN" ]; then
    echo "✗ Could not fetch API_TOKEN from Fly. Is 'fly auth' current?" >&2
    exit 1
  fi
fi
export API_TOKEN
export RUN_SMOKE=true

cd "$(dirname "$0")/.."

# Determine test name for Vlad's status
if [ -n "$FILTER" ]; then
  TASK_NAME="Running smoke: $FILTER"
else
  TASK_NAME="Running all smoke tests"
fi

# Set Vlad to busy
vlad_status() {
  curl -sf -X PATCH \
    -H "Authorization: Bearer $API_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"status\": \"$1\", \"current_task\": $2}" \
    "$API_BASE/agents/$VLAD_AGENT/status" >/dev/null 2>&1 || true
}

vlad_status "busy" "\"$TASK_NAME\""
echo "🤖 Vlad → busy ($TASK_NAME)"

# Always set Vlad back to online when done (success or failure)
cleanup() {
  vlad_status "online" "null"
  echo "🤖 Vlad → online"
}
trap cleanup EXIT

# Give the status time to propagate and be visible on web/iOS/Telegram
sleep 8

if [ -n "$FILTER" ]; then
  matches=$(find test/smoke -name "*${FILTER}*.rb" -type f)
  if [ -z "$matches" ]; then
    echo "✗ No smoke test matches '$FILTER' under test/smoke/" >&2
    exit 1
  fi
  bin/rails test $matches
else
  bin/rails test test/smoke/
fi
