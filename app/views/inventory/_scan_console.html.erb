<%# Shared scan-in / scan-out console. Locals:
      direction    "in" (Lora receives cases) | "out" (Chris removes bottles)
      title, blurb  headings
      allow_create  true on receive — unknown codes can be set up inline %>
<%
  inbound   = direction == "in"
  confirm_cls = inbound ? "bg-orange-600 hover:bg-orange-500" : "bg-red-600 hover:bg-red-500"
  verb      = inbound ? "Receive" : "Remove"
%>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24"
     data-controller="inventory-scanner"
     data-inventory-scanner-direction-value="<%= direction %>"
     data-inventory-scanner-allow-create-value="<%= allow_create %>"
     data-inventory-scanner-lookup-url-value="<%= nyk_inventory_lookup_path %>"
     data-inventory-scanner-movements-url-value="<%= nyk_inventory_movements_path %>"
     data-inventory-scanner-lib-url-value="<%= asset_path("html5-qrcode.js") %>">

  <h2 class="text-xl font-bold text-white mb-1"><%= title %></h2>
  <p class="text-gray-400 text-sm mb-5"><%= blurb %></p>

  <%# ── Camera scanner — html5-qrcode injects the <video> into #reader ──── %>
  <div data-inventory-scanner-target="cameraWrap" class="hidden mb-4">
    <div id="cellar-reader-<%= direction %>" data-inventory-scanner-target="reader"
         class="rounded-xl overflow-hidden bg-black border border-gray-800 min-h-[220px]"></div>
    <div class="flex items-center justify-between mt-2">
      <span data-inventory-scanner-target="status" class="text-xs text-gray-500"></span>
      <button type="button" data-action="inventory-scanner#toggleCamera" data-inventory-scanner-target="cameraBtn"
              class="text-sm px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-white font-semibold">Start camera</button>
    </div>
  </div>
  <div data-inventory-scanner-target="cameraUnsupported" class="hidden mb-4 text-xs text-gray-500 rounded-lg bg-gray-900 border border-gray-800 p-3">
    📷 Camera scanning needs the latest app version. Type or paste a barcode below, or use a USB/Bluetooth scanner in the meantime.
  </div>

  <%# ── Manual / hardware-scanner code entry ───────────────────────────── %>
  <div class="flex gap-2 mb-3">
    <input type="text" inputmode="numeric" autocomplete="off" enterkeyhint="search"
           data-inventory-scanner-target="codeInput"
           data-action="keydown.enter->inventory-scanner#manualLookup"
           placeholder="Scan or type a barcode…"
           class="flex-1 rounded-lg bg-gray-900 border border-gray-700 text-white text-base px-3 py-2.5 placeholder-gray-500 focus:border-orange-500 focus:outline-none">
    <button type="button" data-action="inventory-scanner#manualLookup"
            class="px-4 py-2.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-white font-semibold">Look up</button>
  </div>

  <%# ── Find by name (no barcode) ──────────────────────────────────────── %>
  <div class="relative mb-4">
    <input type="search" autocomplete="off"
           data-inventory-scanner-target="searchInput"
           data-action="input->inventory-scanner#search"
           placeholder="…or find by name"
           class="w-full rounded-lg bg-gray-900 border border-gray-700 text-white text-base px-3 py-2 placeholder-gray-500 focus:border-orange-500 focus:outline-none">
    <div data-inventory-scanner-target="results" class="hidden mt-1 rounded-lg border border-gray-800 divide-y divide-gray-800 overflow-hidden"></div>
  </div>

  <%# ── Resolved item → confirm quantity ───────────────────────────────── %>
  <div data-inventory-scanner-target="panel" class="hidden rounded-xl bg-gray-900 border border-orange-700/50 p-4 mb-4">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <div data-inventory-scanner-target="itemName" class="text-white font-semibold truncate"></div>
        <div data-inventory-scanner-target="itemMeta" class="text-xs text-gray-500 truncate"></div>
      </div>
      <div class="text-right shrink-0">
        <div data-inventory-scanner-target="onHand" class="text-lg font-black text-white tabular-nums"></div>
        <div class="text-[10px] uppercase tracking-wide text-gray-500">on hand</div>
      </div>
    </div>
    <div class="flex items-center gap-3 mt-4">
      <div class="inline-flex items-center rounded-lg border border-gray-700 overflow-hidden">
        <button type="button" data-action="inventory-scanner#dec" class="px-3 py-2 text-lg text-white bg-gray-800 hover:bg-gray-700">−</button>
        <input type="number" min="1" data-inventory-scanner-target="qty"
               class="w-16 text-center bg-gray-900 text-white text-base py-2 border-x border-gray-700 focus:outline-none">
        <button type="button" data-action="inventory-scanner#inc" class="px-3 py-2 text-lg text-white bg-gray-800 hover:bg-gray-700">+</button>
      </div>
      <button type="button" data-action="inventory-scanner#confirm" data-inventory-scanner-target="confirmBtn"
              class="flex-1 px-4 py-2.5 rounded-lg <%= confirm_cls %> text-white font-semibold"><%= verb %></button>
      <button type="button" data-action="inventory-scanner#cancel" class="text-sm text-gray-400 hover:text-white">Cancel</button>
    </div>
  </div>

  <%# ── Unknown code → set up new item (receive only) ──────────────────── %>
  <% if allow_create %>
    <div data-inventory-scanner-target="newPanel" class="hidden rounded-xl bg-gray-900 border border-amber-700/50 p-4 mb-4">
      <div class="text-amber-300 text-sm font-semibold mb-1">New barcode — set it up</div>
      <div class="text-xs text-gray-500 mb-3">Code <span data-inventory-scanner-target="newCode" class="font-mono text-gray-400"></span> isn't in the catalog yet.</div>
      <div class="space-y-3">
        <input type="text" data-inventory-scanner-target="newName" placeholder="Product name"
               class="w-full rounded-lg bg-gray-950 border border-gray-700 text-white text-base px-3 py-2 focus:border-orange-500 focus:outline-none">
        <div class="grid grid-cols-2 gap-3">
          <select data-inventory-scanner-target="newCategory"
                  class="rounded-lg bg-gray-950 border border-gray-700 text-white text-base px-3 py-2 focus:border-orange-500 focus:outline-none">
            <% InventoryItem::CATEGORIES.each do |c| %><option value="<%= c %>"><%= c.capitalize %></option><% end %>
          </select>
          <input type="number" min="1" value="12" data-inventory-scanner-target="newUnits" placeholder="Bottles per case"
                 class="rounded-lg bg-gray-950 border border-gray-700 text-white text-base px-3 py-2 focus:border-orange-500 focus:outline-none">
        </div>
        <div class="flex items-center gap-4 text-sm text-gray-300">
          <span class="text-gray-500">This barcode is a:</span>
          <label class="inline-flex items-center gap-1.5"><input type="radio" name="newkind" value="case" checked class="text-orange-500"> Case/box</label>
          <label class="inline-flex items-center gap-1.5"><input type="radio" name="newkind" value="bottle" class="text-orange-500"> Single bottle</label>
        </div>
        <button type="button" data-action="inventory-scanner#createAndReceive"
                class="w-full px-4 py-2.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white font-semibold">Add &amp; receive</button>
      </div>
    </div>
  <% else %>
    <div data-inventory-scanner-target="newPanel" class="hidden rounded-xl bg-gray-900 border border-gray-800 p-4 mb-4 text-sm text-gray-400">
      Unknown barcode <span data-inventory-scanner-target="newCode" class="font-mono text-gray-300"></span> —
      <%= link_to "set it up on the Receive screen", nyk_inventory_receive_path, class: "text-orange-400 hover:text-orange-300" %> first.
    </div>
  <% end %>

  <%# ── This session's log ─────────────────────────────────────────────── %>
  <div>
    <div class="text-xs uppercase tracking-wide text-gray-500 mb-2">Logged this session</div>
    <div data-inventory-scanner-target="recent" class="space-y-1.5"></div>
    <div data-inventory-scanner-target="recentEmpty" class="text-sm text-gray-600">Nothing scanned yet.</div>
  </div>
</div>
