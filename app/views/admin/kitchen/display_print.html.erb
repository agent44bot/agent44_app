<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>New York Kitchen · Upcoming Classes (flyer)</title>
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #fff;
      color: #111;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      line-height: 1.3;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    /* Each .page is one printed side: 9 classes → front, next 9 → back. */
    .page { max-width: 7.5in; margin: 0.4in auto; padding: 0 0.25in; }
    .header {
      display: flex; align-items: baseline; justify-content: space-between;
      padding-bottom: 8px; border-bottom: 2px solid #111; margin-bottom: 12px;
    }
    .brand { font-size: 16pt; font-weight: 800; letter-spacing: 0.01em; }
    .brand .accent { color: #c2410c; }
    .brand-logo { height: 60px; width: auto; vertical-align: middle; margin-right: 14px; }
    .meta-head { font-size: 8.5pt; color: #555; }

    /* Compact row: photo · text · QR. Fixed height so exactly nine fit on a
       side (a 10th would spill the page break). */
    .event {
      display: flex; align-items: center; gap: 12px;
      height: 0.98in; border-bottom: 1px solid #e2e2e2;
      page-break-inside: avoid; overflow: hidden;
    }
    .event:last-child { border-bottom: 0; }
    /* 16:9 to match the site's featured photos (768x433) — a square crop
       was cutting the sides off every image. */
    .thumb {
      width: 1.46in; height: 0.82in; flex: 0 0 auto;
      object-fit: cover; border-radius: 6px; background: #f1f1f1;
    }
    .body { flex: 1 1 auto; min-width: 0; }
    .name {
      font-size: 11pt; font-weight: 700; line-height: 1.15; margin-bottom: 3px;
      display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .info { font-size: 9pt; color: #333; }
    .info .sep { color: #bbb; padding: 0 2px; }
    .qr { flex: 0 0 auto; text-align: center; width: 0.8in; }
    .qr svg { width: 0.72in; height: 0.72in; display: block; margin: 0 auto; }
    .qr-cap { font-size: 6pt; color: #888; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 1px; }

    .footer {
      margin-top: 16px; padding-top: 8px; border-top: 1px solid #ddd;
      font-size: 8.5pt; color: #777; text-align: center;
    }
    .footer-cta { display: inline-flex; align-items: center; gap: 12px; text-align: left; }
    .footer-qr svg { width: 0.62in; height: 0.62in; display: block; }
    .footer-cta .lead { font-size: 11pt; font-weight: 700; color: #333; line-height: 1.35; }
    .footer-cta .url { color: #c2410c; }
    .footer-cta .more { font-size: 8.5pt; font-weight: 400; color: #777; }
    .empty { text-align: center; padding: 60px 0; color: #777; font-size: 12pt; }
    .actions { max-width: 7.5in; margin: 0.4in auto 0; padding: 0 0.25in; display: flex; gap: 10px; justify-content: flex-end; }
    .btn {
      display: inline-block; padding: 6px 14px; font-size: 10pt;
      border: 1px solid #444; background: #fff; color: #111;
      border-radius: 4px; cursor: pointer; text-decoration: none;
    }
    .btn-primary { background: #111; color: #fff; border-color: #111; }
    @media print {
      .actions { display: none; }
      .page { margin: 0; max-width: none; page-break-after: always; }
      .page:last-of-type { page-break-after: auto; }
      @page { margin: 0.4in; }
    }
  </style>
</head>
<body>
  <div class="actions">
    <a class="btn" href="<%= nyk_display_settings_path %>">← Back</a>
    <a class="btn" href="<%= nyk_display_print_path(variant: "stall") %>">Stall poster</a>
    <% if @show_photos %>
      <a class="btn" href="<%= nyk_display_print_path(photos: 0) %>">Text only</a>
    <% else %>
      <a class="btn" href="<%= nyk_display_print_path %>">With photos</a>
    <% end %>
    <button id="print-btn" type="button" class="btn btn-primary">🖨 Print</button>
  </div>

  <% if @events.any? %>
    <% pages = @events.each_slice(@per_page).to_a %>
    <% pages.each_with_index do |page_events, page_idx| %>
      <div class="page">
        <div class="header">
          <div class="brand">
            <% if @display_workspace&.logo&.attached? %>
              <img class="brand-logo" src="<%= url_for(@display_workspace.logo) %>" alt="New York Kitchen">
            <% else %>
              New York Kitchen
            <% end %>
          </div>
          <div class="meta-head">
            <% if page_idx > 0 %>continued · <% end %><%= pluralize(@events.size, "class") %><% if @more_count > 0 %> of <%= @events.size + @more_count %><% end %><% if @last_updated %> · updated <%= @last_updated.strftime("%b %-d, %Y") %><% end %>
          </div>
        </div>

        <% page_events.each do |event| %>
          <%
            start = event.start_at
            time_str = start.strftime("%-l:%M %p")
            time_str += " to #{event.end_at.strftime('%-l:%M %p')}" if event.end_at.present?
            venue = event.venue.presence || "New York Kitchen, Canandaigua"

            parts = [ start.strftime("%a, %b %-d"), time_str ]
            if @agent.setting(:show_price) && event.price.present?
              price = event.price.to_s.strip
              price = "$#{price}" unless price.match?(/[$£€]/)
              parts << price
            end
            if @agent.setting(:show_spots) && event.spots_left.present? && event.spots_left > 0
              parts << "#{pluralize(event.spots_left, "spot")} left"
            end
            parts << venue
          %>
          <div class="event">
            <% if @show_photos && event.image_url.present? %>
              <img class="thumb" src="<%= event.image_url %>" alt="" loading="eager">
            <% end %>
            <%# Per Lora, the flyer is name + details + QR only: no menu, no
                description. The menu is still scraped and stored on the event
                for other surfaces, just not printed here. %>
            <div class="body">
              <div class="name"><%= event.name.presence || "Class at New York Kitchen" %></div>
              <div class="info"><%= safe_join(parts, content_tag(:span, "·", class: "sep")) %></div>
            </div>
            <% if event.url.present? %>
              <div class="qr">
                <%= nyk_scan_qr(event, workspace: @display_workspace, source: "flyer") %>
                <div class="qr-cap">Scan to reserve</div>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if page_idx == pages.size - 1 %>
          <div class="footer">
            <div class="footer-cta">
              <span class="footer-qr"><%= nyk_scan_qr_url("https://nykitchen.com/calendar/", workspace: @display_workspace, source: "flyer") %></span>
              <span class="lead">
                Check out other New York Kitchen classes<br>
                @ <span class="url">nykitchen.com/calendar/</span>
                <% if @more_count.to_i > 0 %><br><span class="more">+ <%= pluralize(@more_count, "more class") %></span><% end %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="page">
      <div class="empty">No upcoming classes right now. Check back at nykitchen.com/calendar/.</div>
    </div>
  <% end %>

  <%# Inline event handlers (onclick=) are blocked by the app's CSP nonce
      policy, so attach via a nonced <script> instead. %>
  <%= javascript_tag nonce: true do %>
    document.getElementById("print-btn")?.addEventListener("click", function() {
      window.print();
    });
    // Opened straight from the hub's "Flyer" button → pop the print dialog
    // automatically. Wait for images so photos aren't blank on paper.
    if (new URLSearchParams(window.location.search).has("autoprint")) {
      window.addEventListener("load", function() {
        setTimeout(function() { window.print(); }, 600);
      });
    }
  <% end %>
</body>
</html>
