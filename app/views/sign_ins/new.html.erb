<% content_for(:title, "Sign in") %>

<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">Sign in</h1>
      <p class="mt-2 text-sm text-gray-500">Enter your email and we'll send you a sign-in code. New here? This creates your account.</p>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-sm p-6">
      <%# Passkey / Face ID sign-in. Auto-hides where WebAuthn isn't available. %>
      <div data-controller="passkey"
           data-passkey-auth-challenge-url-value="<%= passkey_auth_challenge_path %>"
           data-passkey-auth-url-value="<%= passkey_authenticate_path %>">
        <button type="button" data-action="passkey#authenticate"
                class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-orange-600 to-amber-600 text-white font-semibold rounded-lg hover:from-orange-700 hover:to-amber-700 transition shadow-sm">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M3 17v2a2 2 0 002 2h2M17 21h2a2 2 0 002-2v-2M8 11v1M16 11v1M9 16c.5.5 1.5 1 3 1s2.5-.5 3-1M12 8v5"/>
          </svg>
          Sign in with Face ID
        </button>
        <p data-passkey-target="status" class="text-xs text-gray-400 text-center mt-2"></p>
        <div class="relative my-5">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-800"></div></div>
          <div class="relative flex justify-center text-xs"><span class="bg-gray-900 px-2 text-gray-500">or use your email</span></div>
        </div>
      </div>

      <%= form_with url: sign_in_path, method: :post, class: "space-y-5" do %>
        <div>
          <label for="email_address" class="block text-sm font-medium text-gray-300 mb-1">Email address</label>
          <input type="email" name="email_address" id="email_address" required autofocus
                 autocomplete="email" inputmode="email"
                 class="w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-base sm:text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
                 placeholder="you@example.com">
        </div>
        <button type="submit"
                class="w-full px-4 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm">
          Continue
        </button>
      <% end %>

      <p class="text-center text-sm text-gray-500 mt-5">
        Prefer a password or Nostr key? <%= link_to "Sign in here", new_session_path, class: "text-orange-500 hover:text-orange-300 font-medium" %>
      </p>
    </div>
  </div>
</div>
