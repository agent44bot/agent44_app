<% content_for(:title, "Admin: Users") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Manage Users</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @users.size %> registered user(s)</p>
    </div>
  </div>

  <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-800">
      <thead class="bg-gray-900">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Auth Method</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Active</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Sessions</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-800 transition">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-white"><%= user.display_identifier %></div>
              <% if user.email_address.present? && user.display_name.present? %>
                <div class="text-xs text-gray-400"><%= user.email_address %></div>
              <% end %>
              <% if user.npub.present? %>
                <div class="text-xs text-gray-400 font-mono"><%= user.short_npub %></div>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <% if user.email_address.present? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Email</span>
              <% end %>
              <% if user.pubkey_hex.present? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-orange-900/50 text-orange-400">Nostr</span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= user.admin? ? 'bg-orange-900/50 text-orange-400' : 'bg-gray-800 text-gray-200' %>">
                <%= user.role %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= user.created_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <% last_session = user.sessions.max_by(&:updated_at) %>
              <%= last_session&.updated_at&.strftime("%b %d, %Y %H:%M") || "Never" %>
            </td>
            <td class="px-6 py-4 text-sm text-white text-right font-semibold">
              <%= user.sessions.size %>
            </td>
            <td class="px-6 py-4 text-sm text-right">
              <% if user.admin? || user.id == Current.real_user&.id %>
                <span class="text-xs text-gray-600">—</span>
              <% else %>
                <div class="inline-flex items-center gap-2 justify-end">
                  <% if user.email_address == "lora.downie@nykitchen.com" && Current.user&.email_address == "botwhisperer@hey.com" %>
                    <%= link_to "Track →", admin_track_lora_path,
                          class: "inline-flex items-center px-2.5 py-1 rounded-md bg-gray-800 hover:bg-gray-700 border border-gray-700 hover:border-orange-500 text-gray-200 text-xs font-semibold" %>
                  <% end %>
                  <%= button_to "View as →", impersonate_path(user_id: user.id),
                        method: :post,
                        form: { data: { turbo_confirm: "Sign in as #{user.display_identifier}? Every action is logged." } },
                        class: "inline-flex items-center px-2.5 py-1 rounded-md bg-amber-600 hover:bg-amber-500 text-white text-xs font-semibold cursor-pointer" %>
                  <% owned = user.owned_workspaces.active.pluck(:name) %>
                  <% confirm = "Delete #{user.display_identifier}? Removes their workspace memberships, sent invites, and posts." +
                               (owned.any? ? " Also permanently deletes the workspace(s) they own: #{owned.to_sentence}." : "") +
                               " Cannot be undone." %>
                  <%= button_to "Delete", admin_user_path(user),
                        method: :delete,
                        form: { data: { turbo_confirm: confirm } },
                        class: "inline-flex items-center px-2.5 py-1 rounded-md bg-red-700 hover:bg-red-600 text-white text-xs font-semibold cursor-pointer" %>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @users.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-500">No users yet.</p>
      </div>
    <% end %>
  </div>
</div>
