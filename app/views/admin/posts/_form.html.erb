<%= form_with model: [:admin, @post], class: "space-y-6" do |f| %>
  <% if @post.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <h3 class="text-sm font-medium text-red-800"><%= pluralize(@post.errors.count, "error") %> prevented this post from being saved:</h3>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% @post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label for="post_title" class="block text-sm font-medium text-gray-300 mb-1">Title</label>
    <%= f.text_field :title, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition", placeholder: "Post title" %>
  </div>

  <div>
    <label for="post_slug" class="block text-sm font-medium text-gray-300 mb-1">Slug</label>
    <%= f.text_field :slug, class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition font-mono", placeholder: "post-url-slug (leave blank to auto-generate)" %>
  </div>

  <div>
    <label for="post_body" class="block text-sm font-medium text-gray-300 mb-1">Body</label>
    <%= f.rich_text_area :body, class: "w-full min-h-[300px] bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500" %>
  </div>

  <div class="flex items-center gap-6">
    <div class="flex items-center gap-2">
      <%= f.check_box :published, class: "h-4 w-4 text-orange-600 border-gray-700 rounded focus:ring-orange-500" %>
      <label for="post_published" class="text-sm font-medium text-gray-300">Published</label>
    </div>

    <div class="flex-1">
      <label for="post_published_at" class="block text-sm font-medium text-gray-300 mb-1">Published At</label>
      <%= f.datetime_local_field :published_at, class: "px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-800">
    <%= f.submit class: "px-6 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", admin_posts_path, class: "px-4 py-2.5 text-sm font-medium text-gray-300 hover:text-orange-400 transition" %>
  </div>
<% end %>
