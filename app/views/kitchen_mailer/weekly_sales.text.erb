<%
  bw = @s[:booked_week] || {}
  wow = bw[:prior_revenue].to_i.positive? ? (100.0 * (bw[:revenue].to_i - bw[:prior_revenue]) / bw[:prior_revenue]).round : nil
  short = ->(n) { n.to_i.abs >= 1000 ? "~$#{number_with_delimiter((n / 1000.0).round)}K" : number_to_currency(n, precision: 0) }
-%>
NY Kitchen — Weekly Team Report
<%= @s[:snapshot_date]&.strftime("Week of %B %-d, %Y") %>
<% if @s[:headline].present? -%>

<%= @s[:headline] %>
  — Carson, your concierge
<% end -%>

IRIS · ANALYST
BOOKED THIS WEEK: <%= number_to_currency(bw[:revenue].to_i, precision: 0) %><%= wow ? " (#{wow >= 0 ? '+' : ''}#{wow}% vs last week)" : "" %> · <%= bw[:tickets].to_i %> tickets
Pipeline: <%= number_to_currency(@s[:rev_sold], precision: 0) %> booked of <%= short.call(@s[:rev_total]) %> · <%= @s[:rev_total].to_f.positive? ? (100.0 * @s[:rev_sold] / @s[:rev_total]).round : 0 %>% sold · <%= short.call(@s[:rev_left]) %> still to sell, across <%= @s[:rev_priced_count] %> classes.

<% if @s[:periods].present? -%>
BY PERIOD  (money in · % sold-through · open)
<% @s[:periods].each do |p| -%>
- <%= p[:label].ljust(11) %> <%= number_to_currency(p[:sold], precision: 0).rjust(8) %> · <%= "#{p[:pct].to_i}%".rjust(4) %> · <%= short.call(p[:left]) %> <%= p[:kind] == :past ? "(booked/missed)" : "(sold/left)" %>
<% end -%>
<% end -%>
<% if @s[:newly_sold_out].present? -%>

SOLD OUT THIS WEEK
<% @s[:newly_sold_out].first(6).each do |e| -%>
- <%= e.name %> (<%= e.start_at&.strftime("%a %-m/%-d") %>)
<% end -%>
<% end -%>
<% if @s[:movers].present? -%>

BIGGEST MOVERS THIS WEEK
<% @s[:movers].each_with_index do |row, i| -%>
<%= i + 1 %>. <%= row[:event].name %> (<%= row[:event].start_at&.strftime("%a %-m/%-d") %>) — +<%= row[:tickets] %> tickets, <%= number_to_currency(row[:revenue], precision: 0) %>
<% end -%>
<% end -%>
<% if @s[:needs_a_push].present? -%>

NEEDS A PUSH
<% @s[:needs_a_push].each_with_index do |row, i| -%>
<%= i + 1 %>. <%= row[:event].name %> (<%= row[:event].start_at&.strftime("%a %-m/%-d") %>, in <%= row[:days_until] %>d) — needs ~<%= row[:needed_pace] %>/day, selling ~<%= row[:observed_pace] %>/day
<% end -%>
<% end -%>
<% if @s[:selling_fastest].present? -%>

SELLING FASTEST (all-time pace)
<% @s[:selling_fastest].each_with_index do |row, i| -%>
<%= i + 1 %>. <%= row[:event].name %> (<%= row[:event].start_at&.strftime("%a %-m/%-d") %>) — ~<%= row[:pace] %>/day
<% end -%>
<% end -%>
<% if @s[:empty_last_week].present? -%>

RAN WITH EMPTY SEATS (last 7 days)
<% @s[:empty_last_week].each do |e| -%>
- <%= e.name %> (<%= e.start_at&.strftime("%a %-m/%-d") %>) — <%= e.spots_left %> unsold
<% end -%>
<% end -%>

TICKETS SOLD BY WEEK
<% Array(@s[:weekly_tickets]).last(6).each do |w| -%>
- <%= w[:label] %>: <%= w[:tickets] %> tickets
<% end -%>
<% argus = @s[:argus] || {}; scout = @s[:scout] || {} -%>
<% if argus[:total].to_i.positive? -%>

ARGUS · SENTRY (site uptime)
<%= argus[:total] %> calendar checks — <%= argus[:passed] %> passed<%= argus[:failed].to_i.positive? ? ", #{argus[:failed]} failed (#{argus[:fail_pct]}%)" : "" %>. <%= argus[:fail_pct].to_i.zero? ? "Calendar stayed up all week." : "Booking site had trouble #{argus[:fail_pct]}% of the time." %>
<% end -%>
<% if scout[:snapshots].to_i.positive? || scout[:total].to_i.positive? -%>

SCOUT · RECON (data)
<%= scout[:snapshots] %> snapshots taken<%= scout[:total].to_i.positive? ? " across #{scout[:total]} scrape runs (#{scout[:passed]} ok#{scout[:failed].to_i.positive? ? ", #{scout[:failed]} failed" : ''})" : "" %>.
<% end -%>

<% sam = @s[:sam] || {}; echo = @s[:echo] -%>

SAM · SCHEDULER (calendar)
<%= (sam[:added].to_i + sam[:removed].to_i + sam[:price_changes].to_i).positive? ? "#{sam[:added].to_i} added, #{sam[:removed].to_i} removed, #{sam[:price_changes].to_i} price change(s)." : "Held steady — no classes added or removed." %>
<% if echo -%>

ECHO · BROADCAST (social)
<%= echo[:posts].to_i.positive? ? "#{echo[:posts]} post(s) published#{echo[:by_platform].present? ? " (#{echo[:by_platform].map { |p, n| "#{p.to_s.capitalize}: #{n}" }.join(', ')})" : ''} — #{echo[:likes]} likes, #{echo[:reposts]} reposts, #{echo[:replies]} replies." : "No posts published this week across #{echo[:accounts]} connected account(s)." %>
<% end -%>
<% neon = @s[:neon] || {} -%>
<% if neon[:last_seen_at] || neon[:days_seen].to_i.positive? -%>

NEON · MARQUEE (in-store screen)
<%= neon[:days_seen].to_i.positive? ? "Live on #{neon[:days_seen]} of the last 7 days#{neon[:last_seen_at] ? " (last seen #{time_ago_in_words(neon[:last_seen_at])} ago)" : ''}." : "Last seen #{time_ago_in_words(neon[:last_seen_at])} ago. Daily uptime tracking just started." %>
<% end -%>
<% if @s[:changelog].present? -%>

NEW THIS WEEK (improvements your team shipped)
<% @s[:changelog].each do |c| -%>
- <%= c[:note] %>
<% end -%>
<% end -%>

