<% content_for(:title, @job.title) %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Back link -->
  <div class="mb-6">
    <%= link_to "&larr; Back to Jobs".html_safe, jobs_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
  </div>

  <!-- Job Header -->
  <div class="bg-white rounded-xl border border-gray-200 p-8">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
      <div>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 mb-3">
          <%= @job.category&.titleize || "General" %>
        </span>
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900"><%= @job.title %></h1>
        <p class="mt-2 text-lg text-gray-600"><%= @job.company %></p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <% if authenticated? %>
          <% if @saved %>
            <%= button_to job_saved_job_path(@job), method: :delete, class: "inline-flex items-center gap-2 px-4 py-3 bg-red-50 text-red-600 font-medium rounded-lg hover:bg-red-100 transition whitespace-nowrap border border-red-200", title: "Unsave job" do %>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
              Saved
            <% end %>
          <% else %>
            <%= button_to job_saved_job_path(@job), method: :post, class: "inline-flex items-center gap-2 px-4 py-3 bg-gray-50 text-gray-600 font-medium rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition whitespace-nowrap border border-gray-200", title: "Save job" do %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 2h14a1 1 0 011 1v19.143a.5.5 0 01-.766.424L12 18.03l-7.234 4.536A.5.5 0 014 22.143V3a1 1 0 011-1z"/></svg>
              Save
            <% end %>
          <% end %>
          <% if @applied %>
            <%= button_to toggle_applied_job_saved_job_path(@job), method: :post, class: "inline-flex items-center gap-2 px-4 py-3 bg-green-50 text-green-700 font-medium rounded-lg hover:bg-green-100 transition whitespace-nowrap border border-green-200", title: "Mark as not applied" do %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Applied <%= @saved_job.applied_at.in_time_zone("Eastern Time (US & Canada)").strftime("%-m/%-d") %>
            <% end %>
          <% else %>
            <%= button_to toggle_applied_job_saved_job_path(@job), method: :post, class: "inline-flex items-center gap-2 px-4 py-3 bg-gray-50 text-gray-600 font-medium rounded-lg hover:bg-green-50 hover:text-green-700 transition whitespace-nowrap border border-gray-200", title: "Mark as applied" do %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Applied
            <% end %>
          <% end %>
        <% end %>
        <% if @job.description.present? %>
          <button onclick="copyJobDescription(this)" class="inline-flex items-center gap-2 px-4 py-3 bg-gray-50 text-gray-600 font-medium rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition whitespace-nowrap border border-gray-200" title="Copy job description">
            <svg class="w-5 h-5 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <svg class="w-5 h-5 check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="copy-label">Copy</span>
          </button>
        <% end %>
        <% if @job.url.present? %>
          <%= link_to @job.url, target: "_blank", rel: "noopener noreferrer",
                class: "inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition shadow-sm whitespace-nowrap" do %>
            Apply Now
            <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Meta -->
    <div class="flex flex-wrap gap-4 text-sm text-gray-500 border-t border-gray-100 pt-6 mb-8">
      <% if @job.location.present? %>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span><%= @job.location %></span>
        </div>
      <% end %>
      <% if @job.salary.present? %>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-green-600 font-medium"><%= @job.salary %></span>
        </div>
      <% end %>
      <% if @job.source.present? %>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          <span>via <%= @job.source %></span>
        </div>
      <% end %>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span>Posted <%= days_ago_in_words(@job.created_at) %></span>
      </div>
    </div>

    <!-- Description -->
    <% if @job.description.present? %>
      <div class="prose prose-indigo max-w-none">
        <%= simple_format(@job.description) %>
      </div>
    <% end %>

    <!-- Bottom Apply -->
    <% if @job.url.present? %>
      <div class="mt-10 pt-6 border-t border-gray-100">
        <%= link_to @job.url, target: "_blank", rel: "noopener noreferrer",
              class: "inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition shadow-sm" do %>
          Apply for this Position
          <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<script>
function copyJobDescription(button) {
  var description = document.querySelector('.prose.prose-indigo');
  if (!description) return;
  navigator.clipboard.writeText(description.innerText).then(function() {
    button.querySelector('.copy-icon').classList.add('hidden');
    button.querySelector('.check-icon').classList.remove('hidden');
    button.querySelector('.copy-label').textContent = 'Copied!';
    setTimeout(function() {
      button.querySelector('.copy-icon').classList.remove('hidden');
      button.querySelector('.check-icon').classList.add('hidden');
      button.querySelector('.copy-label').textContent = 'Copy';
    }, 2000);
  });
}
</script>
