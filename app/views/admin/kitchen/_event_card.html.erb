<% post_log = defined?(@post_logs) ? @post_logs[event.url] : nil %>
<div data-kitchen-filter-target="card" data-status="<%= event.availability_status %>"
     data-controller="social-post"
     data-social-post-name-value="<%= event.name %>"
     data-social-post-date-value="<%= event.start_at.strftime("%A, %B %-d") %>"
     data-social-post-time-value="<%= event.start_at.strftime("%-I:%M %p") %><%= event.end_at ? " - #{event.end_at.strftime("%-I:%M %p")}" : "" %>"
     data-social-post-price-value="<%= event.price %>"
     data-social-post-spots-value="<%= event.spots_left %>"
     data-social-post-capacity-value="<%= event.capacity %>"
     data-social-post-url-value="<%= event.url %>"
     data-social-post-description-value="<%= truncate(CGI.unescapeHTML(strip_tags(event.description.to_s)).gsub("&nbsp;", " ").gsub(/([ap]m)([A-Z])/, '\1 \2').gsub(/\n/, ' ').squeeze(' ').strip, length: 200, separator: '. ', omission: '.') %>"
     data-social-post-image-url-value="<%= event.image_url %>"
     data-social-post-log-url-value="/nykitchen/social_post_log"
     data-social-post-enhance-url-value="/nykitchen/enhance_post"
     <% default_ws = Array(@sendable_workspaces).first %>
     <% if default_ws %>data-social-post-send-to-workspace-url-value="/nykitchen/send_to_workspace"
     data-social-post-workspace-slug-value="<%= default_ws.slug %>"<% end %>
     data-social-post-posted-value="<%= post_log&.posted? ? 'true' : 'false' %>"
     data-social-post-enhanced-text-value="<%= post_log&.enhanced_text %>"
     class="bg-gray-900 rounded-lg p-4 flex items-stretch gap-3">
  <div class="flex-1 min-w-0">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-sm font-semibold text-gray-300">
          <% if show_date %>
            <%= event.start_at.strftime("%a %-m/%-d %-I:%M %p") %>
          <% else %>
            <%= event.start_at.strftime("%-I:%M %p") %>
          <% end %>
        </span>
        <a href="<%= event.url %>" target="_blank" rel="noopener"
           class="text-sm font-medium text-orange-400 hover:text-orange-300 transition truncate">
          <%= event.name %>
        </a>
      </div>
      <div class="flex items-center gap-2 mt-1 text-xs text-gray-500 flex-wrap">
        <% if event.instructor %><span><%= event.instructor %></span><span>&middot;</span><% end %>
        <% if event.price.present? %><span>$<%= event.price %></span><% end %>
        <% ws_status = defined?(@workspace_status_by_url) ? @workspace_status_by_url[event.url] : nil %>
        <% if ws_status %>
          <span>&middot;</span>
          <% if ws_status[:kind] == :posted %>
            <%= link_to social_workspace_path(ws_status[:workspace_slug]),
                        class: "text-green-500 hover:text-green-400 transition",
                        title: "Open #{ws_status[:workspace_name]} workspace" do %>
              ✓ Posted <%= time_ago_in_words(ws_status[:time]) %> ago
              <span class="text-gray-500">to <%= ws_status[:platforms].map(&:titleize).join(' + ') %></span>
            <% end %>
          <% else %>
            <%= link_to social_workspace_path(ws_status[:workspace_slug]),
                        class: "text-gray-400 hover:text-gray-300 transition",
                        title: "Open #{ws_status[:workspace_name]} workspace" do %>
              ✓ Drafted <%= time_ago_in_words(ws_status[:time]) %> ago
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="shrink-0 flex flex-col items-end gap-1">
      <% case event.availability.to_s.downcase %>
      <% when /soldout/ %>
        <span class="inline-block px-2 py-0.5 rounded-full bg-red-900/50 text-red-400 text-xs font-semibold">SOLD OUT</span>
      <% when /closed/ %>
        <span class="inline-block px-2 py-0.5 rounded-full bg-red-900/50 text-red-400 text-xs font-semibold">TICKETS NO LONGER AVAILABLE</span>
      <% when /limited/ %>
        <span class="inline-block px-2 py-0.5 rounded-full bg-amber-900/50 text-amber-400 text-xs font-semibold">LIMITED</span>
      <% when /instock/ %>
        <span class="inline-block px-2 py-0.5 rounded-full bg-green-900/50 text-green-400 text-xs font-semibold">AVAILABLE</span>
      <% else %>
        <span class="inline-block px-2 py-0.5 rounded-full bg-gray-800 text-gray-500 text-xs"><%= event.availability %></span>
      <% end %>
      <% if event.sold_out? && event.tickets_sold && !(event.capacity_via_proxy? && event.tickets_sold.zero?) %>
        <%# Sold out: show how many tickets sold rather than "0 left".
            Uses KitchenEvent#tickets_sold/#tickets_total three-tier fallback
            (live cap → snapshotted cap → observed high-water proxy). The proxy
            only knows a floor, so render it as "X+ sold" — but suppress it when
            that floor is 0 (we never saw any inventory), which carries no info. %>
        <span class="text-xs font-semibold text-red-400">
          <% if event.capacity_via_proxy? %>
            <%= "#{event.tickets_sold}+ sold" %>
          <% else %>
            <%= "#{event.tickets_sold} of #{event.tickets_total} tickets sold" %>
          <% end %>
        </span>
      <% elsif !event.sold_out? && event.spots_left %>
        <% color = event.spots_left <= 0 ? "text-red-400" : (event.spots_left <= 3 ? "text-amber-400" : "text-green-400") %>
        <span class="text-xs font-semibold <%= color %>">
          <%= event.capacity ? "#{event.spots_left} of #{event.capacity} left" : "#{event.spots_left} left" %>
        </span>
      <% end %>
    </div>
  </div>
  </div>
  <%# Action rail: per-class icon buttons on the right edge of each card, each
      a stacked emoji + tiny label. Echo draft post, recipe (add/print), and a
      grocery list for the class (only once a recipe is attached, since the
      list is built from the recipe). Recipe/grocery only render on pages that
      load @handouts_by_url (Sam's list). %>
  <% recipe_col = defined?(@handouts_by_url) && @handouts_by_url %>
  <% handout_id = recipe_col ? @handouts_by_url[event.url] : nil %>
  <% echo_col   = !event.sold_out? && default_ws %>
  <% if recipe_col || echo_col %>
    <div class="shrink-0 flex items-stretch divide-x divide-gray-800 border-l border-gray-800">
      <% if echo_col %>
        <div class="flex flex-col items-center justify-center gap-0.5 w-16 px-1">
          <button data-action="social-post#sendToWorkspace"
                  data-social-post-target="sendToWorkspaceBtn"
                  title="Draft a social post to Echo"
                  class="text-2xl leading-none text-blue-400 hover:text-blue-300 transition cursor-pointer">🔈</button>
          <span class="text-[10px] font-medium text-blue-400">Draft Post</span>
        </div>
      <% end %>
      <% if recipe_col %>
        <div class="flex flex-col items-center justify-center w-16 px-1">
          <% if handout_id %>
            <%= link_to print_nyk_handout_path(handout_id), target: "_blank", rel: "noopener",
                  title: "Print recipe",
                  class: "flex flex-col items-center gap-0.5 text-emerald-400 hover:text-emerald-300 transition" do %>
              <span class="text-2xl leading-none">🖨</span>
              <span class="text-[10px] font-medium">Print</span>
            <% end %>
          <% else %>
            <%= link_to new_nyk_handout_path(event_url: event.url, event_name: event.name),
                  title: "Add a recipe",
                  class: "flex flex-col items-center gap-0.5 text-gray-500 hover:text-gray-300 transition" do %>
              <span class="text-2xl leading-none grayscale opacity-60">📝</span>
              <span class="text-[10px] font-medium">Recipe</span>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if handout_id && event.start_at %>
        <div class="flex flex-col items-center justify-center w-16 px-1">
          <%= link_to nyk_grocery_path(from: event.start_at.to_date.iso8601, to: event.start_at.to_date.iso8601),
                title: "Grocery list for this class",
                class: "flex flex-col items-center gap-0.5 text-gray-400 hover:text-orange-400 transition" do %>
            <span class="text-2xl leading-none">🛒</span>
            <span class="text-[10px] font-medium">Grocery</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
