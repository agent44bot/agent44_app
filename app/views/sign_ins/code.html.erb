<% content_for(:title, "Enter your code") %>

<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">Check your email</h1>
      <p class="mt-2 text-sm text-gray-500">
        We sent a 6-digit code to <span class="text-gray-300 font-medium"><%= @email %></span>.
      </p>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-sm p-6">
      <%= form_with url: verify_sign_in_path, method: :post, class: "space-y-5" do %>
        <%= hidden_field_tag :email_address, @email %>
        <div>
          <label for="code" class="block text-sm font-medium text-gray-300 mb-1">Sign-in code</label>
          <input type="text" name="code" id="code" required autofocus
                 inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]*" maxlength="6"
                 class="w-full px-3 py-3 bg-gray-800 border border-gray-700 rounded-lg text-center text-2xl tracking-[0.4em] font-semibold text-white placeholder-gray-600 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
                 placeholder="000000">
        </div>
        <button type="submit"
                class="w-full px-4 py-2.5 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition shadow-sm">
          Verify &amp; sign in
        </button>
      <% end %>

      <div class="flex items-center justify-between mt-5 text-sm">
        <%= link_to "← Different email", sign_in_path, class: "text-gray-500 hover:text-gray-300 transition" %>
        <%= button_to "Resend code", sign_in_path, params: { email_address: @email },
              class: "text-orange-500 hover:text-orange-300 font-medium bg-transparent border-0 p-0 cursor-pointer" %>
      </div>
    </div>
  </div>
</div>
