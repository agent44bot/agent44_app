<% content_for :title, "X Posts" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">X Posts</h1>
      <p class="text-sm text-gray-400 mt-1">
        Trial autopost log for <a class="text-orange-400 underline" target="_blank" href="https://x.com/agent44bot">@agent44bot</a>.
        Daily draft fires at 9am ET.
      </p>
    </div>
    <%= link_to "Back to NYK", "/nykitchen",
          class: "text-sm text-gray-400 hover:text-orange-400 transition" %>
  </div>

  <% sections = [
       ["Pending drafts",  @pending, "border-orange-700 bg-orange-950/20"],
       ["Posted",          @posted,  "border-green-800 bg-green-950/20"],
       ["History (skipped or deleted)", @history, "border-gray-800 bg-gray-900"]
     ] %>

  <% sections.each do |title, list, color| %>
    <section class="mb-8">
      <h2 class="text-base font-semibold text-white mb-3"><%= title %> <span class="text-gray-500 font-normal">(<%= list.size %>)</span></h2>
      <% if list.empty? %>
        <p class="text-sm text-gray-500 italic">None.</p>
      <% else %>
        <div class="space-y-3">
          <% list.each do |log| %>
            <div class="rounded-lg border <%= color %> p-4">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="min-w-0 flex-1">
                  <% if log.event_url.present? %>
                    <a href="<%= log.event_url %>" target="_blank" class="text-sm font-semibold text-white hover:text-orange-400 break-words">
                      <%= log.event_url.split("/event/").last&.delete_suffix("/")&.gsub("-", " ")&.titleize.presence || log.event_url %>
                    </a>
                  <% end %>
                  <p class="text-xs text-gray-500 mt-0.5 font-mono break-all"><%= log.event_url %></p>
                </div>
                <div class="text-xs text-gray-500 text-right shrink-0 leading-tight">
                  <% if log.x_drafted_at.present? %>
                    <div>drafted <%= time_ago_in_words(log.x_drafted_at) %> ago</div>
                  <% end %>
                  <% if log.x_posted_at.present? %>
                    <div class="text-green-400">posted <%= time_ago_in_words(log.x_posted_at) %> ago</div>
                  <% end %>
                  <% if log.x_skipped_at.present? %>
                    <div class="text-gray-400">skipped <%= time_ago_in_words(log.x_skipped_at) %> ago</div>
                  <% end %>
                  <% if log.x_deleted_at.present? %>
                    <div class="text-red-400">deleted <%= time_ago_in_words(log.x_deleted_at) %> ago</div>
                  <% end %>
                </div>
              </div>

              <% if log.x_draft_text.present? %>
                <p class="text-sm text-gray-200 mb-3 whitespace-pre-wrap break-words"><%= log.x_draft_text %></p>
              <% end %>

              <div class="flex items-center gap-2 flex-wrap">
                <% if log.x_post_id.blank? && log.x_skipped_at.blank? && log.x_approval_token.present? %>
                  <%= button_to "Post to X", "/nykitchen/x_drafts/#{log.x_approval_token}/post",
                        method: :post,
                        data: { turbo_confirm: "Post this to @agent44bot now?" },
                        class: "px-3 py-1.5 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-xs font-semibold transition cursor-pointer" %>
                  <%= button_to "Skip", "/nykitchen/x_drafts/#{log.x_approval_token}/skip",
                        method: :post,
                        class: "px-3 py-1.5 rounded-md bg-gray-800 hover:bg-gray-700 text-gray-300 text-xs transition cursor-pointer" %>
                  <%= link_to "Open draft", nyk_x_draft_path(token: log.x_approval_token),
                        class: "text-xs text-gray-500 hover:text-orange-400 underline ml-auto" %>
                <% elsif log.x_post_id.present? && log.x_deleted_at.blank? %>
                  <a href="https://x.com/agent44bot/status/<%= log.x_post_id %>" target="_blank"
                     class="px-3 py-1.5 rounded-md bg-gray-800 hover:bg-gray-700 text-gray-200 text-xs font-semibold transition">
                    View on X
                  </a>
                  <%= button_to "Delete tweet", "/nykitchen/x_drafts/#{log.x_approval_token}/delete_tweet",
                        method: :post,
                        data: { turbo_confirm: "Delete this tweet from X? This can't be undone." },
                        class: "px-3 py-1.5 rounded-md bg-red-600 hover:bg-red-500 text-white text-xs font-semibold transition cursor-pointer" %>
                <% elsif log.x_post_id.present? && log.x_deleted_at.present? %>
                  <span class="text-xs text-gray-500">Tweet deleted from X.</span>
                <% elsif log.x_skipped_at.present? %>
                  <span class="text-xs text-gray-500">Skipped — never posted.</span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
