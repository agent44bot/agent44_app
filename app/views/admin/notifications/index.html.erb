<% content_for :title, "Notifications" %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Notifications</h1>
      <p class="text-sm text-gray-400 mt-1">
        <%= pluralize(@unread_count, "unread notification") %>
      </p>
    </div>
    <% if @unread_count > 0 %>
      <%= button_to "Mark all read", mark_all_read_admin_notifications_path,
            method: :post,
            class: "text-sm font-medium px-3 py-1.5 rounded-md bg-orange-600 hover:bg-orange-700 text-white transition" %>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div class="rounded-lg bg-gray-900 border border-gray-700 p-8 text-center">
      <p class="text-gray-400">No notifications yet.</p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @notifications.each do |n| %>
        <% level_color = case n.level
           when "error" then "border-red-600 bg-red-950/40"
           when "warning" then "border-yellow-600 bg-yellow-950/30"
           when "success" then "border-green-600 bg-green-950/30"
           else "border-gray-700 bg-gray-900"
           end %>
        <% icon = case n.level
           when "error" then "🚨"
           when "warning" then "⚠️"
           when "success" then "✅"
           else "ℹ️"
           end %>
        <div class="rounded-lg border <%= level_color %> p-4 <%= 'opacity-60' if n.read? %>">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-lg"><%= icon %></span>
                <span class="text-xs font-mono text-gray-500"><%= n.source %></span>
                <span class="text-xs text-gray-500"><%= n.created_at.in_time_zone.strftime("%b %-d, %Y %-l:%M %p %Z") %></span>
                <% unless n.read? %>
                  <span class="text-xs font-semibold text-orange-400 uppercase">New</span>
                <% end %>
              </div>
              <h3 class="text-sm font-semibold text-white"><%= n.title %></h3>
              <% if n.body.present? %>
                <p class="text-sm text-gray-300 mt-1 whitespace-pre-wrap"><%= n.body %></p>
              <% end %>
            </div>
            <div class="flex-shrink-0 flex items-center gap-2">
              <% unless n.read? %>
                <%= button_to "Mark read", admin_notification_path(n),
                      method: :patch,
                      class: "text-xs text-gray-400 hover:text-orange-400 transition" %>
              <% end %>
              <%= button_to "Delete", admin_notification_path(n),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this notification?" } },
                    class: "text-xs text-gray-500 hover:text-red-400 transition" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
