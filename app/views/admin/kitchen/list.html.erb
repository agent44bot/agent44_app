<% content_for(:title, "NY Kitchen · List Agent") %>

<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10" data-controller="kitchen-filter recipe-loading dialog">
  <%# Shown by recipe-loading#show while a no-recipe class is drafting its recipe
      with AI (several seconds before the redirect to the editor). %>
  <div data-recipe-loading-target="overlay"
       class="hidden fixed inset-0 z-50 flex flex-col items-center justify-center gap-4 bg-gray-950/90 backdrop-blur-sm text-center px-6">
    <svg class="animate-spin h-10 w-10 text-orange-500" viewBox="0 0 24 24" fill="none">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    <p class="text-white text-base font-semibold">Agent Sam is generating a recipe for you...</p>
    <p class="text-gray-400 text-sm">This takes a few seconds. Sam is putting together the recipe, equipment items, pull sheet, and grocery list.</p>
  </div>
  <% list_crumbs = capture do %>
    <%= render "admin/kitchen/breadcrumbs", kind: "list", wrapper_class: "flex items-center gap-2 min-w-0 text-base text-gray-400" %>
  <% end %>
  <% list_actions = capture do %>
    <% if @nyk_manager %>
      <button type="button" data-action="click->dialog#open"
              class="flex items-center gap-1.5 px-3 h-8 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold transition">
        <span class="text-base leading-none">+</span><span>Add a class</span>
      </button>
    <% end %>
    <%= link_to nyk_recipes_path,
          class: "flex items-center gap-1.5 px-3 h-8 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" do %>
      📖 <span>Recipes</span>
    <% end %>
    <%= link_to nyk_prices_path,
          class: "flex items-center gap-1.5 px-3 h-8 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" do %>
      🥫 <span>Pantry</span>
    <% end %>
    <% if authenticated? && Current.user.admin? %>
      <%= link_to nyk_billing_path,
            class: "flex items-center gap-1.5 px-3 h-8 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-medium transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>Billing</span>
      <% end %>
    <% end %>
  <% end %>
  <%= render "shared/ws_header", workspace: @nyk_workspace, breadcrumbs: list_crumbs, actions: list_actions %>

  <%# Manager-only: add a class/camp that isn't on nykitchen.com's calendar.
      Opens as a modal so the page doesn't jump; posts to create_manual_class. %>
  <% if @nyk_manager %>
    <dialog data-dialog-target="modal" data-action="click->dialog#backdropClose"
            class="bg-transparent backdrop:bg-black/80 p-0 w-[92vw] max-w-lg fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0">
      <div class="bg-gray-900 rounded-xl border border-gray-800">
        <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-gray-800">
          <span class="text-sm font-bold text-white">Add a class</span>
          <button type="button" data-action="click->dialog#close" aria-label="Close" class="text-gray-500 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <%= form_with url: nyk_manual_classes_path, method: :post, class: "p-5 space-y-3" do %>
          <% field_class = "w-full rounded-md bg-black border border-gray-700 text-white px-3 py-2 text-base focus:border-orange-500 focus:outline-none" %>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Class name</label>
            <%= text_field_tag :name, nil, required: true, placeholder: "Summer Kids Camp", class: field_class %>
          </div>
          <div class="flex flex-wrap gap-3">
            <div class="flex-1 min-w-[130px]">
              <label class="block text-xs text-gray-400 mb-1">Date</label>
              <%= date_field_tag :date, nil, required: true, class: field_class %>
            </div>
            <div class="flex-1 min-w-[105px]">
              <label class="block text-xs text-gray-400 mb-1">Start</label>
              <%= time_field_tag :start_time, nil, required: true, class: field_class %>
            </div>
            <div class="flex-1 min-w-[105px]">
              <label class="block text-xs text-gray-400 mb-1">End <span class="text-gray-600">(optional)</span></label>
              <%= time_field_tag :end_time, nil, class: field_class %>
            </div>
          </div>
          <div class="flex flex-wrap gap-3">
            <div class="flex-1 min-w-[130px]">
              <label class="block text-xs text-gray-400 mb-1">Price <span class="text-gray-600">(optional)</span></label>
              <%= text_field_tag :price, nil, placeholder: "$45", class: field_class %>
            </div>
            <div class="flex-1 min-w-[130px]">
              <label class="block text-xs text-gray-400 mb-1">Notes <span class="text-gray-600">(optional)</span></label>
              <%= text_field_tag :notes, nil, placeholder: "Ages 8-12", class: field_class %>
            </div>
          </div>
          <div class="flex items-center justify-end gap-2 pt-1">
            <button type="button" data-action="click->dialog#close" class="px-3 py-2 rounded-md bg-gray-800 border border-gray-700 hover:border-gray-500 text-gray-200 text-sm cursor-pointer">Cancel</button>
            <%= submit_tag "Add to schedule", class: "px-4 py-2 rounded-md bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </dialog>
  <% end %>

  <div class="mb-6">
    <%= render "admin/kitchen/agent_title", title: "List Agent", kind: "list" %>
    <p class="text-gray-400 mt-1">
      Cooking classes at NY Kitchen &middot;
      <%= @total %> upcoming
      <% if @last_updated %>
        &middot; Updated <%= @last_updated.strftime("%b %-d") %>
      <% end %>
    </p>
  </div>

  <% if @events.empty? %>
    <div class="bg-gray-900 rounded-xl p-8 text-center">
      <p class="text-gray-400">No events scraped yet. The scraper runs every 3 hours.</p>
    </div>
  <% else %>
    <%# Live class search: filters cards by name/dish/recipe/ingredient and auto-expands the
        weeks that contain a match. Pure client-side (all classes are already
        on the page), so it filters as you type. %>
    <div class="mb-5">
      <input type="search"
             data-kitchen-filter-target="query"
             data-action="input->kitchen-filter#search"
             placeholder="Search classes, recipes, or ingredients…"
             autocomplete="off" aria-label="Search classes"
             class="w-full rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-4 py-2.5 focus:border-orange-500 focus:outline-none">
      <p data-kitchen-filter-target="empty" class="hidden text-sm text-gray-500 mt-2">No classes match your search.</p>
    </div>

    <%# Grocery list + Upload receipt, lifted out of the per-week sections so
        they sit right under the search box. Grocery opens the list defaulted to
        this week; the From/To picker there covers any other range. Receipt
        tracks real prices for the current week. %>
    <% groc_mon = Date.current.beginning_of_week(:monday) %>
    <% groc_sun = Date.current.end_of_week(:monday) %>
    <% groc_receipt = @receipt_by_week_start && @receipt_by_week_start[groc_mon] %>
    <div class="flex flex-col sm:flex-row gap-3 mb-6">
      <%= link_to nyk_grocery_path,
            title: "Open the grocery list",
            class: "flex-1 group flex items-center gap-3 px-4 py-3 rounded-lg border border-orange-500/40 bg-gradient-to-r from-orange-500/15 to-orange-500/5 hover:from-orange-500/25 hover:to-orange-500/10 transition" do %>
        <span class="flex items-center justify-center w-9 h-9 rounded-full bg-orange-500/20 text-orange-300 shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </span>
        <span class="flex flex-col min-w-0">
          <span class="text-sm font-semibold text-orange-200">Grocery list</span>
          <span class="text-xs text-orange-300/70">Combined shopping list, pick any date range</span>
        </span>
        <%# This week's estimated grocery $ (read from cache; only once the list
            has been built and price estimates are on). %>
        <% groc_total = @grocery_total_by_week_start && @grocery_total_by_week_start[groc_mon] %>
        <% show_est = @show_grocery_prices && groc_total && groc_total > 0 %>
        <% if show_est %>
          <span class="ml-auto shrink-0 text-right leading-tight">
            <span class="block text-base font-extrabold text-orange-200">~<%= number_to_currency(groc_total, precision: 0) %></span>
            <span class="block text-[10px] uppercase tracking-wide text-orange-300/60">est. total</span>
          </span>
        <% end %>
        <svg class="w-5 h-5 text-orange-400/60 <%= show_est ? "ml-2" : "ml-auto" %> shrink-0 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>

      <%= form_with url: nyk_grocery_receipts_path, method: :post, multipart: true,
            data: { controller: "receipt-upload" }, class: "flex-1 flex" do %>
        <%= hidden_field_tag :from, groc_mon.iso8601 %>
        <%= hidden_field_tag :to, groc_sun.iso8601 %>
        <%= file_field_tag :receipt, accept: "image/*,application/pdf", class: "hidden",
              data: { action: "change->receipt-upload#submit" } %>
        <button type="button" data-action="receipt-upload#open"
                class="w-full group flex items-center gap-3 px-4 py-3 rounded-lg border border-sky-500/40 bg-gradient-to-r from-sky-500/15 to-sky-500/5 hover:from-sky-500/25 hover:to-sky-500/10 transition text-left">
          <span class="flex items-center justify-center w-9 h-9 rounded-full bg-sky-500/20 text-sky-300 shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
          </span>
          <span class="flex flex-col min-w-0">
            <span class="text-sm font-semibold text-sky-200">Upload receipt</span>
            <% if groc_receipt&.parsed? %>
              <span class="text-xs text-sky-300/70">Saved<%= groc_receipt.total_dollars ? " (#{number_to_currency(groc_receipt.total_dollars, precision: 0)})" : "" %>, sharpening future estimates</span>
            <% elsif groc_receipt && !groc_receipt.failed? %>
              <span class="text-xs text-sky-300/70">Reading the last receipt now</span>
            <% else %>
              <span class="text-xs text-sky-300/70">Snap your store receipt to track real prices</span>
            <% end %>
          </span>
        </button>
      <% end %>
    </div>

    <%= render "admin/kitchen/list_panel" %>
  <% end %>
</div>

<%= javascript_tag nonce: true do %>
// Deep-link: #week-N scrolls to and expands that week section.
(function() {
  var hash = window.location.hash;
  if (hash && hash.match(/^#week-\d+$/)) {
    var section = document.getElementById(hash.slice(1));
    if (section) {
      var body = section.querySelector('[data-collapsible-target="body"]');
      var icon = section.querySelector('[data-collapsible-target="icon"]');
      if (body && body.classList.contains('hidden')) {
        body.classList.remove('hidden');
        if (icon) icon.classList.remove('-rotate-90');
      }
      setTimeout(function() {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
})();
<% end %>
