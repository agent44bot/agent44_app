<%# Renders the H1 title row for an agent detail page (list/test/data/social).
    Shows: <Title> · [pet name] · #207, with an inline rename form for
    workspace owner/admin members.
    Locals:
      title: "List Agent"
      kind:  "list" | "social" | "data" | "test"
%>
<% agent = @workspace_agents[kind.to_s] %>
<% can_rename = false # rename UI hidden for now %>
<div class="flex items-center gap-3 flex-wrap" <% if can_rename %>data-controller="collapsible" data-collapsible-collapsed-value="true"<% end %>>
  <h1 class="text-3xl font-black text-white tracking-tight"><%= title %></h1>
  <% if agent %>
    <div class="flex items-baseline gap-2 text-base font-medium">
      <% if agent.display_name.present? %>
        <span class="text-orange-300"><%= agent.display_name %></span>
      <% end %>
      <span class="text-gray-500 font-mono">#<%= agent.agent_number %></span>
    </div>
    <% if can_rename %>
      <button type="button" data-action="click->collapsible#toggle"
              class="text-xs text-gray-500 hover:text-orange-400 transition underline decoration-dotted underline-offset-2">
        <%= agent.display_name.present? ? "rename" : "give it a name" %>
      </button>
    <% end %>
  <% end %>
</div>
<% if can_rename %>
  <div data-collapsible-target="body" class="mt-3">
    <%= form_with url: nyk_rename_agent_path(kind: kind), method: :patch, local: true,
                  class: "flex flex-wrap items-center gap-2" do |f| %>
      <%= text_field_tag :display_name, agent.display_name, placeholder: "e.g. Spot, Scout, Echo",
          maxlength: 40,
          class: "rounded-md bg-gray-900 border border-gray-700 text-white px-3 py-1.5 text-sm focus:border-orange-500 focus:outline-none" %>
      <%= submit_tag "Save", class: "text-xs text-gray-300 hover:text-white px-3 py-1.5 border border-gray-700 rounded-md hover:border-orange-500 cursor-pointer" %>
      <% if agent.display_name.present? %>
        <%= button_to "Clear", nyk_rename_agent_path(kind: kind), method: :patch,
            params: { display_name: "" },
            class: "text-xs text-gray-500 hover:text-red-400 px-3 py-1.5 cursor-pointer" %>
      <% end %>
    <% end %>
  </div>
<% end %>
