<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">
  <%= link_to "← Back to Sam's list", nyk_list_path, class: "text-sm text-gray-500 hover:text-orange-400" %>
  <h1 class="text-2xl font-bold text-white mt-3 mb-1">Add a recipe handout</h1>
  <% if @event_name.present? %>
    <p class="text-sm text-gray-400 mb-6">For <span class="text-orange-400 font-medium"><%= @event_name %></span></p>
  <% end %>

  <% if @suggested %>
    <div class="bg-emerald-900/30 border border-emerald-800 rounded-xl p-4 mb-6">
      <p class="text-sm text-emerald-300 mb-3">
        This looks like a class we already have a packet for:
        <span class="font-semibold"><%= @suggested.title %></span>
      </p>
      <%= button_to "Reuse this packet", nyk_handouts_path,
            params: { existing_id: @suggested.id, event_url: @event_url },
            class: "px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold cursor-pointer" %>
    </div>
  <% end %>

  <%= form_with url: nyk_handouts_path, method: :post, multipart: true do |f| %>
    <%= hidden_field_tag :event_url, @event_url %>
    <%= hidden_field_tag :event_name, @event_name %>

    <label class="block text-sm font-semibold text-gray-300 mb-2">Upload a recipe PDF</label>
    <%= file_field_tag :pdf, accept: "application/pdf",
          class: "block w-full text-sm text-gray-400 file:mr-3 file:px-4 file:py-2 file:rounded-lg file:border-0 file:bg-gray-800 file:text-gray-300 file:cursor-pointer" %>
    <p class="text-xs text-gray-600 mt-1">Have a Publisher (.pub) file? Print it to PDF first, then upload that.</p>

    <div class="my-4 text-center text-xs text-gray-600">or</div>

    <label class="block text-sm font-semibold text-gray-300 mb-2">Paste a recipe link</label>
    <%= url_field_tag :recipe_url, "", placeholder: "https://...",
          class: "w-full rounded-lg bg-gray-900 border border-gray-800 text-gray-200 text-base px-3 py-2.5 focus:border-orange-500 focus:outline-none" %>
    <p class="text-xs text-gray-600 mt-1">A link to a recipe online. We read the page and rebuild it in the NY Kitchen format.</p>

    <div class="my-4 text-center text-xs text-gray-600">or</div>

    <label class="block text-sm font-semibold text-gray-300 mb-2">Paste the recipe text</label>
    <%= text_area_tag :recipe_text, "", rows: 8, placeholder: "Ingredients, amounts, and directions. Multiple recipes are fine (dough, filling, sauce).",
          class: "w-full rounded-xl bg-gray-900 border border-gray-800 text-gray-200 text-base p-4 focus:border-orange-500 focus:outline-none" %>

    <%= submit_tag "Build the recipe", class: "mt-6 px-5 py-2.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white font-semibold cursor-pointer" %>
    <p class="text-xs text-gray-500 mt-2">The agent reads the recipe, splits out each part, and proposes single-station amounts. You review it against a live PDF preview before printing.</p>
  <% end %>

  <% others = @existing - [ @suggested ].compact %>
  <% if others.any? %>
    <div class="mt-10">
      <h2 class="text-sm font-semibold text-gray-400 mb-3">Or attach an existing packet</h2>
      <div class="space-y-2">
        <% others.first(10).each do |h| %>
          <div class="flex items-center justify-between bg-gray-900 border border-gray-800 rounded-lg px-4 py-2.5">
            <span class="text-sm text-gray-300"><%= h.title %></span>
            <%= button_to "Attach", nyk_handouts_path,
                  params: { existing_id: h.id, event_url: @event_url },
                  class: "text-xs px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
