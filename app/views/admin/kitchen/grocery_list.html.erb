<%# Frame content: the aggregated, printable grocery list. Loaded lazily into
    the #grocery_list frame from the shell. Literal color classes live here so
    Tailwind picks them up. %>
<%# Light chips (tint background, dark saturated text): readable on the white
    grocery sheet and on the dark page legend, and they print cleanly. %>
<% chip_colors = [
     "bg-sky-100 text-sky-800 border-sky-300", "bg-emerald-100 text-emerald-800 border-emerald-300",
     "bg-amber-100 text-amber-800 border-amber-300", "bg-violet-100 text-violet-800 border-violet-300",
     "bg-rose-100 text-rose-800 border-rose-300", "bg-teal-100 text-teal-800 border-teal-300" ] %>
<% chip = ->(tag) { chip_colors[(@tag_index[tag] || 0) % chip_colors.size] } %>
<% est_total = @result&.ok? ? @result.categories.sum { |cat| Array(cat["items"]).sum { |i| i["price"].to_f } } : 0 %>
<%# A "pull sheet" is this same list scoped to a single class: drop the
    multi-class legend / per-item class chips and title it for that one class. %>
<% single = @single_class %>
<% single_event = single ? @with_recipe.first&.dig(:event) : nil %>
<% sheet_title = single ? "NY Kitchen Pull Sheet" : "NY Kitchen Grocery List" %>
<%# Carry the exact window the page is showing onto the download/print links.
    from/to covers the week pills AND a custom date range; @range is always set. %>
<% action_params =
     if single
       { event_url: @event_url, name: @event_name }
     else
       { from: @range.first.iso8601, to: @range.last.iso8601 }
     end %>

<%# data-controller goes on a wrapper INSIDE the frame, not on the frame tag:
    Turbo replaces only the frame's inner HTML on a lazy load and keeps the
    shell frame's attributes, so a controller on the frame tag never attaches. %>
<%= turbo_frame_tag "grocery_list" do %>
  <% if @building %>
    <%= render "admin/kitchen/grocery_building" %>
  <% elsif @needs_generate %>
    <%# The list isn't built yet and this is a plain visit: don't auto-bill the
        Opus call. Let the user kick it off. Clicking navigates this same frame
        with generate=1, which enqueues the build and swaps in the spinner. %>
    <div class="flex flex-col items-center justify-center py-20 text-center">
      <p class="text-gray-300 text-sm mb-1"><%= pluralize(@with_recipe.size, "class") %> with recipes, <%= pluralize(@total_headcount, "person") %> booked</p>
      <p class="text-gray-500 text-xs mb-5 max-w-xs">Combine every class's recipe into one shopping list for <%= @range.first.strftime("%b %-d") %> to <%= @range.last.strftime("%b %-d") %>. This runs the Opus model and takes up to a minute.</p>
      <%= link_to nyk_grocery_path(action_params.merge(generate: 1)),
            data: { turbo_frame: "grocery_list" },
            class: "px-5 py-2.5 rounded-lg bg-orange-600 hover:bg-orange-500 text-white text-sm font-semibold cursor-pointer" do %>
        Generate grocery list
      <% end %>
    </div>
  <% else %>
  <div data-controller="recipe-popover" data-recipe-popover-recipes-value="<%= (@recipe_by_tag || {}).to_json %>">
  <p class="text-sm text-gray-400 mb-6">
    <% if single && single_event %>
      <%= single_event.start_at.strftime("%a %b %-d") %> ·
      <%= pluralize(@total_headcount, "person") %> booked
    <% else %>
      <%= @range.first.strftime("%a %b %-d") %> to <%= @range.last.strftime("%a %b %-d") %> ·
      <%= pluralize(@with_recipe.size, "class") %> with recipes ·
      <%= pluralize(@total_headcount, "person") %> booked
    <% end %>
  </p>

  <% if @with_recipe.empty? %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-gray-400">
      <% if single %>
        This class has no recipe attached yet. Add one from
        <%= link_to "Sam's schedule", nyk_list_path, class: "text-orange-400 hover:text-orange-300" %>
        and the pull sheet will fill in.
      <% else %>
        No classes in this range have a recipe attached yet. Add recipes from
        <%= link_to "Sam's schedule", nyk_list_path, class: "text-orange-400 hover:text-orange-300" %>
        and they will roll into this list.
      <% end %>
    </div>
  <% elsif @result&.ok? %>
    <% unless params[:embedded] %>
      <div class="mb-4 -mt-2 flex items-center justify-end gap-2 no-print">
        <%= link_to "⬇ Excel",
              nyk_grocery_path(action_params.merge(download: 1, xlsx: 1)),
              data: { turbo_frame: "_top" },
              class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-gray-700 text-gray-300 hover:bg-gray-800/70 text-sm font-semibold whitespace-nowrap" %>
        <%= link_to "⬇ PDF",
              nyk_grocery_path(action_params.merge(download: 1)),
              data: { turbo_frame: "_top" },
              class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-gray-700 text-gray-300 hover:bg-gray-800/70 text-sm font-semibold whitespace-nowrap" %>
        <button type="button"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-emerald-600 text-emerald-300 hover:bg-emerald-600/10 text-sm font-semibold cursor-pointer whitespace-nowrap"
                id="grocery-print-btn">🖨 Print</button>
      </div>
    <% end %>

    <%# Legend: which color is which class. Skipped on a single-class pull sheet. %>
    <% unless single %>
      <div class="flex flex-wrap gap-2 mb-4 no-print">
        <% @with_recipe.each do |c| %>
          <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full border cursor-pointer <%= chip.call(c[:tag]) %>"
                tabindex="0" role="button"
                data-action="mouseenter->recipe-popover#show mouseleave->recipe-popover#hide click->recipe-popover#toggle"
                data-recipe-popover-tag-param="<%= c[:tag] %>" data-recipe-popover-item-param="">
            <%= c[:tag] %> <span class="opacity-70">· <%= c[:headcount] %> ppl</span>
          </span>
        <% end %>
      </div>
    <% end %>

    <%# Per-ticket portion: most classes are 1 person/ticket, but couples classes
        seat two, which doubles the food. We auto-detect from the listing text;
        this lets a manager correct it. The choice is saved per class and sticks
        across nightly rescrapes. Changing it rebuilds the list (new headcount).
        Skipped on a single-class pull sheet to keep it minimal. %>
    <% unless single %>
      <details class="mb-5 no-print text-sm">
        <summary class="cursor-pointer text-gray-400 hover:text-orange-400">Ticket portions (people per ticket)</summary>
        <div class="mt-2 space-y-1.5">
          <% @with_recipe.each do |c| %>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center text-xs px-2 py-0.5 rounded-full border <%= chip.call(c[:tag]) %>"><%= c[:tag] %></span>
              <%= form_with url: nyk_grocery_portion_path, method: :patch, data: { turbo: false }, class: "flex items-center gap-1" do %>
                <%= hidden_field_tag :url, c[:event].url %>
                <% [ 1, 2 ].each do |n| %>
                  <% on = c[:per_ticket] == n %>
                  <button type="submit" name="people_per_ticket" value="<%= n %>"
                          class="px-2 py-0.5 rounded border text-xs cursor-pointer <%= on ? 'bg-orange-600 border-orange-500 text-white' : 'bg-gray-900 border-gray-700 text-gray-300 hover:border-orange-500' %>">
                    <%= n %> <%= "person".pluralize(n) %>/ticket
                  </button>
                <% end %>
              <% end %>
              <span class="text-xs text-gray-500"><%= c[:per_ticket_overridden] ? "set by hand" : "auto" %></span>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>

    <div class="bg-white text-gray-900 rounded-xl p-6 print-sheet">
      <div class="flex items-baseline justify-between border-b-2 border-gray-900 pb-2 mb-4">
        <span class="text-lg font-extrabold"><%= sheet_title %></span>
        <span class="text-xs text-gray-500">
          <% if single && single_event %>
            <%= single_event.start_at.strftime("%b %-d") %>
          <% else %>
            <%= @range.first.strftime("%b %-d") %> to <%= @range.last.strftime("%b %-d") %>
          <% end %>
        </span>
      </div>
      <% if single && single_event %>
        <p class="text-sm font-semibold text-gray-700 -mt-2 mb-4"><%= single_event.name %></p>
      <% end %>
      <% @result.categories.each do |cat| %>
        <% next if Array(cat["items"]).empty? %>
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mt-4 mb-1"><%= cat["name"] %></h2>
        <ul class="mb-2">
          <% cat["items"].each do |it| %>
            <li class="flex items-start gap-2 py-1 text-sm border-b border-gray-100">
              <span class="inline-block w-4 h-4 border border-gray-400 rounded shrink-0 mt-0.5"></span>
              <span class="font-semibold w-24 shrink-0"><%= KitchenUnits.standardize(it["quantity"]) %></span>
              <span class="flex-1 min-w-0">
                <%= it["item"] %>
                <%# Pull sheet (single class) is for the cook line: no prices. %>
                <% if @show_grocery_prices && !single && it["price"].to_f > 0 %><span class="text-gray-400">~<%= format("$%.2f", it["price"].to_f) %></span><% end %>
              </span>
              <%# Which classes need this item. Capped + wrapping so a long tag
                  list wraps inside the sheet instead of overflowing the edge.
                  Skipped on a single-class pull sheet (every line is that one
                  class, so the tags add no information). %>
              <% unless single %>
                <span class="flex flex-wrap gap-1 justify-end shrink-0 max-w-[48%]">
                  <% Array(it["classes"]).each do |tag| %>
                    <span class="text-[11px] font-medium px-2 py-0.5 rounded-full border whitespace-nowrap cursor-pointer <%= chip.call(tag) %>"
                          tabindex="0" role="button"
                          data-action="mouseenter->recipe-popover#show mouseleave->recipe-popover#hide click->recipe-popover#toggle"
                          data-recipe-popover-tag-param="<%= tag %>" data-recipe-popover-item-param="<%= it["item"] %>"><%= tag %></span>
                  <% end %>
                </span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
      <% if @result.to_taste.present? %>
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mt-4 mb-1">To taste / on hand</h2>
        <p class="text-sm text-gray-600"><%= @result.to_taste.join(", ") %></p>
      <% end %>
      <%# Gear per station (owned, just set up): pull sheet ONLY. Read straight
          off the packet (no AI). Grouped by class on a multi-class list. %>
      <% station_classes = single ? @with_recipe.select { |c| Array(c[:packet]&.equipment).any? } : [] %>
      <% if station_classes.any? %>
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mt-5 mb-1">
          Equipment per station<%= station_classes.first[:stations] ? " (set up at each of #{pluralize(station_classes.first[:stations], "station")})" : "" %>
        </h2>
        <% station_classes.each do |c| %>
          <ul class="mb-2">
            <% Array(c[:packet].equipment).each do |eq| %>
              <li class="flex items-start gap-2 py-1 text-sm border-b border-gray-100">
                <span class="inline-block w-4 h-4 border border-gray-400 rounded shrink-0 mt-0.5"></span>
                <span class="flex-1 min-w-0"><%= eq %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
      <% end %>
      <%# Gear to BUY: pull sheet AND grocery list. Deduped union across the
          classes in view, so it lands on the shopping run once. %>
      <% purchase = @with_recipe.flat_map { |c| Array(c[:packet]&.purchase_equipment) }.map { |e| e.to_s.strip }.reject(&:blank?).uniq { |e| e.downcase } %>
      <% if purchase.any? %>
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mt-5 mb-1">Equipment to purchase</h2>
        <ul class="mb-2">
          <% purchase.each do |eq| %>
            <li class="flex items-start gap-2 py-1 text-sm border-b border-gray-100">
              <span class="inline-block w-4 h-4 border border-gray-400 rounded shrink-0 mt-0.5"></span>
              <span class="flex-1 min-w-0"><%= eq %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
      <% if @show_grocery_prices && !single && est_total > 0 %>
        <div class="mt-5 pt-3 border-t-2 border-gray-900 flex items-baseline justify-between">
          <span class="text-base font-extrabold">Estimated total</span>
          <span class="text-lg font-extrabold"><%= format("$%.2f", est_total) %></span>
        </div>
        <p class="text-xs text-gray-500 mt-1">Rough estimate of typical US grocery prices, for budgeting only. Actual cost varies by store and season.</p>
      <% end %>
      <div class="mt-6 pt-3 border-t border-gray-200 text-xs text-gray-500">
        Covers: <%= @with_recipe.map { |c| "#{c[:event].name} (#{c[:headcount]} booked, #{c[:stations]} stations)" }.join(" · ") %>
      </div>
    </div>

    <div class="mt-4 flex items-center gap-4 no-print">
      <% if @from_cache %>
        <span class="text-xs text-gray-500">Saved list (no new AI cost)</span>
      <% elsif @result.cost_cents %>
        <span class="text-xs text-gray-500">Built with the Opus model (cost <%= format("$%.2f", @result.cost_cents / 100.0) %>)</span>
      <% end %>
    </div>
  <% else %>
    <div class="bg-red-900/30 border border-red-800 rounded-xl p-4 text-red-300">
      Could not build the list: <%= @result&.error %>
    </div>
  <% end %>

  <%# Hover/tap a class tag to see that class's recipe with this ingredient
      highlighted. One shared panel, positioned by the controller. %>
  <div data-recipe-popover-target="panel"
       class="hidden fixed z-50 w-72 max-h-80 overflow-auto rounded-xl border border-gray-700 bg-gray-900 shadow-2xl p-3 text-sm">
    <div data-recipe-popover-target="title" class="font-semibold text-white mb-1 pb-1 border-b border-gray-800"></div>
    <ul data-recipe-popover-target="list" class="space-y-0.5 mt-1"></ul>
  </div>
  <%# Safelist: the popover JS applies these classes to recipe lines at runtime,
      so they must exist in a scanned template for Tailwind to generate them. %>
  <span class="hidden bg-yellow-200 text-gray-900 font-semibold text-gray-300 px-1.5 py-0.5 rounded"></span>

  <% if @without_recipe.any? %>
    <div class="mt-8 no-print">
      <h2 class="text-sm font-semibold text-amber-400 mb-2">⚠ Classes in range with no recipe (not in the list)</h2>
      <ul class="space-y-1">
        <% @without_recipe.each do |e| %>
          <li class="text-sm text-gray-400">
            <%= e.start_at.strftime("%a %-m/%-d") %> · <%= e.name %>
            <%= link_to "add recipe", new_nyk_packet_path(event_url: e.url, event_name: e.name), class: "text-orange-400 hover:text-orange-300 ml-1" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
  </div>
  <% end %><%# end @building else %>
<% end %>
