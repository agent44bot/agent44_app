<%
  s = @s
  money  = ->(n) { number_to_currency(n, precision: 0) }
  short  = ->(n) { n.to_i.abs >= 1000 ? "~$#{number_with_delimiter((n / 1000.0).round)}K" : number_to_currency(n, precision: 0) }
  hero_pct = s[:rev_total].to_f.positive? ? (100.0 * s[:rev_sold] / s[:rev_total]).round : 0
  host = "https://agent44labs.com"
  analyst_url = "#{host}/nykitchen/analyst"
  # Each agent banner deep-links to that agent's live page (signed-in users).
  agent_url = ->(path) { "#{host}#{path}" }

  serif = "Georgia,'Times New Roman',serif"
  sans  = "-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif"
  mono  = "'SFMono-Regular',Menlo,Consolas,'Liberation Mono',monospace"

  ink="#1a1a1a"; mut="#8a8276"; faint="#a8a08f"; accent="#c2410c"
  green="#1b6e3a"; amber="#b35900"; red="#b42318"; track="#e7e2d9"; line="#e8e1d6"; blue="#0a58ca"; cream="#faf7f2"
  iris="#1b6e3a"; argus_c="#0e7490"; scout_c="#be185d"; sam_c="#0369a1"; echo_c="#6d28d9"; neon_c="#b45309"; cellar_c="#9d174d"

  bar = ->(pct, w) {
    fill = [[(pct.to_i * w / 100.0).round, 0].max, w].min
    %(<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="#{w}" style="width:#{w}px"><tr>) +
      (fill.positive? ? %(<td height="7" width="#{fill}" style="background:#{green};font-size:0;line-height:0;border-radius:3px">&nbsp;</td>) : "") +
      (fill < w ? %(<td height="7" style="background:#{track};font-size:0;line-height:0;border-radius:3px">&nbsp;</td>) : "") +
      %(</tr></table>)
  }
  delta = ->(pct) {
    return "" if pct.nil?
    up = pct >= 0
    %(<span style="font-family:#{mono};font-size:13px;font-weight:bold;color:#{up ? green : red}">#{up ? '&#9650;' : '&#9660;'} #{pct.abs}%</span> <span style="font-family:#{sans};font-size:12px;color:#{mut}">vs last week</span>)
  }
  # Agent section banner: emoji + codename + classification (accent) + optional
  # status. When `url` is given the codename + tag link to that agent's live
  # page, with a small accent arrow as the click affordance.
  agent_banner = ->(emoji, name, tag, ac, status, url = nil) {
    inner = %(#{emoji} #{name} <span style="font-family:#{mono};font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#{ac};font-weight:bold">&nbsp;#{tag}</span>)
    label = url ? %(<a href="#{url}" style="color:#{ink};text-decoration:none">#{inner}</a> <a href="#{url}" style="color:#{ac};text-decoration:none;font-family:#{sans};font-size:13px">&rarr;</a>) : inner
    %(<tr><td style="padding:24px 30px 8px">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#{cream};border-left:3px solid #{ac};border-radius:0 8px 8px 0"><tr>
          <td style="padding:10px 14px;font-family:#{serif};font-size:16px;font-weight:bold;color:#{ink}">#{label}</td>
          #{status.to_s.empty? ? "" : %(<td style="padding:10px 14px;text-align:right;white-space:nowrap;font-family:#{sans};font-size:11px;font-weight:bold">#{status}</td>)}
        </tr></table>
      </td></tr>).html_safe
  }
  subhead = ->(txt) { %(<div style="font-family:#{sans};font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:#{faint};font-weight:bold;margin:18px 0 6px">#{txt}</div>).html_safe }

  bw      = s[:booked_week] || {}
  tw_rev  = bw[:revenue].to_i
  wow_rev = bw[:prior_revenue].to_i.positive? ? (100.0 * (tw_rev - bw[:prior_revenue]) / bw[:prior_revenue]).round : nil
  argus   = s[:argus] || {}
  scout   = s[:scout] || {}
%>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f1ea;margin:0;padding:0">
<tr><td align="center" style="padding:24px 12px">
<%# Feedback-sample note, only present on sample sends, never the real recap. %>
<% if s[:sample_note].present? %>
<table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;max-width:600px;margin-bottom:12px">
  <tr><td style="background:<%= cream %>;border:1px solid <%= line %>;border-left:4px solid <%= accent %>;border-radius:8px;padding:14px 18px;font-family:<%= sans %>;font-size:13px;color:<%= ink %>;line-height:1.55"><%= s[:sample_note] %></td></tr>
</table>
<% end %>
<table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;max-width:600px;background:#ffffff;border:1px solid <%= line %>;border-radius:12px;overflow:hidden">

  <%# ── Header ───────────────────────────────────────────── %>
  <tr><td style="border-top:4px solid <%= accent %>;padding:26px 30px 14px">
    <div style="font-family:<%= serif %>;font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:<%= accent %>;font-weight:bold">Weekly Team Report</div>
    <div style="font-family:<%= serif %>;font-size:27px;font-weight:bold;color:<%= ink %>;margin-top:3px">NY Kitchen</div>
    <div style="font-family:<%= sans %>;font-size:12px;color:<%= mut %>;margin-top:6px"><%= s[:snapshot_date]&.strftime("Week of %B %-d, %Y") %><% if s[:stale] %> &middot; latest snapshot <%= s[:snapshot_date]&.strftime("%b %-d") %><% end %></div>
  </td></tr>

  <%# ── Carson hosts ─────────────────────────────────────── %>
  <% if s[:headline].present? %>
    <tr><td style="padding:6px 30px 0">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:<%= cream %>;border-left:3px solid <%= accent %>;border-radius:0 8px 8px 0"><tr>
        <td style="padding:13px 16px;font-family:<%= serif %>;font-size:14px;font-style:italic;color:<%= ink %>;line-height:1.5"><%= s[:headline] %><div style="font-family:<%= sans %>;font-style:normal;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:<%= faint %>;margin-top:6px">Carson, your concierge</div></td>
      </tr></table>
    </td></tr>
  <% end %>

  <%# ════ IRIS · Analyst ═════════════════════════════════════ %>
  <%= agent_banner.call("&#128202;", "Iris", "Analyst", iris,
        wow_rev ? "<span style=\"font-family:#{mono};color:#{wow_rev >= 0 ? green : red}\">#{wow_rev >= 0 ? '&#9650;' : '&#9660;'} #{wow_rev.abs}%</span> <span style=\"color:#{mut};font-weight:normal\">wk</span>" : "",
        agent_url.call("/nykitchen/analyst")).html_safe %>
  <tr><td style="padding:6px 30px 4px">
    <div style="font-family:<%= sans %>;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:<%= mut %>">Booked &middot; this week</div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:2px"><tr>
      <td style="vertical-align:baseline;font-family:<%= mono %>;font-size:36px;font-weight:bold;color:<%= green %>;line-height:1.1"><%= money.call(tw_rev) %></td>
      <td style="vertical-align:baseline;text-align:right"><%= delta.call(wow_rev).html_safe %></td>
    </tr></table>
    <div style="font-family:<%= sans %>;font-size:12px;color:<%= mut %>;margin-top:4px"><%= bw[:tickets].to_i %> <%= "ticket".pluralize(bw[:tickets].to_i) %> sold this week (Mon-Sun)</div>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;background:<%= cream %>;border:1px solid <%= line %>;border-radius:8px"><tr>
      <td style="padding:11px 14px;font-family:<%= sans %>;font-size:13px;color:#555;line-height:1.5">
        <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= money.call(s[:rev_sold]) %></span> booked of <span style="font-family:<%= mono %>"><%= short.call(s[:rev_total]) %></span> pipeline &middot; <span style="font-family:<%= mono %>;font-weight:bold"><%= hero_pct %>%</span> sold &middot; <span style="font-family:<%= mono %>;color:<%= amber %>"><%= short.call(s[:rev_left]) %></span> still to sell
        <div style="font-size:11px;color:<%= faint %>;margin-top:4px">Across <%= s[:rev_priced_count] %> upcoming classes with capacity data<% if s[:rev_proxy_count].to_i.positive? %> &middot; <%= s[:rev_proxy_count] %> estimated<% end %>.</div>
      </td>
    </tr></table>

    <% if s[:periods].present? %>
      <%= subhead.call("By period") %>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="padding:0 0 4px;font-family:<%= sans %>;font-size:10px;letter-spacing:.4px;text-transform:uppercase;color:<%= faint %>">Period</td>
          <td style="padding:0 0 4px;text-align:right;font-family:<%= sans %>;font-size:10px;letter-spacing:.4px;text-transform:uppercase;color:<%= faint %>">Booked</td>
          <td style="padding:0 0 4px 14px;font-family:<%= sans %>;font-size:10px;letter-spacing:.4px;text-transform:uppercase;color:<%= faint %>">% of $ sold</td>
          <td style="padding:0 0 4px;text-align:right;font-family:<%= sans %>;font-size:10px;letter-spacing:.4px;text-transform:uppercase;color:<%= faint %>">Left to sell</td>
        </tr>
        <% prev_kind = nil %>
        <% s[:periods].each do |p| %>
          <% if prev_kind == :past && p[:kind] == :forward %><tr><td colspan="4" style="border-top:1px solid <%= line %>;font-size:0;line-height:0;height:1px">&nbsp;</td></tr><% end %>
          <% pc = p[:pct].to_i %>
          <tr>
            <td style="padding:6px 0;font-family:<%= sans %>;font-size:13px;color:<%= ink %>;font-weight:600"><%= p[:label] %> <span style="font-family:<%= mono %>;font-size:11px;font-weight:normal;color:<%= faint %>">&middot; <%= p[:total_count] %> <%= "class".pluralize(p[:total_count].to_i) %></span></td>
            <td style="padding:6px 0;text-align:right;font-family:<%= mono %>;font-size:13px;font-weight:bold;color:<%= green %>"><%= money.call(p[:sold]) %></td>
            <td style="padding:6px 0 6px 14px"><table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td style="vertical-align:middle"><%= bar.call(pc, 78).html_safe %></td><td style="vertical-align:middle;padding-left:8px;font-family:<%= mono %>;font-size:11px;color:#666"><%= p[:pct] ? "#{pc}%" : "-".html_safe %></td></tr></table></td>
            <td style="padding:6px 0;text-align:right;font-family:<%= mono %>;font-size:13px;color:<%= amber %>"><%= short.call(p[:left]) %></td>
          </tr>
          <% prev_kind = p[:kind] %>
        <% end %>
      </table>
      <div style="font-family:<%= sans %>;font-size:11px;color:<%= faint %>;margin-top:6px">% of $ sold = booked &divide; total ticket value. Past rows show booked &amp; what went unsold (missed); upcoming show sold &amp; still to sell.</div>
    <% end %>

    <% if s[:newly_sold_out].present? %>
      <%= subhead.call("&#127881; Sold out this week") %>
      <% s[:newly_sold_out].first(6).each do |e| %>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-bottom:1px solid <%= line %>"><tr>
          <td style="padding:7px 0;font-family:<%= sans %>;font-size:13px"><a href="<%= e.url %>" style="color:<%= blue %>;text-decoration:none;font-weight:600"><%= e.name %></a> <span style="color:<%= mut %>">&middot; <%= e.start_at&.strftime("%a %-m/%-d") %></span></td>
          <td style="padding:7px 0;text-align:right;white-space:nowrap;font-family:<%= sans %>;font-size:11px;font-weight:bold;color:<%= green %>;text-transform:uppercase;letter-spacing:0.04em">Sold out</td>
        </tr></table>
      <% end %>
    <% end %>

    <% if s[:movers].present? %>
      <%= subhead.call("&#128640; Biggest movers this week") %>
      <% s[:movers].each_with_index do |row, i| %><% e = row[:event] %>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-bottom:1px solid <%= line %>"><tr>
          <td style="padding:7px 0;font-family:<%= sans %>;font-size:13px"><span style="font-family:<%= mono %>;color:<%= faint %>"><%= i + 1 %></span> <a href="<%= e.url %>" style="color:<%= blue %>;text-decoration:none;font-weight:600"><%= e.name %></a> <span style="color:<%= mut %>">&middot; <%= e.start_at&.strftime("%a %-m/%-d") %></span></td>
          <td style="padding:7px 0;text-align:right;white-space:nowrap;font-family:<%= mono %>;font-size:13px;font-weight:bold;color:<%= green %>">+<%= row[:tickets] %><% if row[:revenue].to_i > 0 %> <span style="font-weight:normal;color:<%= mut %>;font-size:12px"><%= money.call(row[:revenue]) %></span><% end %></td>
        </tr></table>
      <% end %>
    <% end %>

    <% if s[:needs_a_push].present? %>
      <%= subhead.call("&#129482; Needs a push") %>
      <% s[:needs_a_push].each_with_index do |row, i| %><% e = row[:event] %>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-bottom:1px solid <%= line %>"><tr>
          <td style="padding:7px 0;font-family:<%= sans %>;font-size:13px"><span style="font-family:<%= mono %>;color:<%= faint %>"><%= i + 1 %></span> <a href="<%= e.url %>" style="color:<%= blue %>;text-decoration:none;font-weight:600"><%= e.name %></a> <span style="color:<%= mut %>">&middot; <%= e.start_at&.strftime("%a %-m/%-d") %> &middot; in <%= row[:days_until] %>d</span></td>
          <td style="padding:7px 0;text-align:right;white-space:nowrap;font-family:<%= mono %>;font-size:13px"><span style="font-weight:bold;color:<%= amber %>">needs ~<%= row[:needed_pace] %>/day</span><div style="font-size:11px;color:<%= mut %>">selling ~<%= row[:observed_pace] %>/day</div></td>
        </tr></table>
      <% end %>
    <% end %>

    <% if s[:selling_fastest].present? %>
      <%= subhead.call("&#128293; Selling fastest &middot; all-time pace") %>
      <% s[:selling_fastest].each_with_index do |row, i| %><% e = row[:event] %>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-bottom:1px solid <%= line %>"><tr>
          <td style="padding:7px 0;font-family:<%= sans %>;font-size:13px"><span style="font-family:<%= mono %>;color:<%= faint %>"><%= i + 1 %></span> <a href="<%= e.url %>" style="color:<%= blue %>;text-decoration:none;font-weight:600"><%= e.name %></a> <span style="color:<%= mut %>">&middot; <%= e.start_at&.strftime("%a %-m/%-d") %></span></td>
          <td style="padding:7px 0;text-align:right;white-space:nowrap;font-family:<%= mono %>;font-size:13px;font-weight:bold;color:<%= ink %>">~<%= row[:pace] %>/day</td>
        </tr></table>
      <% end %>
    <% end %>

    <% if s[:empty_last_week].present? %>
      <%= subhead.call("&#129681; Ran with empty seats &middot; last 7 days") %>
      <% s[:empty_last_week].each do |e| %>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-bottom:1px solid <%= line %>"><tr>
          <td style="padding:7px 0;font-family:<%= sans %>;font-size:13px"><a href="<%= e.url %>" style="color:<%= blue %>;text-decoration:none;font-weight:600"><%= e.name %></a> <span style="color:<%= mut %>">&middot; <%= e.start_at&.strftime("%a %-m/%-d") %></span></td>
          <td style="padding:7px 0;text-align:right;white-space:nowrap;font-family:<%= mono %>;font-size:13px;color:<%= amber %>"><%= e.spots_left %> unsold</td>
        </tr></table>
      <% end %>
    <% end %>

    <% if s[:weekly_tickets].present? %>
      <% wk = s[:weekly_tickets].last(6); peak = [wk.map { |w| w[:tickets] }.max, 1].max %>
      <%= subhead.call("&#128200; Tickets sold by week") %>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <% prev_t = nil %>
        <% wk.each do |w| %>
          <% d = (prev_t && prev_t.positive?) ? (100.0 * (w[:tickets] - prev_t) / prev_t).round : nil %>
          <tr>
            <td style="padding:3px 0;width:62px;font-family:<%= sans %>;font-size:12px;color:<%= mut %>;white-space:nowrap"><%= w[:label] %></td>
            <td style="padding:3px 0 3px 10px"><%= bar.call((100.0 * w[:tickets] / peak).round, 280).html_safe %></td>
            <td style="padding:3px 0 3px 8px;text-align:right;font-family:<%= mono %>;font-size:12px;font-weight:600;color:<%= ink %>;white-space:nowrap"><%= w[:tickets] %></td>
            <td style="padding:3px 0 3px 8px;text-align:right;width:46px;font-family:<%= mono %>;font-size:11px;white-space:nowrap;color:<%= d.nil? ? faint : (d >= 0 ? green : red) %>"><%= (d.nil? ? "" : "#{d >= 0 ? '&#9650;' : '&#9660;'}#{d.abs}%").html_safe %></td>
          </tr>
          <% prev_t = w[:tickets] %>
        <% end %>
      </table>
    <% end %>
  </td></tr>

  <%# ════ ARGUS · Sentry (site uptime) ══════════════════════ %>
  <% if argus[:total].to_i.positive? %>
    <%= agent_banner.call("&#128737;", "Argus", "Sentry", argus_c,
          argus[:fail_pct].to_i.zero? ? "<span style=\"color:#{green}\">&#10003; All clear</span>" : "<span style=\"color:#{red}\">&#9888; #{argus[:failed]} failed</span>",
          agent_url.call("/nykitchen/test")).html_safe %>
    <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
      Ran <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= argus[:total] %></span> calendar checks this week:
      <span style="font-family:<%= mono %>;color:<%= green %>"><%= argus[:passed] %> passed</span><% if argus[:failed].to_i.positive? %>, <span style="font-family:<%= mono %>;color:<%= red %>"><%= argus[:failed] %> failed</span> (<%= argus[:fail_pct] %>%)<% end %>.
      <div style="font-size:12px;color:<%= mut %>;margin-top:2px"><%= argus[:fail_pct].to_i.zero? ? "The class calendar stayed up all week." : "#{argus[:fail_pct]}% of checks didn't complete, usually a transient hiccup on our checker, not a customer-facing outage. Argus retries and escalates anything that persists." %></div>
    </td></tr>
  <% end %>

  <%# ════ SCOUT · Recon (data) ══════════════════════════════ %>
  <% if scout[:snapshots].to_i.positive? || scout[:total].to_i.positive? %>
    <%= agent_banner.call("&#128376;", "Scout", "Recon", scout_c,
          scout[:fail_pct].to_i.zero? ? "<span style=\"color:#{green}\">&#10003; Healthy</span>" : "<span style=\"color:#{red}\">&#9888; #{scout[:failed]} failed</span>",
          agent_url.call("/nykitchen/data")).html_safe %>
    <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
      Took <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= scout[:snapshots] %></span> calendar snapshots this week<% if scout[:total].to_i.positive? %> across <span style="font-family:<%= mono %>"><%= scout[:total] %></span> scrape runs (<span style="font-family:<%= mono %>;color:<%= green %>"><%= scout[:passed] %> ok</span><% if scout[:failed].to_i.positive? %>, <span style="color:<%= red %>"><%= scout[:failed] %> failed</span><% end %>)<% end %>.
      <div style="font-size:12px;color:<%= mut %>;margin-top:2px">Keeps Iris's numbers and the calendar fresh.</div>
    </td></tr>
  <% end %>

  <%# ════ SAM · Scheduler (calendar churn) ══════════════════ %>
  <% sam = s[:sam] || {} %>
  <%= agent_banner.call("&#128197;", "Sam", "Scheduler", sam_c, "<span style=\"color:#{mut};font-weight:normal\">calendar</span>", agent_url.call("/nykitchen/list")).html_safe %>
  <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
    <% if sam[:added].to_i.positive? || sam[:removed].to_i.positive? || sam[:price_changes].to_i.positive? %>
      Tended the calendar this week:
      <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= sam[:added].to_i %></span> added,
      <span style="font-family:<%= mono %>"><%= sam[:removed].to_i %></span> removed,
      <span style="font-family:<%= mono %>"><%= sam[:price_changes].to_i %></span> price <%= "change".pluralize(sam[:price_changes].to_i) %>.
    <% else %>
      The calendar held steady this week. No classes added or removed.
    <% end %>
  </td></tr>

  <%# ════ ECHO · Broadcast (social) ═════════════════════════ %>
  <% echo = s[:echo] %>
  <% if echo %>
    <%= agent_banner.call("&#128226;", "Echo", "Broadcast", echo_c,
          echo[:posts].to_i.positive? ? "<span style=\"color:#{green}\">&#10003; #{echo[:posts]} posted</span>" : "<span style=\"color:#{mut}\">quiet week</span>",
          agent_url.call("/nykitchen/social")).html_safe %>
    <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
      <% if echo[:posts].to_i.positive? %>
        <% engagement = echo[:likes].to_i + echo[:reposts].to_i + echo[:replies].to_i %>
        Published <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= echo[:posts] %></span> <%= "post".pluralize(echo[:posts]) %> this week<% if echo[:by_platform].present? %> (<%= echo[:by_platform].map { |p, n| "#{p.to_s.capitalize}: #{n}" }.join(", ") %>)<% end %><% if engagement > 0 %>, <span style="font-family:<%= mono %>"><%= echo[:likes] %></span> likes, <span style="font-family:<%= mono %>"><%= echo[:reposts] %></span> reposts, <span style="font-family:<%= mono %>"><%= echo[:replies] %></span> replies<% end %>.
      <% else %>
        No posts published this week across <%= echo[:accounts] %> connected <%= "account".pluralize(echo[:accounts]) %>.
      <% end %>
    </td></tr>
  <% end %>

  <%# ════ NEON · Marquee (in-store screen) ══════════════════ %>
  <% neon = s[:neon] || {} %>
  <% if neon[:last_seen_at] || neon[:days_seen].to_i.positive? %>
    <% live = neon[:last_seen_at] && (Time.current - neon[:last_seen_at]) < 6 * 3600 %>
    <%= agent_banner.call("&#128250;", "Neon", "Marquee", neon_c,
          live ? "<span style=\"color:#{green}\">&#9679; Live</span>" : "<span style=\"color:#{red}\">&#9888; Offline</span>",
          agent_url.call("/nykitchen/display/settings")).html_safe %>
    <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
      <% if neon[:days_seen].to_i.positive? %>
        Cycled classes on the lobby screen <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= neon[:days_seen] %></span> of the last 7 days<% if neon[:last_seen_at] %>, last seen <%= time_ago_in_words(neon[:last_seen_at]) %> ago<% end %>.
        <% if neon[:tracking_since] && neon[:tracking_since] > Date.current - 7 %><div style="font-size:11px;color:<%= faint %>;margin-top:2px">Daily uptime tracking began <%= neon[:tracking_since].strftime("%b %-d") %>.</div><% end %>
      <% elsif neon[:last_seen_at] %>
        Last seen <%= time_ago_in_words(neon[:last_seen_at]) %> ago. <span style="color:<%= faint %>">Daily uptime tracking just started. Full weekly numbers in next week's report.</span>
      <% end %>
    </td></tr>
  <% end %>

  <%# ════ CELLAR · Inventory (storage room stock) ══════════ %>
  <% cellar = s[:cellar] || {} %>
  <% if cellar.present? %>
    <% if cellar[:setup] %>
      <%= agent_banner.call("&#127863;", "Cellar", "Inventory", cellar_c,
            "<span style=\"color:#{mut}\">setting up</span>",
            agent_url.call("/nykitchen/inventory")).html_safe %>
      <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
        Ready for your first stock count. Scan a case in or import your list to start tracking bottles on hand.
      </td></tr>
    <% else %>
      <%= agent_banner.call("&#127863;", "Cellar", "Inventory", cellar_c,
            cellar[:low_stock].to_i.positive? ? "<span style=\"color:#{red}\">&#9888; #{cellar[:low_stock]} low</span>" : "<span style=\"color:#{green}\">&#10003; Stocked</span>",
            agent_url.call("/nykitchen/inventory")).html_safe %>
      <tr><td style="padding:8px 30px 4px;font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.6">
        <span style="font-family:<%= mono %>;font-weight:bold;color:<%= ink %>"><%= number_with_delimiter(cellar[:units].to_i) %></span> <%= "unit".pluralize(cellar[:units].to_i) %> on hand across <span style="font-family:<%= mono %>"><%= cellar[:items] %></span> <%= "item".pluralize(cellar[:items].to_i) %><% if cellar[:low_stock].to_i.positive? %>, <span style="color:<%= red %>"><%= cellar[:low_stock] %> at or below par</span><% end %>.
        <% if cellar[:moves].to_i.positive? %>
          <div style="font-size:12px;color:<%= mut %>;margin-top:2px">This week: <span style="font-family:<%= mono %>;color:<%= green %>"><%= cellar[:received].to_i %> in</span>, <span style="font-family:<%= mono %>;color:<%= amber %>"><%= cellar[:removed].to_i %> out</span> across <%= cellar[:moves] %> <%= "movement".pluralize(cellar[:moves].to_i) %>.</div>
        <% else %>
          <div style="font-size:12px;color:<%= faint %>;margin-top:2px">No scans this week.</div>
        <% end %>
      </td></tr>
    <% end %>
  <% end %>

  <%# ════ New this week (Carson's changelog) ════════════════ %>
  <% if s[:changelog].present? %>
    <tr><td style="padding:26px 30px 4px">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:<%= cream %>;border-left:3px solid <%= accent %>;border-radius:0 8px 8px 0"><tr>
        <td style="padding:13px 16px">
          <div style="font-family:<%= serif %>;font-size:15px;font-weight:bold;color:<%= ink %>">&#10024; New this week</div>
          <div style="font-family:<%= sans %>;font-size:11px;color:<%= faint %>;margin-top:1px">Improvements your team shipped, with Carson's compliments.</div>
          <% s[:changelog].each do |c| %>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:9px"><tr>
              <td width="14" style="vertical-align:top;font-family:<%= sans %>;font-size:13px;color:<%= accent %>">&bull;</td>
              <td style="font-family:<%= sans %>;font-size:13px;color:#444;line-height:1.5"><%= c[:note] %></td>
            </tr></table>
          <% end %>
        </td>
      </tr></table>
    </td></tr>
  <% end %>

  <%# ── CTA + footer ─────────────────────────────────────── %>
  <tr><td style="padding:28px 30px 6px;text-align:center">
    <a href="<%= analyst_url %>" style="display:inline-block;background:<%= accent %>;color:#ffffff;text-decoration:none;font-family:<%= sans %>;font-weight:bold;font-size:14px;padding:12px 26px;border-radius:8px">View the full dashboard &rarr;</a>
  </td></tr>
  <tr><td style="padding:20px 30px 26px;border-top:1px solid <%= line %>;font-family:<%= sans %>;font-size:11px;color:<%= faint %>;text-align:center">
    Filed every Sunday evening by your NY Kitchen agent team.<br>
    Manage this email from the <a href="<%= analyst_url %>" style="color:<%= mut %>">Analyst dashboard</a>.
  </td></tr>

</table>
</td></tr>
</table>
