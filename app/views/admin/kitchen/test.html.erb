<% content_for(:title, "NY Kitchen · Test Agent") %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <% bc = capture do %><%= render "admin/kitchen/breadcrumbs", kind: "test", wrapper_class: "flex items-center gap-2 min-w-0 text-base text-gray-400" %><% end %>
  <%= render "shared/ws_header", workspace: @nyk_workspace, breadcrumbs: bc %>

  <div class="mb-6">
    <%= render "admin/kitchen/agent_title", title: "Test Agent", kind: "test" %>
    <p class="text-gray-400 mt-1">Twice-daily health checks on the NY Kitchen calendar.</p>
  </div>

  <%= render "admin/kitchen/test_panel" %>
</div>
