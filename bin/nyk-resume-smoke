#!/usr/bin/env bash
# One-shot script: Wed 2026-04-29 09:47 ET, swaps the lightweight calendar
# ping back to the full Playwright smoke test.
#
# Steps:
#   1. Stop the lightweight ping
#   2. Re-enable the heavy Playwright smoke (1/9/16 cron)
#   3. Notify Telegram
#   4. Unload itself (prevents re-firing next year)

set -uo pipefail

cd "$(dirname "$0")/.."

[[ -s "$HOME/.rvm/scripts/rvm" ]] && source "$HOME/.rvm/scripts/rvm"
if [[ -f "$HOME/.agent44_smoke_env" ]]; then
  source "$HOME/.agent44_smoke_env"
fi

PING_PLIST="$HOME/Library/LaunchAgents/com.agent44.calendar-ping.plist"
SMOKE_PLIST="$HOME/Library/LaunchAgents/com.agent44.smoke-nyk.plist"
RESUME_PLIST="$HOME/Library/LaunchAgents/com.agent44.smoke-nyk-resume.plist"

launchctl unload "$PING_PLIST" 2>/dev/null || true
launchctl load   "$SMOKE_PLIST" 2>/dev/null || true

# Notify Telegram via the Rails app
if [[ -n "${API_TOKEN:-}" ]]; then
  curl -fsS -X POST \
    -H "Authorization: Bearer $API_TOKEN" \
    -H "Content-Type: application/json" \
    -d '{"source":"nyk_calendar_ping","title":"▶ NYK smoke automation resumed","body":"Lightweight ping retired. Full Playwright smoke is back on the 1/9/16 cron.","level":"success","telegram":true}' \
    "https://agent44-app.fly.dev/api/v1/notifications" >/dev/null || true
fi

# Self-unload so this doesn't fire again next April 29
launchctl unload "$RESUME_PLIST" 2>/dev/null || true
