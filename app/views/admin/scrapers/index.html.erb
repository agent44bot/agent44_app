<% content_for(:title, "Admin: Scrapers") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Manage Scrapers</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @scrapers.size %> source(s) configured</p>
    </div>
    <%= link_to "New Scraper", new_admin_scraper_path,
          class: "inline-flex items-center px-4 py-2 bg-orange-600 text-white text-sm font-medium rounded-lg hover:bg-orange-700 transition shadow-sm" %>
  </div>

  <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-800">
      <thead class="bg-gray-900">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Run</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Jobs Found</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cost</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% @scrapers.each do |scraper| %>
          <tr class="hover:bg-gray-800 transition">
            <td class="px-6 py-4">
              <div class="flex items-center gap-2">
                <% if scraper.enabled? %>
                  <span class="h-2 w-2 rounded-full bg-green-400"></span>
                <% else %>
                  <span class="h-2 w-2 rounded-full bg-gray-600"></span>
                <% end %>
                <div>
                  <div class="text-sm font-medium text-white"><%= scraper.name %></div>
                  <div class="text-xs text-gray-500 font-mono"><%= scraper.slug %></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-400"><%= scraper.schedule_label %></td>
            <td class="px-6 py-4">
              <% if scraper.last_run_status.present? %>
                <% color = scraper.status_color %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= color == 'green' ? 'bg-green-900/50 text-green-400' : color == 'red' ? 'bg-red-900/50 text-red-400' : color == 'yellow' ? 'bg-yellow-900/50 text-yellow-400' : 'bg-gray-700 text-gray-400' %>">
                  <%= scraper.last_run_status %>
                </span>
              <% else %>
                <span class="text-xs text-gray-600">Never run</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= scraper.last_run_at ? time_ago_in_words(scraper.last_run_at) + " ago" : "—" %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-400"><%= scraper.last_run_jobs_found %></td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-900/50 text-green-400"><%= scraper.cost_label %></span>
            </td>
            <td class="px-6 py-4 text-right space-x-3">
              <%= link_to "View", admin_scraper_path(scraper), class: "text-sm font-medium text-orange-600 hover:text-orange-300 transition" %>
              <%= button_to "Run", run_admin_scraper_path(scraper), method: :post,
                    data: { turbo_confirm: "Run #{scraper.name} now?" },
                    class: "text-sm font-medium text-green-500 hover:text-green-300 transition" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @scrapers.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-500">No scrapers configured yet.</p>
        <%= link_to "Add your first scraper", new_admin_scraper_path, class: "text-sm text-orange-600 hover:text-orange-300" %>
      </div>
    <% end %>
  </div>
</div>
